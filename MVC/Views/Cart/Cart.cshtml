@{
    ViewData["Title"] = "Cart | Artify";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #f4f6f8;
            --bg-soft: #fbfcfd;
            --surface: rgba(255, 255, 255, 0.84);
            --surface-strong: #ffffff;
            --text-main: #17212b;
            --text-muted: #64707d;
            --text-soft: #94a0ad;
            --heading-blue: #173b7a;
            --accent-gold: #b9862f;
            --accent-green: #18794e;
            --line: rgba(23, 33, 43, 0.08);
            --line-strong: rgba(23, 33, 43, 0.14);
            --shadow-soft: 0 20px 48px rgba(15, 23, 42, 0.07);
            --shadow-hover: 0 22px 44px rgba(15, 23, 42, 0.1);
            --gradient-main: linear-gradient(135deg, #16386f 0%, #274f99 100%);
            --gradient-soft: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: var(--gradient-soft); color: var(--text-main); line-height: 1.6; min-height: 100vh; }
        h1,h2,h3,h4,h5,h6 { font-family: 'Playfair Display', serif; }

        nav {
            position: sticky; top: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.25rem 4rem;
            background: rgba(223, 230, 233, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--line);
        }
        .nav-logo { display: flex; align-items: center; gap: .7rem; text-decoration: none; }
        .nav-logo-icon {
            height: 40px; width: 40px; border-radius: 12px;
            background: var(--heading-blue); display: grid; place-items: center;
            font-weight: 900; color: #fff; font-size: 1.2rem;
        }
        .nav-logo span { font-size: 1.4rem; font-weight: 700; color: var(--text-main); letter-spacing: -.02em; font-family: 'Playfair Display', serif; }
        .nav-links { display: flex; gap: 2.5rem; list-style: none; }
        .nav-links a { text-decoration: none; font-size: .88rem; color: var(--text-main); opacity: .7; transition: opacity .2s, color .2s; }
        .nav-links a:hover { opacity: 1; color: var(--heading-blue); }
        .nav-actions { display: flex; align-items: center; gap: 1rem; }
        .nav-icon-btn {
            position: relative; display: grid; place-items: center;
            height: 40px; width: 40px; border-radius: 50%;
            border: 1.5px solid var(--line);
            background: rgba(255,255,255,.5); cursor: pointer;
            color: var(--text-main); transition: background .2s, border-color .2s, transform .2s;
            text-decoration: none;
        }
        .nav-icon-btn:hover { background: var(--heading-blue); color: #fff; border-color: var(--heading-blue); transform: scale(1.08); }
        .nav-badge {
            position: absolute; top: -4px; right: -4px;
            height: 16px; min-width: 16px; padding: 0 3px;
            background: var(--accent-gold); color: #fff; border-radius: 999px;
            font-size: .62rem; font-weight: 700; display: grid; place-items: center;
        }
        .nav-signin { font-size: .88rem; color: var(--text-main); text-decoration: none; opacity: .8; transition: opacity .2s, color .2s; }
        .nav-signin:hover { opacity: 1; color: var(--heading-blue); }

        .navbar { position: sticky; top: 0; z-index: 100; background: rgba(243, 239, 232, 0.78); backdrop-filter: blur(20px); border-bottom: 1px solid var(--line); }
        .navbar-inner { max-width: 1300px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; }
        .logo-wrap { display: flex; align-items: center; gap: 14px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--line); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-main); text-decoration: none; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .back-btn:hover { background: var(--heading-blue); color: #fff; border-color: var(--heading-blue); transform: translateX(-4px); }
        .logo { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--text-main); text-decoration: none; letter-spacing: -0.01em; }
        .nav-links { display: flex; gap: 2.5rem; }
        .nav-links a { font-size: 0.9rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color 0.3s; position: relative; }
        .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--heading-blue); transition: width 0.3s; }
        .nav-links a:hover { color: var(--text-main); }
        .nav-links a:hover::after { width: 100%; }
        .nav-actions { display: flex; align-items: center; gap: 1.25rem; }
        .icon-btn { position: relative; width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--line); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: all 0.3s; text-decoration: none; }
        .icon-btn:hover { background: var(--heading-blue); color: #fff; border-color: var(--heading-blue); transform: translateY(-3px); }
        .avatar-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--line); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: all 0.3s; text-decoration: none; }
        .avatar-btn:hover { background: var(--heading-blue); color: #fff; border-color: var(--heading-blue); transform: translateY(-3px); }
        .badge { position: absolute; top: -5px; right: -5px; min-width: 20px; height: 20px; padding: 0 5px; border-radius: 999px; background: var(--accent-gold); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; border: 2px solid white; }
        .badge.zero { display: none; }

        .page { max-width: 1320px; margin: 0 auto; padding: 2.75rem 2rem 4rem; min-height: 80vh; }
        .checkout-shell { background: rgba(255, 255, 255, 0.72); border: 1px solid rgba(255, 255, 255, 0.82); box-shadow: var(--shadow-soft); border-radius: 30px; padding: 2rem; backdrop-filter: blur(18px); }
        .page-header { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 28px; align-items: end; margin-bottom: 2.5rem; }
        .eyebrow { display: inline-flex; align-items: center; gap: 10px; padding: 8px 14px; border-radius: 999px; background: rgba(23, 59, 122, 0.07); color: var(--heading-blue); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 0.9rem; }
        .page-header h1 { font-size: clamp(1.9rem, 3vw, 2.7rem); font-weight: 700; color: var(--text-main); margin-bottom: 0.55rem; line-height: 1.08; }
        .page-header p { max-width: 620px; font-size: 0.92rem; color: var(--text-muted); font-weight: 500; }
        .count-pill { display: inline-flex; align-items: center; justify-content: center; padding: 0.8rem 1.05rem; border-radius: 999px; background: var(--surface-strong); border: 1px solid var(--line); font-size: 0.88rem; font-weight: 700; color: var(--text-main); box-shadow: 0 10px 30px rgba(31, 41, 51, 0.05); }

        .checkout-steps { position: relative; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-bottom: 2.5rem; }
        .checkout-steps::before { content: ''; position: absolute; top: 22px; left: calc(16.66% + 22px); right: calc(16.66% + 22px); height: 1px; background: rgba(23, 33, 43, 0.1); z-index: 0; }
        .step-card { position: relative; z-index: 1; display: flex; align-items: center; gap: 14px; padding: 1rem 1.1rem; border-radius: 22px; border: 1px solid var(--line); background: rgba(255,255,255,0.92); min-height: 88px; }
        .step-card.active { border-color: rgba(23, 59, 122, 0.18); box-shadow: 0 14px 28px rgba(23, 59, 122, 0.08); }
        .step-card.pending { opacity: 0.8; }
        .step-index { width: 42px; height: 42px; border-radius: 14px; display: flex; align-items: center; justify-content: center; background: var(--gradient-main); color: #fff; font-size: 0.92rem; font-weight: 700; flex-shrink: 0; box-shadow: 0 10px 20px rgba(22, 56, 111, 0.18); }
        .step-copy small { display: block; color: var(--text-soft); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.14em; font-weight: 700; margin-bottom: 4px; }
        .step-copy strong { display: block; color: var(--text-main); font-size: 0.92rem; font-weight: 700; }

        .cart-layout { display: grid; grid-template-columns: minmax(0, 1fr) 390px; gap: 32px; align-items: start; }
        .cart-main { display: flex; flex-direction: column; gap: 22px; }
        .cart-panel { background: rgba(255,255,255,0.8); border: 1px solid var(--line); border-radius: 28px; overflow: hidden; }
        .cart-panel-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--line); background: rgba(248,250,252,0.95); }
        .cart-panel-head h2 { font-size: 1.2rem; color: var(--text-main); }
        .cart-panel-head p { font-size: 0.88rem; color: var(--text-muted); }
        .cart-items { display: flex; flex-direction: column; gap: 18px; padding: 1.1rem; }
        .cart-item { background: var(--surface-strong); border-radius: 24px; border: 1px solid var(--line); display: grid; grid-template-columns: 148px minmax(0, 1fr); padding: 18px; gap: 22px; transition: all 0.3s ease; animation: fade-up 0.6s ease-out forwards; opacity: 0; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05); }
        .cart-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); border-color: rgba(23, 59, 122, 0.12); }
        .cart-item-img { width: 100%; height: 188px; border-radius: 18px; overflow: hidden; cursor: pointer; flex-shrink: 0; background: #ebeef2; }
        .cart-item-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
        .cart-item:hover .cart-item-img img { transform: scale(1.1); }
        .cart-item-info { min-width: 0; display: flex; flex-direction: column; justify-content: space-between; gap: 18px; }
        .cart-item-top { position: relative; display: flex; flex-direction: column; gap: 10px; }
        .item-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .item-tag { display: inline-flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 999px; background: rgba(23, 59, 122, 0.07); color: var(--heading-blue); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
        .item-stock { color: var(--accent-green); font-size: 0.84rem; font-weight: 700; }
        .cart-item-top h3 { font-size: clamp(1.05rem, 1.8vw, 1.3rem); font-weight: 700; color: var(--text-main); cursor: pointer; transition: color 0.3s; line-height: 1.15; }
        .cart-item-top h3:hover { color: var(--heading-blue); }
        .cart-item-top .artist { font-size: 0.86rem; color: var(--text-muted); font-weight: 600; }
        .cart-item-top .cart-copy { color: var(--text-soft); font-size: 0.84rem; max-width: 540px; }
        .cart-item-bottom { display: flex; align-items: flex-end; justify-content: space-between; gap: 18px; flex-wrap: wrap; }
        .price-block small { display: block; color: var(--text-soft); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
        .cart-item-price { font-size: 1.45rem; font-weight: 800; color: var(--text-main); font-family: 'Playfair Display', serif; line-height: 1; }
        .item-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: flex-end; }
        .remove-btn { display: flex; align-items: center; gap: 8px; padding: 12px 18px; border-radius: 999px; border: 1px solid rgba(214, 76, 65, 0.16); background: rgba(214, 76, 65, 0.06); font-size: 12px; font-weight: 700; font-family: 'Inter', sans-serif; cursor: pointer; color: #c44538; transition: all 0.3s; }
        .remove-btn:hover { background: #d64c41; color: #fff; border-color: #d64c41; box-shadow: 0 8px 20px rgba(214, 76, 65, 0.2); }

        .order-summary { background: linear-gradient(180deg, #1d2f4a 0%, #16253c 100%); color: #fff; border-radius: 28px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.06); box-shadow: 0 22px 42px rgba(15, 23, 42, 0.2); position: sticky; top: 118px; overflow: hidden; }
        .order-summary::before { content: ''; position: absolute; inset: auto -50px -80px auto; width: 180px; height: 180px; border-radius: 50%; background: radial-gradient(circle, rgba(185,134,47,0.3), transparent 70%); pointer-events: none; }
        .summary-top { position: relative; z-index: 1; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 1.35rem; }
        .summary-top h2 { font-size: 1.45rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
        .summary-top p { color: rgba(255,255,255,0.7); font-size: 0.84rem; }
        .summary-badge { display: inline-flex; align-items: center; justify-content: center; min-width: 64px; padding: 0.65rem 0.85rem; border-radius: 16px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.12); font-weight: 700; }
        .summary-card { position: relative; z-index: 1; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 1.1rem; margin-bottom: 1.15rem; }
        .summary-note { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-bottom: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .summary-note strong { font-size: 0.88rem; }
        .summary-note span { color: rgba(255,255,255,0.72); font-size: 0.78rem; display: block; }
        .summary-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.86rem; margin-bottom: 16px; }
        .summary-row span:first-child { color: rgba(255,255,255,0.7); font-weight: 500; }
        .summary-row span:last-child { color: #fff; font-weight: 600; }
        .summary-row span.summary-accent { color: #79e2b6; }
        .summary-row.total { padding-top: 20px; border-top: 1px dashed rgba(255,255,255,0.18); margin-top: 8px; font-size: 1.2rem; font-weight: 800; color: #fff; font-family: 'Playfair Display', serif; }
        .summary-row.total span:first-child, .summary-row.total span:last-child { color: #fff; }
        .checkout-btn { width: 100%; margin-top: 20px; padding: 18px; border-radius: 999px; border: none; background: linear-gradient(135deg, #f0c06a 0%, #b9862f 100%); color: #17212b; font-size: 0.92rem; font-weight: 800; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 14px 28px rgba(185, 134, 47, 0.22); }
        .checkout-btn:hover { transform: translateY(-3px); box-shadow: 0 18px 30px rgba(185, 134, 47, 0.26); }
        .continue-btn { width: 100%; margin-top: 14px; padding: 15px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.05); color: #fff; font-size: 0.86rem; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; text-decoration: none; display: block; text-align: center; transition: all 0.3s; }
        .continue-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.24); }
        .benefits { position: relative; z-index: 1; display: grid; gap: 12px; margin-top: 18px; }
        .benefit { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.76); font-size: 0.8rem; }
        .benefit svg { flex-shrink: 0; color: #e6b24e; }

        .loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; min-height: 320px; text-align: center; background: rgba(255,255,255,0.72); border: 1px solid var(--line); border-radius: 32px; }
        .loading-state p { color: var(--text-muted); font-weight: 600; }
        .loading-spinner { width: 48px; height: 48px; border-radius: 50%; border: 3px solid rgba(37, 70, 168, 0.15); border-top-color: var(--heading-blue); animation: spin 0.9s linear infinite; }

        .empty-state { text-align: center; padding: 100px 40px; background: rgba(255,255,255,0.78); border-radius: 3rem; border: 1px solid var(--line); }
        .empty-state svg { color: var(--heading-blue); opacity: 0.5; margin-bottom: 30px; }
        .empty-state h2 { font-size: 2.5rem; font-weight: 700; color: var(--text-main); }
        .empty-state p { font-size: 1.1rem; color: var(--text-muted); margin-top: 12px; }
        .empty-state a { display: inline-block; margin-top: 32px; padding: 16px 40px; border-radius: 99px; background: var(--heading-blue); color: #fff; text-decoration: none; font-size: 1rem; font-weight: 700; transition: all 0.3s; }
        .empty-state a:hover { transform: translateY(-4px); box-shadow: 0 10px 20px rgba(37, 70, 168, 0.2); }

        @@keyframes fade-up { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes spin { to { transform: rotate(360deg); } }
        @@media(max-width:1100px) {
            .page-header { grid-template-columns: 1fr; align-items: start; }
            .checkout-steps { grid-template-columns: 1fr; }
            .checkout-steps::before { display: none; }
            .cart-layout { grid-template-columns: 1fr; gap: 28px; }
            .order-summary { position: static; max-width: 560px; margin: 0 auto; width: 100%; }
        }
        @@media(max-width:768px) {
            nav { padding: 1rem 1.25rem; }
            .nav-links { display: none; }
            .navbar-inner { padding: 1rem 1.5rem; }
            .page { padding: 2rem 1rem 3rem; }
            .checkout-shell { padding: 1.2rem; border-radius: 28px; }
            .page-header h1 { font-size: 2.25rem; }
            .cart-panel-head { flex-direction: column; align-items: flex-start; }
            .cart-item { grid-template-columns: 1fr; border-radius: 24px; padding: 16px; }
            .cart-item-img { width: 100%; height: 240px; }
            .cart-item-bottom, .item-actions { align-items: stretch; justify-content: flex-start; }
            .item-meta { flex-direction: column; align-items: flex-start; }
            .remove-btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    @Html.Partial("_Navbar")

    <div class="page">
        <div class="checkout-shell">
            <div class="page-header">
                <div>
                    <span class="eyebrow">Checkout</span>
                    <h1>Review your cart</h1>
                    <p>Confirm your selected artworks and continue to secure checkout.</p>
                </div>
                <div class="count-pill" id="countText">Loading...</div>
            </div>

            <div class="checkout-steps">
                <div class="step-card active">
                    <div class="step-index">01</div>
                    <div class="step-copy">
                        <small>Current Step</small>
                        <strong>Shopping Cart</strong>
                    </div>
                </div>
                <div class="step-card pending">
                    <div class="step-index">02</div>
                    <div class="step-copy">
                        <small>Next</small>
                        <strong>Checkout</strong>
                    </div>
                </div>
                <div class="step-card pending">
                    <div class="step-index">03</div>
                    <div class="step-copy">
                        <small>Finish</small>
                        <strong>Complete</strong>
                    </div>
                </div>
            </div>

            <div id="content">
                <div class="loading-state">
                    <div class="loading-spinner"></div>
                    <p>Loading your cart...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        var API_BASE = 'http://localhost:5183';

        function getToken() { return localStorage.getItem('token'); }
        function authFetch(url, options) {
            options = options || {};
            var token = getToken();
            return fetch(url, Object.assign({}, options, {
                headers: Object.assign({ 'Content-Type': 'application/json' },
                    token ? { 'Authorization': 'Bearer ' + token } : {},
                    options.headers || {})
            }));
        }
        function imageUrl(path) {
            if (!path) return 'https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=600';
            if (path.startsWith('http')) return path;
            return window.location.origin + path;
        }

        // â”€â”€ localStorage helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        function getCart() { try { return JSON.parse(localStorage.getItem('artify_cart') || '[]'); } catch(e) { return []; } }
        function saveCart(arr) { localStorage.setItem('artify_cart', JSON.stringify(arr)); }
        function getWishlist() { try { return JSON.parse(localStorage.getItem('artify_wishlist') || '[]'); } catch(e) { return []; } }

        var PLATFORM_FEE_RATE = 0.02; // 18%

        // updateBadges handled globally via globalBadges.js

        function removeFromCart(artworkId) {
            var ct = getCart();
            var idx = ct.findIndex(function(id) { return id != null && id.toString() === artworkId.toString(); });
            if (idx !== -1) { ct.splice(idx, 1); saveCart(ct); }
            loadedItems = loadedItems.filter(function(x) { return x.artworkId !== artworkId; });
            updateBadges();
            render(loadedItems);
        }

        var loadedItems = [];

        function render(items) {
            // â”€â”€ CHANGED: calculate subtotal, platform fee, and grand total â”€â”€
            var subtotal = items.reduce(function(s, a) { return s + parseFloat(a.price); }, 0);
            var platformFee = Math.round(subtotal * PLATFORM_FEE_RATE);
            var grandTotal = subtotal + platformFee;

            document.getElementById('countText').textContent = items.length + ' artwork' + (items.length === 1 ? '' : 's');

            if (items.length === 0) {
                document.getElementById('content').innerHTML =
                    '<div class="empty-state">'
                    + '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>'
                    + '<h2>Your cart is empty</h2>'
                    + '<p>Add artworks you love and they\'ll appear here</p>'
                    + '<a href="/Buyer/ExploreArt">Explore Art</a>'
                    + '</div>';
                return;
            }

            var itemsHtml = items.map(function(a, i) {
                var img = imageUrl(a.previewPath);
                var detailUrl = '/Buyer/ArtworkDetail/' + a.artworkId;
                return '<div class="cart-item" style="animation-delay:' + (i * 0.06) + 's">'
                    + '<div class="cart-item-img" onclick="window.location.href=\'' + detailUrl + '\'">'
                    + '<img src="' + img + '" alt="' + a.title + '" loading="lazy"/>'
                    + '</div>'
                    + '<div class="cart-item-info">'
                    + '<div class="cart-item-top">'
                    + '<div class="item-meta">'
                    + '<span class="item-tag">' + (a.categoryName || 'Original Artwork') + '</span>'
                    + '<span class="item-stock">Available</span>'
                    + '</div>'
                    + '<h3 onclick="window.location.href=\'' + detailUrl + '\'">' + a.title + '</h3>'
                    + '<p class="artist">by ' + a.artistName + '</p>'
                    + '<p class="cart-copy">Selected for checkout and ready for confirmation.</p>'
                    + '</div>'
                    + '<div class="cart-item-bottom">'
                    + '<div class="price-block"><small>Artwork Price</small><span class="cart-item-price">$' + Number(a.price).toLocaleString('en-US') + '</span></div>'
                    + '<div class="item-actions">'
                    + '<button class="remove-btn" type="button" onclick="removeFromCart(' + a.artworkId + ')">'
                    + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>Remove'
                    + '</button>'
                    + '</div>'
                    + '</div>'
                    + '</div>'
                    + '</div>';
            }).join('');

            // â”€â”€ CHANGED: show subtotal, platform fee (18%), and grand total â”€â”€
            document.getElementById('content').innerHTML =
                '<div class="cart-layout">'
                + '<div class="cart-main">'
                + '<div class="cart-panel">'
                + '<div class="cart-panel-head"><div><h2>Shopping Cart</h2><p>Review the details of each artwork before proceeding.</p></div><span class="item-tag">' + items.length + ' selected</span></div>'
                + '<div class="cart-items">' + itemsHtml + '</div>'
                + '</div>'
                + '</div>'
                + '<div class="order-summary">'
                + '<div class="summary-top"><div><h2>Order Summary</h2><p>A clear breakdown before payment.</p></div><div class="summary-badge">' + items.length + '</div></div>'
                + '<div class="summary-card">'
                + '<div class="summary-note"><div><strong>Estimated total</strong><span>Final taxes may apply at payment</span></div><strong>$' + grandTotal.toLocaleString('en-US') + '</strong></div>'
                + '<div class="summary-row"><span>' + items.length + ' artwork' + (items.length===1?'':'s') + '</span><span>$' + subtotal.toLocaleString('en-US') + '</span></div>'
                + '<div class="summary-row"><span>Shipping</span><span class="summary-accent">Free</span></div>'
                + '<div class="summary-row"><span>Platform fees (2%)</span><span>$' + platformFee.toLocaleString('en-US') + '</span></div>'
                + '<div class="summary-row total"><span>Total</span><span>$' + grandTotal.toLocaleString('en-US') + '</span></div>'
                + '</div>'
                + '<button class="checkout-btn" onclick="goToCheckout()">'
                + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>Proceed to Checkout</button>'
                + '<a href="/Buyer/ExploreArt" class="continue-btn">Continue Shopping</a>'
                + '<div class="benefits">'
                + '<div class="benefit"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-4z"/></svg>Secure transition to payment</div>'
                + '<div class="benefit"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>Artwork details preserved from your cart</div>'
                + '</div>'
                + '</div></div>';
        }

        function goToCheckout() {
            // â”€â”€ CHANGED: include platformFee in each item's checkout data â”€â”€
            var subtotal = loadedItems.reduce(function(s, a) { return s + parseFloat(a.price); }, 0);
            var platformFee = Math.round(subtotal * PLATFORM_FEE_RATE);

            var checkoutCart = loadedItems.map(function(a) {
                return {
                    ArtworkId: a.artworkId,
                    name: a.title,
                    artist: a.artistName,
                    price: parseFloat(a.price),
                    previewUrl: imageUrl(a.previewPath),
                    icon: 'ðŸ–¼'
                };
            });

            // â”€â”€ CHANGED: also store the computed fee so Payment page can read it â”€â”€
            var checkoutMeta = {
                subtotal: subtotal,
                platformFee: platformFee,
                grandTotal: subtotal + platformFee
            };

            sessionStorage.setItem('artify_checkout_cart', JSON.stringify(checkoutCart));
            sessionStorage.setItem('artify_checkout_meta', JSON.stringify(checkoutMeta));
            localStorage.setItem('artvault_cart', JSON.stringify(checkoutCart));

            window.location.href = '/Payment/Index';
        }

        async function loadCart() {
            var cartIds = getCart();
            updateBadges();

            if (cartIds.length === 0) {
                loadedItems = [];
                render([]);
                return;
            }

            try {
                var res = await authFetch(API_BASE + '/api/artwork');
                if (!res.ok) throw new Error('Failed');
                var data = await res.json();

                var all = Array.isArray(data) ? data
                    : (data.$values || data.items || data.data || data.artworks || []);

                loadedItems = cartIds
    .map(function(id) {
        return all.find(function(a) {
            return (a.artworkId || a.id).toString() === id.toString();
        });
    })
    .filter(Boolean);

                render(loadedItems);
            } catch(err) {
                document.getElementById('content').innerHTML =
                    '<div class="loading-state"><p>Failed to load cart. <a href="/Buyer/ExploreArt" style="color:var(--accent)">Continue shopping</a></p></div>';
            }
        }

        document.addEventListener('DOMContentLoaded', loadCart);
    </script>
</body>
</html>
