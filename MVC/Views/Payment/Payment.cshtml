@{
    ViewData["Title"] = "Checkout - Artify";
    Layout = "_Layout";
    var apiBase = (ViewData["PaymentApiBaseUrl"] ?? string.Empty).ToString()?.TrimEnd('/');
    var payPalClientId = (ViewData["PayPalClientId"] ?? string.Empty).ToString();
    var payPalCurrency = (ViewData["PayPalCurrency"] ?? "USD").ToString();
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
:root {
    --bg: #f4f6f8;
    --bg-soft: #fbfcfd;
    --surface: rgba(255, 255, 255, 0.84);
    --surface-strong: #ffffff;
    --text-main: #17212b;
    --text-muted: #64707d;
    --text-soft: #94a0ad;
    --primary-blue: #173b7a;
    --heading-blue: #173b7a;
    --accent-gold: #b9862f;
    --accent-green: #18794e;
    --card-white: #ffffff;
    --border: rgba(23, 33, 43, 0.08);
    --shadow-soft: 0 20px 48px rgba(15, 23, 42, 0.07);
    --shadow-hover: 0 22px 44px rgba(15, 23, 42, 0.10);
    --danger: #d64c41;
    --success: #18794e;
    --gradient-main: linear-gradient(135deg, #16386f 0%, #274f99 100%);
    --gradient-soft: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', sans-serif;
    background: var(--gradient-soft);
    color: var(--text-main);
    line-height: 1.6;
}

h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', serif;
}

nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 4rem;
    background: rgba(223, 230, 233, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: .7rem;
    text-decoration: none;
}

.nav-logo-icon {
    height: 40px;
    width: 40px;
    border-radius: 12px;
    background: var(--primary-blue);
    display: grid;
    place-items: center;
    font-weight: 900;
    color: #fff;
    font-size: 1.2rem;
}

.nav-logo span {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-main);
    letter-spacing: -.02em;
    font-family: 'Playfair Display', serif;
}

.nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
}

.nav-links a {
    text-decoration: none;
    font-size: .88rem;
    color: var(--text-main);
    opacity: .7;
    transition: opacity .2s, color .2s;
}

.nav-links a:hover {
    opacity: 1;
    color: var(--heading-blue);
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.nav-icon-btn {
    position: relative;
    display: grid;
    place-items: center;
    height: 40px;
    width: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: rgba(255,255,255,.5);
    cursor: pointer;
    color: var(--text-main);
    transition: background .2s, border-color .2s, transform .2s;
    text-decoration: none;
}

.nav-icon-btn:hover {
    background: var(--primary-blue);
    color: #fff;
    border-color: var(--primary-blue);
    transform: scale(1.08);
}

.nav-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    height: 16px;
    min-width: 16px;
    padding: 0 3px;
    background: var(--accent-gold);
    color: #fff;
    border-radius: 999px;
    font-size: .62rem;
    font-weight: 700;
    display: grid;
    place-items: center;
}

.nav-signin {
    font-size: .88rem;
    color: var(--text-main);
    text-decoration: none;
    opacity: .8;
    transition: opacity .2s, color .2s;
}

.nav-signin:hover {
    opacity: 1;
    color: var(--heading-blue);
}

.navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(244, 246, 248, 0.82);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
}

.navbar-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
}

.logo-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
}

.back-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.back-btn:hover {
    background: var(--primary-blue);
    color: #ffffff;
    border-color: var(--primary-blue);
    transform: translateX(-4px);
}

.logo {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-main);
    text-decoration: none;
    letter-spacing: -0.01em;
}

.nav-links { display: flex; gap: 2.5rem; }
.nav-links a { font-size: 0.9rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color 0.3s; position: relative; }
.nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--heading-blue); transition: width 0.3s; }
.nav-links a:hover { color: var(--text-main); }
.nav-links a:hover::after { width: 100%; }
.nav-actions { display: flex; align-items: center; gap: 1.25rem; }
.icon-btn { position: relative; width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--border); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: all 0.3s; text-decoration: none; }
.icon-btn:hover { background: var(--primary-blue); color: #fff; border-color: var(--primary-blue); transform: translateY(-3px); }
.avatar-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--border); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: all 0.3s; text-decoration: none; }
.avatar-btn:hover { background: var(--primary-blue); color: #fff; border-color: var(--primary-blue); transform: translateY(-3px); }
.badge { position: absolute; top: -5px; right: -5px; min-width: 20px; height: 20px; padding: 0 5px; border-radius: 999px; background: var(--accent-gold); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; border: 2px solid white; }
.badge.zero { display: none; }

.checkout-page {
    max-width: 1320px;
    margin: 0 auto;
    padding: 2.75rem 2rem 4rem;
}

.checkout-shell {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow-soft);
    border-radius: 30px;
    padding: 2rem;
    backdrop-filter: blur(18px);
}

.page-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    margin-bottom: 2.2rem;
}

.eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(23, 59, 122, 0.07);
    color: var(--heading-blue);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
}

.page-header h1 {
    font-size: clamp(1.9rem, 3vw, 2.7rem);
    font-weight: 700;
    color: var(--text-main);
}

.page-header p {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin-top: 4px;
}

.count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.05rem;
    border-radius: 999px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-main);
    box-shadow: 0 10px 30px rgba(31, 41, 51, 0.05);
}

.checkout-steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 2.2rem;
}

.checkout-steps::before {
    content: '';
    position: absolute;
    top: 22px;
    left: calc(16.66% + 22px);
    right: calc(16.66% + 22px);
    height: 1px;
    background: rgba(23, 33, 43, 0.1);
    z-index: 0;
}

.step-card {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.92);
    min-height: 88px;
}

.step-card.active {
    border-color: rgba(23, 59, 122, 0.18);
    box-shadow: 0 14px 28px rgba(23, 59, 122, 0.08);
}

.step-card.complete {
    border-color: rgba(24, 121, 78, 0.16);
}

.step-card.pending {
    opacity: 0.8;
}

.step-index {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-main);
    color: #fff;
    font-size: 0.92rem;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 0 10px 20px rgba(22, 56, 111, 0.18);
}

.step-card.complete .step-index {
    background: linear-gradient(135deg, #18794e 0%, #28a36a 100%);
}

.step-copy small {
    display: block;
    color: var(--text-soft);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    margin-bottom: 4px;
}

.step-copy strong {
    display: block;
    color: var(--text-main);
    font-size: 0.92rem;
    font-weight: 700;
}

.checkout-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 390px;
    gap: 32px;
    align-items: start;
}

.co-card {
    background: rgba(255,255,255,0.80);
    border-radius: 28px;
    border: 1px solid var(--border);
    padding: 28px;
    box-shadow: var(--shadow-soft);
    transition: all 0.3s ease;
}

.co-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
.co-card + .co-card { margin-top: 24px; }

.card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 14px;
    color: var(--text-main);
    border-bottom: 1px solid var(--border);
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.form-row { margin-bottom: 14px; }

.form-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: #f9fbfc;
    color: var(--text-main);
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: all 0.3s ease;
}

.form-input:focus {
    border-color: var(--primary-blue);
    background: white;
    box-shadow: 0 0 0 4px rgba(23, 59, 122, 0.06);
}

.field-error {
    display: block;
    min-height: 16px;
    margin-top: 4px;
    color: var(--danger);
    font-size: 12px;
}

.paypal-note {
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.8;
    margin-bottom: 14px;
}

.paypal-box {
    background: #f7f9fb;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 16px;
}

.paypal-disabled {
    opacity: 0.5;
    pointer-events: none;
}

.status-banner {
    display: none;
    margin-top: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
}

.status-banner.show { display: block; }
.status-banner.success { background: rgba(34, 197, 94, 0.1); color: #15803d; }
.status-banner.error   { background: rgba(214, 76, 65, 0.1); color: var(--danger); }

.order-actions {
    display: none;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.order-actions.show { display: flex; }

.action-btn {
    padding: 10px 22px;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: white;
    color: var(--text-main);
    text-decoration: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    transition: all 0.3s;
}

.action-btn:hover {
    background: var(--primary-blue);
    color: white;
    border-color: var(--primary-blue);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(23, 59, 122, 0.16);
}

.order-item {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.10);
    position: relative;
    z-index: 1;
}

.order-item:last-child { border-bottom: none; }

.order-thumb {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    background: #eef2f6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
}

.order-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.order-name { font-size: 14px; font-weight: 700; color: #fff; }
.order-artist { font-size: 12px; color: rgba(255,255,255,0.70); margin-top: 2px; }
.order-price { margin-left: auto; font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 600; white-space: nowrap; color: #fff; }

.sticky-summary {
    position: sticky;
    top: 118px;
    background: linear-gradient(180deg, #1d2f4a 0%, #16253c 100%);
    color: #fff;
    overflow: hidden;
}

.sticky-summary::before {
    content: '';
    position: absolute;
    inset: auto -50px -80px auto;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(185,134,47,0.3), transparent 70%);
    pointer-events: none;
}

.sticky-summary .card-title {
    color: #fff;
    border-bottom-color: rgba(255,255,255,0.10);
    position: relative;
    z-index: 1;
}

.totals {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.10);
    position: relative;
    z-index: 1;
}

.summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.86rem;
    margin-bottom: 10px;
}

.summary-row span:first-child { color: rgba(252, 252, 252, 0.72); }
.summary-row span:last-child { color: #fff; }

.summary-row.grand {
    padding-top: 14px;
    border-top: 1px dashed rgba(255,255,255,0.18);
    margin-top: 8px;
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
}

.summary-row.grand span:first-child,
.summary-row.grand span:last-child { color: rgba(255, 255, 255, 0.72); } }

.notes-card {
    background: rgba(255,255,255,0.80);
    border: 1px solid var(--border);
    border-radius: 28px;
    padding: 24px;
    margin-top: 24px;
}

.notes-card .card-title {
    font-size: 1rem;
    border-color: var(--border);
}

.notes-card p {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.9;
}

.success-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(30, 20, 12, 0.48);
    backdrop-filter: blur(6px);
    z-index: 1000;
}

.success-modal.show { display: flex; }

.success-modal-card {
    width: min(420px, 100%);
    transform: translateY(16px) scale(0.98);
    opacity: 0;
    transition: transform 0.25s ease, opacity 0.25s ease;
}

.success-modal.show .success-modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
}

.success-dialog-content {
    background: #ffffff;
    border-radius: 16px 16px 0 0;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    position: relative;
    font-family: 'Inter', sans-serif;
    color: #1a1612;
}

.modal-close-btn {
    position: absolute;
    top: 14px;
    right: 18px;
    font-size: 1.1rem;
    color: #64707d;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
}

.modal-close-btn:hover { color: #17212b; }

.icon-container {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
}

.success-dialog-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: #1a202c;
}

.success-desc {
    color: #718096;
    font-size: 13px;
    margin-bottom: 1.25rem;
    line-height: 1.5;
}

.amt-container { margin-bottom: 1.25rem; }

.amt-label {
    display: block;
    font-size: 12px;
    color: #718096;
    margin-bottom: 4px;
}

.amt-value {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #1a202c;
}

.meta-info {
    font-size: 12px;
    color: #718096;
    margin-bottom: 1.5rem;
}

.meta-info strong { color: #4a5568; font-weight: 600; }

.modal-action-buttons {
    display: flex;
    gap: 10px;
    justify-content: center;
}

.modal-btn {
    background: #ffffff;
    border: 1.5px solid #e2e8f0;
    color: #1a202c;
    padding: 9px 18px;
    font-weight: 600;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
}

.modal-btn:hover { background: #f8fafc; }

.scalloped-bottom {
    height: 14px;
    background-image: radial-gradient(circle at 10px 0, #ffffff 10px, transparent 11px);
    background-size: 20px 20px;
    background-repeat: repeat-x;
    transform: translateY(-1px);
}

@@media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .sticky-summary { position: static !important; }
}

@@media (max-width: 600px) {
    .form-grid { grid-template-columns: 1fr; }
}

@@media (max-width: 768px) {
    nav { padding: 1rem 1.25rem; }
    .nav-links { display: none; }
    .checkout-page { padding: 2rem 1rem 3rem; }
    .checkout-shell { padding: 1.2rem; border-radius: 28px; }
    .page-header { grid-template-columns: 1fr; align-items: start; }
    .checkout-steps { grid-template-columns: 1fr; }
    .checkout-steps::before { display: none; }
}
</style>

<div id="successModal" class="success-modal" role="dialog" aria-modal="true" aria-labelledby="successTitle">
    <div class="success-modal-card">
        <div class="success-dialog-content">
            <button class="modal-close-btn" onclick="closeSuccessWindow()" aria-label="Close">&#x2715;</button>

            <div class="icon-container">
                <svg style="transform:rotate(12deg);" width="60" height="78" viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 5V25H60V5C60 0 55 0 55 0H25C25 0 20 0 20 5Z" fill="#E2E8F0"/>
                    <path d="M25 10H55" stroke="#CBD5E1" stroke-width="2" stroke-dasharray="4 4"/>
                    <path d="M25 17H45" stroke="#CBD5E1" stroke-width="2" stroke-dasharray="4 4"/>
                    <rect x="15" y="25" width="50" height="65" rx="8" fill="#2563EB"/>
                    <rect x="22" y="34" width="36" height="24" rx="4" fill="#EFF6FF"/>
                    <rect x="25" y="64" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="36.5" y="64" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="48" y="64" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="25" y="73" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="36.5" y="73" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="48" y="73" width="7" height="5" rx="2" fill="#93C5FD"/>
                    <rect x="25" y="82" width="7" height="5" rx="2" fill="#EF4444"/>
                    <rect x="36.5" y="82" width="7" height="5" rx="2" fill="#FBBF24"/>
                    <rect x="48" y="82" width="7" height="5" rx="2" fill="#10B981"/>
                </svg>
            </div>

            <h2 id="successTitle">Payment Successful!</h2>
            <p class="success-desc">Your transaction has been processed smoothly.</p>

            <div class="amt-container">
                <span class="amt-label">Amount</span>
                <span class="amt-value" id="successAmount">$0.00</span>
            </div>

            <div class="meta-info">
                <span id="successDate">00-00-0000</span> &bull; Bill ID: <strong id="successBillId">#0</strong>
            </div>
        </div>
        <div class="scalloped-bottom"></div>
    </div>
</div>

@Html.Partial("_Navbar")

<div class="checkout-page">
    <div class="checkout-shell">
        <div class="page-header">
            <div>
                <span class="eyebrow">Checkout</span>
                <h1>Complete your payment</h1>
                <p>Fill in your billing details, review the order summary, and continue with PayPal.</p>
            </div>
            <div class="count-pill" id="checkoutCount">Order items</div>
        </div>

        <div class="checkout-steps">
            <div class="step-card complete">
                <div class="step-index">01</div>
                <div class="step-copy">
                    <small>Completed</small>
                    <strong>Shopping Cart</strong>
                </div>
            </div>
            <div class="step-card active">
                <div class="step-index">02</div>
                <div class="step-copy">
                    <small>Current Step</small>
                    <strong>Checkout</strong>
                </div>
            </div>
            <div class="step-card pending">
                <div class="step-index">03</div>
                <div class="step-copy">
                    <small>Next</small>
                    <strong>Complete</strong>
                </div>
            </div>
        </div>

        <div class="checkout-layout">
            <div>
                <div class="co-card">
                    <p class="card-title">Billing Details</p>

                    <div class="form-row">
                        <label class="form-label">Full Name</label>
                        <input class="form-input" id="fullName" placeholder="Your full name" autocomplete="name" />
                        <span class="field-error" id="err-name"></span>
                    </div>

                    <div class="form-row">
                        <label class="form-label">Email Address</label>
                        <input class="form-input" id="email" type="email" placeholder="you@example.com" autocomplete="email" />
                        <span class="field-error" id="err-email"></span>
                    </div>

                    <div class="form-grid">
                        <div class="form-row">
                            <label class="form-label">Phone</label>
                            <input class="form-input" id="phone" placeholder="+1 555 123 4567" autocomplete="tel" />
                            <span class="field-error" id="err-phone"></span>
                        </div>
                        <div class="form-row">
                            <label class="form-label">City</label>
                            <input class="form-input" id="city" placeholder="City" />
                            <span class="field-error" id="err-city"></span>
                        </div>
                    </div>

                    <div class="form-row" style="margin-bottom:0;">
                        <label class="form-label">Postal Code</label>
                        <input class="form-input" id="pincode" placeholder="Postal code" />
                        <span class="field-error" id="err-pin"></span>
                    </div>
                </div>

                <div class="co-card">
                    <p class="card-title">Pay With PayPal</p>
                    <p class="paypal-note">
                        Use your PayPal sandbox buyer account to complete this test purchase.
                        We create the order on the server, PayPal approves it, and then we capture and save it in Artify.
                    </p>
                    <div class="paypal-box" style="margin-bottom:14px;">
                        <div class="summary-row" style="margin-bottom:8px;">
                            <span>Artwork subtotal</span>
                            <span id="paypal-subtotal-val">$0.00</span>
                        </div>
                        <div class="summary-row" style="margin-bottom:8px;">
                            <span>Platform fee</span>
                            <span id="paypal-fee-val">$0.00</span>
                        </div>
                        <div class="summary-row grand" style="padding-top:12px;margin-top:0;font-size:1rem;">
                            <span>PayPal total</span>
                            <span id="paypal-total-val">$0.00</span>
                        </div>
                    </div>
                    <div class="paypal-box" id="paypal-box">
                        <div id="paypal-button-container"></div>
                    </div>
                    <div class="status-banner" id="status-banner"></div>
                    <div class="order-actions" id="order-actions">
                        <a class="action-btn" id="view-order-btn" href="#">View Order</a>
                        <button class="action-btn" id="invoice-btn" type="button">Download Invoice</button>
                    </div>
                </div>
            </div>

            <div>
                <div class="co-card sticky-summary">
                    <p class="card-title">Order Summary</p>
                    <div id="order-items-list"></div>
                    <div class="totals">
                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span id="subtotal-val">$0.00</span>
                        </div>
                        <div class="summary-row">
                            <span>Shipping</span>
                            <span style="color:#79e2b6;font-weight:600;">Free</span>
                        </div>
                        <div class="summary-row">
                            <span>Platform fee (2%)</span>
                            <span id="fee-val">$0.00</span>
                        </div>
                        <div class="summary-row grand">
                            <span>Total</span>
                            <span id="total-val">$0.00</span>
                        </div>
                    </div>
                </div>

                <div class="notes-card">
                    <p class="card-title">Checkout Notes</p>
                    @* <p>
                        Sandbox client ID must be set in MVC config.<br />
                        Sandbox secret must be set in API config.<br />
                        Currency should match your PayPal sandbox setup.
                    </p> *@
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@if (!string.IsNullOrWhiteSpace(payPalClientId) && payPalClientId != "YOUR_PAYPAL_SANDBOX_CLIENT_ID")
{
<script src="https://www.paypal.com/sdk/js?client-id=@(payPalClientId)&currency=@(payPalCurrency)&intent=capture"></script>
}
<script>
const PAY_API          = '@Html.Raw(apiBase)';
console.log("Api:" + PAY_API);
const PAYPAL_CLIENT_ID = '@Html.Raw(payPalClientId)';
const PAYPAL_CURRENCY  = '@Html.Raw(payPalCurrency)';
const PLATFORM_FEE_RATE = 0.02;
let   successOrderId   = 0;

const successModal = document.getElementById('successModal');

function readStoredMeta() {
    try {
        const checkoutMeta = JSON.parse(sessionStorage.getItem('artify_checkout_meta') || 'null');
        if (checkoutMeta && typeof checkoutMeta === 'object') return checkoutMeta;
    } catch {}

    return null;
}

const demoCart = [
    { ArtworkId: 101, name: 'Monsoon Reverie', artist: 'Priya Sharma', price: 4500, icon: 'ðŸ–¼' }
];

function readStoredCart() {
    try {
        const checkoutCart = JSON.parse(sessionStorage.getItem('artify_checkout_cart') || 'null');
        if (Array.isArray(checkoutCart) && checkoutCart.length > 0) {
            localStorage.setItem('artvault_cart', JSON.stringify(checkoutCart));
            return checkoutCart;
        }
    } catch {}

    try {
        const savedCart = JSON.parse(localStorage.getItem('artvault_cart') || 'null');
        if (Array.isArray(savedCart) && savedCart.length > 0) return savedCart;
    } catch {}

    return demoCart;
}

const cart = readStoredCart();
const storedMeta = readStoredMeta();
document.getElementById('checkoutCount').textContent = cart.length + ' item' + (cart.length === 1 ? '' : 's');

function currencySymbol(currency) {
    return currency === 'USD' ? '$' : currency + ' ';
}

function setBanner(message, type) {
    const banner = document.getElementById('status-banner');
    banner.textContent = message;
    banner.className = `status-banner show ${type}`;
}

function clearErrors() {
    ['err-name', 'err-email', 'err-phone', 'err-city', 'err-pin'].forEach(id => {
        document.getElementById(id).textContent = '';
    });
}

function validateForm() {
    clearErrors();
    let ok = true;

    const name = document.getElementById('fullName').value.trim();
    if (name.length < 2) {
        document.getElementById('err-name').textContent = 'Full name is required.';
        ok = false;
    }

    const email = document.getElementById('email').value.trim();
    if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        document.getElementById('err-email').textContent = 'Enter a valid email address.';
        ok = false;
    }

    const phone = document.getElementById('phone').value.trim();
    if (phone.length < 7) {
        document.getElementById('err-phone').textContent = 'Enter a valid phone number.';
        ok = false;
    }

    const city = document.getElementById('city').value.trim();
    if (!city) {
        document.getElementById('err-city').textContent = 'City is required.';
        ok = false;
    }

    const pin = document.getElementById('pincode').value.trim();
    if (!pin) {
        document.getElementById('err-pin').textContent = 'Postal code is required.';
        ok = false;
    }

    return ok;
}

function buildCheckoutMeta() {
    const subtotal = cart.reduce((sum, item) => sum + Number(item.price || 0), 0);
    const fallbackFee = Math.round(subtotal * PLATFORM_FEE_RATE);

    const metaSubtotal = Number(storedMeta?.subtotal);
    const metaFee = Number(storedMeta?.platformFee);
    const metaTotal = Number(storedMeta?.grandTotal);

    const safeSubtotal = Number.isFinite(metaSubtotal) && metaSubtotal >= 0 ? metaSubtotal : subtotal;
    const safeFee = Number.isFinite(metaFee) && metaFee >= 0 ? metaFee : fallbackFee;
    const safeTotal = Number.isFinite(metaTotal) && metaTotal >= safeSubtotal ? metaTotal : (safeSubtotal + safeFee);

    return {
        subtotal: safeSubtotal,
        platformFee: safeFee,
        grandTotal: safeTotal
    };
}

const checkoutMeta = buildCheckoutMeta();

(function renderOrder() {
    const list   = document.getElementById('order-items-list');
    const symbol = currencySymbol(PAYPAL_CURRENCY);

    cart.forEach(item => {
        const row = document.createElement('div');
        row.className = 'order-item';
        const thumb = item.previewUrl
            ? `<div class="order-thumb"><img src="${item.previewUrl}" alt="${item.name}" loading="lazy" /></div>`
            : `<div class="order-thumb">${item.icon || 'ðŸ–¼'}</div>`;
        row.innerHTML = `
            ${thumb}
            <div>
                <div class="order-name">${item.name}</div>
                <div class="order-artist">by ${item.artist}</div>
            </div>
            <div class="order-price">${symbol}${Number(item.price).toLocaleString('en-US')}</div>`;
        list.appendChild(row);
    });

    document.getElementById('subtotal-val').textContent = symbol + checkoutMeta.subtotal.toLocaleString('en-US');
    document.getElementById('fee-val').textContent      = symbol + checkoutMeta.platformFee.toLocaleString('en-US');
    document.getElementById('total-val').textContent    = symbol + checkoutMeta.grandTotal.toLocaleString('en-US');
    document.getElementById('paypal-subtotal-val').textContent = symbol + checkoutMeta.subtotal.toLocaleString('en-US');
    document.getElementById('paypal-fee-val').textContent = symbol + checkoutMeta.platformFee.toLocaleString('en-US');
    document.getElementById('paypal-total-val').textContent = symbol + checkoutMeta.grandTotal.toLocaleString('en-US');
})();

@* async function createPaypalOrder() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${PAY_API}/api/payment/create-paypal-order`, {
        method: 'POST',
        headers:
        {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
            Currency: PAYPAL_CURRENCY,
            Subtotal: checkoutMeta.subtotal,
            CommissionAmount: checkoutMeta.platformFee,
            TotalAmount: checkoutMeta.grandTotal,
            Cart: cart.map(c => ({ ArtworkId: c.ArtworkId, Price: c.price }))
        })
    });
    if (!response.ok) throw new Error(await response.text());
    const data = await response.json();
