<!-- ── Navbar ── -->
<nav class="checkout-navbar">
    <div class="checkout-navbar-inner">
        <div class="logo-wrap">
            <a href="javascript:history.back()" class="back-btn" title="Back">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12" />
                    <polyline points="12 19 5 12 12 5" />
                </svg>
            </a>
            <a href="/Buyer/ExploreArt" class="site-logo">Artify</a>
        </div>
        <span class="step-pill">Cart &rsaquo; Payment &rsaquo; Confirm</span>
    </div>
</nav>

<!-- ── Page ── -->
<div class="checkout-page">
    <div class="page-header">
        <h1>Checkout</h1>
        <p>Complete your billing details and pay via PayPal</p>
    </div>

    <div class="checkout-layout">

        <!-- Left column -->
        <div>

            <!-- Billing Details -->
            <div class="co-card">
                <p class="card-title">Billing Details</p>

                <div class="form-row">
                    <label class="form-label">Full Name</label>
                    <input class="form-input" id="fullName" placeholder="Your full name" autocomplete="name" />
                    <span class="field-error" id="err-name"></span>
                </div>

                <div class="form-row">
                    <label class="form-label">Email Address</label>
                    <input class="form-input" id="email" type="email" placeholder="you@example.com" autocomplete="email" />
                    <span class="field-error" id="err-email"></span>
                </div>

                <div class="form-grid">
                    <div class="form-row">
                        <label class="form-label">Phone</label>
                        <input class="form-input" id="phone" placeholder="+1 555 123 4567" autocomplete="tel" />
                        <span class="field-error" id="err-phone"></span>
                    </div>
                    <div class="form-row">
                        <label class="form-label">City</label>
                        <input class="form-input" id="city" placeholder="City" />
                        <span class="field-error" id="err-city"></span>
                    </div>
                </div>

                <div class="form-row" style="margin-bottom:0;">
                    <label class="form-label">Postal Code</label>
                    <input class="form-input" id="pincode" placeholder="Postal code" />
                    <span class="field-error" id="err-pin"></span>
                </div>
            </div>

            <!-- Pay with PayPal -->
            <div class="co-card">
                <p class="card-title">Pay With PayPal</p>
                <p class="paypal-note">
                    Use your PayPal sandbox buyer account to complete this test purchase.
                    We create the order on the server, PayPal approves it, and then we capture and save it in Artify.
                </p>
                <div class="paypal-box" id="paypal-box">
                    <div id="paypal-button-container"></div>
                </div>
                <div class="status-banner" id="status-banner"></div>
                <div class="order-actions" id="order-actions">
                    <a class="action-btn" id="view-order-btn" href="#">View Order</a>
                    <button class="action-btn" id="invoice-btn" type="button">Download Invoice</button>
                </div>
            </div>

        </div>

        <!-- Right column -->
        <div>

            <!-- Order Summary -->
            <div class="co-card sticky-summary" style="position:sticky;top:88px;">
                <p class="card-title">Your Order</p>
                <div id="order-items-list"></div>
                <!-- ── CHANGED: added platform fee row and renamed IDs ── -->
                <div class="totals">
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span id="subtotal-val">$0.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span style="color:var(--success);font-weight:600;">Free</span>
                    </div>
                    <div class="summary-row">
                        <span>Platform fee (2%)</span>
                        <span id="fee-val">$0.00</span>
                    </div>
                    <div class="summary-row grand">
                        <span>Total</span>
                        <span id="total-val">$0.00</span>
                    </div>
                </div>
            </div>

            <!-- Checkout Notes -->
            <div class="notes-card">
                <p class="card-title">Checkout Notes</p>
                <p>
                    Sandbox client ID must be set in MVC config.<br />
                    Sandbox secret must be set in API config.<br />
                    Currency should match your PayPal sandbox setup.
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
@if (!string.IsNullOrWhiteSpace(payPalClientId) && payPalClientId != "YOUR_PAYPAL_SANDBOX_CLIENT_ID")
{
<script src="https://www.paypal.com/sdk/js?client-id=@(payPalClientId)&currency=@(payPalCurrency)&intent=capture"></script>
}
<script>
const PAY_API          = '@Html.Raw(apiBase)';
console.log("Api:" + PAY_API);
const PAYPAL_CLIENT_ID = '@Html.Raw(payPalClientId)';
const PAYPAL_CURRENCY  = '@Html.Raw(payPalCurrency)';
const PLATFORM_FEE_RATE = 0.02; // ── CHANGED: 18% platform fee constant ──
let   successOrderId   = 0;

const successModal = document.getElementById('successModal');

// ── Cart reading ───────────────────────────────────────────────────────────
const demoCart = [
    { ArtworkId: 101, name: 'Monsoon Reverie', artist: 'Priya Sharma', price: 4500, icon: '🖼' }
];

function readStoredCart() {
    try {
        const checkoutCart = JSON.parse(sessionStorage.getItem('artify_checkout_cart') || 'null');
        if (Array.isArray(checkoutCart) && checkoutCart.length > 0) {
            localStorage.setItem('artvault_cart', JSON.stringify(checkoutCart));
            return checkoutCart;
        }
    } catch {}

    try {
        const savedCart = JSON.parse(localStorage.getItem('artvault_cart') || 'null');
        if (Array.isArray(savedCart) && savedCart.length > 0) return savedCart;
    } catch {}

    return demoCart;
}

const cart = readStoredCart();

function currencySymbol(currency) {
    return currency === 'USD' ? '$' : currency + ' ';
}

// ── Banner ─────────────────────────────────────────────────────────────────
function setBanner(message, type) {
    const banner = document.getElementById('status-banner');
    banner.textContent = message;
    banner.className = `status-banner show ${type}`;
}

// ── Validation ─────────────────────────────────────────────────────────────
function clearErrors() {
    ['err-name', 'err-email', 'err-phone', 'err-city', 'err-pin'].forEach(id => {
        document.getElementById(id).textContent = '';
    });
}

function validateForm() {
    clearErrors();
    let ok = true;

    const name = document.getElementById('fullName').value.trim();
    if (name.length < 2) {
        document.getElementById('err-name').textContent = 'Full name is required.';
        ok = false;
    }

    const email = document.getElementById('email').value.trim();
    if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        document.getElementById('err-email').textContent = 'Enter a valid email address.';
        ok = false;
    }

    const phone = document.getElementById('phone').value.trim();
    if (phone.length < 7) {
        document.getElementById('err-phone').textContent = 'Enter a valid phone number.';
        ok = false;
    }

    const city = document.getElementById('city').value.trim();
    if (!city) {
        document.getElementById('err-city').textContent = 'City is required.';
        ok = false;
    }

    const pin = document.getElementById('pincode').value.trim();
    if (!pin) {
        document.getElementById('err-pin').textContent = 'Postal code is required.';
        ok = false;
    }

    return ok;
}

// ── Render order items ─────────────────────────────────────────────────────
// ── CHANGED: calculate and display subtotal, platform fee (18%), and grand total ──
(function renderOrder() {
    const list   = document.getElementById('order-items-list');
    const symbol = currencySymbol(PAYPAL_CURRENCY);
    let subtotal = 0;

    cart.forEach(item => {
        subtotal += Number(item.price);
        const row = document.createElement('div');
        row.className = 'order-item';
        const thumb = item.previewUrl
            ? `<div class="order-thumb"><img src="${item.previewUrl}" alt="${item.name}" loading="lazy" /></div>`
            : `<div class="order-thumb">${item.icon || '🖼'}</div>`;
        row.innerHTML = `
            ${thumb}
            <div>
                <div class="order-name">${item.name}</div>
                <div class="order-artist">by ${item.artist}</div>
            </div>
            <div class="order-price">${symbol}${Number(item.price).toLocaleString('en-US')}</div>`;
        list.appendChild(row);
    });

    // ── CHANGED: compute fee and grand total ──
    const platformFee = Math.round(subtotal * PLATFORM_FEE_RATE);
    const grandTotal  = subtotal + platformFee;

    document.getElementById('subtotal-val').textContent = symbol + subtotal.toLocaleString('en-US');
    document.getElementById('fee-val').textContent      = symbol + platformFee.toLocaleString('en-US');
    document.getElementById('total-val').textContent    = symbol + grandTotal.toLocaleString('en-US');
})();

// ── PayPal API calls ────────────────────────────────────────────────────────
async function createPaypalOrder() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${PAY_API}/api/payment/create-paypal-order`, {
        method: 'POST',
        headers: 
        { 
            'Content-Type': 'application/json' , 
            'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(cart.map(c => ({ ArtworkId: c.ArtworkId, Price: c.price })))
    });
    if (!response.ok) throw new Error(await response.text());
    const data = await response.json();
    if (data.success && data.orderId) {
        return data.orderId;
    } else {
        throw new Error(data.message || 'Failed to create PayPal order.');
    }
}

async function verifyPaypalOrder(paypalOrderId) {
    const token = localStorage.getItem('token');

    const response = await fetch(`${PAY_API}/api/payment/verify-paypal`, {
        method: 'POST',
        headers: { 
            'Content-Type': 'application/json', 
            'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
            PaypalOrderId: paypalOrderId,
            Currency: PAYPAL_CURRENCY,
            Cart: cart.map(c => ({ ArtworkId: c.ArtworkId, Price: c.price }))
        })
    });

    if (!response.ok) throw new Error(await response.text());
    const data = await response.json();
    if (!data.success) throw new Error(data.message || 'Payment verification failed.');
    return data;
}

// ── Success modal helpers ───────────────────────────────────────────────────
function bindSuccessActions(orderId) {
    successOrderId = orderId;
    document.getElementById('view-order-btn').href = `/Buyer/Orders`;
    document.getElementById('invoice-btn').onclick  = () => window.open(`${PAY_API}/api/order/${orderId}/invoice`, '_blank');
    document.getElementById('order-actions').classList.add('show');
}

function closeSuccessWindow() {
    successModal.classList.remove('show');
    if (successOrderId > 0) window.location.href = `/Buyer/Orders`;
}

function successDownloadPdf() {
    if (successOrderId > 0) window.open(`${PAY_API}/api/order/${successOrderId}/invoice`, '_blank');
}

function successPrintReceipt() {
    if (successOrderId > 0) {
        const win = window.open(`${PAY_API}/api/order/${successOrderId}/invoice`, '_blank');
        if (win) win.onload = function () { win.print(); };
    }
}

// Close modal on backdrop click or Escape
successModal.addEventListener('click', e => { if (e.target === successModal) closeSuccessWindow(); });
document.addEventListener('keydown',  e => { if (e.key === 'Escape' && successModal.classList.contains('show')) closeSuccessWindow(); });

// ── PayPal button init ──────────────────────────────────────────────────────
if (!PAYPAL_CLIENT_ID || PAYPAL_CLIENT_ID === 'YOUR_PAYPAL_SANDBOX_CLIENT_ID') {
    document.getElementById('paypal-box').classList.add('paypal-disabled');
    setBanner('Add your real PayPal sandbox client ID in MVC appsettings before testing checkout.', 'error');
} else if (!PAY_API) {
    document.getElementById('paypal-box').classList.add('paypal-disabled');
    setBanner('Payment API base URL is missing in MVC configuration.', 'error');
} else {
    paypal.Buttons({
        style: {
            shape: 'pill',
            layout: 'vertical',
            color: 'gold',
            label: 'paypal'
        },
        onClick: function (data, actions) {
            if (!validateForm()) {
                setBanner('Please complete the billing details before continuing to PayPal.', 'error');
                return actions.reject();
            }
            setBanner('Opening PayPal sandbox checkout...', 'success');
            return actions.resolve();
        },
        createOrder: async function () {
            return await createPaypalOrder();
        },
        onApprove: async function (data) {
            try {
                const result = await verifyPaypalOrder(data.orderID);

                localStorage.removeItem('artify_cart');
                sessionStorage.removeItem('artify_checkout_cart');
                sessionStorage.removeItem('artify_checkout_meta');
                localStorage.removeItem('artvault_cart');

                successOrderId = result.orderId;
                bindSuccessActions(result.orderId);

                // ── CHANGED: show grand total (with fee) in the success modal ──
                const totalAmt = document.getElementById('total-val').textContent;
                const now      = new Date();
                const currDate = ("0" + now.getDate()).slice(-2) + "-"
                                + ("0" + (now.getMonth() + 1)).slice(-2) + "-"
                                + now.getFullYear();

                document.getElementById('successAmount').textContent  = totalAmt;
                document.getElementById('successDate').textContent    = currDate;
                document.getElementById('successBillId').textContent  = "#" + (result.orderId || data.orderID);
                successModal.classList.add('show');

            } catch (error) {
                setBanner(error.message || 'PayPal verification failed.', 'error');
            }
        },
        onError:  function (error)  { setBanner(error.message || 'PayPal checkout failed.',    'error'); },
        onCancel: function ()        { setBanner('PayPal payment was cancelled.',               'error'); }
    }).render('#paypal-button-container');
}
</script>
}