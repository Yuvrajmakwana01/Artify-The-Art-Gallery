@{
    ViewData["Title"] = "Checkout - Artify";
    Layout = "_Layout";
    var apiBase = (ViewData["PaymentApiBaseUrl"] ?? string.Empty).ToString()?.TrimEnd('/');
    var payPalClientId = (ViewData["PayPalClientId"] ?? string.Empty).ToString();
    var payPalCurrency = (ViewData["PayPalCurrency"] ?? "USD").ToString();
}

 
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
:root {
    --background: hsl(36, 33%, 97%);
    --foreground: hsl(30, 10%, 15%);
    --card: #ffffff;
    --primary: hsl(30, 45%, 25%);
    --primary-foreground: hsl(36, 33%, 97%);
    --secondary: hsl(32, 25%, 88%);
    --muted: hsl(30, 10%, 45%);
    --accent: hsl(38, 60%, 55%);
    --border: hsl(32, 20%, 85%);
    --danger: #DC4A4A;
    --success: #22c55e;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', sans-serif;
    background: var(--background);
    color: var(--foreground);
    line-height: 1.6;
}

h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', serif;
}

/* ── Navbar ── */
.checkout-navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: hsla(36, 33%, 97%, 0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
}

.checkout-navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
}

.logo-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
}

.back-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
}

.back-btn:hover {
    background: var(--secondary);
    color: var(--foreground);
}

.site-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--foreground);
    text-decoration: none;
    letter-spacing: -0.025em;
    transition: color 0.3s;
}

.site-logo:hover { color: var(--accent); }

.step-pill {
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--secondary);
    padding: 5px 14px;
    border-radius: 9999px;
    font-weight: 500;
}

/* ── Page ── */
.checkout-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
}

.page-header { margin-bottom: 2rem; }

.page-header h1 {
    font-size: 2rem;
    font-weight: 700;
}

.page-header p {
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
}

/* ── Layout ── */
.checkout-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 32px;
    align-items: start;
}

/* ── Cards ── */
.co-card {
    background: var(--card);
    border-radius: 1rem;
    border: 1px solid var(--border);
    padding: 24px;
    transition: box-shadow 0.2s;
}

.co-card + .co-card { margin-top: 16px; }

.card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
}

/* ── Form ── */
.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.form-row { margin-bottom: 14px; }

.form-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.form-input {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--background);
    color: var(--foreground);
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
}

.form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px hsla(38, 60%, 55%, 0.1);
}

.field-error {
    display: block;
    min-height: 16px;
    margin-top: 4px;
    color: var(--danger);
    font-size: 12px;
}

/* ── PayPal section ── */
.paypal-note {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.8;
    margin-bottom: 14px;
}

.paypal-box {
    background: var(--background);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 14px;
}

.paypal-disabled {
    opacity: 0.5;
    pointer-events: none;
}

/* ── Status banner ── */
.status-banner {
    display: none;
    margin-top: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
}

.status-banner.show { display: block; }
.status-banner.success { background: rgba(34, 197, 94, 0.1); color: #15803d; }
.status-banner.error   { background: rgba(220, 74, 74, 0.1);  color: var(--danger); }

/* ── Order actions ── */
.order-actions {
    display: none;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.order-actions.show { display: flex; }

.action-btn {
    padding: 9px 16px;
    border-radius: 9999px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--foreground);
    text-decoration: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
}

.action-btn:hover {
    border-color: var(--accent);
    color: var(--primary);
}

/* ── Order items ── */
.order-item {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
}

.order-item:last-child { border-bottom: none; }

.order-thumb {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
}

.order-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.order-name   { font-size: 14px; font-weight: 600; }
.order-artist { font-size: 12px; color: var(--muted); margin-top: 2px; }
.order-price  { margin-left: auto; font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 600; white-space: nowrap; }

/* ── Summary ── */
.totals { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border); }

.summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    margin-bottom: 10px;
}

.summary-row span:first-child { color: var(--muted); }

.summary-row.grand {
    padding-top: 14px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
    font-size: 16px;
    font-weight: 700;
}

.summary-row.grand span:first-child { color: var(--foreground); }

/* ── Notes card ── */
.notes-card {
    background: hsla(38, 60%, 55%, 0.07);
    border: 1px solid hsla(38, 60%, 55%, 0.25);
    border-radius: 1rem;
    padding: 18px 20px;
    margin-top: 16px;
}

.notes-card .card-title {
    font-size: 1rem;
    border-color: hsla(38, 60%, 55%, 0.25);
}

.notes-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 2;
}

/* ── Success Modal ── */
.success-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(30, 20, 12, 0.48);
    backdrop-filter: blur(6px);
    z-index: 1000;
}

.success-modal.show { display: flex; }

.success-modal-card {
    width: min(420px, 100%);
    transform: translateY(16px) scale(0.98);
    opacity: 0;
    transition: transform 0.25s ease, opacity 0.25s ease;
}

.success-modal.show .success-modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
}

.success-dialog-content {
    background: #ffffff;
    border-radius: 16px 16px 0 0;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    position: relative;
    font-family: 'Inter', sans-serif;
    color: #1a1612;
}

.modal-close-btn {
    position: absolute;
    top: 14px;
    right: 18px;
    font-size: 1.1rem;
    color: var(--muted);
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
}

.modal-close-btn:hover { color: var(--foreground); }

.icon-container {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
}

.success-dialog-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: #1a202c;
}

.success-desc {
    color: #718096;
    font-size: 13px;
    margin-bottom: 1.25rem;
    line-height: 1.5;
}

.amt-container { margin-bottom: 1.25rem; }

.amt-label {
    display: block;
    font-size: 12px;
    color: #718096;
    margin-bottom: 4px;
}

.amt-value {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #1a202c;
}

.meta-info {
    font-size: 12px;
    color: #718096;
    margin-bottom: 1.5rem;
}

.meta-info strong { color: #4a5568; font-weight: 600; }

.modal-action-buttons {
    display: flex;
    gap: 10px;
    justify-content: center;
}

.modal-btn {
    background: #ffffff;
    border: 1.5px solid #e2e8f0;
    color: #1a202c;
    padding: 9px 18px;
    font-weight: 600;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
}

.modal-btn:hover { background: #f8fafc; }

.scalloped-bottom {
    height: 14px;
    background-image: radial-gradient(circle at 10px 0, #ffffff 10px, transparent 11px);
    background-size: 20px 20px;
    background-repeat: repeat-x;
    transform: translateY(-1px);
}

/* ── Responsive ── */
@@media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .sticky-summary  { position: static !important; }
}

@@media (max-width: 600px) {
    .form-grid { grid-template-columns: 1fr; }
}

@@media (max-width: 768px) {
    .checkout-navbar-inner .step-pill { display: none; }
}
</style>


