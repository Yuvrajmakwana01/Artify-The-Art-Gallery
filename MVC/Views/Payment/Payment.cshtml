        throw new Error(data.message || 'Failed to create PayPal order.');
    }
} *@

async function createPaypalOrder() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${PAY_API}/api/payment/create-paypal-order`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
            Currency: PAYPAL_CURRENCY,
            Subtotal: checkoutMeta.subtotal,
            CommissionAmount: checkoutMeta.platformFee,
            TotalAmount: checkoutMeta.grandTotal,
            Cart: cart.map(c => ({ ArtworkId: c.ArtworkId, ArtistId: c.ArtistId ?? 0, Price: c.price ?? c.Price ?? 0 }))
        })
    });
    if (!response.ok) throw new Error(await response.text());
    const data = await response.json();
    if (data.success && data.orderId) return data.orderId;
    throw new Error(data.message || 'Failed to create PayPal order.');
}

async function verifyPaypalOrder(paypalOrderId) {
    const token = localStorage.getItem('token');

    const response = await fetch(`${PAY_API}/api/payment/verify-paypal`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
            PaypalOrderId: paypalOrderId,
            Currency: PAYPAL_CURRENCY,
            Subtotal: checkoutMeta.subtotal,
            CommissionAmount: checkoutMeta.platformFee,
            TotalAmount: checkoutMeta.grandTotal,
            Cart: cart.map(c => ({ ArtworkId: c.ArtworkId, Price: c.price }))
        })
    });

    if (!response.ok) throw new Error(await response.text());
    const data = await response.json();
    if (!data.success) throw new Error(data.message || 'Payment verification failed.');
    return data;
}

function bindSuccessActions(orderId) {
    successOrderId = orderId;
    document.getElementById('view-order-btn').href = `/Buyer/Orders`;
    document.getElementById('invoice-btn').onclick  = () => window.open(`${PAY_API}/api/order/${orderId}/invoice`, '_blank');
    document.getElementById('order-actions').classList.add('show');
}

function closeSuccessWindow() {
    successModal.classList.remove('show');
    if (successOrderId > 0) window.location.href = `/Buyer/Dashboard`;
}

function successDownloadPdf() {
    if (successOrderId > 0) window.open(`${PAY_API}/api/order/${successOrderId}/invoice`, '_blank');
}

function successPrintReceipt() {
    if (successOrderId > 0) {
        const win = window.open(`${PAY_API}/api/order/${successOrderId}/invoice`, '_blank');
        if (win) win.onload = function () { win.print(); };
    }
}

successModal.addEventListener('click', e => { if (e.target === successModal) closeSuccessWindow(); });
document.addEventListener('keydown',  e => { if (e.key === 'Escape' && successModal.classList.contains('show')) closeSuccessWindow(); });

if (!PAYPAL_CLIENT_ID || PAYPAL_CLIENT_ID === 'YOUR_PAYPAL_SANDBOX_CLIENT_ID') {
    document.getElementById('paypal-box').classList.add('paypal-disabled');
    setBanner('Add your real PayPal sandbox client ID in MVC appsettings before testing checkout.', 'error');
} else if (!PAY_API) {
    document.getElementById('paypal-box').classList.add('paypal-disabled');
    setBanner('Payment API base URL is missing in MVC configuration.', 'error');
} else {
    paypal.Buttons({
        style: {
            shape: 'pill',
            layout: 'vertical',
            color: 'gold',
            label: 'paypal'
        },
        onClick: function (data, actions) {
            if (!validateForm()) {
                setBanner('Please complete the billing details before continuing to PayPal.', 'error');
                return actions.reject();
            }
            setBanner('Opening PayPal sandbox checkout...', 'success');
            return actions.resolve();
        },
        createOrder: async function () {
            return await createPaypalOrder();
        },
        onApprove: async function (data) {
            try {
                const result = await verifyPaypalOrder(data.orderID);

                localStorage.removeItem('artify_cart');
                sessionStorage.removeItem('artify_checkout_cart');
                sessionStorage.removeItem('artify_checkout_meta');
                localStorage.removeItem('artvault_cart');

                successOrderId = result.orderId;
                bindSuccessActions(result.orderId);

                const totalAmt = document.getElementById('total-val').textContent;
                const now      = new Date();
                const currDate = ("0" + now.getDate()).slice(-2) + "-"
                                + ("0" + (now.getMonth() + 1)).slice(-2) + "-"
                                + now.getFullYear();

                document.getElementById('successAmount').textContent  = totalAmt;
                document.getElementById('successDate').textContent    = currDate;
                document.getElementById('successBillId').textContent  = "#" + (result.orderId || data.orderID);
                successModal.classList.add('show');

            } catch (error) {
                setBanner(error.message || 'PayPal verification failed.', 'error');
            }
        },
        onError:  function (error)  { setBanner(error.message || 'PayPal checkout failed.', 'error'); },
        onCancel: function ()        { setBanner('PayPal payment was cancelled.', 'error'); }
    }).render('#paypal-button-container');
}
</script>
}
