@{
    ViewData["Title"] = "Sales & Earnings";
    Layout = "~/Views/Shared/_ArtisLayout.cshtml";
}

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<!-- DataTables -->
<link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />

<!-- Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    :root {
        --primary: #7c3aed;
        --bg-main: #f3f4f6;
        --border: #e5e7eb;
    }

    body {
        background: var(--bg-main);
        font-family: 'Segoe UI', sans-serif;
    }

    /* SIDEBAR */
    .sidebar {
        position: fixed;
        width: 220px;
        height: 100%;
        background: #fff;
        border-right: 1px solid var(--border);
        padding: 20px;
    }

    .sidebar .nav-link {
        color: #6b7280;
        margin-bottom: 10px;
        border-radius: 8px;
    }

    .sidebar .nav-link:hover,
    .sidebar .nav-link.active {
        background: #ede9fe;
        color: var(--primary);
    }

    /* MAIN */
    .main {
        margin-left: 220px;
    }

    /* TOPBAR */
    .topbar {
        background: #fff;
        padding: 15px 25px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .content {
        padding: 25px;
    }

    .card-box {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid var(--border);
    }

    .status-badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .completed { background: #dcfce7; color: #16a34a; }
    .processing { background: #fef9c3; color: #d97706; }

</style>

<!-- SIDEBAR -->
<div class="sidebar">
    <h5 class="mb-4"><i class="bi bi-palette"></i> ArtSpace</h5>

    <nav class="nav flex-column">
        <a class="nav-link active" href="#">Dashboard</a>
        <a class="nav-link" href="#">Sales History</a>
        <a class="nav-link" href="#">Artworks</a>
        <a class="nav-link" href="#">Earnings</a>
        <a class="nav-link" href="#">Settings</a>
    </nav>
</div>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
        <h5><i class="bi bi-bar-chart"></i> Sales & Earnings</h5>

        <div class="d-flex align-items-center gap-3">
            <input type="text" class="form-control" placeholder="Search..." style="width:200px;" />
            <i class="bi bi-bell"></i>
            <div class="bg-primary text-white rounded-circle px-2">A</div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- CARDS -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card-box">
                    <h6>Total Earnings</h6>
                    <h4>$12,450</h4>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <h6>Balance</h6>
                    <h4>$3,205</h4>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <h6>Commission</h6>
                    <h4>$1,867</h4>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="card-box">
            <table id="salesTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>Artwork</th>
                        <th>Buyer</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
            </table>
        </div>

    </div>
</div>

@section Scripts {

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

    const salesData = [
        { artwork: "Neon Dreams", buyer: "Alex", date: "2023-10-12", amount: 850, status: "Completed" },
        { artwork: "Static Motion", buyer: "Sarah", date: "2023-10-11", amount: 2400, status: "Processing" },
        { artwork: "Vortex Waves", buyer: "Marcus", date: "2023-10-09", amount: 420, status: "Completed" }
    ];

    function getBadge(status) {
        let cls = status === "Completed" ? "completed" : "processing";
        return `<span class="status-badge ${cls}">${status}</span>`;
    }

    $(document).ready(function () {

        $('#salesTable').DataTable({
            data: salesData,
            columns: [
                { data: 'artwork' },
                { data: 'buyer' },
                { data: 'date' },
                {
                    data: 'amount',
                    render: function (d) { return "$" + d; }
                },
                {
                    data: 'status',
                    render: function (d) { return getBadge(d); }
                }
            ]
        });

    });

</script>
}