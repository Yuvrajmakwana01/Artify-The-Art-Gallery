@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}


<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.default-v2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.13.1/font/bootstrap-icons.min.css" integrity="sha512-t7Few9xlddEmgd3oKZQahkNI4dS6l80+eGEzFQiqtyVYdvcSG2D3Iub77R20BdotfRPA9caaRkg1tyaJiPmO0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />



<div class="container sp-fade-up" style="max-width:780px">
    <div class="studio-card">
        <form id="editForm" enctype="multipart/form-data">
            <input type="hidden" id="ArtistId" name="ArtistId" value="1" />

            <!-- CARD HEADER -->
            <div class="header-group">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-wrapper">BS</div>
                    <div>
                        <h4 style="font-family:var(--font-display);font-size:1.3rem;font-weight:400;color:var(--sp-ink);margin:0">
                            Edit Artist Profile
                        </h4>
                        <p style="font-size:0.82rem;color:var(--sp-muted);margin:0">Customize your professional presence</p>
                    </div>
                </div>
                <button type="button" class="sp-btn sp-btn-amber" onclick="$('#editForm').submit()">
                    <i class="bi bi-floppy-fill me-1"></i> Save Changes
                </button>
            </div>

            <!-- ALERT -->
            <div id="msgBox" class="alert d-none mb-4"></div>

            <!-- BASIC INFO -->
            <div class="section-divider"><span>Basic Studio Info</span></div>

            <div class="mb-4">
                <label class="form-label">Artist Name</label>
                <input type="text" class="k-input w-100" id="ArtistName" name="ArtistName" placeholder="Your name" />
            </div>

            <div class="mb-4">
                <label class="form-label">Biography</label>
                <textarea class="k-textarea w-100" id="Biography" name="Biography" rows="4"
                    placeholder="Share your artistic journey…"></textarea>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label d-block">Account Status</label>
                    <div class="status-container" id="statusToggle">
                        <button type="button" class="status-opt selected-active" id="optActive"  onclick="setStatus(true)">Active</button>
                        <button type="button" class="status-opt"                 id="optInactive" onclick="setStatus(false)">Inactive</button>
                    </div>
                    <input type="hidden" id="IsActive" name="IsActive" value="true" />
                </div>
            </div>

            <!-- VISUALS -->
            <div class="section-divider"><span>Visuals</span></div>

            <div class="mb-4">
                <label class="form-label">Studio Cover Image</label>
                <div class="sp-upload-zone" onclick="$('#CoverImageFile').click()" style="cursor:pointer">
                    <input type="file" id="CoverImageFile" name="CoverImageFile" accept="image/*" class="d-none"
                           onchange="handleFileChange(this)" />
                    <div class="sp-upload-zone-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                    <div class="sp-upload-zone-label" id="uploadLabel">Click to upload brand imagery</div>
                    <div class="sp-upload-zone-sub">PNG or JPG — up to 10 MB</div>
                </div>
            </div>

            <!-- SOCIAL LINKS -->
            <div class="section-divider"><span>Social Connections</span></div>
            <div id="urlContainer"></div>
            <button type="button" class="sp-btn sp-btn-outline mt-2" id="addUrlBtn" style="font-size:0.82rem">
                <i class="bi bi-plus-circle me-1"></i> Add another link
            </button>

        </form>
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // 1. Get User ID from LocalStorage (set during Login in your Controller)
            const userData = JSON.parse(localStorage.getItem("userData"));
            if (!userData || !userData.c_User_Id) {
                Swal.fire("Error", "Session expired. Please login again.", "error");
                return;
            }
            const artistId = userData.c_User_Id;
            $("#ArtistId").val(artistId);

            // 2. Fetch Profile Data using the correct endpoint from your Repository
            // Matches: [HttpGet("profile/{id}")] in your Controller
            $.get(`http://localhost:5183/api/ArtistApi/profile/${artistId}`, function (data) {
                if (data) {
                    // Mapping fields from t_ArtistProfile model
                    $("#ArtistName").val(data.artistName || "");
                    $("#Biography").val(data.biography || "");
                    
                    // Set status toggle
                    setStatus(data.isActive !== false);

                    // Map URLs array
                    $("#urlContainer").empty();
                    if (data.urls && data.urls.length > 0) {
                        data.urls.forEach(function(u) { addUrl(u); });
                    } else { 
                        addUrl(); 
                    }

                    // Optional: Update UI Avatar initials
                    if(data.artistName) {
                        const initials = data.artistName.split(' ').map(n => n[0]).join('').toUpperCase();
                        $(".avatar-wrapper").text(initials.substring(0,2));
                    }
                }
            });

            // 3. Status Toggle Logic
            window.setStatus = function (val) {
                $("#IsActive").val(val ? "true" : "false");
                if (val) {
                    $("#optActive").addClass("selected-active");
                    $("#optInactive").removeClass("selected-inactive");
                } else {
                    $("#optInactive").addClass("selected-inactive");
                    $("#optActive").removeClass("selected-active");
                }
            };

            // 4. Social Links Logic
            window.addUrl = function (val) {
                val = val || "";
                var id = "url_" + Date.now();
                $("#urlContainer").append(`
                    <div class="url-item" id="wrap_${id}">
                        <span class="url-prefix">https://</span>
                        <input type="text" class="k-input url-input" value="${val}" placeholder="behance.net/username" />
                        <button type="button" class="sp-btn sp-btn-danger" onclick="$('#wrap_${id}').remove()">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                `);
            };

            $("#addUrlBtn").click(function() { addUrl(); });

            // 5. Submit Logic
            $("#editForm").submit(function (e) {
    e.preventDefault();

    var formData = new FormData();
    formData.append("ArtistId", $("#ArtistId").val());
    formData.append("ArtistName", $("#ArtistName").val());
    formData.append("Biography", $("#Biography").val());
    formData.append("IsActive", $("#IsActive").val());
    
    // 1. Append the file if selected
    var fileInput = document.getElementById('CoverImageFile');
    if (fileInput.files.length > 0) {
        formData.append("CoverImageFile", fileInput.files[0]);
    }

    // 2. Append URLs correctly as an array for the model
    $(".url-input").each(function(index) {
        let val = $(this).val().trim();
        if(val) {
            formData.append(`Urls[${index}]`, val);
        }
    });

    $.ajax({
        url: "http://localhost:5183/api/ArtistApi/profile", 
        type: "POST",
        data: formData,
        contentType: false, // Required for FormData
        processData: false, // Required for FormData
        success: function (res) {
            Swal.fire("Success", "Profile updated successfully!", "success")
                .then(() => window.location.href = "/Artist/MyProfile");
        },
        error: function (xhr) {
            Swal.fire("Error", "Failed to update profile: " + xhr.responseText, "error");
        }
    });
});

        });

        function handleFileChange(input) {
            if (input.files && input.files[0]) {
                $("#uploadLabel").text(input.files[0].name).css("color", "#d97706");
            }
        }
    </script>
}