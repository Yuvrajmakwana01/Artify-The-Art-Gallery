@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artify — Sign In</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.default-v2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <style>
        :root{--navy:#14122a;--gold:#c9a96e;--paper:#faf8f5;--text:#1a1612;--muted:#6b6057;--border:rgba(0,0,0,.09)}
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'DM Sans',sans-serif;background:var(--paper);min-height:100vh;
             display:flex;align-items:center;justify-content:center;padding:2rem 1rem;}
        body::before{content:'';position:fixed;inset:0;pointer-events:none;
            background:radial-gradient(ellipse 60% 55% at 8% 15%,rgba(201,169,110,.08) 0%,transparent 70%),
                        radial-gradient(ellipse 55% 65% at 92% 85%,rgba(20,18,42,.07) 0%,transparent 70%);}
        .wrap{width:100%;max-width:430px;position:relative;z-index:1;}
        .brand{display:flex;align-items:center;gap:10px;margin-bottom:1.75rem;justify-content:center;}
        .brand-dot{width:30px;height:30px;border-radius:8px;background:var(--navy);display:flex;align-items:center;justify-content:center;}
        .brand-dot span{width:9px;height:9px;border-radius:50%;background:var(--gold);display:block;}
        .brand-name{font-family:'Syne',sans-serif;font-size:.78rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:var(--text);}
        .card{background:#fff;border:1px solid var(--border);border-radius:20px;padding:2.5rem;box-shadow:0 2px 20px rgba(0,0,0,.06);}
        .card h1{font-family:'Syne',sans-serif;font-size:1.65rem;font-weight:800;color:var(--navy);margin-bottom:4px;}
        .card .sub{font-size:.88rem;color:var(--muted);margin-bottom:2rem;}
        .field{display:flex;flex-direction:column;gap:6px;margin-bottom:1.1rem;}
        .field label{font-size:.73rem;font-weight:600;color:var(--muted);letter-spacing:.3px;}
        .k-textbox{background:#faf8f5!important;border:1px solid var(--border)!important;border-radius:10px!important;
                   padding:12px 14px!important;width:100%!important;font-family:'DM Sans',sans-serif!important;
                   font-size:.9rem!important;color:var(--text)!important;transition:border-color .18s,box-shadow .18s!important;}
        .k-textbox:focus{border-color:var(--gold)!important;box-shadow:0 0 0 3px rgba(201,169,110,.2)!important;}
        .k-callout{display:none!important}
        .k-tooltip-validation{background:transparent!important;color:#c0392b!important;box-shadow:none!important;
                               border:none!important;font-size:.72rem!important;padding:4px 0 0!important;}
        .pw-wrap{position:relative;}
        .pw-wrap .k-textbox{padding-right:56px!important;}
        .pw-toggle{position:absolute;right:0;top:0;bottom:0;width:46px;display:flex;align-items:center;
                   justify-content:center;background:none;border:none;cursor:pointer;color:var(--muted);
                   font-size:.72rem;font-weight:600;font-family:'DM Sans',sans-serif;letter-spacing:.3px;}
        .pw-toggle:hover{color:var(--navy);}
        .btn-login{width:100%;height:50px;border-radius:12px;border:none;background:var(--navy);color:#fff;
                   font-family:'Syne',sans-serif;font-size:.88rem;font-weight:700;letter-spacing:1px;
                   text-transform:uppercase;cursor:pointer;margin-top:.5rem;transition:all .2s;
                   display:flex;align-items:center;justify-content:center;gap:8px;}
        .btn-login:hover{background:#1e1b38;transform:translateY(-1px);box-shadow:0 6px 22px rgba(20,18,42,.3);}
        .btn-login:disabled{opacity:.6;transform:none;cursor:not-allowed;}
        .gold-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);flex-shrink:0;}
        .pending-banner{display:none;background:#fffbeb;border:1px solid #fcd34d;border-radius:12px;
                         padding:1rem 1.25rem;margin-bottom:1.25rem;font-size:.85rem;color:#92400e;}
        .pending-banner strong{display:block;margin-bottom:3px;font-size:.88rem;}
        .divider{display:flex;align-items:center;gap:12px;margin:1.5rem 0;}
        .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border);}
        .divider span{font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-weight:600;}
        .footer-note{text-align:center;font-size:.85rem;color:var(--muted);}
        .footer-note a{color:#8a5e1a;font-weight:600;text-decoration:none;}
        .footer-note a:hover{text-decoration:underline;}
    </style>
</head>
<body>
<div class="wrap">
    <div class="brand">
        <div class="brand-dot"><span></span></div>
        <span class="brand-name">Artify</span>
    </div>

    <div class="card">
        <h1>Welcome back</h1>
        <p class="sub">Sign in to your creative studio.</p>

        <!-- Shown when account is pending approval -->
        <div class="pending-banner" id="pendingBanner">
            <strong>⏳ Account Pending Approval</strong>
            Your registration is under review. You will receive access once an admin approves your account.
        </div>

        <form id="loginForm" novalidate>
            <div class="field">
                <label for="txtEmail">Email Address</label>
                <input id="txtEmail" name="c_Email" type="email" required
                       placeholder="artist@example.com"
                       data-email-msg="Please enter a valid email"
                       data-required-msg="Email is required" />
            </div>
            <div class="field">
                <label for="txtPassword">Password</label>
                <div class="pw-wrap">
                    <input id="txtPassword" name="c_Password" type="password" required
                           placeholder="••••••••"
                           data-required-msg="Password is required" />
                    <button type="button" class="pw-toggle" id="togglePw">Show</button>
                </div>
            </div>
            <button type="button" class="btn-login" id="btnLogin">
                <div class="gold-dot"></div>
                <span id="btnText">Sign In</span>
            </button>
        </form>

        <div class="divider"><span>New here?</span></div>
        <p class="footer-note">
            Don't have an account? <a href="/Artist/Register">Create one</a>
        </p>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
$(function () {

    $("#txtEmail,#txtPassword").kendoTextBox();

    // Password show / hide
    $("#togglePw").on("click", function () {
        var inp = $("#txtPassword")[0];
        if (inp.type === "password") { inp.type = "text";     $(this).text("Hide"); }
        else                         { inp.type = "password"; $(this).text("Show"); }
    });

    var validator = $("#loginForm").kendoValidator().data("kendoValidator");

    $("#btnLogin").on("click", function () {
        if (!validator.validate()) return;

        var btn = $(this);
        btn.prop("disabled", true);
        $("#btnText").text("Signing in…");
        $("#pendingBanner").hide();

        $.ajax({
            url:         "http://localhost:5183/api/ArtistApi/Login",
            type:        "POST",
            data:        new FormData($("#loginForm")[0]),
            contentType: false,
            processData: false,
            // ─────────────────────────────────────────────────
            // withCredentials:true is set HERE and ONLY here.
            // This is the only call that needs to receive the
            // Set-Cookie header from the API. Setting it globally
            // via $.ajaxSetup would conflict with CORS on other
            // endpoints that use a different policy (wildcard).
            // ─────────────────────────────────────────────────
            xhrFields: { withCredentials: true },
            success: function (res) {
    btn.prop("disabled", false);
    $("#btnText").text("Sign In");

    if (res.success) {
        localStorage.setItem("authToken", res.token);
        localStorage.setItem("userData", JSON.stringify(res.userData));

        // ✅ NEW: Write session on the MVC server before redirecting
        $.ajax({
            url: "/Artist/SetSession",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({
                artistId: res.userData.c_User_Id,
                token: res.token
            }),
            success: function () {
                Swal.fire({
                    icon: "success",
                    title: "Welcome!",
                    showConfirmButton: false,
                    timer: 1100
                }).then(function () {
                    window.location.href = "/Artist/DashBoard";
                });
            },
            error: function () {
                Swal.fire({ icon: "error", title: "Session error", text: "Could not establish session." });
            }
        });

                } else if (res.inactive) {
                    $("#pendingBanner").slideDown(200);

                } else {
                    Swal.fire({
                        icon:             "error",
                        title:            "Sign-in failed",
                        text:             res.message || "Invalid email or password.",
                        confirmButtonColor: "#14122a"
                    });
                }
            },
            error: function (xhr) {
                btn.prop("disabled", false);
                $("#btnText").text("Sign In");
                var msg = (xhr.responseJSON && xhr.responseJSON.message) || "Could not reach the server.";
                Swal.fire({ icon: "warning", title: "Connection error", text: msg, confirmButtonColor: "#14122a" });
            }
        });
    });

    // Allow Enter key to submit
    $(document).on("keypress", function (e) {
        if (e.key === "Enter") $("#btnLogin").trigger("click");
    });
});
</script>
</body>
</html>
