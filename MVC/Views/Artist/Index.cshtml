@{
    ViewData["Title"] = "Artify";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --ink: #0D0D0D;
      @* --cream: #F5F0E8; *@
      --cream: #FDFAF6;

      --gold: #EDA312;
      --gold-light: #E8D5A0;
      --cobalt: #1A3A6B;
      --cobalt-light: #2E5FA3;
      --mist: #E8ECF0;
      --warm-white: #FAF8F4;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
      --mono: 'Space Mono', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: var(--sans);
      overflow-x: hidden;
    }

    /* ===== NOISE TEXTURE OVERLAY ===== */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
    }

    /* ===== NAVBAR ===== */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.2rem 5vw;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s, backdrop-filter 0.4s, box-shadow 0.4s;
    }

    nav.scrolled {
      background: #FDFAF6;
      backdrop-filter: blur(16px);
      box-shadow: 0 1px 0 rgba(0,0,0,0.08);
    }

    .nav-brand {
      font-family: var(--serif);
      font-size: 1.75rem;
      font-weight: 900;
      color: #040404ff;
      letter-spacing: 0.03em;
      text-decoration: none;
    }

    .nav-brand span { color: var(--gold); }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--cobalt);
      text-decoration: none;
      position: relative;
      opacity: 0.75;
      transition: opacity 0.2s;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -3px; left: 0;
      width: 0; height: 1.5px;
      background: var(--gold);
      transition: width 0.3s ease;
    }

    .nav-links a:hover { opacity: 1; }
    .nav-links a:hover::after { width: 100%; }

    .nav-cta {
      background: var(--cobalt);
      color: #fff !important;
      padding: 0.55rem 1.4rem;
      border-radius: 100px;
      opacity: 1 !important;
      transition: background 0.25s, transform 0.25s !important;
    }

    .nav-cta::after { display: none !important; }
    .nav-cta:hover { background: var(--cobalt-light) !important; transform: translateY(-1px); }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }

    .nav-hamburger span {
      width: 24px; height: 2px;
      background: var(--cobalt);
      border-radius: 2px;
      transition: 0.3s;
    }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 120px 5vw 80px;
      gap: 4rem;
      position: relative;
      overflow: hidden;
    }

    /* Background decorative elements */
    .hero-bg-circle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
    }

    .hero-bg-circle-1 {
      width: 600px; height: 600px;
      right: -80px; top: -80px;
      background: radial-gradient(circle, rgba(201,168,76,0.12) 0%, transparent 70%);
      animation: floatCircle 8s ease-in-out infinite;
    }

    .hero-bg-circle-2 {
      width: 400px; height: 400px;
      left: -120px; bottom: 0;
      background: radial-gradient(circle, rgba(26,58,107,0.08) 0%, transparent 70%);
      animation: floatCircle 10s ease-in-out infinite reverse;
    }

    @@keyframes floatCircle {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(20px, -30px) scale(1.04); }
      66% { transform: translate(-15px, 15px) scale(0.97); }
    }

    /* Diagonal decorative line */
    .hero-diagonal {
      position: absolute;
      top: 0; right: 30%;
      width: 1px;
      height: 100%;
      background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.2) 30%, rgba(201,168,76,0.2) 70%, transparent);
      transform: rotate(15deg) translateX(100px);
    }

    .hero-left {
      position: relative;
      z-index: 2;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.8rem;
      opacity: 0;
      animation: fadeSlideUp 0.8s 0.2s forwards;
    }

    .hero-eyebrow::before {
      content: '';
      width: 32px; height: 1px;
      background: var(--gold);
    }

    .hero-headline {
      font-family: var(--serif);
      font-size: clamp(3.2rem, 5vw, 5.5rem);
      font-weight: 900;
      line-height: 1.02;
      color: var(--cobalt);
      letter-spacing: -0.03em;
      opacity: 0;
      animation: fadeSlideUp 0.9s 0.4s forwards;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--gold);
      display: block;
    }

    .hero-typewriter-wrap {
      margin-top: 1.6rem;
      opacity: 0;
      animation: fadeSlideUp 0.9s 0.6s forwards;
    }

    .hero-typewriter-label {
      font-size: 0.78rem;
      font-family: var(--mono);
      color: rgba(13,13,13,0.45);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .hero-typewriter-line {
      font-family: var(--serif);
      font-size: clamp(1.4rem, 2.2vw, 1.85rem);
      font-weight: 400;
      font-style: italic;
      color: var(--cobalt);
      min-height: 2.4em;
      display: flex;
      align-items: center;
    }

    .cursor {
      display: inline-block;
      width: 2px;
      height: 1.1em;
      background: var(--gold);
      margin-left: 3px;
      vertical-align: middle;
      animation: blink 0.75s step-end infinite;
    }

    @@keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .hero-desc {
      margin-top: 1.8rem;
      font-size: 1rem;
      line-height: 1.75;
      color: rgba(13,13,13,0.65);
      max-width: 440px;
      opacity: 0;
      animation: fadeSlideUp 0.9s 0.8s forwards;
    }

    .hero-actions {
      margin-top: 2.4rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      opacity: 0;
      animation: fadeSlideUp 0.9s 1s forwards;
    }

    .btn-primary {
      background: var(--cobalt);
      color: #fff;
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.02em;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
      box-shadow: 0 8px 24px rgba(26,58,107,0.2);
    }

    .btn-primary:hover {
      background: var(--cobalt-light);
      transform: translateY(-2px);
      box-shadow: 0 14px 32px rgba(26,58,107,0.28);
    }

    .btn-outline {
      background: transparent;
      color: var(--cobalt);
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-weight: 500;
      font-size: 0.9rem;
      text-decoration: none;
      border: 1.5px solid rgba(26,58,107,0.3);
      cursor: pointer;
      transition: border-color 0.25s, background 0.25s, transform 0.25s;
    }

    .btn-outline:hover {
      border-color: var(--cobalt);
      background: rgba(26,58,107,0.05);
      transform: translateY(-2px);
    }

    .hero-stats {
      margin-top: 3rem;
      display: flex;
      gap: 2.5rem;
      opacity: 0;
      animation: fadeSlideUp 0.9s 1.2s forwards;
    }

    .stat-item { }
    .stat-num {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 700;
      color: var(--cobalt);
      line-height: 1;
    }

    .stat-num span { color: var(--gold); }
    .stat-label {
      font-size: 0.72rem;
      font-family: var(--mono);
      color: rgba(13,13,13,0.45);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 0.25rem;
    }

    /* ===== HERO RIGHT - FLOATING GALLERY ===== */
    .hero-right {
      position: relative;
      height: 580px;
      z-index: 2;
      opacity: 0;
      animation: fadeIn 1.2s 0.6s forwards;
    }

    .float-card {
      position: absolute;
      border-radius: 20px;
      overflow: hidden;
      background: var(--warm-white);
      box-shadow: 0 20px 50px rgba(0,0,0,0.14), 0 4px 12px rgba(0,0,0,0.06);
      transition: transform 0.08s ease-out;
      border: 1px solid rgba(255,255,255,0.8);
    }

    .float-card img {
      width: 100%;
      height: 75%;
      object-fit: cover;
      display: block;
    }

    .float-card-info {
      padding: 10px 12px;
      background: var(--warm-white);
    }

    .float-card-title {
      font-family: var(--serif);
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--cobalt);
    }

    .float-card-artist {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: rgba(13,13,13,0.45);
      margin-top: 2px;
    }

    .fc-1 {
      width: 200px; height: 260px;
      top: 2%; left: 5%;
      transform: rotate(-6deg);
      animation: floatA 6s ease-in-out infinite;
    }

    .fc-2 {
      width: 220px; height: 285px;
      top: 15%; right: 5%;
      transform: rotate(4deg);
      animation: floatB 7s ease-in-out infinite;
    }

    .fc-3 {
      width: 185px; height: 240px;
      bottom: 8%; left: 22%;
      transform: rotate(-3deg);
      animation: floatC 8s ease-in-out infinite;
    }

    .fc-badge {
      position: absolute;
      top: -10px; right: -10px;
      background: var(--gold);
      color: #fff;
      font-family: var(--mono);
      font-size: 0.6rem;
      font-weight: 700;
      padding: 4px 8px;
      border-radius: 100px;
      letter-spacing: 0.04em;
    }

    @@keyframes floatA {
      0%, 100% { transform: rotate(-6deg) translateY(0); }
      50% { transform: rotate(-6deg) translateY(-18px); }
    }

    @@keyframes floatB {
      0%, 100% { transform: rotate(4deg) translateY(0); }
      50% { transform: rotate(4deg) translateY(-24px); }
    }

    @@keyframes floatC {
      0%, 100% { transform: rotate(-3deg) translateY(0); }
      50% { transform: rotate(-3deg) translateY(-14px); }
    }

    @@keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    /* ===== MARQUEE ===== */
    .marquee-section {
      background: var(--cobalt);
      padding: 1.2rem 0;
      overflow: hidden;
      position: relative;
    }

    .marquee-inner {
      display: flex;
      gap: 0;
      animation: marqueeRoll 30s linear infinite;
      white-space: nowrap;
      width: fit-content;
    }

    .marquee-item {
      display: inline-flex;
      align-items: center;
      gap: 1.2rem;
      padding: 0 2rem;
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.65);
      flex-shrink: 0;
    }

    .marquee-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    @@keyframes marqueeRoll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ===== SECTIONS SHARED ===== */
    .section {
      padding: 7rem 5vw;
    }

    .section-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .section-tag::before {
      content: '';
      width: 24px; height: 1px;
      background: var(--gold);
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 4vw, 3.8rem);
      font-weight: 800;
      line-height: 1.1;
      color: var(--cobalt);
      letter-spacing: -0.02em;
    }

    .section-title em {
      font-style: italic;
      color: var(--gold);
    }

    /* ===== ARTISTS SECTION ===== */
    .artists-section { background: var(--warm-white); }

    .artists-grid {
      margin-top: 3.5rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .artist-card {
      background: #FBFBFB;
      border-radius: 24px;
      padding: 2rem 1.5rem;
      text-align: center;
      border: 2px solid rgba(201,168,76,0.15);
      transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.3, 1.2), box-shadow 0.4s;
      opacity: 0;
      transform: translateY(30px);
    }

    .artist-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .artist-card:hover {
      transform: translateY(-10px) scale(1.02);
      box-shadow: 0 24px 48px rgba(26,58,107,0.12);
    }

    .artist-avatar {
      width: 90px; height: 90px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--gold-light);
      margin-bottom: 1.2rem;
    }

    .artist-name {
      font-family: var(--serif);
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--cobalt);
    }

    .artist-genre {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .artist-quote {
      font-size: 0.85rem;
      font-style: italic;
      color: rgba(13,13,13,0.5);
      margin-top: 0.8rem;
      line-height: 1.5;
    }

    /* ===== GALLERY ===== */
    .gallery-section { background: var(--cream); }

    .gallery-grid {
      margin-top: 3.5rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .gallery-item {
      border-radius: 20px;
      overflow: hidden;
      background: var(--warm-white);
      box-shadow: 0 6px 20px rgba(0,0,0,0.06);
      opacity: 0;
      transform: translateY(25px);
      transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.4s;
    }

    .gallery-item.visible { opacity: 1; transform: translateY(0); }
    .gallery-item:hover { box-shadow: 0 20px 40px rgba(0,0,0,0.12); }

    .gallery-item:hover .gallery-img { transform: scale(1.05); }

    .gallery-img-wrap {
      height: 260px;
      overflow: hidden;
    }

    .gallery-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .gallery-meta {
      padding: 1.2rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .gallery-title {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--cobalt);
    }

    .gallery-by {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: rgba(13,13,13,0.45);
      margin-top: 3px;
    }

    .gallery-price {
      font-family: var(--mono);
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--gold);
    }

    /* ===== JOIN FLOW SECTION ===== */
    .join-section { background: var(--cobalt); position: relative; overflow: hidden; }

    .join-section::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      top: -150px; right: -150px;
      border-radius: 50%;
      background: rgba(201,168,76,0.07);
      pointer-events: none;
    }

    .join-section::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      bottom: -100px; left: -100px;
      border-radius: 50%;
      background: rgba(201,168,76,0.05);
      pointer-events: none;
    }

    .join-section .section-tag { color: var(--gold-light); }
    .join-section .section-tag::before { background: var(--gold-light); }
    .join-section .section-title { color: #fff; }
    .join-section .section-title em { color: var(--gold); }

    .join-subtitle {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      margin-top: 0.8rem;
      max-width: 520px;
      line-height: 1.7;
    }

    .join-steps {
      margin-top: 4.5rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
      z-index: 1;
    }

    /* Connector line between steps */
    .join-steps::before {
      content: '';
      position: absolute;
      top: 38px;
      left: calc(12.5% + 20px);
      right: calc(12.5% + 20px);
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(201,168,76,0.4) 20%, rgba(201,168,76,0.4) 80%, transparent);
      z-index: 0;
    }

    .join-step {
      text-align: center;
      padding: 0 1.5rem;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s ease;
      position: relative;
      z-index: 1;
    }

    .join-step.visible { opacity: 1; transform: translateY(0); }

    .step-num-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 1.8rem;
    }

    .step-num {
      width: 76px; height: 76px;
      border-radius: 50%;
      border: 1.5px solid rgba(201,168,76,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--serif);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--gold);
      background: rgba(201,168,76,0.06);
      position: relative;
      transition: background 0.3s, border-color 0.3s, transform 0.3s;
    }

    .join-step:hover .step-num {
      background: rgba(201,168,76,0.15);
      border-color: var(--gold);
      transform: scale(1.08);
    }

    .step-icon {
      font-size: 1.8rem;
    }

    .step-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.7rem;
    }

    .step-desc {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.65;
    }

    .join-cta-wrap {
      margin-top: 4rem;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .btn-gold {
      background: var(--gold);
      color: var(--ink);
      padding: 1rem 2.8rem;
      border-radius: 100px;
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
      box-shadow: 0 8px 28px rgba(201,168,76,0.35);
      display: inline-block;
    }

    .btn-gold:hover {
      background: #d4b054;
      transform: translateY(-2px);
      box-shadow: 0 16px 40px rgba(201,168,76,0.45);
    }

    .join-note {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: rgba(255,255,255,0.35);
      margin-top: 1.2rem;
      letter-spacing: 0.08em;
    }

    /* ===== EDITORIAL QUOTE SECTION ===== */
    .editorial-section {
      background: var(--warm-white);
      padding: 7rem 5vw;
    }

    .editorial-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .editorial-img-wrap {
      position: relative;
      border-radius: 28px;
      overflow: hidden;
    }

    .editorial-img-wrap img {
      width: 100%;
      height: 500px;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }

    .editorial-img-wrap:hover img { transform: scale(1.04); }

    .editorial-img-caption {
      position: absolute;
      bottom: 1.5rem; left: 1.5rem;
      background: rgba(245,240,232,0.92);
      backdrop-filter: blur(8px);
      padding: 0.6rem 1rem;
      border-radius: 100px;
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--cobalt);
      letter-spacing: 0.08em;
    }

    .editorial-quote {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 400;
      font-style: italic;
      color: var(--cobalt);
      line-height: 1.45;
      padding-left: 1.8rem;
      border-left: 3px solid var(--gold);
      margin-bottom: 2rem;
    }

    .editorial-body {
      font-size: 1rem;
      line-height: 1.8;
      color: rgba(13,13,13,0.6);
    }

    /* ===== CTA SECTION ===== */
    .cta-section {
      background: var(--cream);
      padding: 5rem 5vw 8rem;
    }

    .cta-card {
      background: linear-gradient(135deg, var(--cobalt) 0%, #0f2548 100%);
      border-radius: 40px;
      padding: 5rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-card::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      top: -200px; right: -100px;
      border-radius: 50%;
      background: rgba(201,168,76,0.08);
    }

    .cta-headline {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 4vw, 4rem);
      font-weight: 900;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1.1;
      position: relative;
      z-index: 1;
    }

    .cta-headline em { color: var(--gold); font-style: italic; }

    .cta-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      margin: 1.2rem auto 0;
      max-width: 480px;
      line-height: 1.7;
      position: relative;
      z-index: 1;
    }

    .cta-actions {
      margin-top: 2.4rem;
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .btn-gold-outline {
      background: transparent;
      color: var(--gold);
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-weight: 500;
      font-size: 0.9rem;
      text-decoration: none;
      border: 1.5px solid rgba(201,168,76,0.5);
      cursor: pointer;
      transition: border-color 0.25s, background 0.25s;
    }

    .btn-gold-outline:hover {
      border-color: var(--gold);
      background: rgba(201,168,76,0.08);
    }

    /* ===== FOOTER ===== */
    footer {
      background: #0f2548;
      color: rgba(255,255,255,0.45);
      padding: 3rem 5vw;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-brand {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 900;
      color: #fff;
    }

    .footer-brand span { color: var(--gold); }

    footer p {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
    }

    /* ===== SCROLL REVEAL UTILITY ===== */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 1024px) {
      .artists-grid { grid-template-columns: repeat(2, 1fr); }
      .join-steps { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
      .join-steps::before { display: none; }
    }

    @@media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
        padding: 100px 5vw 60px;
        text-align: center;
      }
      .hero-right { display: none; }
      .hero-desc { margin-left: auto; margin-right: auto; }
      .hero-actions { justify-content: center; }
      .hero-stats { justify-content: center; }
      .hero-eyebrow { display: inline-flex; justify-content: center; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .editorial-inner { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
    }

    @@media (max-width: 600px) {
      .gallery-grid { grid-template-columns: 1fr; }
      .artists-grid { grid-template-columns: 1fr; }
      .join-steps { grid-template-columns: 1fr; }
      .cta-card { padding: 3rem 1.5rem; }
      footer { flex-direction: column; text-align: center; }
    }

    /* ===== MOBILE MENU ===== */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(245,240,232,0.97);
      backdrop-filter: blur(20px);
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }

    .mobile-menu.open { display: flex; }

    .mobile-menu a {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 700;
      color: #366ca2ff;
      text-decoration: none;
    }

    .mobile-close {
      position: absolute;
      top: 1.5rem; right: 2rem;
      background: none; border: none;
      font-size: 1.5rem;
      color: var(--cobalt);
      cursor: pointer;
    }

    /* Pulse animation for CTA button */
    @@keyframes pulse {
      0% { box-shadow: 0 8px 28px rgba(201,168,76,0.35); }
      50% { box-shadow: 0 8px 40px rgba(201,168,76,0.6); }
      100% { box-shadow: 0 8px 28px rgba(201,168,76,0.35); }
    }

    .btn-gold.pulse { animation: pulse 2s ease-in-out infinite; }

    .logo-box{
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap :10px;
    }
  </style>
</head>
<body>

