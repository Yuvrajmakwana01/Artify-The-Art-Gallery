<script>
  // ===== NAVBAR SCROLL =====
  const nav = document.getElementById('mainNav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 50);
  });

  // ===== MOBILE MENU =====
  document.getElementById('hamburger').addEventListener('click', () => {
    document.getElementById('mobileMenu').classList.add('open');
  });
  document.getElementById('mobileClose').addEventListener('click', () => closeMobileMenu());
  function closeMobileMenu() {
    document.getElementById('mobileMenu').classList.remove('open');
  }

  // ===== SMOOTH SCROLL =====
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const target = document.querySelector(a.getAttribute('href'));
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
    });
  });

  // ===== TYPEWRITER EFFECT =====
  const lines = [
    "Every canvas holds a universe waiting to be seen.",
    "We don't paint the world — we reimagine it entirely.",
    "Art is the only language that needs no translation.",
    "Bold strokes. Quiet revolutions. Endless possibility.",
    "The canvas is infinite. So is your imagination.",
    "Digital dreams come alive.",
  ];

  let lineIdx = 0, charIdx = 0, isDeleting = false;
  const el = document.getElementById('typewriter-text');

  function typeLoop() {
    const current = lines[lineIdx];
    if (!isDeleting) {
      el.textContent = current.slice(0, ++charIdx);
      if (charIdx === current.length) {
        isDeleting = true;
        setTimeout(typeLoop, 2200);
        return;
      }
      setTimeout(typeLoop, 46);
    } else {
      el.textContent = current.slice(0, --charIdx);
      if (charIdx === 0) {
        isDeleting = false;
        lineIdx = (lineIdx + 1) % lines.length;
        setTimeout(typeLoop, 400);
        return;
      }
      setTimeout(typeLoop, 22);
    }
  }
  setTimeout(typeLoop, 1400);

  // ===== MARQUEE =====
  const marqueeItems = [
    "Digital Art", "Generative Works", "Pixel Art", "Photography",
    "Afro-surrealism", "3D Art", "Immersive Installations",
    "Mixed Media", "Oil & Canvas", "Kinetic Art", "Sketch & Line Art", "Abstract"
  ];
  const inner = document.getElementById('marqueeInner');
  const full = [...marqueeItems, ...marqueeItems];
  inner.innerHTML = full.map(t =>
    `<span class="marquee-item"><span class="marquee-dot"></span>${t}</span>`
  ).join('');

  // ===== GALLERY CARDS =====
  const artworks = [
    { img: "https://images.fineartamerica.com/images/artworkimages/mediumlarge/3/baby-elephant-4-rhonda-barrett.jpg", title: "Crimson Echoes", artist: "Amara O.", price: "$ 2.4" },
    { img: "https://wallup.net/wp-content/uploads/2018/10/05/962154-destiny-sci-fi-shooter-fps-action-fighting-futuristic-warrior-fantasy-mmo-online-rpg.jpg", title: "Midnight Bloom", artist: "Julian M.", price: "$ 1.8" },
    { img: "https://mir-s3-cdn-cf.behance.net/project_modules/max_1200/be750116096301.562a55a265fe9.jpg", title: "Digital Whispers", artist: "Yuki T.", price: "$ 3.1" },
    { img: "https://img.freepik.com/premium-photo/digital-art-selected_1086710-20828.jpg", title: "Golden Ratio", artist: "Carlos R.", price: "$ 2.2" },
    { img: "https://iso.500px.com/wp-content/uploads/2022/08/Fisher-in-Inle-lake-By-keehwan-Kim-2.jpeg", title: "Neon Spectrum", artist: "Elena V.", price: "$ 1.5" },
    { img: "https://img.freepik.com/free-psd/3d-rendering-floating-island-illustration_23-2151403525.jpg", title: "Liquid Dreams", artist: "Kai C.", price: "$ 2.9" }
  ];

  const galleryGrid = document.getElementById('galleryGrid');
  artworks.forEach(art => {
    galleryGrid.innerHTML += `
      <div class="gallery-item">
        <div class="gallery-img-wrap">
          <img class="gallery-img" src="${art.img}" alt="${art.title}" loading="lazy">
        </div>
        <div class="gallery-meta">
          <div>
            <div class="gallery-title">${art.title}</div>
            <div class="gallery-by">by ${art.artist}</div>
          </div>
          <div class="gallery-price">${art.price}</div>
        </div>
      </div>`;
  });

  // ===== MOUSE PARALLAX ON HERO CARDS =====
  const hero3d = document.getElementById('hero3d');
  if (hero3d) {
    document.addEventListener('mousemove', e => {
      const mx = (e.clientX / window.innerWidth - 0.5) * 18;
      const my = (e.clientY / window.innerHeight - 0.5) * 12;
      hero3d.querySelectorAll('.float-card').forEach((c, i) => {
        const depth = [0.6, 0.4, 0.8][i] || 0.5;
        c.style.transform = c.style.transform.replace(/translate\(.*?\)/g, '') ||
          c.classList.contains('fc-1') ? `rotate(-6deg) translate(${mx*depth}px,${my*depth}px)` :
          c.classList.contains('fc-2') ? `rotate(4deg) translate(${mx*depth*0.7}px,${my*depth*0.7}px)` :
          `rotate(-3deg) translate(${mx*depth*1.1}px,${my*depth*1.1}px)`;
      });
    });
  }

  // ===== INTERSECTION OBSERVER =====
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal, .artist-card, .gallery-item, .join-step').forEach((el, i) => {
    el.style.transitionDelay = el.classList.contains('artist-card') || el.classList.contains('gallery-item') || el.classList.contains('join-step')
      ? `${i * 0.08}s` : '0s';
    io.observe(el);
  });

  // ===== JOIN BUTTON =====
  document.getElementById('joinBtn').addEventListener('click', function(e) {
    e.preventDefault();
    this.textContent = '✓ Application Sent — We\'ll reach out within 48h!';
    this.style.background = '#2E7D32';
    this.style.boxShadow = '0 8px 28px rgba(46,125,50,0.4)';
    this.classList.remove('pulse');
  });
</script>
</body>
</html>
