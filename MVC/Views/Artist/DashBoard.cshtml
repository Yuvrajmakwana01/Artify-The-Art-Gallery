
@{
    Layout = "~/Views/Artist/_ArtistLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["Active"] = "Dashboard";
}

@section HeadStyles {
<style>
    /* ── KPI Cards ── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 28px;
    }

    .kpi-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 22px 20px;
        border: 1px solid rgba(3,40,159,.05);
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        overflow: hidden;
        transition: all var(--transition);
    }

    .kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-hover);
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0; right: 0;
        width: 80px; height: 80px;
        border-radius: 0 var(--radius) 0 80px;
        opacity: .07;
    }

    .kpi-card.c1::before { background: var(--primary); }
    .kpi-card.c2::before { background: var(--gold); }
    .kpi-card.c3::before { background: #10b981; }
    .kpi-card.c4::before { background: #f59e0b; }

    .kpi-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
    }

    .kpi-card.c1 .kpi-icon { background: rgba(3,40,159,.1); color: var(--primary); }
    .kpi-card.c2 .kpi-icon { background: rgba(237,163,18,.12); color: var(--gold); }
    .kpi-card.c3 .kpi-icon { background: rgba(16,185,129,.12); color: #10b981; }
    .kpi-card.c4 .kpi-icon { background: rgba(245,158,11,.12); color: #f59e0b; }

    .kpi-label {
        font-size: .75rem;
        font-weight: 500;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .kpi-value {
        font-family: Times New Roman, serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .kpi-delta {
        font-size: .75rem;
        display: flex; align-items: center; gap: 4px;
    }

    .kpi-delta.up { color: #10b981; }
    .kpi-delta.down { color: #ef4444; }

    /* ── Bottom Grid ── */
    .bottom-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 20px;
    }

    /* ── Activity List ── */
    .activity-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid rgba(3,40,159,.05);
    }

    .activity-item:last-child { border-bottom: none; }

    .activity-dot {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .dot-upload  { background: rgba(107,155,230,.15); color: var(--accent); }
    .dot-sale    { background: rgba(16,185,129,.12); color: #10b981; }
    .dot-review  { background: rgba(245,158,11,.12); color: #f59e0b; }
    .dot-like    { background: rgba(239,68,68,.1); color: #ef4444; }

    .activity-text { font-size: .855rem; color: var(--text); line-height: 1.5; }
    .activity-time { font-size: .75rem; color: var(--muted); margin-top: 2px; }

    /* ── Quick Actions ── */
    .quick-actions { display: flex; flex-direction: column; gap: 10px; }

    .qa-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 10px;
        background: var(--bg);
        text-decoration: none;
        color: var(--text);
        font-size: .87rem;
        font-weight: 500;
        transition: all var(--transition);
        border: 1px solid rgba(3,40,159,.06);
    }

    .qa-item:hover {
        background: rgba(3,40,159,.06);
        color: var(--primary);
        transform: translateX(4px);
    }

    .qa-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        background: var(--card-bg);
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }

    /* ── Welcome Banner ── */
    .welcome-banner {
        background: linear-gradient(120deg, var(--primary) 0%, #1e4fc9 55%, var(--accent) 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 24px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

    .welcome-banner::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
    }

    .welcome-banner::after {
        content: '';
        position: absolute;
        bottom: -60px; right: 80px;
        width: 150px; height: 150px;
        border-radius: 50%;
        background: rgba(237,163,18,.12);
    }

    .welcome-banner h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .welcome-banner p {
        font-size: .88rem;
        opacity: .8;
        margin: 0;
    }

    @@media (max-width: 1199px) {
        .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 991px) {
        .bottom-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 575px) {
        .kpi-grid { grid-template-columns: 1fr 1fr; }
        .welcome-banner { flex-direction: column; align-items: flex-start; gap: 16px; }
    }

    @@media (max-width: 420px) {
        .kpi-grid { grid-template-columns: 1fr; }
    }

    /* Stagger animation */
    .kpi-card { animation: fadeUp .45s ease both; }
    .kpi-card:nth-child(1) { animation-delay: .05s; }
    .kpi-card:nth-child(2) { animation-delay: .10s; }
    .kpi-card:nth-child(3) { animation-delay: .15s; }
    .kpi-card:nth-child(4) { animation-delay: .20s; }
</style>
}

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div>
        <h2>Welcome back, <span id="wbName" style="color:var(--gold)">Artist</span> 👋</h2>
        <p>Here's what's happening in your studio today.</p>
    </div>
    <a href="/Artist/Upload" class="btn-artify btn-artify-gold" style="position:relative;z-index:2">
        <i class="bi bi-plus-lg"></i> Upload Artwork
    </a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card c1">
        <div class="kpi-icon"><i class="bi bi-images"></i></div>
        <div class="kpi-label">Total Artworks</div>
        <div class="kpi-value" id="kpiArtworks">–</div>
        <div class="kpi-delta up"><i class="bi bi-arrow-up-short"></i><span id="kpiArtworksDelta">Loading…</span></div>
    </div>
    <div class="kpi-card c2">
        <div class="kpi-icon"><i class="bi bi-bag-check-fill"></i></div>
        <div class="kpi-label">Total Sales</div>
        <div class="kpi-value" id="kpiSales">–</div>
        <div class="kpi-delta up"><i class="bi bi-arrow-up-short"></i><span id="kpiSalesDelta">Loading…</span></div>
    </div>
    <div class="kpi-card c3">
        <div class="kpi-icon"><i class="bi bi-currency-dollar"></i></div>
        <div class="kpi-label">Total Earnings</div>
        <div class="kpi-value" id="kpiEarnings"></div>
        <div class="kpi-delta up"><i class="bi bi-arrow-up-short"></i><span id="kpiEarningsDelta">Loading…</span></div>
    </div>
    <div class="kpi-card c4">
        <div class="kpi-icon"><i class="bi bi-clock-history"></i></div>
        <div class="kpi-label">Pending Approvals</div>
        <div class="kpi-value" id="kpiPending">–</div>
        <div class="kpi-delta" id="kpiPendingDelta"><span style="color:var(--muted)">Loading…</span></div>
    </div>
</div>

<!-- Bottom Row -->
<div class="bottom-grid">

    <!-- Recent Activity -->
    <div class="card-artify p-4">
        <div class="section-title">Recent <span>Activity</span></div>
        <div id="activityList">
            <!-- Skeleton placeholders -->
            @for (int i = 0; i < 5; i++) {
                <div class="activity-item">
                    <div class="activity-dot" style="background:#eee;"></div>
                    <div style="flex:1">
                        <div style="height:13px;background:#eee;border-radius:6px;width:70%;margin-bottom:6px;"></div>
                        <div style="height:10px;background:#f5f5f5;border-radius:6px;width:35%;"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card-artify p-4">
        <div class="section-title">Quick <span>Actions</span></div>
        <div class="quick-actions">
            <a href="/Artist/Upload" class="qa-item">
                <div class="qa-icon" style="color:var(--primary)"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                Upload New Artwork
            </a>
            <a href="/Artist/Gallery" class="qa-item">
                <div class="qa-icon" style="color:var(--accent)"><i class="bi bi-images"></i></div>
                View My Gallery
            </a>
            <a href="/Artist/Sales_Earnings" class="qa-item">
                <div class="qa-icon" style="color:#10b981"><i class="bi bi-bar-chart-line-fill"></i></div>
                Earnings & Analytics
            </a>
            <a href="/Artist/ManageProfile" class="qa-item">
                <div class="qa-icon" style="color:var(--gold)"><i class="bi bi-person-circle"></i></div>
                Edit My Profile
            </a>
            <a href="/Artist/Settings" class="qa-item">
                <div class="qa-icon" style="color:var(--muted)"><i class="bi bi-gear-fill"></i></div>
                Account Settings
            </a>
        </div>
    </div>

</div>

@section Scripts {
<script>
(async function() {
    const artistId = @(Context.Session.GetInt32("ArtistId") ?? 0);
    const API_BASE  = 'http://localhost:5183/api/ArtistApi'; // API runs on port 5183, MVC on 5092

    // Set welcome name from session / localStorage
    const storedName = sessionStorage.getItem('artistName') || 'Artist';
    document.getElementById('wbName').textContent = storedName;

    if (!artistId) return;

    /* ── Fetch dashboard KPIs ── */
    try {
        const res = await fetch(`${API_BASE}/dashboard`, {
            credentials: 'include'
        });
        if (!res.ok) throw new Error('API error');
        const d = await res.json();

        // Map actual t_Artist_Dashboard model fields (c_ prefix, exact casing)
        document.getElementById('kpiArtworks').textContent = d.c_TotalArtworkCount ?? 0;
        document.getElementById('kpiSales').textContent    = d.c_TotalSellCount ?? 0;
        document.getElementById('kpiEarnings').textContent = '$' + (d.c_TotalEarning ?? 0).toLocaleString('en-USD');
        document.getElementById('kpiPending').textContent  = '…'; // updated after artworks load

        document.getElementById('kpiSalesDelta').textContent    = d.c_TotalSellCount > 0 ? `${d.c_TotalSellCount} sold` : '—';
        document.getElementById('kpiEarningsDelta').textContent = d.c_TotalEarning   > 0 ? `$${parseFloat(d.c_TotalEarning).toLocaleString('en-IN')} total` : '—';
    } catch(e) {
        console.warn('Dashboard KPI fetch failed', e);
        ['kpiArtworks','kpiSales','kpiEarnings','kpiPending'].forEach(id => {
            document.getElementById(id).textContent = '–';
        });
    }

    /* ── Build activity list from artworks + compute pending count ── */
    try {
        const res = await fetch(`${API_BASE}/GetMyArtworks`, { credentials: 'include' });
        const json = await res.json();
        // GetMyArtworks returns { success, data: [...] } wrapper
        const artworks = Array.isArray(json) ? json : (json.data || json.c_Data || []);

        // ── Fix #1: Compute pending count from artworks list ──────────────
        const pendingCount  = artworks.filter(a => (a.c_approval_status || 'Pending') === 'Pending').length;
        const approvedCount = artworks.filter(a => a.c_approval_status === 'Approved').length;
        const rejectedCount = artworks.filter(a => a.c_approval_status === 'Rejected').length;

        document.getElementById('kpiPending').textContent = pendingCount;
        const pendingDeltaEl = document.getElementById('kpiPendingDelta');
        if (pendingCount > 0) {
            pendingDeltaEl.innerHTML = `<i class="bi bi-hourglass-split" style="color:#f59e0b"></i> <span style="color:#f59e0b">${pendingCount} awaiting review</span>`;
        } else {
            pendingDeltaEl.innerHTML = `<span style="color:#10b981"><i class="bi bi-check-circle"></i> All approved</span>`;
        }

        // Update artworks delta (total vs approved breakdown)
        document.getElementById('kpiArtworksDelta').textContent =
            `${approvedCount} approved · ${rejectedCount} rejected`;
        // ─────────────────────────────────────────────────────────────────

        const icons = { Approved: { cls:'dot-sale', icon:'bi-check-circle-fill' },
                        Pending:  { cls:'dot-review', icon:'bi-hourglass-split' },
                        Rejected: { cls:'dot-like', icon:'bi-x-circle-fill' } };

        const list = document.getElementById('activityList');
        list.innerHTML = '';

        const recent = artworks.slice(0, 6);
        if (recent.length === 0) {
            list.innerHTML = `<p class="text-muted text-center py-4" style="font-size:.87rem">No activity yet. Upload your first artwork!</p>`;
            return;
        }

        recent.forEach(a => {
            const status = a.c_approval_status || 'Pending';
            const ic = icons[status] || icons['Pending'];
            list.innerHTML += `
                <div class="activity-item">
                    <div class="activity-dot ${ic.cls}"><i class="bi ${ic.icon}"></i></div>
                    <div>
                        <div class="activity-text">
                            <strong>${escapeHtml(a.c_title)}</strong>
                            <span class="ms-2 badge-${status.toLowerCase()}">${status}</span>
                        </div>
                        <div class="activity-time">$${parseFloat(a.c_price).toLocaleString('en-IN')} &bull; Artwork #${a.c_artwork_id}</div>
                    </div>
                </div>`;
        });
    } catch(e) {
        document.getElementById('activityList').innerHTML =
            `<p class="text-muted text-center py-4" style="font-size:.87rem">Could not load activity.</p>`;
    }

    function escapeHtml(t) {
        return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
})();
</script>
}
