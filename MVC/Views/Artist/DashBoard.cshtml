@{
    Layout = "../Shared/_ArtistLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .dashboard-header {
    background: linear-gradient(135deg, #1c1b18, #553939);
    color: white;
    border-radius: 16px;
    padding: 30px;
    margin-bottom: 20px;
    }

    .chart-container {
    position: relative;
    width: 100%;
    height: 300px;
    /* 🔥 CONTROL HEIGHT HERE */
    }

    .card-custom {
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    padding: 20px;
    background: white;
    }

    .stat-title {
    color: gray;
    font-size: 14px;
    }

    .stat-value {
    font-size: 28px;
    font-weight: bold;
    }
</style>

<!-- 🔥 HEADER -->
<div class="dashboard-header">
    <h2 id="artistName">Welcome</h2>
    <p id="artistBio"></p>
    <h1 id="totalEarnings">$0</h1>
</div>

<!-- 🔥 CARDS -->
<div class="row g-3">

    <div class="col-md-3">
        <div class="card-custom">
            <div class="stat-title">ARTWORKS</div>
            <div class="stat-value" id="artworks">0</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-custom">
            <div class="stat-title">LIKES</div>
            <div class="stat-value" id="likes">0</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-custom">
            <div class="stat-title">SALES</div>
            <div class="stat-value" id="sales">0</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-custom">
            <div class="stat-title">RATING</div>
            <div class="stat-value" id="rating">0</div>
        </div>
    </div>

</div>

<br />

<!-- 🔥 CHART SECTION (Placeholder for now) -->
<div class="card-custom">
    <h5>Revenue (Last 12 Months)</h5>
    <div class="chart-container">
        <canvas id="revenueChart"></canvas>
    </div>
</div>

<br />

<div class="card-custom">
    <h5>Sales by Category</h5>
    <div class="chart-container">
        <canvas id="categoryChart"></canvas>
    </div>
</div>



@section Scripts {
    <script>
        
        $(document).ready(function () {

        const baseUrl = "http://localhost:5183/api/ArtistApi";

        $.ajax({
        url: `${baseUrl}/dashboard`,
        type: "GET",
        headers: {
        "Authorization": "Bearer " + localStorage.getItem("authToken")
        },
        success: function (data) {

        console.log("API DATA:", data); // 🔥 DEBUG FIRST

        // HEADER
        $("#artistName").text("Welcome, " + data.c_ArtistName);
        $("#artistBio").text(data.c_Biography);
        $("#rating").text(data.c_RatingAvg);

        // CARDS
        $("#artworks").text(data.c_TotalArtworkCount);
        $("#likes").text(data.c_TotalLikeCount);
        $("#sales").text(data.c_TotalSellCount);

        $("#totalEarnings").text("$" + data.c_TotalEarning);
        },
        error: function () {
        alert("Failed to load dashboard");
        }
        });

        $.ajax({
        url: `${baseUrl}/revenue`,
        type: "GET",
        headers: {
        "Authorization": "Bearer " + localStorage.getItem("authToken")
        },
        success: function (res) {

        const allMonths = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

        const revenueMap = {};

        res.forEach(x => {
        revenueMap[x.month] = x.revenue;
        });

        const finalData = allMonths.map(m => revenueMap[m] || 0);

        new Chart(document.getElementById("revenueChart"), {
        type: 'line',
        data: {
        labels: allMonths,
        datasets: [{
        label: "Revenue",
        data: finalData
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false
        }
        });
        }
        });


        $.ajax({
        url: `${baseUrl}/category-sales`,
        type: "GET",
        headers: {
        "Authorization": "Bearer " + localStorage.getItem("authToken")
        },
        success: function (res) {

        const labels = res.map(x => x.category);
        const data = res.map(x => x.sales);

        new Chart(document.getElementById("categoryChart"), {
        type: 'pie',
        data: {
        labels: labels,
        datasets: [{
        data: data
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false
        }
        });
        }
        });

        });
    </script>
}