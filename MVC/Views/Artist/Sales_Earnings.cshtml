@section Scripts {
<!-- Kendo UI Free CDN -->
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2023.3.1114/styles/kendo.common.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2023.3.1114/styles/kendo.default-v2.min.css" />
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://kendo.cdn.telerik.com/2023.3.1114/js/kendo.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/authHelper.js"></script>
<script>
$(function () {
    if (!AuthHelper.requireAuth()) return;

    var BASE = AuthHelper.API_BASE;

    function fmt(v) {
        return "\u20B9" + parseFloat(v || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    $.ajax({
        url: BASE + "/earnings-summary",
        type: "GET",
        success: function (data) {
            var avail = data.availableBalance || 0;
            $("#availableBalance").text(fmt(avail));
            $("#requestedBalance").text(fmt(data.requestedBalance));
            $("#revenueBalance").text(fmt(data.revenueBalance));
            $("#withdrawAmt").text(fmt(avail));
            if (avail > 0) $("#btnPayout").prop("disabled", false);
        },
        error: function (xhr) {
            console.error("Earnings error:", xhr.status);
            if (xhr.status !== 401) {
                Swal.fire({ icon: "error", title: "Could not load earnings", confirmButtonColor: "#03289F" });
            }
        }
    });

    $("#btnPayout").on("click", function () {
        Swal.fire({
            title: "Request Payout?",
            text: "This will initiate a withdrawal of your available balance.",
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#03289F",
            confirmButtonText: "Yes, request"
        }).then(function (r) {
            if (r.isConfirmed) {
                Swal.fire({ icon: "success", title: "Request Submitted", text: "Your payout will be processed within 3\u20135 business days.", confirmButtonColor: "#03289F" });
            }
        });
    });

    /* ── Artwork data for table + Top Artworks chart ── */
    var allRows = [];

    $.ajax({
        url: BASE + "/GetMyArtworks",
        type: "GET",
        success: function (res) {
            var items = Array.isArray(res) ? res : (res.c_Data || res.data || []);
            allRows = items.filter(function (a) { return a.c_sell_count > 0; });
            renderTable();
            buildTopArtworksChart(allRows);
        },
        error: function () {
            Swal.fire({ icon: "error", title: "Could not load sales", confirmButtonColor: "#03289F" });
        }
    });

    /* ── Monthly Revenue Chart ── */
    $.ajax({
        url: BASE + "/revenue", type: "GET",
        success: function (data) { buildRevenueChart(data); },
        error: function ()       { emptyChart('#revenueChart', 'No revenue data available'); }
    });

    /* ── Category Sales Chart ── */
    $.ajax({
        url: BASE + "/category-sales", type: "GET",
        success: function (data) { buildCategoryChart(data); },
        error: function ()       { emptyChart('#categoryChart', 'No category data available'); }
    });

    /* ── Earnings Gauge (reuse earnings-summary) ── */
    $.ajax({
        url: BASE + "/earnings-summary", type: "GET",
        success: function (data) {
            var avail = data.availableBalance || 0;
            $("#availableBalance").text(fmt(avail));
            $("#requestedBalance").text(fmt(data.requestedBalance));
            $("#revenueBalance").text(fmt(data.revenueBalance));
            $("#withdrawAmt").text(fmt(avail));
            if (avail > 0) $("#btnPayout").prop("disabled", false);
            buildEarningsGauge(data);
        },
        error: function (xhr) {
            console.error("Earnings error:", xhr.status);
            emptyChart('#earningsGauge', 'No earnings data');
            if (xhr.status !== 401)
                Swal.fire({ icon: "error", title: "Could not load earnings", confirmButtonColor: "#03289F" });
        }
    });

    /* ══ Payout History ══ */
    $.ajax({
        url: BASE + "/my-payout-history", type: "GET",
        success: function(data) { renderPayoutHistory(data); },
        error: function() {
            $("#payoutHistoryContainer").html('<div class="payout-hist-empty"><i class="bi bi-clock-history"></i><p>Unable to load payout history.</p></div>');
        }
    });

    /* ══ Transaction Logs ══ */
    $.ajax({
        url: BASE + "/my-transaction-logs", type: "GET",
        success: function(data) { renderTransactionLogs(data); },
        error: function(xhr) {
            $('#txnTableBody').html('<tr><td colspan="7" style="padding:32px;text-align:center;color:#ef4444;font-size:.85rem;">Failed to load transactions.</td></tr>');
        }
    });

    /* ══ Kendo UI Chart Builders ══ */
    var COLORS = ['#03289F','#EDA312','#10b981','#6b9be6','#f59e0b','#ef4444','#8b5cf6'];

    function emptyChart(sel, msg) {
        $(sel).html('<div class="chart-empty"><i class="bi bi-bar-chart-line"></i><span>' + msg + '</span></div>');
    }

    /* ── Sales by Category (Kendo Donut + custom legend) ── */
    function buildCategoryChart(data) {
        if (!data || !data.length) { emptyChart('#categoryChart', 'No category data yet'); return; }
        var total = data.reduce(function(s,d){ return s + parseFloat(d.sales || d.c_Sales || 1); }, 0);
        $('#categoryChart').kendoChart({
            chartArea: { background: 'transparent', height: 260 },
            legend: { visible: false },
            seriesColors: COLORS,
            series: [{ type: 'donut', holeSize: 70, labels: { visible: false },
                data: data.map(function(d) { return { category: d.category || d.c_Category || 'Other', value: parseFloat(d.sales || d.c_Sales || 1) }; }),
                field: 'value', categoryField: 'category'
            }],
            tooltip: { visible: true, template: '#= category #: <b>#= value # sales</b>' }
        });
        /* Custom legend */
        var legend = data.map(function(d, i) {
            var val = parseFloat(d.sales || d.c_Sales || 1);
            var pct = total > 0 ? ((val / total) * 100).toFixed(1) : 0;
            return '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">'
                 + '<span style="width:12px;height:12px;border-radius:50%;background:' + COLORS[i % COLORS.length] + ';flex-shrink:0;"></span>'
                 + '<span style="font-size:.82rem;color:var(--text);flex:1;">' + (d.category || d.c_Category || 'Other') + '</span>'
                 + '<span style="font-size:.8rem;font-weight:700;color:var(--primary);">' + pct + '%</span>'
                 + '</div>';
        }).join('');
        $('#categoryLegend').html(legend);
    }

    /* ── Payout History renderer ── */
    function renderPayoutHistory(data) {
        if (!data || !data.length) {
            $('#payoutHistoryContainer').html('<div class="payout-hist-empty"><i class="bi bi-check2-circle"></i><p>No approved payouts yet.</p></div>');
            return;
        }
        var html = data.map(function(p) {
            var d = p.processedDate ? new Date(p.processedDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '\u2014';
            return '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 4px;border-bottom:1px solid rgba(3,40,159,.06);">'
                + '<div><div style="font-weight:600;font-size:.87rem;color:var(--text);">' + (p.requestMonth || '\u2014') + '</div>'
                + '<div style="font-size:.74rem;color:var(--muted);margin-top:2px;">Paid: ' + d + '</div>'
                + '<div style="font-size:.73rem;color:var(--muted);">Commission: \u20B9' + parseFloat(p.commission || 0).toFixed(2) + '</div></div>'
                + '<div style="text-align:right;">'
                + '<div style="font-size:1.05rem;font-weight:700;color:#10b981;">\u20B9' + parseFloat(p.netAmount || 0).toFixed(2) + '</div>'
                + '<span class="badge-approved" style="font-size:.68rem;">' + (p.status || 'Approved') + '</span></div>'
                + '</div>';
        }).join('');
        $('#payoutHistoryContainer').html('<div style="max-height:420px;overflow-y:auto;">' + html + '</div>'
            + '<div style="margin-top:12px;padding-top:10px;border-top:1px solid rgba(3,40,159,.07);font-size:.78rem;color:var(--muted);">'
            + data.length + ' approved payout' + (data.length !== 1 ? 's' : '') + ' total</div>');
    }

    /* ── Transaction Logs ── */
    var allTxn = [];

    function renderTransactionLogs(data) {
        allTxn = data || [];
        filterTxnTable();
    }

    function filterTxnTable() {
        var q = ($('#txnSearch').val() || '').toLowerCase();
        var list = allTxn.filter(function(t) {
            return !q
                || (t.artworkTitle || '').toLowerCase().indexOf(q) !== -1
                || (t.buyerName || '').toLowerCase().indexOf(q) !== -1;
        });

        $('#txnCountInfo').text(list.length + ' transaction' + (list.length !== 1 ? 's' : ''));

        if (!list.length) {
            $('#txnTableBody').empty();
            $('#txnEmptyState').show();
            $('#txnEmptyMsg').text(q ? 'No results for "' + q + '"' : 'No transactions recorded yet.');
            return;
        }
        $('#txnEmptyState').hide();

        var statusColor = { 'Completed': '#10b981', 'Pending': '#f59e0b', 'Failed': '#ef4444' };
        var html = list.map(function(t) {
            var dt = t.paidAt ? new Date(t.paidAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '\u2014';
            var sc = statusColor[t.paymentStatus] || '#6b7280';
            var title = (t.artworkTitle || 'Untitled').length > 22 ? (t.artworkTitle).slice(0,22) + '\u2026' : (t.artworkTitle || 'Untitled');
            return '<tr>'
                + '<td style="font-size:.8rem;color:var(--muted);">' + dt + '</td>'
                + '<td><div style="font-weight:600;font-size:.85rem;">' + esc(title) + '</div></td>'
                + '<td style="font-size:.84rem;">' + esc(t.buyerName || 'Unknown') + '</td>'
                + '<td style="font-weight:700;color:var(--primary);">\u20B9' + parseFloat(t.amountPaid || 0).toFixed(2) + '</td>'
                + '<td style="font-size:.82rem;color:#f59e0b;">\u20B9' + parseFloat(t.commission || 0).toFixed(2) + '</td>'
                + '<td style="font-weight:700;color:#10b981;">\u20B9' + parseFloat(t.netPayout || 0).toFixed(2) + '</td>'
                + '<td><span style="font-size:.72rem;font-weight:700;padding:3px 8px;border-radius:20px;background:' + sc + '20;color:' + sc + ';">' + esc(t.paymentStatus || 'Completed') + '</span></td>'
                + '</tr>';
        }).join('');
        $('#txnTableBody').html(html);
    }

    window.filterTxnTable = filterTxnTable;

    function esc(t) {
        return (t || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

});
</script>
}