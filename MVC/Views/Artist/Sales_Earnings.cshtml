@{
    ViewData["Title"] = "Earnings";
    Layout = "~/Views/Artist/_ArtistLayout.cshtml";
    ViewData["Active"] = "Earnings";
}

@section HeadStyles {
<style>
    /* ── Page Banner ── */
    .earnings-banner {
        background: linear-gradient(120deg, var(--primary) 0%, #1e4fc9 55%, var(--accent) 100%);
        border-radius: var(--radius);
        padding: 26px 30px;
        margin-bottom: 24px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

    .earnings-banner::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
        pointer-events: none;
    }

    .earnings-banner::after {
        content: '';
        position: absolute;
        bottom: -60px; right: 80px;
        width: 150px; height: 150px;
        border-radius: 50%;
        background: rgba(237,163,18,.12);
        pointer-events: none;
    }

    .earnings-banner h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.45rem;
        font-weight: 700;
        margin-bottom: 4px;
        position: relative; z-index: 1;
    }

    .earnings-banner p {
        font-size: .87rem;
        opacity: .82;
        margin: 0;
        position: relative; z-index: 1;
    }

    /* ── KPI Grid ── */
    .earn-kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .earn-kpi-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 22px 20px;
        border: 1px solid rgba(3,40,159,.05);
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        overflow: hidden;
        transition: all var(--transition);
        animation: fadeUp .45s ease both;
    }

    .earn-kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-hover);
    }

    .earn-kpi-card::before {
        content: '';
        position: absolute;
        top: 0; right: 0;
        width: 80px; height: 80px;
        border-radius: 0 var(--radius) 0 80px;
        opacity: .07;
        pointer-events: none;
    }

    .earn-kpi-card.c1::before { background: #10b981; }
    .earn-kpi-card.c2::before { background: #f59e0b; }
    .earn-kpi-card.c3::before { background: var(--primary); }

    .earn-kpi-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
    }

    .earn-kpi-card.c1 .earn-kpi-icon { background: rgba(16,185,129,.12); color: #10b981; }
    .earn-kpi-card.c2 .earn-kpi-icon { background: rgba(245,158,11,.12); color: #f59e0b; }
    .earn-kpi-card.c3 .earn-kpi-icon { background: rgba(3,40,159,.1);   color: var(--primary); }

    .earn-kpi-label {
        font-size: .75rem;
        font-weight: 500;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .earn-kpi-value {
        font-family: 'Playfair Display', serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .earn-kpi-sub {
        font-size: .76rem;
        color: var(--muted);
        display: flex; align-items: center; gap: 4px;
    }

    /* Skeleton shimmer */
    @@keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .skel {
        background: linear-gradient(90deg, #e8eef7 25%, #dfe6e9 50%, #e8eef7 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
        display: inline-block;
    }

    /* Stagger animations */
    .earn-kpi-card:nth-child(1) { animation-delay: .05s; }
    .earn-kpi-card:nth-child(2) { animation-delay: .10s; }
    .earn-kpi-card:nth-child(3) { animation-delay: .15s; }

    /* ── Payout Card ── */
    .payout-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        border: 1px solid rgba(3,40,159,.05);
        padding: 24px 28px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        transition: box-shadow var(--transition), transform var(--transition);
    }

    .payout-card:hover {
        box-shadow: var(--shadow-hover);
        transform: translateY(-2px);
    }

    .payout-info h5 {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 4px;
    }

    .payout-info p {
        font-size: .875rem;
        color: var(--muted);
        margin: 0;
    }

    .payout-info strong {
        color: var(--text);
        font-weight: 700;
    }

    .payout-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .82rem;
        color: var(--muted);
        margin-top: 6px;
    }

    .payout-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--gold);
        flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(237,163,18,.2);
    }

    /* ── Section panels (card-artify wrapper) ── */
    .panel-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    /* ── Chart area ── */
    .chart-placeholder {
        height: 220px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(3,40,159,.04) 0%, rgba(107,155,230,.08) 100%);
        border: 1.5px dashed rgba(3,40,159,.12);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        gap: 10px;
    }

    .chart-placeholder i { font-size: 2.8rem; color: var(--accent); opacity: .5; }
    .chart-placeholder span { font-size: .82rem; font-weight: 500; }

    /* ── Toolbar ── */
    .table-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 180px;
        max-width: 280px;
    }

    .search-box i {
        position: absolute;
        left: 13px; top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: .9rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 9px 13px 9px 38px;
        border-radius: 10px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--bg);
        font-size: .87rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
    }

    .search-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(107,155,230,.15);
        background: #fff;
    }

    .filter-select {
        padding: 9px 14px;
        border-radius: 10px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--bg);
        font-size: .87rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        outline: none;
        cursor: pointer;
        transition: border-color var(--transition);
    }

    .filter-select:focus { border-color: var(--accent); }

    /* ── Table ── */
    .artify-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    .artify-table thead th {
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .9px;
        text-transform: uppercase;
        color: var(--muted);
        padding: 12px 16px;
        border-bottom: 2px solid rgba(3,40,159,.07);
        white-space: nowrap;
        background: transparent;
    }

    .artify-table tbody tr {
        border-bottom: 1px solid rgba(3,40,159,.05);
        transition: background var(--transition);
    }

    .artify-table tbody tr:last-child { border-bottom: none; }

    .artify-table tbody tr:hover { background: rgba(3,40,159,.03); }

    .artify-table tbody td {
        padding: 13px 16px;
        color: var(--text);
        vertical-align: middle;
    }

    .table-artwork-title {
        font-weight: 600;
        color: var(--text);
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .table-category {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .73rem;
        font-weight: 600;
        background: rgba(107,155,230,.12);
        color: var(--primary);
    }

    .table-price { font-weight: 600; color: var(--text); }

    .table-revenue {
        font-weight: 700;
        color: #10b981;
    }

    .table-units {
        font-weight: 600;
        color: var(--accent);
    }

    /* Empty state */
    .empty-table {
        text-align: center;
        padding: 48px 20px;
        color: var(--muted);
    }

    .empty-table i {
        font-size: 3rem;
        color: var(--accent);
        opacity: .4;
        display: block;
        margin-bottom: 12px;
    }

    .empty-table p { font-size: .87rem; margin: 0; }

    /* ── Payout history ── */
    .payout-hist-empty {
        text-align: center;
        padding: 40px 20px;
        color: var(--muted);
    }

    .payout-hist-empty i {
        font-size: 2.5rem;
        color: var(--accent);
        opacity: .4;
        display: block;
        margin-bottom: 10px;
    }

    .payout-hist-empty p { font-size: .87rem; margin: 0; }

    /* ── Kendo Charts Grid ── */
    .charts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }
    .chart-card { animation: fadeUp .45s ease both; }
    .chart-card:nth-child(1) { animation-delay: .08s; }
    .chart-card:nth-child(2) { animation-delay: .14s; }
    .chart-card:nth-child(3) { animation-delay: .20s; }
    .chart-card:nth-child(4) { animation-delay: .26s; }
    .chart-badge {
        display: inline-block; padding: 3px 10px;
        border-radius: 20px; font-size: .72rem; font-weight: 600;
        background: rgba(3,40,159,.08); color: var(--primary);
    }
    .chart-empty {
        height: 220px; display: flex; align-items: center;
        justify-content: center; flex-direction: column; gap: 8px;
        color: var(--muted); font-size: .85rem;
    }
    .chart-empty i { font-size: 2.2rem; opacity: .35; color: var(--accent); }
    /* Kendo chart background fix */
    .k-chart { background: transparent !important; }
    @@media (max-width: 991px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── Bottom two-col layout ── */
    .bottom-earn-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 20px;
    }

    /* ── Responsive ── */
    @@media (max-width: 1199px) {
        .earn-kpi-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @@media (max-width: 991px) {
        .bottom-earn-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 768px) {
        .earn-kpi-grid { grid-template-columns: 1fr 1fr; }
        .payout-card { flex-direction: column; align-items: flex-start; }
    }

    @@media (max-width: 480px) {
        .earn-kpi-grid { grid-template-columns: 1fr; }
        .earnings-banner { flex-direction: column; align-items: flex-start; gap: 14px; }
    }
</style>
}

<!-- ── Page Banner ── -->
