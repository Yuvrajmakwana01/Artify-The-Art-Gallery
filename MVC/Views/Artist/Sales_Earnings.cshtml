@{
    ViewData["Title"] = "Earnings";
    Layout = "~/Views/Artist/_ArtistLayout.cshtml";
    ViewData["Active"] = "Earnings";
}

@section HeadStyles {
<style>
    /* ── Page Banner ── */
    .earnings-banner {
        background: linear-gradient(120deg, var(--primary) 0%, #1e4fc9 55%, var(--accent) 100%);
        border-radius: var(--radius);
        padding: 26px 30px;
        margin-bottom: 24px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

    .earnings-banner::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
        pointer-events: none;
    }

    .earnings-banner::after {
        content: '';
        position: absolute;
        bottom: -60px; right: 80px;
        width: 150px; height: 150px;
        border-radius: 50%;
        background: rgba(237,163,18,.12);
        pointer-events: none;
    }

    .earnings-banner h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.45rem;
        font-weight: 700;
        margin-bottom: 4px;
        position: relative; z-index: 1;
    }

    .earnings-banner p {
        font-size: .87rem;
        opacity: .82;
        margin: 0;
        position: relative; z-index: 1;
    }

    /* ── KPI Grid ── */
    .earn-kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .earn-kpi-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 22px 20px;
        border: 1px solid rgba(3,40,159,.05);
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        overflow: hidden;
        transition: all var(--transition);
        animation: fadeUp .45s ease both;
    }

    .earn-kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-hover);
    }

    .earn-kpi-card::before {
        content: '';
        position: absolute;
        top: 0; right: 0;
        width: 80px; height: 80px;
        border-radius: 0 var(--radius) 0 80px;
        opacity: .07;
        pointer-events: none;
    }

    .earn-kpi-card.c1::before { background: #10b981; }
    .earn-kpi-card.c2::before { background: #f59e0b; }
    .earn-kpi-card.c3::before { background: var(--primary); }

    .earn-kpi-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
    }

    .earn-kpi-card.c1 .earn-kpi-icon { background: rgba(16,185,129,.12); color: #10b981; }
    .earn-kpi-card.c2 .earn-kpi-icon { background: rgba(245,158,11,.12); color: #f59e0b; }
    .earn-kpi-card.c3 .earn-kpi-icon { background: rgba(3,40,159,.1);   color: var(--primary); }

    .earn-kpi-label {
        font-size: .75rem;
        font-weight: 500;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .earn-kpi-value {
        font-family: 'Playfair Display', serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .earn-kpi-sub {
        font-size: .76rem;
        color: var(--muted);
        display: flex; align-items: center; gap: 4px;
    }

    /* Skeleton shimmer */
    @@keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .skel {
        background: linear-gradient(90deg, #e8eef7 25%, #dfe6e9 50%, #e8eef7 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
        display: inline-block;
    }

    /* Stagger animations */
    .earn-kpi-card:nth-child(1) { animation-delay: .05s; }
    .earn-kpi-card:nth-child(2) { animation-delay: .10s; }
    .earn-kpi-card:nth-child(3) { animation-delay: .15s; }

    /* ── Payout Card ── */
    .payout-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        border: 1px solid rgba(3,40,159,.05);
        padding: 24px 28px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        transition: box-shadow var(--transition), transform var(--transition);
    }

    .payout-card:hover {
        box-shadow: var(--shadow-hover);
        transform: translateY(-2px);
    }

    .payout-info h5 {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 4px;
    }

    .payout-info p {
        font-size: .875rem;
        color: var(--muted);
        margin: 0;
    }

    .payout-info strong {
        color: var(--text);
        font-weight: 700;
    }

    .payout-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .82rem;
        color: var(--muted);
        margin-top: 6px;
    }

    .payout-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--gold);
        flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(237,163,18,.2);
    }

    /* ── Section panels (card-artify wrapper) ── */
    .panel-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    /* ── Chart area ── */
    .chart-placeholder {
        height: 220px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(3,40,159,.04) 0%, rgba(107,155,230,.08) 100%);
        border: 1.5px dashed rgba(3,40,159,.12);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        gap: 10px;
    }

    .chart-placeholder i { font-size: 2.8rem; color: var(--accent); opacity: .5; }
    .chart-placeholder span { font-size: .82rem; font-weight: 500; }

    /* ── Toolbar ── */
    .table-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 180px;
        max-width: 280px;
    }

    .search-box i {
        position: absolute;
        left: 13px; top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: .9rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 9px 13px 9px 38px;
        border-radius: 10px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--bg);
        font-size: .87rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
    }

    .search-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(107,155,230,.15);
        background: #fff;
    }

    .filter-select {
        padding: 9px 14px;
        border-radius: 10px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--bg);
        font-size: .87rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        outline: none;
        cursor: pointer;
        transition: border-color var(--transition);
    }

    .filter-select:focus { border-color: var(--accent); }

    /* ── Table ── */
    .artify-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    .artify-table thead th {
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .9px;
        text-transform: uppercase;
        color: var(--muted);
        padding: 12px 16px;
        border-bottom: 2px solid rgba(3,40,159,.07);
        white-space: nowrap;
        background: transparent;
    }

    .artify-table tbody tr {
        border-bottom: 1px solid rgba(3,40,159,.05);
        transition: background var(--transition);
    }

    .artify-table tbody tr:last-child { border-bottom: none; }

    .artify-table tbody tr:hover { background: rgba(3,40,159,.03); }

    .artify-table tbody td {
        padding: 13px 16px;
        color: var(--text);
        vertical-align: middle;
    }

    .table-artwork-title {
        font-weight: 600;
        color: var(--text);
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .table-category {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .73rem;
        font-weight: 600;
        background: rgba(107,155,230,.12);
        color: var(--primary);
    }

    .table-price { font-weight: 600; color: var(--text); }

    .table-revenue {
        font-weight: 700;
        color: #10b981;
    }

    .table-units {
        font-weight: 600;
        color: var(--accent);
    }

    /* Empty state */
    .empty-table {
        text-align: center;
        padding: 48px 20px;
        color: var(--muted);
    }

    .empty-table i {
        font-size: 3rem;
        color: var(--accent);
        opacity: .4;
        display: block;
        margin-bottom: 12px;
    }

    .empty-table p { font-size: .87rem; margin: 0; }

    /* ── Payout history ── */
    .payout-hist-empty {
        text-align: center;
        padding: 40px 20px;
        color: var(--muted);
    }

    .payout-hist-empty i {
        font-size: 2.5rem;
        color: var(--accent);
        opacity: .4;
        display: block;
        margin-bottom: 10px;
    }

    .payout-hist-empty p { font-size: .87rem; margin: 0; }

    /* ── Kendo Charts Grid ── */
    .charts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }
    .chart-card { animation: fadeUp .45s ease both; }
    .chart-card:nth-child(1) { animation-delay: .08s; }
    .chart-card:nth-child(2) { animation-delay: .14s; }
    .chart-card:nth-child(3) { animation-delay: .20s; }
    .chart-card:nth-child(4) { animation-delay: .26s; }
    .chart-badge {
        display: inline-block; padding: 3px 10px;
        border-radius: 20px; font-size: .72rem; font-weight: 600;
        background: rgba(3,40,159,.08); color: var(--primary);
    }
    .chart-empty {
        height: 220px; display: flex; align-items: center;
        justify-content: center; flex-direction: column; gap: 8px;
        color: var(--muted); font-size: .85rem;
    }
    .chart-empty i { font-size: 2.2rem; opacity: .35; color: var(--accent); }
    /* Kendo chart background fix */
    .k-chart { background: transparent !important; }
    @@media (max-width: 991px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── Bottom two-col layout ── */
    .bottom-earn-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 20px;
    }

    /* ── Responsive ── */
    @@media (max-width: 1199px) {
        .earn-kpi-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @@media (max-width: 991px) {
        .bottom-earn-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 768px) {
        .earn-kpi-grid { grid-template-columns: 1fr 1fr; }
        .payout-card { flex-direction: column; align-items: flex-start; }
    }

    @@media (max-width: 480px) {
        .earn-kpi-grid { grid-template-columns: 1fr; }
        .earnings-banner { flex-direction: column; align-items: flex-start; gap: 14px; }
    }
</style>
}

<!-- ── Page Banner ── -->
<div class="earnings-banner">
    <div>
        <h2>Earnings &amp; Analytics</h2>
        <p>Track your revenue, available balance, and payout history.</p>
    </div>
    <a href="/Artist/Sales" class="btn-artify btn-artify-gold" style="position:relative;z-index:2">
        <i class="bi bi-receipt"></i> View Sales
    </a>
</div>

<!-- ── KPI Cards ── -->
<div class="earn-kpi-grid">
    <!-- Available Balance -->
    <div class="earn-kpi-card c1">
        <div class="earn-kpi-icon"><i class="bi bi-wallet2"></i></div>
        <div class="earn-kpi-label">Available Balance</div>
        <div class="earn-kpi-value" id="availableBalance">
            <span class="skel" style="width:100px;height:1.9rem;">&nbsp;</span>
        </div>
        <div class="earn-kpi-sub"><i class="bi bi-check-circle-fill" style="color:#10b981"></i> Ready for withdrawal</div>
    </div>

    <!-- Requested / Processing -->
    <div class="earn-kpi-card c2">
        <div class="earn-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="earn-kpi-label">Requested Balance</div>
        <div class="earn-kpi-value" id="requestedBalance">
            <span class="skel" style="width:100px;height:1.9rem;">&nbsp;</span>
        </div>
        <div class="earn-kpi-sub"><i class="bi bi-arrow-repeat" style="color:#f59e0b"></i> Processing payout</div>
    </div>

    <!-- Total Revenue -->
    <div class="earn-kpi-card c3">
        <div class="earn-kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="earn-kpi-label">Total Revenue</div>
        <div class="earn-kpi-value" id="revenueBalance">
            <span class="skel" style="width:100px;height:1.9rem;">&nbsp;</span>
        </div>
        <div class="earn-kpi-sub"><i class="bi bi-bag-check-fill" style="color:var(--primary)"></i> Completed transactions</div>
    </div>
</div>

<!-- ── Analytics Charts Grid ── -->
<div class="charts-grid">

    <!-- Monthly Revenue Area Chart -->
    <div class="card-artify p-4 chart-card">
        <div class="panel-heading mb-2">
            <div class="section-title mb-0" style="font-size:1rem;">Monthly <span>Revenue</span></div>
            <span class="chart-badge"><i class="bi bi-calendar3 me-1"></i>12 months</span>
        </div>
        <div id="revenueChart"></div>
    </div>

    <!-- Category Donut Chart -->
    <div class="card-artify p-4 chart-card">
        <div class="panel-heading mb-2">
            <div class="section-title mb-0" style="font-size:1rem;">Sales by <span>Category</span></div>
            <span class="chart-badge"><i class="bi bi-pie-chart-fill me-1"></i>Distribution</span>
        </div>
        <div id="categoryChart"></div>
    </div>

    <!-- Top Artworks Bar Chart -->
    <div class="card-artify p-4 chart-card">
        <div class="panel-heading mb-2">
            <div class="section-title mb-0" style="font-size:1rem;">Top <span>Artworks</span></div>
            <span class="chart-badge"><i class="bi bi-trophy-fill me-1"></i>By revenue</span>
        </div>
        <div id="topArtworksChart"></div>
    </div>

    <!-- Earnings Radial Gauge -->
    <div class="card-artify p-4 chart-card d-flex flex-column align-items-center">
        <div class="panel-heading mb-2 w-100">
            <div class="section-title mb-0" style="font-size:1rem;">Balance <span>Breakdown</span></div>
            <span class="chart-badge"><i class="bi bi-speedometer2 me-1"></i>Availability</span>
        </div>
        <div id="earningsGauge"></div>
        <div id="gaugeLabel" style="font-size:.8rem;color:var(--muted);margin-top:6px;text-align:center;"></div>
    </div>

</div>

<!-- ── Payout Request Card ── -->
<div class="payout-card">
    <div class="payout-info">
        <h5><i class="bi bi-send-fill me-2" style="color:var(--gold)"></i>Request a Payout</h5>
        <p>
            You have <strong id="withdrawAmt">$0.00</strong> available for withdrawal.
            Payouts are processed within 3–5 business days.
        </p>
        <div class="payout-indicator">
            <span class="payout-dot"></span>
            Funds are transferred to your registered bank account
        </div>
    </div>
    <button class="btn-artify btn-artify-gold" id="btnPayout" disabled style="min-width:160px; position:relative; z-index:1;">
        <i class="bi bi-cash-coin"></i> Request Payout
    </button>
</div>

<!-- ── Bottom Grid: Sales Table + Payout History ── -->
<div class="bottom-earn-grid">

    <!-- Sales Table Panel -->
    <div class="card-artify p-4">
        <div class="panel-heading">
            <div class="section-title mb-0">Sales <span>Transactions</span></div>
            <div class="table-toolbar" style="margin-bottom:0;">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" class="search-input" id="tableSearch" placeholder="Search artworks…" oninput="filterTable()" />
                </div>
                <select class="filter-select" id="statusFilter" onchange="filterTable()">
                    <option value="">All Status</option>
                    <option value="Approved">Approved</option>
                    <option value="Pending">Pending</option>
                    <option value="Rejected">Rejected</option>
                </select>
            </div>
        </div>

        <div style="overflow-x:auto;">
            <table class="artify-table" id="salesTable">
                <thead>
                    <tr>
                        <th>Artwork</th>
                        <th>Category</th>
                        <th>Unit Price</th>
                        <th>Units Sold</th>
                        <th>Revenue</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="salesTableBody">
                    <!-- Populated by JS -->
                </tbody>
            </table>
            <div class="empty-table" id="salesEmptyState" style="display:none;">
                <i class="bi bi-bag-x"></i>
                <p id="salesEmptyMsg">No sales recorded yet.</p>
            </div>
        </div>

        <!-- Table info row -->
        <div class="d-flex align-items-center justify-content-between mt-3 pt-3" style="border-top:1px solid rgba(3,40,159,.06);">
            <span style="font-size:.8rem;color:var(--muted);" id="tableCountInfo">Loading…</span>
            <span style="font-size:.8rem;color:var(--muted);">Showing sold artworks only</span>
        </div>
    </div>

    <!-- Payout History Panel -->
    <div class="card-artify p-4">
        <div class="section-title">Payout <span>History</span></div>
        <div class="payout-hist-empty">
            <i class="bi bi-clock-history"></i>
            <p>No payout history available yet.</p>
        </div>
        <!-- Future: payout list rendered here -->
    </div>

</div>

@section Scripts {
<!-- Kendo UI -->
<!-- ECharts (Apache 2.0 — no license required) -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/authHelper.js"></script>
<script>
$(function () {
    if (!AuthHelper.requireAuth()) return;

    var BASE = AuthHelper.API_BASE;

    function fmt(v) {
        return "\u20B9" + parseFloat(v || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    $.ajax({
        url: BASE + "/earnings-summary",
        type: "GET",
        success: function (data) {
            var avail = data.availableBalance || 0;
            $("#availableBalance").text(fmt(avail));
            $("#requestedBalance").text(fmt(data.requestedBalance));
            $("#revenueBalance").text(fmt(data.revenueBalance));
            $("#withdrawAmt").text(fmt(avail));
            if (avail > 0) $("#btnPayout").prop("disabled", false);
        },
        error: function (xhr) {
            console.error("Earnings error:", xhr.status);
            if (xhr.status !== 401) {
                Swal.fire({ icon: "error", title: "Could not load earnings", confirmButtonColor: "#03289F" });
            }
        }
    });

    $("#btnPayout").on("click", function () {
        Swal.fire({
            title: "Request Payout?",
            text: "This will initiate a withdrawal of your available balance.",
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#03289F",
            confirmButtonText: "Yes, request"
        }).then(function (r) {
            if (r.isConfirmed) {
                Swal.fire({ icon: "success", title: "Request Submitted", text: "Your payout will be processed within 3\u20135 business days.", confirmButtonColor: "#03289F" });
            }
        });
    });

    /* ── Artwork data for table + Top Artworks chart ── */
    var allRows = [];

    $.ajax({
        url: BASE + "/GetMyArtworks",
        type: "GET",
        success: function (res) {
            var items = Array.isArray(res) ? res : (res.c_Data || res.data || []);
            allRows = items.filter(function (a) { return a.c_sell_count > 0; });
            renderTable();
            buildTopArtworksChart(allRows);
        },
        error: function () {
            Swal.fire({ icon: "error", title: "Could not load sales", confirmButtonColor: "#03289F" });
        }
    });

    /* ── Monthly Revenue Chart ── */
    $.ajax({
        url: BASE + "/revenue", type: "GET",
        success: function (data) { buildRevenueChart(data); },
        error: function ()       { emptyChart('#revenueChart', 'No revenue data available'); }
    });

    /* ── Category Sales Chart ── */
    $.ajax({
        url: BASE + "/category-sales", type: "GET",
        success: function (data) { buildCategoryChart(data); },
        error: function ()       { emptyChart('#categoryChart', 'No category data available'); }
    });

    /* ── Earnings Gauge (reuse earnings-summary) ── */
    $.ajax({
        url: BASE + "/earnings-summary", type: "GET",
        success: function (data) {
            var avail = data.availableBalance || 0;
            $("#availableBalance").text(fmt(avail));
            $("#requestedBalance").text(fmt(data.requestedBalance));
            $("#revenueBalance").text(fmt(data.revenueBalance));
            $("#withdrawAmt").text(fmt(avail));
            if (avail > 0) $("#btnPayout").prop("disabled", false);
            buildEarningsGauge(data);
        },
        error: function (xhr) {
            console.error("Earnings error:", xhr.status);
            emptyChart('#earningsGauge', 'No earnings data');
            if (xhr.status !== 401)
                Swal.fire({ icon: "error", title: "Could not load earnings", confirmButtonColor: "#03289F" });
        }
    });

    /* ══════════════════════════════════════════
       ECharts Chart Builders (Apache 2.0)
    ══════════════════════════════════════════ */
    var COLORS = ['#03289F','#EDA312','#10b981','#6b9be6','#f59e0b','#ef4444','#8b5cf6'];

    function emptyChart(sel, msg) {
        $(sel).html('<div class="chart-empty"><i class="bi bi-bar-chart-line"></i><span>' + msg + '</span></div>');
    }

    function buildRevenueChart(data) {
        if (!data || !data.length) { emptyChart('#revenueChart','No revenue data yet'); return; }
        var el = document.getElementById('revenueChart');
        el.style.height = '230px';
        var chart = echarts.init(el, null, { renderer:'canvas' });
        chart.setOption({
            backgroundColor: 'transparent',
            grid: { left:52, right:16, top:16, bottom:48 },
            tooltip: { trigger:'axis', formatter: function(p){ return p[0].axisValue + '<br/><b>$' + p[0].value.toFixed(2) + '</b>'; } },
            xAxis: { type:'category',
                data: data.map(function(d){ return d.month||d.c_Month||''; }),
                axisLine:{ lineStyle:{ color:'rgba(3,40,159,.15)' } },
                axisLabel:{ rotate:30, fontFamily:'DM Sans,sans-serif', fontSize:11, color:'#6b7280' },
                axisTick:{ show:false }
            },
            yAxis: { type:'value',
                axisLabel:{ formatter:'${value}', fontFamily:'DM Sans,sans-serif', fontSize:11, color:'#6b7280' },
                splitLine:{ lineStyle:{ color:'rgba(3,40,159,.06)' } },
                axisLine:{ show:false }, axisTick:{ show:false }
            },
            series:[{ type:'line', smooth:true,
                data: data.map(function(d){ return parseFloat(d.revenue||d.c_Revenue||0); }),
                lineStyle:{ color:'#03289F', width:2.5 },
                itemStyle:{ color:'#03289F' },
                areaStyle:{ color:{ type:'linear', x:0,y:0,x2:0,y2:1,
                    colorStops:[{offset:0,color:'rgba(107,155,230,.35)'},{offset:1,color:'rgba(107,155,230,.03)'}] } },
                symbol:'circle', symbolSize:5
            }]
        });
    }

    function buildCategoryChart(data) {
        if (!data || !data.length) { emptyChart('#categoryChart','No category data yet'); return; }
        var el = document.getElementById('categoryChart');
        el.style.height = '230px';
        var chart = echarts.init(el, null, { renderer:'canvas' });
        chart.setOption({
            backgroundColor: 'transparent',
            tooltip: { trigger:'item', formatter:'{b}: {c} ({d}%)' },
            legend: { bottom:4, textStyle:{ fontFamily:'DM Sans,sans-serif', fontSize:11, color:'#6b7280' }, itemWidth:12, itemHeight:12 },
            color: COLORS,
            series:[{ type:'pie', radius:['42%','68%'], center:['50%','44%'],
                data: data.map(function(d){ return { value:parseFloat(d.sales||d.c_Sales||d.count||1), name:d.category||d.c_Category||'Other' }; }),
                label:{ show:false },
                emphasis:{ label:{ show:true, fontSize:13, fontWeight:'bold', fontFamily:'Playfair Display,serif' } },
                itemStyle:{ borderRadius:5, borderWidth:2, borderColor:'#fff' }
            }]
        });
    }

    function buildTopArtworksChart(artworks) {
        var top5 = artworks.slice()
            .sort(function(a,b){ return (b.c_price*b.c_sell_count)-(a.c_price*a.c_sell_count); })
            .slice(0,5);
        if (!top5.length) { emptyChart('#topArtworksChart','No sold artworks yet'); return; }
        var el = document.getElementById('topArtworksChart');
        el.style.height = '230px';
        var chart = echarts.init(el, null, { renderer:'canvas' });
        var labels = top5.map(function(a){ var t=a.c_title||''; return t.length>15?t.slice(0,15)+'…':t; });
        var revs   = top5.map(function(a){ return parseFloat((a.c_price*a.c_sell_count).toFixed(2)); });
        chart.setOption({
            backgroundColor: 'transparent',
            grid: { left:10, right:24, top:10, bottom:10, containLabel:true },
            tooltip: { trigger:'axis', axisPointer:{type:'shadow'},
                formatter:function(p){ return '<b>'+p[0].name+'</b><br/>$'+p[0].value.toFixed(2); } },
            xAxis: { type:'value',
                axisLabel:{ formatter:'${value}', fontFamily:'DM Sans,sans-serif', fontSize:11, color:'#6b7280' },
                splitLine:{ lineStyle:{ color:'rgba(3,40,159,.06)' } },
                axisLine:{ show:false }, axisTick:{ show:false }
            },
            yAxis: { type:'category', data: labels,
                axisLabel:{ fontFamily:'DM Sans,sans-serif', fontSize:11, color:'#374151' },
                axisLine:{ show:false }, axisTick:{ show:false }
            },
            series:[{ type:'bar', data: revs, barMaxWidth:24,
                itemStyle:{ borderRadius:[0,6,6,0],
                    color:{ type:'linear', x:0,y:0,x2:1,y2:0,
                        colorStops:[{offset:0,color:'#6b9be6'},{offset:1,color:'#03289F'}] } },
                emphasis:{ itemStyle:{ color:{ type:'linear', x:0,y:0,x2:1,y2:0,
                    colorStops:[{offset:0,color:'#03289F'},{offset:1,color:'#1e40af'}] } } },
                label:{ show:true, position:'right', formatter:'${c}', fontFamily:'DM Sans,sans-serif', fontSize:10, color:'#374151' }
            }]
        });
    }

    function buildEarningsGauge(data) {
        var total = parseFloat(data.revenueBalance  || 0);
        var avail = parseFloat(data.availableBalance || 0);
        var pct   = total > 0 ? Math.min(100, Math.round((avail/total)*100)) : 0;
        var el = document.getElementById('earningsGauge');
        el.style.height = '200px';
        var chart = echarts.init(el, null, { renderer:'canvas' });
        chart.setOption({
            backgroundColor: 'transparent',
            series:[{ type:'gauge', startAngle:200, endAngle:-20,
                min:0, max:100, radius:'85%', center:['50%','55%'],
                progress:{ show:true, width:14,
                    itemStyle:{ color:{ type:'linear', x:0,y:0,x2:1,y2:0,
                        colorStops:[{offset:0,color:pct<34?'#ef4444':pct<67?'#f59e0b':'#10b981'},
                                    {offset:1,color:pct<34?'#dc2626':pct<67?'#d97706':'#059669'}] } } },
                axisLine:{ lineStyle:{ width:14, color:[[1,'#e5e7eb']] } },
                axisTick:{ show:false }, splitLine:{ show:false }, axisLabel:{ show:false },
                pointer:{ show:false },
                detail:{ valueAnimation:true, formatter:'{value}%',
                    color:'#03289F', fontFamily:'Playfair Display,serif', fontSize:22, fontWeight:'bold', offsetCenter:[0,'0%'] },
                title:{ offsetCenter:[0,'28%'], color:'#6b7280', fontSize:11, fontFamily:'DM Sans,sans-serif' },
                data:[{ value:pct, name:'Available' }]
            }]
        });
        $('#gaugeLabel').html('<strong>' + pct + '%</strong> available<br/>'
            + '<span style="color:#10b981;font-weight:600;">$' + avail.toFixed(2) + '</span>'
            + ' of $' + total.toFixed(2));
    }

    window.filterTable = function () { renderTable(); };


    function renderTable() {
        var query  = ($("#tableSearch").val() || "").toLowerCase();
        var status = $("#statusFilter").val();

        var list = allRows;

        if (status) {
            list = list.filter(function (r) { return (r.c_approval_status || "Pending") === status; });
        }
        if (query) {
            list = list.filter(function (r) { return (r.c_title || "").toLowerCase().indexOf(query) !== -1; });
        }

        $("#tableCountInfo").text(list.length + " record" + (list.length !== 1 ? "s" : ""));

        if (!list.length) {
            $("#salesTableBody").empty();
            $("#salesEmptyState").show();
            $("#salesEmptyMsg").text(
                query ? ('No results for "' + query + '"') :
                status ? ("No " + status + " sales found.") :
                "No sales recorded yet."
            );
            return;
        }

        $("#salesEmptyState").hide();

        var html = list.map(function (d) {
            var s        = d.c_approval_status || "Pending";
            var badgeCls = s === "Approved" ? "badge-approved" : s === "Rejected" ? "badge-rejected" : "badge-pending";
            var revenue  = (parseFloat(d.c_price) * (d.c_sell_count || 0)).toFixed(2);
            var cat      = d.CategoryName || "—";

            return '<tr>'
                + '<td><div class="table-artwork-title" title="' + esc(d.c_title) + '">' + esc(d.c_title) + '</div></td>'
                + '<td><span class="table-category">' + esc(cat) + '</span></td>'
                + '<td class="table-price">\u20B9' + parseFloat(d.c_price).toFixed(2) + '</td>'
                + '<td class="table-units">' + d.c_sell_count + '</td>'
                + '<td class="table-revenue">\u20B9' + revenue + '</td>'
                + '<td><span class="' + badgeCls + '">' + s + '</span></td>'
                + '</tr>';
        }).join("");

        $("#salesTableBody").html(html);
    }

    function esc(t) {
        return (t || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }
});
</script>
}