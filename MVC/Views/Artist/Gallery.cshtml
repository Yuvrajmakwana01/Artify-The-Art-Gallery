@{
    ViewData["Title"] = "Digital Gallery";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.bootstrap-v4.min.css" rel="stylesheet" />

<style>
    :root {
        --primary-dark: #0f172a;
        --accent-gold: #b39359; /* Sophisticated gold accent */
        --bg-canvas: #f8fafc;
        --glass-bg: rgba(255, 255, 255, 0.85);
    }

    body { 
        background-color: var(--bg-canvas); 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        color: var(--primary-dark);
    }

    /* ── Header Section ── */
    .gallery-section { padding-top: 3rem;}
    
    .gallery-title { 
        font-family: 'Bodoni Moda', serif; 
        font-size: 2.5rem; 
        font-weight: 700; 
        letter-spacing: -1px;
    }

    .stat-badge {
        background: white;
        padding: 6px 16px;
        border-radius: 100px;
        border: 1px solid #e2e8f0;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* ── Professional Grid ── */
    #artworkListView {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 40px;
        border: none !important;
        background: transparent !important;
        margin-top: 3rem;
        padding: 20px;
    }

    /* ── The Artwork Card ── */
    .art-card {
        background: transparent;
        border-radius: 0px; /* Sharp modern edges or slight 4px radius */
        transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        position: relative;
        border-radius: 12px;
        @* box-shadow: rgba(0, 0, 0, 0.16) 0px 1px 4px; *@
        box-shadow: rgba(50, 50, 93, 0.25) 0px 2px 5px -1px, rgba(0, 0, 0, 0.3) 0px 1px 3px -1px;
    }

    .image-container {
        position: relative;
        aspect-ratio: 6 / 5; /* Elegant portrait ratio */
        overflow: hidden;
       
        background: transparent;
        padding: 5px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    .art-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s ease;
    }

    /* ── Overlay Actions ── */
    .art-overlay {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.2);
        opacity: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 20px;
        transition: all 0.4s ease;
        backdrop-filter: blur(0px);
    }

    .art-card:hover .art-overlay {
        opacity: 1;
        backdrop-filter: blur(8px);
    }

    .art-card:hover .art-img {
        transform: scale(1.08);
    }

    .action-group {
        display: flex;
        gap: 10px;
        transform: translateY(20px);
        transition: transform 0.4s ease;
    }

    .art-card:hover .action-group {
        transform: translateY(0);
    }

    .btn-glass {
        background: var(--glass-bg);
        border: none;
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-dark);
        text-decoration: none !important;
        font-size: 1.1rem;
        transition: 0.3s;
    }

    .btn-glass:hover {
        background: var(--primary-dark);
        color: white;
    }

    /* ── Content ── */
    .art-details {
        padding: 20px 15px;
    }

    .art-category {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        color: var(--accent-gold);
        margin-bottom: 8px;
    }

    .art-name {
        font-family: 'Bodoni Moda', serif;
        font-size: 1.4rem;
        font-weight: 600;
        margin: 0;
        color: var(--primary-dark);
    }

    .art-price {
        font-size: 1rem;
        color: #64748b;
        font-weight: 400;
        margin-top: 5px;
        display: block;
    }

    /* ── Kendo UI Customization ── */
    .k-dropdown .k-dropdown-wrap {
        border-radius: 10px !important;
        padding: 5px !important;
        border-color: #e2e8f0 !important;
        background: white !important;
    }

    .btn-upload {
        background: var(--primary-dark);
        color: white;
        border-radius: 10px;
        padding: 12px 28px;
        font-weight: 600;
        transition: 0.3s;
        border: none;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-upload:hover {
        background: #334155;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
        color: white;
    }

    .k-pager-wrap {
        border: none !important;
        padding: 40px 0 !important;
        justify-content: center !important;
    }
</style>

<div class="container gallery-section">
    <div class="row align-items-end">
        <div class="col-lg-6">
            <div class="stat-badge mb-3 animate__animated animate__fadeInDown">
                <i class="bi bi-stars"></i>
                <span><span id="artCount">0</span> Masterpieces Found</span>
            </div>
            <p class="gallery-title animate__animated animate__fadeInLeft">The Digital Collection</p>
        </div>
        <div class="col-lg-6 mt-4 mt-lg-0 text-lg-end mb-3">
            <div class="d-inline-flex flex-wrap gap-3">
                <input id="catFilter" />
                <a href="/Artist/Upload" class="btn btn-upload">
                    <i class="bi bi-plus-lg fw-bold"></i> NEW ARTWORK
                </a>
            </div>
        </div>
    </div>

    <div id="artworkListView" class="animate__animated animate__fadeInUp"></div>

    <div id="pager"></div>
    <div id="editWindow" style="display:none;">
    <form id="updateForm" enctype="multipart/form-data" class="p-3">
        <input type="hidden" id="c_artwork_id" name="c_artwork_id" />
        
        <div class="mb-3 text-center">
            <img id="imgPreview" src="" style="max-width: 150px; border-radius: 10px; display:block; margin: 0 auto 10px;" />
            <input type="file" id="ArtworkFile" name="ArtworkFile" class="form-control" style="max-width: 410px;"/>
        </div>

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input id="edit_c_title" name="c_title" class="w-100" />
        </div>

         <div class="mb-3">
            <label class="form-label">Description</label>
            <input id="edit_c_description" name="c_description" class="w-100" />

        </div>
        <input type="hidden" id="c_approval_status_hidden" name="c_approval_status" />

        <div class="mb-3">
            <label class="form-label">Category</label>
            <input id="edit_c_category_id" name="c_category_id" class="w-100" />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Price</label>
            <input id="edit_c_price" name="c_price" class="w-100" />
        </div>
      
        <div class="mb-3" style="max-width: 410px;">
            <button type="button" id="btnSaveUpdate" class="btn btn-warning w-100 py-2">SAVE CHANGES</button>
        </div>

    </form>
</div>
</div>
