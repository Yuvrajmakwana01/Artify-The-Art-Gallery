@{
    Layout = "~/Views/Artist/_ArtistLayout.cshtml";
    ViewData["Title"] = "My Artworks";
    ViewData["Active"] = "Gallery";
}

@section HeadStyles {
<style>
    /* â”€â”€ Toolbar â”€â”€ */
    .gallery-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 24px;
    }

    .search-box {
        position: relative;
        max-width: 280px;
        flex: 1;
    }

    .search-box i {
        position: absolute;
        left: 14px; top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: .95rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 10px 14px 10px 40px;
        border-radius: 10px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--card-bg);
        font-size: .875rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        transition: border-color var(--transition), box-shadow var(--transition);
        outline: none;
    }

    .search-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(107,155,230,.15);
    }

    .filter-tabs {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 8px 16px;
        border-radius: 20px;
        border: 1.5px solid rgba(3,40,159,.12);
        background: var(--card-bg);
        font-size: .8rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all var(--transition);
        white-space: nowrap;
    }

    .filter-tab:hover, .filter-tab.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
    }

    .filter-tab[data-filter="Pending"].active   { background:#f59e0b; border-color:#f59e0b; color:#fff; }
    .filter-tab[data-filter="Approved"].active  { background:#10b981; border-color:#10b981; color:#fff; }
    .filter-tab[data-filter="Rejected"].active  { background:#ef4444; border-color:#ef4444; color:#fff; }

    /* â”€â”€ Grid â”€â”€ */
    .artworks-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 20px;
    }

    /* â”€â”€ Artwork Card â”€â”€ */
    .artwork-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        border: 1px solid rgba(3,40,159,.05);
        overflow: hidden;
        transition: all var(--transition);
        animation: fadeUp .4s ease both;
    }

    .artwork-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
    }

    .artwork-card:hover .artwork-img-overlay { opacity: 1; }

    .artwork-img-wrap {
        position: relative;
        height: 200px;
        overflow: hidden;
        background: linear-gradient(135deg, #e8eef7 0%, #dfe6e9 100%);
    }

    .artwork-img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform .5s ease;
    }

    .artwork-card:hover .artwork-img { transform: scale(1.05); }

    .artwork-img-placeholder {
        width: 100%; height: 100%;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        color: var(--muted);
        font-size: 2.5rem;
        gap: 6px;
    }

    .artwork-img-placeholder span {
        font-size: .7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .artwork-img-overlay {
        position: absolute; inset: 0;
        background: rgba(3,40,159,.55);
        display: flex; align-items: center; justify-content: center;
        gap: 12px;
        opacity: 0;
        transition: opacity var(--transition);
    }

    .overlay-btn {
        width: 42px; height: 42px;
        border-radius: 50%;
        border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        transition: transform var(--transition);
    }

    .overlay-btn:hover { transform: scale(1.12); }
    .overlay-btn.edit-btn   { background: var(--gold); color: #1a1a2e; }
    .overlay-btn.delete-btn { background: #ef4444; color: #fff; }
    .overlay-btn.view-btn   { background: #fff; color: var(--primary); }

    .status-badge {
        position: absolute;
        top: 12px; left: 12px;
        font-size: .7rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .status-Approved { background: #d1fae5; color: #065f46; }
    .status-Pending  { background: #fef3c7; color: #92400e; }
    .status-Rejected { background: #fee2e2; color: #991b1b; }

    .artwork-body { padding: 16px; }

    .artwork-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .artwork-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 8px;
    }

    .artwork-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: .75rem;
        color: var(--muted);
    }

    .artwork-stats {
        display: flex; gap: 12px;
    }

    .artwork-stat { display: flex; align-items: center; gap: 4px; }

    .artwork-actions {
        display: flex;
        gap: 8px;
        padding: 0 16px 16px;
    }

    .artwork-actions .btn { flex: 1; font-size: .8rem; font-weight: 600; border-radius: 8px; padding: 8px; }

    /* â”€â”€ Admin note â”€â”€ */
    .admin-note {
        margin: 0 16px 16px;
        padding: 10px 12px;
        background: #fff5f5;
        border-left: 3px solid #ef4444;
        border-radius: 0 8px 8px 0;
        font-size: .78rem;
        color: #991b1b;
    }

    /* â”€â”€ Empty state â”€â”€ */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
    }

    .empty-state i { font-size: 4rem; color: var(--accent); margin-bottom: 16px; display: block; }
    .empty-state h4 { font-family: 'Playfair Display',serif; color: var(--primary); margin-bottom: 8px; }

    /* â”€â”€ Count info â”€â”€ */
    .results-info { font-size: .82rem; color: var(--muted); }


    @@media (max-width:576px) {
        .gallery-toolbar { flex-direction: column; align-items: flex-start; }
        .search-box { max-width: 100%; width: 100%; }
    }
</style>
}

<!-- Toolbar -->
<div class="gallery-toolbar">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="Search artworks..." oninput="filterArtworks()" />
        </div>
        <span class="results-info" id="resultsInfo">Loading...</span>
    </div>
    <div class="d-flex align-items-center gap-10 flex-wrap">
        <div class="filter-tabs" id="filterTabs">
            <button class="filter-tab active" data-filter="All" onclick="setFilter('All')">All</button>
            <button class="filter-tab" data-filter="Approved" onclick="setFilter('Approved')"> Approved</button>
            <button class="filter-tab" data-filter="Pending"  onclick="setFilter('Pending')"> Pending</button>
            <button class="filter-tab" data-filter="Rejected" onclick="setFilter('Rejected')"> Rejected</button>
        </div>
        <a href="/Artist/Upload" class="btn-artify ms-2">
            <i class="bi bi-plus-lg"></i> Upload
        </a>
    </div>
</div>

<!-- Artworks Grid -->
<div class="artworks-grid" id="artworksGrid">
    <!-- Skeleton -->
    @for(int i = 0; i < 6; i++) {
    <div class="artwork-card">
        <div style="height:200px;background:linear-gradient(90deg,#e8eef7 25%,#dfe6e9 50%,#e8eef7 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;"></div>
        <div class="artwork-body">
            <div style="height:14px;background:#eee;border-radius:6px;width:70%;margin-bottom:8px;"></div>
            <div style="height:18px;background:#e6edf9;border-radius:6px;width:40%;"></div>
        </div>
    </div>
    }
</div>

<!-- Empty State (hidden) -->
<div class="empty-state" id="emptyState" style="display:none;">
    <i class="bi bi-images"></i>
    <h4>No artworks found</h4>
    <p id="emptyMsg">You haven't uploaded any artworks yet.</p>
    <a href="/Artist/Upload" class="btn-artify mt-3"><i class="bi bi-plus-lg"></i> Upload Your First Artwork</a>
</div>

@section Scripts {
<script>
    let allArtworks  = [];
    let currentFilter = 'All';
    const artistId   = @(Context.Session.GetInt32("ArtistId") ?? 0);
    const API_BASE   = 'http://localhost:5183/api/ArtistApi';

    /* â”€â”€ Shimmer keyframe â”€â”€ */
    const _s = document.createElement('style');
    _s.textContent = `@@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}`;
    document.head.appendChild(_s);

    /* â”€â”€ Success toast from EditArtwork redirect â”€â”€ */
    (function() {
        const p = new URLSearchParams(window.location.search);
        const s = p.get('success');
        if (s === 'updated') showToast('Artwork updated successfully!', 'success');
        if (s === 'deleted') showToast('Artwork deleted successfully.', 'success');
        if (s) history.replaceState({}, '', window.location.pathname);
    })();

    /* â”€â”€ Load â”€â”€ */
    async function loadArtworks() {
        try {
            const res  = await fetch(`${API_BASE}/GetMyArtworks`, { credentials: 'include' });
            const json = await res.json();
            allArtworks = Array.isArray(json) ? json : (json.data || json.c_Data || []);
            renderArtworks();
        } catch(e) {
            document.getElementById('artworksGrid').innerHTML =
                `<p class="text-danger" style="grid-column:1/-1;text-align:center;padding:40px 0;">Failed to load artworks. Please refresh.</p>`;
        }
    }

    function setFilter(f) {
        currentFilter = f;
        document.querySelectorAll('.filter-tab').forEach(t => t.classList.toggle('active', t.dataset.filter === f));
        renderArtworks();
    }

    function filterArtworks() { renderArtworks(); }

    function renderArtworks() {
        const query = (document.getElementById('searchInput').value || '').toLowerCase();
        let list = allArtworks;

        if (currentFilter !== 'All')
            list = list.filter(a => (a.c_approval_status || 'Pending') === currentFilter);
        if (query)
            list = list.filter(a => a.c_title?.toLowerCase().includes(query));

        document.getElementById('resultsInfo').textContent =
            `${list.length} artwork${list.length !== 1 ? 's' : ''}`;

        const grid  = document.getElementById('artworksGrid');
        const empty = document.getElementById('emptyState');

        if (list.length === 0) {
            grid.innerHTML = '';
            empty.style.display = 'block';
            document.getElementById('emptyMsg').textContent =
                query              ? `No results for "${query}"` :
                currentFilter !== 'All' ? `No ${currentFilter} artworks found.` :
                "You haven't uploaded any artworks yet.";
            return;
        }

        empty.style.display = 'none';
        grid.innerHTML = list.map((a, i) => buildCard(a, i)).join('');
    }

    function buildCard(a, i) {
        const status  = a.c_approval_status || 'Pending';
        const price   = parseFloat(a.c_price || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const title   = escHtml(a.c_title || 'Untitled');
        const editUrl = `/Artist/EditArtwork?id=${a.c_artwork_id}`;
        const delUrl  = `/Artist/EditArtwork?id=${a.c_artwork_id}&action=delete`;
        const imgEl   = a.c_preview_path
            ? `<img src="${escHtml(a.c_preview_path)}" class="artwork-img" alt="${title}"
                    onerror="this.parentElement.innerHTML='<div class=artwork-img-placeholder><i class=bi bi-image></i><span>No Preview</span></div>'" />`
            : `<div class="artwork-img-placeholder"><i class="bi bi-image"></i><span>No Preview</span></div>`;

        const adminNote = (status === 'Rejected' && a.c_admin_note)
            ? `<div class="admin-note"><i class="bi bi-info-circle me-1"></i>${escHtml(a.c_admin_note)}</div>` : '';

        return `
        <div class="artwork-card" style="animation-delay:${i * 0.06}s">
            <div class="artwork-img-wrap">
                ${imgEl}
                <span class="status-badge status-${status}">${status}</span>
                <div class="artwork-img-overlay">
                    <a class="overlay-btn view-btn"   href="${editUrl}"  title="Edit"><i class="bi bi-pencil-fill"></i></a>
                    <a class="overlay-btn delete-btn" href="${delUrl}"   title="Delete"><i class="bi bi-trash3-fill"></i></a>
                </div>
            </div>
            <div class="artwork-body">
                <div class="artwork-title" title="${title}">${title}</div>
                <div class="artwork-price">$${price}</div>
                <div class="artwork-meta">
                    <span style="font-size:.75rem;color:var(--muted);">#${a.c_artwork_id}</span>
                </div>
            </div>
            ${adminNote}
            <div class="artwork-actions">
                <a href="${editUrl}" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a href="${delUrl}"  class="btn btn-outline-danger"><i class="bi bi-trash3 me-1"></i>Delete</a>
            </div>
        </div>`;
    }

    function showToast(msg, type) {
        const t = document.createElement('div');
        t.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;padding:14px 22px;
            border-radius:10px;color:#fff;font-size:.87rem;font-weight:600;
            box-shadow:0 8px 24px rgba(0,0,0,.18);
            background:${type === 'success' ? '#10b981' : '#ef4444'};`;
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 3500);
    }

    function escHtml(t) {
        return (t || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadArtworks();
</script>
}
