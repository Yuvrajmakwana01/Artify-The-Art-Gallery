@{
    ViewData["Title"] = "My Gallery";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.default-v2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.13.1/font/bootstrap-icons.min.css" integrity="sha512-t7Few9xlddEmgd3oKZQahkNI4dS6l80+eGEzFQiqtyVYdvcSG2D3Iub77R20BdotfRPA9caaRkg1tyaJiPmO0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<div class="gallery-section sp-fade-up">

    <!-- PAGE HEADER -->
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-2">
        <div>
            <div class="stat-badge mb-3 animate__animated animate__fadeInDown">
                <i class="bi bi-stars"></i>
                <span><span id="artCount">0</span> Masterpieces</span>
            </div>
            <p class="gallery-title animate__animated animate__fadeInLeft">The Digital Collection</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center animate__animated animate__fadeInRight pb-1">
            <input id="catFilter" />
            <a href="/Artist/Upload" class="btn-upload">
                <i class="bi bi-plus-lg"></i> New Artwork
            </a>
        </div>
    </div>

    <!-- ARTWORK GRID -->
    <div id="artworkListView"></div>

    <!-- PAGER -->
    <div id="pager"></div>

    <!-- EDIT WINDOW (hidden, opened by Kendo Window) -->
    <div id="editWindow" style="display:none">
        <form id="updateForm" enctype="multipart/form-data" class="p-1">
            <input type="hidden" id="c_artwork_id" name="c_artwork_id" />

            <div class="mb-3 text-center">
                <img id="imgPreview" src=""
                     style="max-width:160px;border-radius:12px;display:block;margin:0 auto 12px;border:1px solid var(--sp-border)" />
                <input type="file" id="ArtworkFile" name="ArtworkFile" class="form-control" style="max-width:93%" />
            </div>

            <div class="mb-3">
                <label class="form-label">Title</label>
                <input id="edit_c_title" name="c_title" class="w-100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <input id="edit_c_description" name="c_description" class="w-100" />
            </div>

            <input type="hidden" id="c_approval_status_hidden" name="c_approval_status" />

            <div class="mb-3">
                <label class="form-label">Category</label>
                <input id="edit_c_category_id" name="c_category_id" class="w-100" />
            </div>

            <div class="mb-3">
                <label class="form-label">Price ($)</label>
                <input id="edit_c_price" name="c_price" class="w-100" />
            </div>

            <button type="button" id="btnSaveUpdate" class="sp-btn sp-btn-amber py-2" style="width: 90%;">
                <i class="bi bi-floppy-fill me-1"></i> Save Changes
            </button>
        </form>
    </div>
</div>

<!-- ARTWORK TEMPLATE -->
<script type="text/x-kendo-template" id="artTemplate">
    <div class="art-card">
        <div class="image-container">
            <img src="#:c_preview_path#" class="art-img" alt="#:c_title#" loading="lazy">
            <div class="art-overlay">
                <div class="action-group">
                    <a href="javascript:void(0)" class="btn-glass" onclick="editArtwork(#:c_artwork_id#)" title="Edit">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                    <a href="javascript:void(0)" class="btn-glass" onclick="deleteArtwork(#:c_artwork_id#)" title="Delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="art-details">
            <div class="art-category">#:categoryName#</div>
            <h3 class="art-name">#:c_title#</h3>
            <span class="art-price">$#:c_price#</span>
        </div>
    </div>
</script>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var ds;
        $(document).ready(function () {
            ds = new kendo.data.DataSource({
                transport: {
                    read: { url: "http://localhost:5183/api/ArtistApi/GetAll", dataType: "json" }
                },
                schema: {
                    data: "data",
                    total: function(res) { return res.data ? res.data.length : 0; }
                },
                pageSize: 9,
                change: function() { $("#artCount").text(this.total()); }
            });

            $("#artworkListView").kendoListView({
                dataSource: ds,
                template: kendo.template($("#artTemplate").html()),
                tagName: "div",
                contentElement: false
            });

            $("#pager").kendoPager({
                dataSource: ds,
                responsive: true,
                buttonCount: 5
            });

            $("#catFilter").kendoDropDownList({
                optionLabel: "Filter by Style",
                dataTextField: "name",
                dataValueField: "name",
                dataSource: {
                    transport: { read: { url: "http://localhost:5183/api/ArtistApi/GetCategories", dataType: "json" } }
                },
                change: function() {
                    var v = this.value();
                    ds.filter(v ? { field: "categoryName", operator: "eq", value: v } : {});
                }
            });

            $("#ArtworkFile").change(function() {
                if (this.files && this.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) { $('#imgPreview').attr('src', e.target.result); };
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });

        function deleteArtwork(id) {
            Swal.fire({
                title: 'Remove this artwork?',
                text: "This action cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c8873a',
                cancelButtonColor: '#9ca3af',
                confirmButtonText: 'Yes, remove it'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: 'http://localhost:5183/api/ArtistApi/Delete/' + id,
                        type: 'DELETE',
                        success: function() {
                            Swal.fire('Removed', 'Your artwork has been deleted.', 'success');
                            ds.read();
                        }
                    });
                }
            });
        }

        var editWindow = $("#editWindow").kendoWindow({
        title: "Edit Masterpiece",
        width: "500px",
        visible: false,
        modal: true,
        actions: ["Close"]
    }).data("kendoWindow");

    // 2. Initialize inputs inside the window (Move these inside ready)
    $("#edit_c_title").kendoTextBox();
    $("#edit_c_price").kendoNumericTextBox({ format: "c2" });
    $("#edit_c_description").kendoTextArea({ rows: 5, placeholder: "Enter text..." });
    $("#edit_c_category_id").kendoDropDownList({
        dataTextField: "name",
        dataValueField: "id",
        dataSource: { transport: { read: { url: "http://localhost:5183/api/ArtistApi/GetCategories" } } },
        optionLabel: "Select Category..."
    });

        

        $("#btnSaveUpdate").click(function() {
            var formData = new FormData();
            formData.append("c_artwork_id", $("#c_artwork_id").val());
            formData.append("c_title", $("#edit_c_title").data("kendoTextBox").value());
            formData.append("c_description", $("#edit_c_description").data("kendoTextArea").value());
            formData.append("c_price", $("#edit_c_price").data("kendoNumericTextBox").value());

            var categoryValue = $("#edit_c_category_id").data("kendoDropDownList").value();
            var categoryId = parseInt(categoryValue);
            if (!isNaN(categoryId)) formData.append("c_category_id", categoryId);

            formData.append("c_approval_status", $("#c_approval_status_hidden").val());

            var fileInput = $("#ArtworkFile")[0].files[0];
            if (fileInput) formData.append("ArtworkFile", fileInput);

            $.ajax({
                url: 'http://localhost:5183/api/ArtistApi/Update',
                type: 'PUT',
                data: formData,
                processData: false,
                contentType: false,
                success: function() {
                    Swal.fire('Saved', 'Your artwork has been updated!', 'success');
                    editWindow.close();
                    $("#ArtworkFile").val('');
                    ds.read();
                },
                error: function(xhr) {
                    console.error("Server Error:", xhr.responseText);
                    Swal.fire('Error', 'Something went wrong. Check console for details.', 'error');
                }
            });
        });

        function editArtwork(id) {
            $.get("http://localhost:5183/api/ArtistApi/GetById/" + id, function(data) {
                $("#c_artwork_id").val(data.c_artwork_id);
                $("#edit_c_title").data("kendoTextBox").value(data.c_title);
                $("#edit_c_price").data("kendoNumericTextBox").value(data.c_price);
                $("#edit_c_category_id").data("kendoDropDownList").value(data.c_category_id);
                $("#edit_c_description").data("kendoTextArea").value(data.c_description);
                $("#c_approval_status_hidden").val(data.c_approval_status);
                $("#ArtworkFile").val('');
                $("#imgPreview").attr("src", data.c_preview_path);
                editWindow.center().open();
            });
        }
    </script>
}
