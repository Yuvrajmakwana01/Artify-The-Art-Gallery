<script type="text/x-kendo-template" id="artTemplate">
    <div class="art-card">
        <div class="image-container">
            <img src="#:c_preview_path#" class="art-img" alt="#:c_title#" loading="lazy">
            <div class="art-overlay">
                <div class="action-group">
                    <a href="javascript:void(0)" class="btn-glass" onclick="editArtwork(#:c_artwork_id#)" title="Edit">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                    <a href="javascript:void(0)" class="btn-glass" onclick="deleteArtwork(#:c_artwork_id#)" title="Delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="art-details">
            <div class="art-category">#:categoryName#</div>
            <h3 class="art-name">#:c_title#</h3>
            <span class="art-price">List Price: $#:c_price#</span>
        </div>
    </div>
</script>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
 <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var ds;
        $(document).ready(function () {
            ds = new kendo.data.DataSource({
                transport: {
                    read: { 
                        url: "http://localhost:5183/api/ArtistApi/GetAll", 
                        dataType: "json" 
                    }
                },
                schema: {
                    data: "data",
                    total: function(res) { return res.data ? res.data.length : 0; }
                },
                pageSize: 9,
                change: function() {
                    $("#artCount").text(this.total());
                }
            });

            $("#artworkListView").kendoListView({
                dataSource: ds,
                template: kendo.template($("#artTemplate").html()),
                tagName: "div",
                contentElement: false
            });

            $("#pager").kendoPager({ 
                dataSource: ds,
                responsive: true,
                buttonCount: 5
            });

            $("#catFilter").kendoDropDownList({
                optionLabel: "Filter by Style",
                dataTextField: "name",
                dataValueField: "name",
                dataSource: {
                    transport: { read: { url: "http://localhost:5183/api/ArtistApi/GetCategories", dataType: "json" } }
                },
                change: function() {
                    var v = this.value();
                    ds.filter(v ? { field: "categoryName", operator: "eq", value: v } : {});
                }
            });
            $("#ArtworkFile").change(function() {
            if (this.files && this.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#imgPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
        });

function deleteArtwork(id) {
    Swal.fire({
        title: 'Are you sure?',
        text: "You won't be able to revert this!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#0f172a',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
        if (result.isConfirmed) {
            $.ajax({
                url: 'http://localhost:5183/api/ArtistApi/Delete/' + id,
                type: 'DELETE',
                success: function() {
                    Swal.fire('Deleted!', 'Your artwork has been removed.', 'success');
                    ds.read(); // Refresh the Kendo DataSource
                }
            });
        }
    });
}
      // 1. Initialize Window
var editWindow = $("#editWindow").kendoWindow({
    title: "Edit Masterpiece",
    width: "500px",
    visible: false,
    modal: true,
    actions: ["Close"]
}).data("kendoWindow");

// 2. Initialize inputs inside the window
$("#edit_c_title").kendoTextBox();

$("#edit_c_price").kendoNumericTextBox({ format: "c2" });
$("#edit_c_description").kendoTextArea({
    rows: 5,
    placeholder: "Enter text..."
});
$("#edit_c_category_id").kendoDropDownList({
    dataTextField: "name",
    dataValueField: "id",
    dataSource: { transport: { read: { url: "http://localhost:5183/api/ArtistApi/GetCategories" } } },
    optionLabel: "Select Category..."
});

// 3. Updated edit function to open the modal instead of redirecting
function editArtwork(id) {
    $.get("http://localhost:5183/api/ArtistApi/GetById/" + id, function(data) {
        $("#c_artwork_id").val(data.c_artwork_id);
        $("#edit_c_title").data("kendoTextBox").value(data.c_title);
        $("#edit_c_price").data("kendoNumericTextBox").value(data.c_price);
        $("#edit_c_category_id").data("kendoDropDownList").value(data.c_category_id);
        $("#edit_c_description").data("kendoTextArea").value(data.c_description);
        
        // Ensure this line actually sets the value:
        $("#c_approval_status_hidden").val(data.c_approval_status); 
        // CLEAR THE FILE INPUT WHEN OPENING
        $("#ArtworkFile").val('');
        $("#imgPreview").attr("src", data.c_preview_path);
        editWindow.center().open();
    });
}


$("#btnSaveUpdate").click(function () {
    var formData = new FormData();
    formData.append("c_artwork_id", $("#c_artwork_id").val());
    formData.append("c_title", $("#edit_c_title").data("kendoTextBox").value());
    formData.append("c_description", $("#edit_c_description").data("kendoTextArea").value());
    formData.append("c_price", $("#edit_c_price").data("kendoNumericTextBox").value());
    
    var categoryValue = $("#edit_c_category_id").data("kendoDropDownList").value();
    console.log("Selected Category ID:", categoryValue); 

    if (categoryValue === "" || categoryValue === undefined || categoryValue === null) {
        console.warn("Kendo DropDown returned an empty value!");
    }
    // ------------------------------------
    
    var categoryId = parseInt(categoryValue);
    if (!isNaN(categoryId)) {
        formData.append("c_category_id", categoryId);
    } else {
        console.warn("Category ID is not a number. Check your DDL binding.");
    }
    
    // Explicitly grab the value from the hidden input field:
    var approvalStatus = $("#c_approval_status_hidden").val();
    formData.append("c_approval_status", approvalStatus); 
    
    var fileInput = $("#ArtworkFile")[0].files[0];
    if (fileInput) formData.append("ArtworkFile", fileInput);

    $.ajax({
        url: 'http://localhost:5183/api/ArtistApi/Update',
        type: 'PUT',
        data: formData,
        processData: false,
        contentType: false,
        success: function() {
            Swal.fire('Success', 'Your artwork has been updated!', 'success');
            editWindow.close();
            $("#ArtworkFile").val('');
            ds.read();
        },
        error: function(xhr) {
            console.error("Server Error:", xhr.responseText);
            Swal.fire('Error', 'Check console for validation details.', 'error');
        }
    });
});
        
    </script>
}