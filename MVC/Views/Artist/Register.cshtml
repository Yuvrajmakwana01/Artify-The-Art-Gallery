@{
    ViewData["Title"] = "Join the Studio";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join the Studio — Artify</title>

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.bootstrap-v4.min.css" rel="stylesheet" />

    <style>
        :root { 
            --glass-bg: rgba(255, 255, 255, 0.9);
            --accent-sage: #7d8c7d;
            --text-main: #2c2c2c;
            --soft-border: #e2e8f0;
            --input-focus: #af9462;
        }

        body, html { 
            margin: 0; padding: 0; height: 100%; 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #f8f9fa; 
            color: var(--text-main);
        }

        /* ── LIGHT MASONRY BACKGROUND ── */
        .bg-canvas { 
            position: fixed; inset: 0; display: flex; gap: 15px; padding: 15px; z-index: 1; opacity: 0.4; pointer-events: none;
        }
        .column { display: flex; flex-direction: column; gap: 15px; flex: 1; }
        .scroll-up { animation: slideUp 80s linear infinite; }
        .scroll-down { animation: slideDown 80s linear infinite; }
        .art-item img { width: 100%; border-radius: 12px; filter: sepia(20%); }

        @@keyframes slideUp { from { transform: translateY(0); } to { transform: translateY(-50%); } }
        @@keyframes slideDown { from { transform: translateY(-50%); } to { transform: translateY(0); } }

        /* ── CENTERED FORM ── */
        .main-wrapper { 
            position: relative; z-index: 10; height: 100vh; display: flex; 
            align-items: center; justify-content: center; overflow-y: auto; padding: 40px 0;
        }

        .studio-card { 
            background: var(--glass-bg); 
            backdrop-filter: blur(20px); 
            width: 100%; max-width: 520px; 
            padding: 50px; border-radius: 24px; 
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid white;
        }

        .header-section { text-align: center; margin-bottom: 35px; }
        .header-section h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; margin: 0; font-weight: 600; }
        .tagline { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 4px; color: var(--accent-sage); font-weight: 700; }

        /* ── KENDO OVERRIDES ── */
        .k-textbox, .k-numerictextbox { 
            width: 100% !important; border-radius: 8px !important; 
            margin-bottom: 15px; border: 1px solid var(--soft-border) !important;
            padding: 12px 15px !important; font-size: 0.9rem !important;
            transition: all 0.3s !important; background: white !important;
        }
        .k-state-focused { border-color: var(--input-focus) !important; box-shadow: 0 0 0 3px rgba(175, 148, 98, 0.1) !important; }

        /* ── PROFILE UPLOAD ── */
        .upload-box { 
            display: flex; flex-direction: column; align-items: center; margin-bottom: 25px; 
        }
        .preview-circle { 
            width: 90px; height: 90px; border-radius: 50%; object-fit: cover;
            border: 3px solid white; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 10px;
        }

        /* ── GENDER PILLS ── */
        .gender-container { display: flex; gap: 10px; margin-top: 5px; }
        .gender-option { flex: 1; position: relative; }
        .gender-option input { position: absolute; opacity: 0; }
        .gender-option label { 
            display: block; padding: 10px; text-align: center; background: white;
            border: 1px solid var(--soft-border); border-radius: 8px; font-size: 0.8rem;
            cursor: pointer; transition: 0.2s; font-weight: 500;
        }
        .gender-option input:checked + label { 
            background: var(--text-main); color: white; border-color: var(--text-main); 
        }

        .btn-submit { 
            background: var(--text-main) !important; color: white !important; 
            width: 100% !important; padding: 16px !important; border-radius: 8px !important;
            border: none !important; font-weight: 600; margin-top: 20px;
            letter-spacing: 1px; transition: 0.3s; cursor: pointer;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

        .k-invalid-msg { color: #d9534f !important; font-size: 0.75rem !important; margin: -10px 0 10px 5px; display: block; }
    </style>
</head>
<body>

    <div class="bg-canvas">
        <div class="column scroll-up">
            <div class="art-item"><img src="https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=400"></div>
            <div class="art-item"><img src="https://images.unsplash.com/photo-1549490349-8643362247b5?w=400"></div>
        </div>
        <div class="column scroll-down">
            <div class="art-item"><img src="https://images.unsplash.com/photo-1578301978693-85fa9c0320b9?w=400"></div>
            <div class="art-item"><img src="https://images.unsplash.com/photo-1582555172866-f73bb12a2ab3?w=400"></div>
        </div>
        <div class="column scroll-up">
            <div class="art-item"><img src="https://images.unsplash.com/photo-1576132710321-70529d201d4a?w=400"></div>
            <div class="art-item"><img src="https://images.unsplash.com/photo-1541963463532-d68292c34b19?w=400"></div>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="studio-card animate__animated animate__fadeIn">
            <div class="header-section">
                <span class="tagline">Artist Registration</span>
                <h1>Create Your Studio</h1>
            </div>

            <form id="regForm">
                <div class="upload-box">
                    <img id="imgPreview" src="https://cdn-icons-png.flaticon.com/512/149/149071.png" class="preview-circle" />
                    <input type="file" id="fProfile" name="ProfilePicture" style="display:none" accept="image/*" />
                    <label for="fProfile" style="cursor:pointer; font-size:0.75rem; color:var(--accent-sage); font-weight:600">
                        <i class="bi bi-plus-circle me-1"></i> Upload Portrait
                    </label>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <input id="txtFullName" name="c_Full_Name" required validationMessage="Enter full name" placeholder="Full Name" />
                    </div>
                    <div class="col-md-6">
                        <input id="txtUserName" name="c_UserName" required validationMessage="Choose a handle" placeholder="Username" />
                    </div>
                </div>

                <input id="txtEmail" name="c_Email" type="email" required data-email-msg="Invalid email address" placeholder="Email Address" />
                
                <input id="txtMobile" name="c_Mobile" required validationMessage="Enter mobile number" placeholder="Mobile Number" />

                <input id="txtPass" name="c_Password" type="password" required 
                       data-passwordComplexity-msg="Need 8+ chars, 1 number & 1 symbol" placeholder="Security Password" />

                <label class="tagline" style="margin-top:10px; display:block">Gender</label>
                <div class="gender-container">
                    <div class="gender-option">
                        <input type="radio" id="m" name="c_Gender" value="Male" checked>
                        <label for="m">Male</label>
                    </div>
                    <div class="gender-option">
                        <input type="radio" id="f" name="c_Gender" value="Female">
                        <label for="f">Female</label>
                    </div>
                </div>

                <button type="button" id="btnGo" class="btn-submit">Initialize Account</button>
            </form>

            <div style="text-align:center; margin-top:25px; font-size:0.85rem">
                <span style="color:#94a3b8">Already have an account?</span> 
                <a href="/Artist/Login" style="color:var(--text-main); font-weight:700; text-decoration:none; margin-left:5px">Sign In</a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Initialize Kendo Inputs
            $("#txtFullName, #txtUserName, #txtEmail, #txtPass, #txtMobile").kendoTextBox();
            
            // Image Preview
            $("#fProfile").change(function(){
                if (this.files && this.files[0]) {
                    let reader = new FileReader();
                    reader.onload = e => $('#imgPreview').attr('src', e.target.result);
                    reader.readAsDataURL(this.files[0]);
                }
            });

            // Validator with Password Complexity
            var validator = $("#regForm").kendoValidator({
                rules: {
                    passwordComplexity: function (input) {
                        if (input.is("[name=c_Password]")) {
                            var val = input.val();
                            // 8 chars, 1 number, 1 special char
                            return /^(?=.*[0-9])(?=.*[!@@#$%^&*])[a-zA-Z0-9!@@#$%^&*]{8,}$/.test(val);
                        }
                        return true;
                    },
                    mobileLength: function(input) {
                        if (input.is("[name=c_Mobile]")) {
                            return input.val().length >= 10;
                        }
                        return true;
                    }
                },
                messages: {
                    passwordComplexity: "8+ chars, 1 number, 1 symbol required",
                    mobileLength: "Enter a valid 10-digit number"
                }
            }).data("kendoValidator");

            // Submit Logic
            $("#btnGo").click(function () {
                if (validator.validate()) {
                    var formData = new FormData($("#regForm")[0]);
                    kendo.ui.progress($(".studio-card"), true);

                    $.ajax({
                        url: 'http://localhost:5183/api/ArtistApi/Register',
                        type: 'POST',
                        data: formData,
                        contentType: false, 
                        processData: false,
                        success: function (res) {
                            kendo.ui.progress($(".studio-card"), false);
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Welcome to the Studio',
                                    text: res.message,
                                    confirmButtonColor: '#2c2c2c'
                                }).then(() => window.location.href = "/Artist/Login");
                            }
                        },
                        error: function (xhr) {
                            kendo.ui.progress($(".studio-card"), false);
                            let msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : "Registration failed";
                            Swal.fire({
                                icon: 'error',
                                title: 'Registration Denied',
                                text: msg,
                                confirmButtonColor: '#2c2c2c'
                            });
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>