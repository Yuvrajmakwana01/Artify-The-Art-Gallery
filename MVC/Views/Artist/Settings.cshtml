@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet">
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
<link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.default-v2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.13.1/font/bootstrap-icons.min.css" />

<div class="settings-container animate__animated animate__fadeIn">

    <div class="mb-4">
        <div class="sp-eyebrow d-inline-flex align-items-center gap-2 mb-2"
             style="font-size:0.68rem;font-weight:700;letter-spacing:1.8px;text-transform:uppercase;color:var(--sp-amber)">
            <i class="bi bi-gear-fill"></i> Settings
        </div>
        <h1
            style="font-family:'Syne', sans-serif;font-size:1.9rem;font-weight:700;color:var(--sp-ink);margin:0;letter-spacing:-0.4px">
            Account Settings
        </h1>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="sp-section-label mb-3 fw-bold">
                <i class="bi bi-person-badge ms-1"></i>&nbsp; Personal Details
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Email Address</label>
                    <input type="text" id="displayEmail" class="k-input k-input-md w-100" readonly
                           style="background:#f8f9fa" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Username</label>
                    <input type="text" id="displayUsername" class="k-input k-input-md w-100" readonly
                           style="background:#f8f9fa" />
                </div>
            </div>

            <div class="sp-plan-banner p-3 rounded-3" style="background: #f0fdf4; border: 1px solid #bbf7d0;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong style="color:#166534;font-size:0.9rem">Verified Artist · Pro Plan</strong><br>
                        <small class="text-muted">85% commission · Unlimited uploads</small>
                    </div>
                    @* <button class="btn btn-sm btn-success px-3">Active</button> *@
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="sp-section-label mb-3 fw-bold">
                <i class="bi bi-shield-lock ms-1"></i>&nbsp; Security & Password
            </div>

            <form id="passwordForm">
                <div class="mb-3">
                    <label class="form-label">Current Password</label>
                    <input type="password" id="currentPwd" class="k-input k-input-md w-100" required />
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">New Password</label>
                        <input type="password" id="newPwd" class="k-input k-input-md w-100" placeholder="••••••••"
                               required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" id="confirmPwd" class="k-input k-input-md w-100" placeholder="••••••••"
                               required />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">Update Password</button>
            </form>
        </div>
    </div>

    <div class="p-4 rounded-4" style="background: #fff5f5; border: 1px solid #feb2b2;">
        <h5 style="color:#c53030;font-weight:700;margin-bottom:6px">
            <i class="bi bi-exclamation-triangle me-2"></i>Danger Zone
        </h5>
        <p style="font-size:0.85rem;color:#742a2a;margin-bottom:16px">
            Permanent actions that cannot be undone.
        </p>
        <div class="d-flex gap-3 flex-wrap">
            <button class="btn btn-outline-secondary btn-sm" onclick="deactivateAccount()">Deactivate Account</button>
            <button class="btn btn-danger btn-sm" onclick="deleteAccount()">Delete Account</button>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
        // 1. Fetch data from LocalStorage
        const userData = JSON.parse(localStorage.getItem("userData"));
        if (!userData) {
        window.location.href = "/Artist/Login";
        return;
        }

        // 2. Populate non-editable fields
        $("#displayEmail").val(userData.c_Email);
        $("#displayUsername").val(userData.c_UserName);

        console.log(JSON.parse(localStorage.getItem("userData")));

        // 3. Password Update Logic
        $("#passwordForm").on("submit", function (e) {
        e.preventDefault();

        const newPwd = $("#newPwd").val();
        const confirmPwd = $("#confirmPwd").val();

        // Client-side validation
        if (newPwd !== confirmPwd) {
        Swal.fire("Error", "New passwords do not match!", "error");
        return;
        }

        if (newPwd.length < 6) {
        Swal.fire("Error", "Password must be at least 6 characters.", "warning");
        return;
        }

        // Inside your #passwordForm submit logic
        const payload = {
        c_Artist_Id: parseInt(userData.c_User_Id), 
        c_CurrentPassword: $("#currentPwd").val(), 
        c_NewPassword: newPwd,                     
        c_ConfirmPassword: confirmPwd             
        };

        $.ajax({
        url: "http://localhost:5183/api/ArtistApi/change-password",
        type: "POST",
        contentType: "application/json",
        data: JSON.stringify(payload), // Now matches C# model structure
        success: function (res) {
        if (res.success) {
        Swal.fire("Success", "Password updated successfully!", "success");
        $("#passwordForm")[0].reset();
        } else {
        Swal.fire("Error", res.message || "Failed to update.", "error");
        }
        },
        error: function (xhr) {
        Swal.fire("Error", "Validation failed. Please check inputs.", "error");
        }
        });
        });
        });

        function deactivateAccount() {
        Swal.fire({
        title: 'Are you sure?',
        text: "You can reactivate this later.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, deactivate'
        }).then((result) => {
        if (result.isConfirmed) {
        Swal.fire('Deactivated!', 'Account status updated.', 'success');
        }
        });
        }

        function deleteAccount() {
        Swal.fire({
        title: 'DANGER!',
        text: "This will permanently delete your portfolio!",
        icon: 'error',
        showCancelButton: true,
        confirmButtonText: 'DELETE PERMANENTLY'
        });
        }
    </script>
}