@{
    ViewBag.Title = "Change Password";
    @* Layout = "~/Views/Shared/_BuyerLayout.cshtml"; *@
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

<style>
    :root {
        --canvas:        #f5f0ea;
        --canvas-2:      #ffffff;
        --canvas-3:      #ede7df;
        --surface:       #faf7f3;
        --border:        rgba(0,0,0,0.06);
        --border-2:      rgba(0,0,0,0.10);
        --gold:          #9a6324;
        --gold-bright:   #c08b3f;
        --gold-dim:      rgba(154,99,36,0.08);
        --gold-ring:     rgba(154,99,36,0.18);
        --text:          #1c1814;
        --text-2:        #5e554a;
        --text-3:        #9e9488;
        --radius-sm:     10px;
        --radius-md:     16px;
        --radius-xl:     36px;
        --shadow-lg:     0 12px 40px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
        --shadow-gold:   0 8px 32px rgba(154,99,36,0.15);
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--canvas); color: var(--text); }

    .edit-page { max-width: 560px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

    .studio-card {
        background: var(--canvas-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .header-group {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.75rem 2.25rem;
        background: linear-gradient(180deg, var(--surface) 0%, var(--canvas-2) 100%);
        border-bottom: 1px solid var(--border);
    }
    .header-group h4 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem; font-weight: 700; color: var(--text); margin: 0;
    }
    .header-group p { font-size: .84rem; color: var(--text-3); margin: 4px 0 0; line-height: 1.4; }
    .header-group .shield-icon {
        width: 48px; height: 48px; border-radius: 50%;
        background: linear-gradient(135deg, var(--gold-dim), rgba(154,99,36,0.15));
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .header-group .shield-icon i { font-size: 1.3rem; color: var(--gold-bright); }

    .form-body { padding: 2.25rem; }
    .form-group { margin-bottom: 1.75rem; }
    .form-label {
        display: flex; align-items: center; gap: 7px;
        font-size: .65rem; font-weight: 700; letter-spacing: 2px;
        text-transform: uppercase; color: var(--text-3); margin-bottom: 8px;
    }
    .form-label i { font-size: .75rem; }

    .pw-input-wrap { position: relative; }
    .form-input {
        width: 100%; padding: 13px 48px 13px 16px;
        border-radius: var(--radius-sm);
        border: 1.5px solid var(--border-2);
        background: var(--canvas); font-size: .92rem; color: var(--text);
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
    }
    .form-input:focus {
        outline: none; border-color: var(--gold-bright);
        box-shadow: 0 0 0 4px var(--gold-dim);
        background: var(--canvas-2);
    }
    .form-input.is-error {
        border-color: #e53e3e;
        box-shadow: 0 0 0 4px rgba(229,62,62,0.10);
        animation: shake 0.4s ease;
    }
    .form-input::placeholder { color: var(--text-3); }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        20% { transform: translateX(-4px); }
        40% { transform: translateX(4px); }
        60% { transform: translateX(-3px); }
        80% { transform: translateX(3px); }
    }

    .eye-btn {
        position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
        background: none; border: none; cursor: pointer;
        color: var(--text-3); padding: 4px; line-height: 1;
        transition: color 0.25s; border-radius: 4px;
    }
    .eye-btn:hover { color: var(--gold); }

    /* Strength bar */
    .strength-bar { display: flex; gap: 5px; margin-top: 10px; }
    .strength-seg {
        height: 4px; flex: 1; border-radius: 99px;
        background: var(--border-2);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .strength-seg.weak   { background: linear-gradient(90deg, #e53e3e, #f56565); }
    .strength-seg.fair   { background: linear-gradient(90deg, #dd6b20, #ed8936); }
    .strength-seg.good   { background: linear-gradient(90deg, #d69e2e, #ecc94b); }
    .strength-seg.strong { background: linear-gradient(90deg, #38a169, #48bb78); }
    .strength-label { font-size: .73rem; margin-top: 5px; font-weight: 600; }

    .btn-amber {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 26px;
        background: linear-gradient(135deg, var(--gold-bright), var(--gold));
        color: #fff; border: none; border-radius: var(--radius-md);
        font-family: 'DM Sans', sans-serif;
        font-weight: 600; cursor: pointer; font-size: .86rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-amber:hover { transform: translateY(-2px); box-shadow: var(--shadow-gold); filter: brightness(1.05); }
    .btn-amber:active { transform: translateY(0); }
    .btn-amber:disabled { opacity: .6; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-cancel {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 24px;
        background: transparent; color: var(--text-2);
        border: 1.5px solid var(--border-2); border-radius: var(--radius-md);
        font-family: 'DM Sans', sans-serif;
        font-size: .86rem; font-weight: 500; cursor: pointer;
        text-decoration: none; transition: all 0.3s;
    }
    .btn-cancel:hover { background: var(--canvas-3); color: var(--text); border-color: var(--text-3); }

    .edit-actions {
        display: flex; justify-content: flex-end; gap: 12px;
        padding: 1.5rem 2.25rem;
        background: linear-gradient(180deg, var(--surface) 0%, rgba(250,247,243,0.8) 100%);
        border-top: 1px solid var(--border);
    }

    #msgBox {
        margin: 1.25rem 2.25rem 0; padding: 14px 18px;
        border-radius: var(--radius-md); font-size: .88rem;
        display: none; align-items: center; gap: 8px; font-weight: 500;
    }
    #msgBox.success { background: rgba(220,252,231,0.9); color: #166534; border: 1px solid #86efac; display: flex; }
    #msgBox.error   { background: rgba(254,226,226,0.9); color: #991b1b; border: 1px solid #fca5a5; display: flex; }

    .sp-fade-up { opacity: 0; transform: translateY(24px); animation: fadeUp .55s cubic-bezier(0.22,1,0.36,1) forwards; }
    @@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    @@media (max-width: 600px) {
        .edit-actions { flex-direction: column; }
        .btn-amber, .btn-cancel { width: 100%; justify-content: center; }
        .form-body { padding: 1.75rem; }
        .header-group { padding: 1.5rem; }
        .edit-page { padding: 2rem 1rem 4rem; }
    }
</style>

<div class="edit-page sp-fade-up">
    <div class="studio-card">

        <div class="header-group">
            <div>
                <h4>Change Password</h4>
                <p>Update your account password securely</p>
            </div>
            <div class="shield-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
        </div>

        <div id="msgBox"></div>

        <div class="form-body">

            <div class="form-group">
                <label class="form-label"><i class="bi bi-key"></i> Current Password</label>
                <div class="pw-input-wrap">
                    <input type="password" id="currentPwd" class="form-input" placeholder="Enter current password" />
                    <button type="button" class="eye-btn" onclick="toggleEye('currentPwd', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="bi bi-lock"></i> New Password</label>
                <div class="pw-input-wrap">
                    <input type="password" id="newPwd" class="form-input"
                           placeholder="Minimum 6 characters" oninput="checkStrength(this.value)" />
                    <button type="button" class="eye-btn" onclick="toggleEye('newPwd', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <div class="strength-bar">
                    <div class="strength-seg" id="seg1"></div>
                    <div class="strength-seg" id="seg2"></div>
                    <div class="strength-seg" id="seg3"></div>
                    <div class="strength-seg" id="seg4"></div>
                </div>
                <div class="strength-label" id="strengthLabel"></div>
            </div>

            <div class="form-group" style="margin-bottom:0;">
                <label class="form-label"><i class="bi bi-check2-circle"></i> Confirm New Password</label>
                <div class="pw-input-wrap">
                    <input type="password" id="confirmPwd" class="form-input" placeholder="Re-type new password" />
                    <button type="button" class="eye-btn" onclick="toggleEye('confirmPwd', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

        </div>

        <div class="edit-actions">
            <a href="@Url.Action("Profile", "Buyer")" class="btn-cancel">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
            <button type="button" class="btn-amber" id="btnUpdate">
                <i class="bi bi-shield-check"></i> Update Password
            </button>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        var BUYER_ID = window.buyerId || document.querySelector('meta[name="buyer-id"]')?.content;
        function toggleEye(inputId, btn) {
            var inp = document.getElementById(inputId);
            var isHidden = inp.type === 'password';
            inp.type = isHidden ? 'text' : 'password';
            btn.querySelector('i').className = isHidden ? 'bi bi-eye-slash' : 'bi bi-eye';
        }

        function checkStrength(val) {
            var score = 0;
            if (val.length >= 6)                         score++;
            if (val.length >= 10)                        score++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val))               score++;

            var colorMap = { 1: 'weak', 2: 'fair', 3: 'good', 4: 'strong' };
            var labelMap = { 1: 'Weak', 2: 'Fair', 3: 'Good', 4: 'Strong' };
            var colorHex = { 1: '#e53e3e', 2: '#dd6b20', 3: '#d69e2e', 4: '#38a169' };

            for (var i = 1; i <= 4; i++) {
                var seg = document.getElementById('seg' + i);
                seg.className = 'strength-seg ' + (i <= score ? colorMap[score] : '');
            }
            var lbl = document.getElementById('strengthLabel');
            lbl.textContent  = val.length > 0 ? labelMap[score] || '' : '';
            lbl.style.color  = val.length > 0 ? colorHex[score] || 'var(--text-3)' : 'var(--text-3)';
        }

        function showMsg(text, type, icon) {
            var box = document.getElementById('msgBox');
            box.innerHTML   = '<i class="bi ' + icon + '"></i> ' + text;
            box.className   = type;
            setTimeout(function () { box.style.display = 'flex';}, 4000);
        }

        $(document).ready(function () {
            $('#btnUpdate').click(function () {
                var cur  = $('#currentPwd').val().trim();
                var nw   = $('#newPwd').val().trim();
                var conf = $('#confirmPwd').val().trim();

                $('#currentPwd, #newPwd, #confirmPwd').removeClass('is-error');

                if (!cur || !nw || !conf) {
                    showMsg('Please fill in all fields.', 'error', 'bi-exclamation-circle');
                    if (!cur)  $('#currentPwd').addClass('is-error');
                    if (!nw)   $('#newPwd').addClass('is-error');
                    if (!conf) $('#confirmPwd').addClass('is-error');
                    return;
                }
                if (nw.length < 6) {
                    showMsg('New password must be at least 6 characters.', 'error', 'bi-exclamation-circle');
                    $('#newPwd').addClass('is-error');
                    return;
                }
                if (nw !== conf) {
                    showMsg('New passwords do not match.', 'error', 'bi-exclamation-circle');
                    $('#confirmPwd').addClass('is-error');
                    return;
                }

                var btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Updating...');

                $.ajax({
                    url:'http://localhost:5183/api/UserProfile/change-password',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        "Authorization": "Bearer " + localStorage.getItem("token")
                    },
                    data: JSON.stringify({
                        @* c_user_id:       BUYER_ID, *@
                        c_CurrentPassword: cur,
                        c_NewPassword:     nw,
                        c_ConfirmPassword: conf
                    }),
                    success: function (res) {
                        btn.prop('disabled', false)
                            .html('<i class="bi bi-shield-check"></i> Update Password');

                        if (res.success) {
                            showMsg('Password updated successfully!', 'success', 'bi-check-circle');
                            $('#currentPwd, #newPwd, #confirmPwd').val('');
                            checkStrength('');
                            setTimeout(function () {
                                window.location.href = '@Url.Action("Profile", "Buyer")';
                            }, 1500);
                        } else {
                            showMsg(res.message || 'Incorrect current password.', 'error', 'bi-exclamation-circle');
                            $('#currentPwd').addClass('is-error');
                        }
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false)
                           .html('<i class="bi bi-shield-check"></i> Update Password');
                        var msg = (xhr.responseJSON && xhr.responseJSON.message)
                                  ? xhr.responseJSON.message : 'Server error. Please try again.';
                        showMsg(msg, 'error', 'bi-exclamation-circle');
                    }
                });
            });
        });
    </script>
}
