<!-- ══════════════════════════════════════════════ SCRIPTS -->
<script>
  /* ═══════════════════════════════════════════════════════════
     FLOATING NAV BEHAVIOR
  ═══════════════════════════════════════════════════════════ */
  document.addEventListener("DOMContentLoaded", function() {
      var nav = document.getElementById('floatingNav');
      var trigger = document.getElementById('floatingNavTrigger');
      var panel = document.getElementById('floatingNavPanel');
      var links = Array.prototype.slice.call(document.querySelectorAll('[data-nav-link]'));
      var defaultLink = links[0];
      var closeTimer = null;
      var isOpen = false;

      if (!nav || !trigger || !panel) return;

      function clearCloseTimer() {
          if (closeTimer) { window.clearTimeout(closeTimer); closeTimer = null; }
      }
      function setActive(link) {
          links.forEach(function (item) { item.classList.toggle('is-active', item === link); });
      }
      function openNav() {
          clearCloseTimer();
          if (isOpen) return;
          isOpen = true;
          nav.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
      }
      function closeNav() {
          clearCloseTimer();
          if (!isOpen) return;
          isOpen = false;
          nav.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
          if (defaultLink) setActive(defaultLink);
      }
      function scheduleClose() {
          clearCloseTimer();
          closeTimer = window.setTimeout(closeNav, 120);
      }

      trigger.addEventListener('mouseenter', openNav);
      trigger.addEventListener('focus', openNav);
      trigger.addEventListener('click', function () { if (isOpen) closeNav(); else openNav(); });

      nav.addEventListener('mouseenter', clearCloseTimer);
      nav.addEventListener('mouseleave', scheduleClose);
      panel.addEventListener('focusin', openNav);
      nav.addEventListener('focusout', function (event) { if (!nav.contains(event.relatedTarget)) scheduleClose(); });

      links.forEach(function (link) {
          link.addEventListener('mouseenter', function () { setActive(link); });
          link.addEventListener('focus', function () { setActive(link); openNav(); });
          link.addEventListener('click', closeNav);
      });

      document.addEventListener('click', function (event) { if (!nav.contains(event.target)) closeNav(); });
      document.addEventListener('keydown', function (event) { if (event.key === 'Escape') closeNav(); });
  });

  /* ═══════════════════════════════════════════════════════════
     CONFIG — ApiBaseUrl is injected from BuyerController via ViewData
     Same pattern used in ArtworkDetail.cshtml
  ═══════════════════════════════════════════════════════════ */
 const API_BASE = 'http://localhost:5183';

  /* ═══════════════════════════════════════════════════════════
     IMAGE HELPER — resolves relative paths from DB the same
     way ArtworkDetail.cshtml does.
  ═══════════════════════════════════════════════════════════ */
  function imageUrl(path) {
    if (!path) return 'https://images.unsplash.com/photo-1547891654-e66ed7ebb968?w=600&q=80';
    if (/^https?:\/\//i.test(path)) return path;
    // Strip leading slash so we can safely join
    var clean = path.replace(/^\/+/, '');
    return API_BASE.replace(/\/+$/, '') + '/' + clean;
  }

  /* ═══════════════════════════════════════════════════════════
     HERO BACKGROUND
     Called immediately with placeholders so the animated
     columns are visible right away (no API wait).
     Called again after API loads to swap in real artwork imgs.
  ═══════════════════════════════════════════════════════════ */
  var PLACEHOLDERS = [
    'https://images.unsplash.com/photo-1547891654-e66ed7ebb968?w=600&q=80',
    'https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=600&q=80',
    'https://images.unsplash.com/photo-1501472312651-726afe119ff1?w=600&q=80',
    'https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=600&q=80',
    'https://images.unsplash.com/photo-1518998053901-5348d3961a04?w=600&q=80',
    'https://images.unsplash.com/photo-1508700115892-45ecd05ae2ad?w=600&q=80',
  ];

  function buildHeroBg(artworks) {
    var heroBg = document.getElementById('heroBg');
    heroBg.innerHTML = '';

    // Use real artwork images if available, pad with placeholders
    var imgs = (artworks || []).slice(0, 12).map(function(a) {
      return imageUrl(a.previewPath || a.originalPath);
    });
    while (imgs.length < 12) imgs = imgs.concat(PLACEHOLDERS);

    var dirs = ['up','down','up','down','up'];
    var durs = ['35s','45s','50s','40s','55s'];
    dirs.forEach(function(dir, ci) {
      var col = document.createElement('div');
      col.className = 'art-col';
      var inner = document.createElement('div');
      inner.className = 'art-col-inner ' + dir;
      // ── CRITICAL: set CSS variable --dur AND animationDuration ──
      inner.style.setProperty('--dur', durs[ci]);
      inner.style.animationDuration = durs[ci];
      inner.style.animationDelay = '-' + (Math.random() * 50).toFixed(1) + 's';
      // Duplicate images so the marquee loops seamlessly
      var colImgs = imgs.concat(imgs);
      colImgs.forEach(function(src) {
        var img = document.createElement('img');
        img.src = src; img.alt = ''; img.loading = 'lazy';
        inner.appendChild(img);
      });
      col.appendChild(inner);
      heroBg.appendChild(col);
    });
  }

  // ── Build hero immediately with placeholders (no API wait) ──
  buildHeroBg([]);

  /* ═══════════════════════════════════════════════════════════
     PARTICLES
  ═══════════════════════════════════════════════════════════ */
  (function buildParticles() {
    var pc = document.getElementById('particles');
    for (var i = 0; i < 22; i++) {
      var p = document.createElement('div');
      p.className = 'particle';
      p.style.cssText = 'top:'+(i*53%100)+'%;left:'+(i*37%100)+'%;animation-delay:'+(i*.4)+'s;animation-duration:'+(5+(i%4))+'s;pointer-events:none;';
      pc.appendChild(p);
    }
  })();

  /* ═══════════════════════════════════════════════════════════
     MARQUEE (Discover section)
     Renders all artworks as cards that link to ArtworkDetail
  ═══════════════════════════════════════════════════════════ */
  function buildMarquee(artworks) {
    var track = document.getElementById('marqueeTrack');
    var skeleton = document.getElementById('marqueeSkeleton');
    track.innerHTML = '';

    if (!artworks.length) {
      skeleton.style.display = 'none';
      track.style.display = 'flex';
      track.innerHTML = '<div style="padding:2rem;color:var(--text-muted);">No artworks yet.</div>';
      return;
    }

    // Duplicate for seamless loop
    var doubled = [...artworks, ...artworks];
    doubled.forEach(function(a, idx) {
      var id = a.artworkId || a.c_artwork_id || idx;
      var title = a.title || a.c_title || 'Untitled';
      var artist = a.artistName || a.c_artist_name || 'Unknown Artist';
      var img = imageUrl(a.previewPath || a.originalPath || a.c_preview_path || a.c_original_path);

      track.innerHTML += `
        <a class="art-card" data-id="${id}" href="/Buyer/ArtworkDetail/${id}">
          <img src="${img}" alt="${escapeHtml(title)}" loading="lazy" />
          <div class="art-card-overlay"></div>
          <div class="artwork-top-actions">
            <button class="action-btn" title="Like" onclick="event.preventDefault(); toggleLike(this, ${id})">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>
          <div class="art-card-info">
            <div class="art-card-title">${escapeHtml(title)}</div>
            <div class="art-card-artist">by ${escapeHtml(artist)}</div>
          </div>
        </a>`;
    });

    skeleton.style.display = 'none';
    track.style.display = '';
  }

  /* ═══════════════════════════════════════════════════════════
     TRENDING DROPS
     Shows top 8 by sell_count (desc), then likes_count as tiebreaker.
     Each card links to ArtworkDetail.
  ═══════════════════════════════════════════════════════════ */
  function buildTrending(artworks) {
    var grid = document.getElementById('trendGrid');
    var skeleton = document.getElementById('trendSkeleton');
    grid.innerHTML = '';

    // Sort by sellCount desc, likesCount desc
    var sorted = artworks.slice().sort(function(a, b) {
      var sellA = a.sellCount || a.c_sell_count || 0;
      var sellB = b.sellCount || b.c_sell_count || 0;
      if (sellB !== sellA) return sellB - sellA;
      var likeA = a.likesCount || a.c_likes_count || 0;
      var likeB = b.likesCount || b.c_likes_count || 0;
      return likeB - likeA;
    });

    var top8 = sorted.slice(0, 8);

    if (!top8.length) {
      grid.innerHTML = '<div class="empty-state"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h18v18H3z"/><path d="M9 9h6v6H9z"/></svg><p>No artworks available yet.</p></div>';
      skeleton.style.display = 'none';
      grid.style.display = 'grid';
      return;
    }

    top8.forEach(function(a) {
      var id     = a.artworkId     || a.c_artwork_id  || 0;
      var title  = a.title         || a.c_title        || 'Untitled';
      var artist = a.artistName    || a.c_artist_name  || 'Unknown Artist';
      var price  = parseFloat(a.price || a.c_price || 0);
      var img    = imageUrl(a.previewPath || a.originalPath || a.c_preview_path || a.c_original_path);
      var priceStr = price > 0 ? '₹' + price.toLocaleString('en-IN') : 'Price on request';

      grid.innerHTML += `
        <div class="trend-card" data-id="${id}">
          <div class="trend-img" onclick="window.location='/Buyer/ArtworkDetail/${id}'">
            <img src="${img}" alt="${escapeHtml(title)}" loading="lazy"/>
            <div class="artwork-top-actions">
              <button class="action-btn" title="Like" onclick="event.stopPropagation(); toggleLike(this, ${id})">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="trend-body">
            <div class="trend-title" title="${escapeHtml(title)}">${escapeHtml(title)}</div>
            <div class="trend-artist">by ${escapeHtml(artist)}</div>
            <div class="artwork-card-actions">
              <button class="pixel-btn" onclick="addToCart(this, ${id})">
                <span class="btn-text-add">Add to Cart</span>
                <span class="btn-cart-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                  </svg>
                </span>
                <span class="btn-text-done">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  In Cart
                </span>
              </button>
              <button class="action-btn" title="Wishlist" onclick="toggleWishlist(this, ${id})">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                </svg>
              </button>
            </div>
            <div class="trend-price-row">
              <span class="trend-price-lbl">Price</span>
              <span class="trend-price-val">${escapeHtml(priceStr)}</span>
            </div>
          </div>
        </div>`;
    });

    skeleton.style.display = 'none';
    grid.style.display = 'grid';
  }

  /* ═══════════════════════════════════════════════════════════
     MAIN: fetch all approved artworks from GET /api/artwork
     API response shape: { success: true, count: N, data: [...] }
     Each artwork has: artworkId, title, artistName, categoryName,
       price, description, previewPath, originalPath,
       likesCount, sellCount, createdAt, approvalStatus
  ═══════════════════════════════════════════════════════════ */
  async function loadArtworks() {
    try {
      var token = document.cookie.split('; ').find(r => r.startsWith('token='));
      var headers = { 'Content-Type': 'application/json' };
      if (token) headers['Authorization'] = 'Bearer ' + token.split('=')[1];

      var res = await fetch(API_BASE.replace(/\/+$/, '') + '/api/artwork', { headers: headers });

      if (!res.ok) throw new Error('API responded with ' + res.status);

      var json = await res.json();
      // Handle { success, count, data: [...] } shape
      var artworks = Array.isArray(json) ? json
                   : (json.data && Array.isArray(json.data)) ? json.data
                   : [];

      // Update hero stats counter
      var statEl = document.getElementById('statArtworks');
      if (statEl) statEl.textContent = artworks.length >= 1000
        ? (artworks.length / 1000).toFixed(1) + 'k+'
        : artworks.length + '+';

      buildHeroBg(artworks);
      buildMarquee(artworks);
      buildTrending(artworks);
      restoreUIStates();

    } catch (err) {
      console.error('Failed to load artworks:', err);

      // Hide skeletons and show a graceful error in trending
      document.getElementById('marqueeSkeleton').style.display = 'none';
      document.getElementById('marqueeTrack').style.display = '';
      document.getElementById('marqueeTrack').innerHTML =
        '<div style="padding:2rem 1.5rem;color:var(--text-muted);font-size:.88rem;">Could not load artworks. Please try again later.</div>';

      document.getElementById('trendSkeleton').style.display = 'none';
      var trendGrid = document.getElementById('trendGrid');
      trendGrid.style.display = 'grid';
      trendGrid.innerHTML = '<div class="empty-state"><p>Could not load artworks. Please try again later.</p></div>';

      // Still build hero bg with placeholders
      buildHeroBg([]);
    }
  }

  /* ═══════════════════════════════════════════════════════════
     STORAGE HELPERS (localStorage — same keys as before)
  ═══════════════════════════════════════════════════════════ */
  function getStorage(key) {
    try { var d = localStorage.getItem(key); return d ? JSON.parse(d) : []; }
    catch(e) { return []; }
  }

  // updateBadges is now handled globally via globalBadges.js

  function restoreUIStates() {
    var cart     = getStorage('artify_cart');
    var wishlist = getStorage('artify_wishlist');
    var likes    = getStorage('artify_likes');

    document.querySelectorAll('.pixel-btn').forEach(function(btn) {
      var card = btn.closest('[data-id]');
      if (card && cart.includes(card.getAttribute('data-id').toString())) {
        btn.classList.add('animating');
      }
    });

    document.querySelectorAll('.action-btn').forEach(function(btn) {
      var card = btn.closest('[data-id]');
      if (!card) return;
      var id = card.getAttribute('data-id').toString();
      var icon = btn.querySelector('svg');
      if (btn.getAttribute('title') === 'Like' && likes.includes(id)) {
        btn.classList.add('liked');
        if (icon) icon.style.fill = '#ff4757';
      } else if (btn.getAttribute('title') === 'Wishlist' && wishlist.includes(id)) {
        btn.classList.add('wished');
        if (icon) icon.style.fill = '#EDA312';
      }
    });

    updateBadges();
  }

  /* ═══════════════════════════════════════════════════════════
     INTERACTIONS
  ═══════════════════════════════════════════════════════════ */
  function toggleLike(btn, id) {
    var likes = getStorage('artify_likes');
    var idx = likes.indexOf(id.toString());
    var icon = btn.querySelector('svg');
    if (idx === -1) {
      likes.push(id.toString());
      btn.classList.add('liked');
      if (icon) icon.style.fill = '#ff4757';
    } else {
      likes.splice(idx, 1);
      btn.classList.remove('liked');
      if (icon) icon.style.fill = 'none';
    }
    localStorage.setItem('artify_likes', JSON.stringify(likes));
  }

  function toggleWishlist(btn, id) {
    var wishlist = getStorage('artify_wishlist');
    var idx = wishlist.indexOf(id.toString());
    var icon = btn.querySelector('svg');
    if (idx === -1) {
      wishlist.push(id.toString());
      btn.classList.add('wished');
      if (icon) icon.style.fill = '#EDA312';
    } else {
      wishlist.splice(idx, 1);
      btn.classList.remove('wished');
      if (icon) icon.style.fill = 'none';
    }
    localStorage.setItem('artify_wishlist', JSON.stringify(wishlist));
    updateBadges();
  }

  function addToCart(btn, id) {
    if (btn && !btn.classList.contains('animating')) {
      btn.classList.add('animating');
    }
    var cart = getStorage('artify_cart');
    if (!cart.includes(id.toString())) {
      cart.push(id.toString());
      localStorage.setItem('artify_cart', JSON.stringify(cart));
      updateBadges();
    }
  }

  /* ── Security helper ─────────────────────────────────────── */
  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  /* ── Boot ────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function() {
    // updateBadges(); // handled by globalBadges.js
    loadArtworks();
  });
</script>
<script src="/js/globalBadges.js"></script>
</body>
</html>
