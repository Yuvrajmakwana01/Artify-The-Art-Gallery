@{
    Layout = null;
    ViewData["Title"] = "Artify — A New Era of Digital Art";
    var apiBase = ViewData["ApiBaseUrl"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ── COLOR PALETTE ─────────────────────────────────────── */  
    :root {
      --bg:          #DFE6E9;
      --text:        #1a1a1a;
      --text-muted:  #636e72;
      --btn:         #03289F;
      --btn-fg:      #ffffff;
      --heading:     #6B9BE6;
      --accent:      #EDA312;
      --border:      rgba(3,40,159,.08);
      --card-bg:     rgba(255,255,255,.85);
      --card-shadow: 0 15px 45px rgba(3,40,159,.06);
      --glow:        0 0 40px rgba(107,155,230,.2);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* ── ANIMATIONS ────────────────────────────────────────── */
    @@keyframes marqueeUp   { from { transform: translateY(0); }   to { transform: translateY(-50%); } }
    @@keyframes marqueeDown { from { transform: translateY(-50%); } to { transform: translateY(0); } }
    @@keyframes fadeUp      { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes blobDrift   {
      0%, 100% { transform: translate(0,0) scale(1); }
      33%       { transform: translate(30px,-30px) scale(1.05); }
      66%       { transform: translate(-20px,20px) scale(0.95); }
    }
    @@keyframes marqueeX    { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @@keyframes floatUp     { 0%,100% { transform: translateY(0); opacity:.7; } 50% { transform: translateY(-12px); opacity:1; } }
    @@keyframes shimmer     { 0% { background-position: -400px 0; } 100% { background-position: 400px 0; } }

    /* ── UTILITY ───────────────────────────────────────────── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
    h1,h2,h3,h4 { font-family: 'Playfair Display', serif; }

    /* ── SKELETON LOADER ───────────────────────────────────── */
    .skeleton {
      background: linear-gradient(90deg, rgba(255,255,255,.3) 25%, rgba(255,255,255,.6) 50%, rgba(255,255,255,.3) 75%);
      background-size: 400px 100%;
      animation: shimmer 1.4s ease-in-out infinite;
      border-radius: 8px;
    }
    .skeleton-card {
      flex-shrink: 0; width: 250px; height: 320px;
      border-radius: 20px; overflow: hidden;
      border: 1px solid var(--border);
    }
    .skeleton-trend {
      border-radius: 18px; overflow: hidden;
      border: 1px solid var(--border); background: var(--card-bg);
    }
    .skeleton-trend-img { aspect-ratio: 3/4; }
    .skeleton-trend-body { padding: 1.25rem 1rem; }
    .skeleton-line { height: 14px; border-radius: 4px; margin-bottom: 8px; }

    /* ─────────────────────────────────────────────────────── */
    /* NAVBAR (Floating)                                       */
    /* ─────────────────────────────────────────────────────── */
    .floating-nav {
        position: fixed;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 220;
        width: min(92vw, 860px);
        display: grid;
        place-items: center;
        pointer-events: none;
    }
    .floating-nav-trigger,
    .floating-nav-panel {
        grid-area: 1 / 1;
    }
    .floating-nav-trigger,
    .floating-nav-panel,
    .floating-nav-logo,
    .floating-nav-link,
    .floating-nav-toggle,
    .nav-icon-btn {
        pointer-events: auto;
    }
    .floating-nav-trigger {
        border: none;
        border-radius: 18px;
        min-width: 150px;
        min-height: 58px;
        padding: 0 30px;
        background: #111111;
        color: #ffffff;
        font-family: 'DM Sans', sans-serif;
        font-size: 24px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 18px 40px rgba(0, 0, 0, .22);
        transition: opacity .28s ease, transform .34s cubic-bezier(.16, 1, .3, 1), box-shadow .25s ease;
    }
    .floating-nav-trigger:hover { box-shadow: 0 22px 48px rgba(0, 0, 0, .28); }
    .floating-nav.is-open .floating-nav-trigger {
        opacity: 0;
        transform: translateY(10px) scale(.88);
        pointer-events: none;
    }
    .floating-nav-panel {
        width: 100%;
        display: grid;
        grid-template-columns: 68px minmax(0, 1fr) 68px;
        align-items: center;
        gap: 18px;
        opacity: 0;
        transform: translateY(10px) scale(.96);
        transform-origin: bottom center;
        transition: opacity .32s ease, transform .42s cubic-bezier(.16, 1, .3, 1);
        pointer-events: none;
    }
    .floating-nav.is-open .floating-nav-panel {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }
    .floating-nav-logo {
        width: 68px;
        height: 68px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        filter: drop-shadow(0 18px 34px rgba(0, 0, 0, .18));
        overflow: hidden; 
        border-radius: 25%; 
        background: #0b0c10;
    }
    .floating-nav-logo img {
        width: 68px;
        height: 68px;
        display: block;
        object-fit: cover;
        transform: scale(2.65) translateX(3%);
    }
    .floating-nav-links {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 20px;
        background: rgba(246, 247, 249, .96);
        border: 1px solid rgba(17, 17, 17, .05);
        box-shadow: 0 18px 40px rgba(15, 23, 42, .14);
        backdrop-filter: blur(16px);
    }
    .floating-nav-link {
        flex: 0 0 auto;
        padding: 13px 22px;
        border-radius: 999px;
        color: #151515;
        font-size: 15px;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
        transition: background .22s ease, color .22s ease, transform .22s ease;
    }
    .floating-nav-link.is-active,
    .floating-nav-link:hover,
    .floating-nav-link:focus-visible {
        background: #111111;
        color: #ffffff;
    }
    .floating-nav-logo:focus-visible,
    .floating-nav-trigger:focus-visible,
    .floating-nav-link:focus-visible {
        outline: 2px solid var(--subhead);
        outline-offset: 4px;
    }
    .floating-nav-toggle {
        position: relative;
        width: 68px;
        height: 68px;
        border: none;
        border-radius: 18px;
        background: #111111;
        box-shadow: 0 18px 34px rgba(0, 0, 0, .18);
        cursor: default;
    }
    .floating-nav-toggle::before,
    .floating-nav-toggle::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        transform: translateY(-50%);
    }
    .floating-nav-toggle::before {
        left: 21px;
        background: rgba(221, 214, 204, .42);
    }
    .floating-nav-toggle::after {
        left: 31px;
        background: #ffffff;
    }
    .nav-actions { display: flex; align-items: center; gap: 6px; margin-left: auto; }
    .nav-icon-btn {
      position: relative; display: grid; place-items: center;
      height: 40px; width: 40px; border-radius: 50%;
      border: 1.5px solid var(--border);
      background: rgba(255,255,255,.5); cursor: pointer;
      color: var(--text); transition: background .2s, border-color .2s, transform .2s;
      text-decoration: none;
    }
    .nav-icon-btn:hover { background: #111111; color: #ffffff; border-color: #111111; transform: scale(1.08); }
    .nav-badge {
      position: absolute; top: -4px; right: -4px;
      height: 16px; min-width: 16px; padding: 0 3px;
      background: var(--heading); color: #fff; border-radius: 999px;
      font-size: .62rem; font-weight: 700; display: grid; place-items: center;
    }
    @@media(max-width:950px) {
        .floating-nav-links {
            justify-content: flex-start;
            overflow-x: auto;
            padding: 8px;
            gap: 6px;
            scrollbar-width: none;
        }
        .floating-nav-links::-webkit-scrollbar { display: none; }
        .floating-nav-link { padding: 11px 16px; font-size: 13px; }
    }
    .nav-signin { font-size: .88rem; color: var(--text); text-decoration: none; opacity: .8; transition: opacity .2s, color .2s; }
    .nav-signin:hover { opacity: 1; color: var(--heading); }
    @@media(max-width:768px) { nav { padding: 1rem 1.25rem; } .nav-links { display: none; } }

    /* ─────────────────────────────────────────────────────── */
    /* HERO                                                    */
    /* ─────────────────────────────────────────────────────── */
    .hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center;
      padding: 0 4rem; overflow: hidden;
    }
    @@media(max-width:768px){ .hero { padding: 2rem 1.25rem; } }

    .hero-bg {
      position: absolute; inset: 0; pointer-events: none;
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; padding: 12px;
      overflow: hidden;
    }
    .art-col { overflow: hidden; position: relative; height: 100%; }
    .art-col-inner { display: flex; flex-direction: column; gap: 12px; }
    .art-col-inner.up   { animation: marqueeUp   var(--dur) linear infinite; }
    .art-col-inner.down { animation: marqueeDown var(--dur) linear infinite; }
    .art-col-inner img { width: 100%; height: 220px; object-fit: cover; border-radius: 14px; }

    .hero-overlay-lr {
      position: absolute; inset: 0; pointer-events: none;
      background: linear-gradient(to right, var(--bg) 22%, rgba(222,230,233,.65) 55%, rgba(222,230,233,.2) 100%);
    }
    .hero-overlay-tb {
      position: absolute; inset: 0; pointer-events: none;
      background: linear-gradient(to bottom, rgba(222,230,233,.5) 0%, transparent 30%, transparent 70%, var(--bg) 100%);
    }
    .orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; animation: blobDrift 14s ease-in-out infinite; }
    .orb1 { width:320px; height:320px; background:rgba(237,163,18,.18); top:15%; left:30%; }
    .orb2 { width:400px; height:400px; background:rgba(107,155,230,.15); bottom:15%; right:20%; animation-delay:-6s; }
    .particle { position: absolute; width:7px; height:7px; border-radius:50%; background: rgba(237,163,18,.6); animation: floatUp 5s ease-in-out infinite; }

    .hero-content { position: relative; z-index: 10; max-width: 680px; animation: fadeUp .9s ease both; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      border: 1px solid rgba(237,163,18,.45); background: rgba(255,255,255,.4);
      backdrop-filter: blur(8px); border-radius: 999px;
      padding: .45rem 1.1rem; font-size: .72rem; letter-spacing: .18em;
      text-transform: uppercase; color: var(--heading); font-weight: 600;
    }
    .hero-title { margin-top: 1.4rem; font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 900; line-height: 1; color: var(--text); letter-spacing: -0.02em; }
    .hero-title .accent { color: var(--accent); }
    .hero-desc { margin-top: 1.4rem; max-width: 500px; font-size: 1.05rem; line-height: 1.7; color: rgba(3,40,159,.7); }
    .hero-btns { margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: 1rem; }
    .btn-primary {
      display: inline-block; padding: .9rem 2.2rem; border-radius: 999px;
      background: var(--btn); color: var(--btn-fg); font-size: .92rem; font-weight: 600;
      text-decoration: none; border: 2px solid var(--btn);
      box-shadow: var(--glow); transition: transform .25s, box-shadow .25s;
    }
    .btn-primary:hover { transform: scale(1.05); box-shadow: 0 0 80px rgba(237,163,18,.5); }
    .btn-secondary {
      display: inline-block; padding: .9rem 2.2rem; border-radius: 999px;
      border: 2px solid rgba(3,40,159,.3); background: rgba(255,255,255,.35);
      backdrop-filter: blur(8px); color: var(--text); font-size: .92rem; font-weight: 600;
      text-decoration: none; transition: border-color .25s, color .25s, transform .25s;
    }
    .btn-secondary:hover { border-color: var(--heading); color: var(--heading); transform: scale(1.05); }

    .hero-stats { margin-top: 3.5rem; display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; max-width: 420px; }
    .stat-card {
      border-radius: 18px; border: 1px solid var(--border);
      background: rgba(255,255,255,.5); backdrop-filter: blur(10px);
      padding: 1.4rem 1rem; box-shadow: var(--card-shadow);
    }
    .stat-val { font-size: 1.9rem; font-weight: 900; color: var(--heading); font-family: 'Playfair Display', serif; }
    .stat-lbl { margin-top: .2rem; font-size: .7rem; letter-spacing: .18em; text-transform: uppercase; color: rgba(3,40,159,.5); }

    /* ─────────────────────────────────────────────────────── */
    /* MARQUEE DISCOVER                                        */
    /* ─────────────────────────────────────────────────────── */
    .section-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: #6B9BE6;
      font-weight: 400;
    }
    .section-title {
      margin-top: 10px;
      font-size: clamp(28px, 4vw, 44px);
      color: #EDA312;
      font-weight: 700;
      font-family: 'Playfair Display', serif;
    }

    .discover { padding: 5rem 0; overflow: hidden; }
    .discover-header { display: flex; align-items: flex-end; justify-content: space-between; padding: 0 4rem 2.5rem; }
    @@media(max-width:768px){ .discover-header { padding: 0 1.25rem 2rem; } }
    .discover-header a { font-size: .88rem; color: var(--text-muted); text-decoration: none; transition: color .2s; }
    .discover-header a:hover { color: var(--heading); }

    .marquee-wrap { position: relative; }
    .marquee-fade-l { position:absolute; inset-y:0; left:0; width:8rem; background:linear-gradient(to right, var(--bg), transparent); z-index:10; pointer-events:none; }
    .marquee-fade-r { position:absolute; inset-y:0; right:0; width:8rem; background:linear-gradient(to left, var(--bg), transparent); z-index:10; pointer-events:none; }
    .marquee-track {
      display: flex; gap: 1.25rem; padding: 0 1.5rem;
      width: max-content;
      animation: marqueeX 40s linear infinite;
    }
    .marquee-track:hover { animation-play-state: paused; }

    .art-card {
      position: relative; flex-shrink: 0; width: 250px; height: 320px;
      border-radius: 20px; overflow: hidden;
      border: 1px solid var(--border); background: var(--card-bg);
      box-shadow: var(--card-shadow); cursor: pointer;
      transition: transform .3s, box-shadow .3s; text-decoration: none; display: block;
    }
    .art-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(3,40,159,.2); }
    .art-card img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s; }
    .art-card:hover img { transform: scale(1.08); }
    .art-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(3,40,159,.75) 0%, transparent 55%); }
    .artwork-top-actions { position: absolute; top: .75rem; left: .75rem; opacity: 1; transform: none; z-index: 10; }
    .artwork-card-actions {
      display: flex; justify-content: space-between; align-items: center;
      gap: .6rem; margin: .8rem 0 0; opacity: 1; transform: none;
    }
    .art-card-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 1.25rem 1rem; z-index: 5; }
    .art-card-title { font-size: .95rem; font-weight: 600; color: #fff; text-shadow: 0 2px 4px rgba(0,0,0,0.3); }
    .art-card-artist { font-size: .78rem; color: rgba(255,255,255,.85); margin-top: .2rem; }

    /* ─────────────────────────────────────────────────────── */
    /* TRENDING DROPS                                          */
    /* ─────────────────────────────────────────────────────── */
    .trending { padding: 5rem 4rem; }
    @@media(max-width:768px){ .trending { padding: 4rem 1.25rem; } }
    .trending-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 3rem; }
    .trending-header a { font-size: .88rem; color: var(--text-muted); text-decoration: none; }
    .trending-header a:hover { color: var(--heading); }
    .trending-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.25rem; }
    @@media(max-width:900px){ .trending-grid { grid-template-columns: repeat(2,1fr); } }
    @@media(max-width:480px){ .trending-grid { grid-template-columns: 1fr; } }

    .trend-card {
      border-radius: 18px; overflow: hidden;
      border: 1px solid var(--border); background: var(--card-bg);
      box-shadow: var(--card-shadow); transition: border-color .3s, box-shadow .3s, transform .3s;
      position: relative; cursor: pointer;
    }
    .trend-card:hover { border-color: rgba(237,163,18,.5); box-shadow: var(--glow); transform: translateY(-4px); }
    .trend-img { aspect-ratio: 3/4; overflow: hidden; position: relative; }
    .trend-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s; display: block; }
    .trend-card:hover .trend-img img { transform: scale(1.08); }
    .trend-body { padding: 1.25rem 1rem; }
    .trend-title { font-size: .95rem; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .trend-artist { font-size: .78rem; color: var(--text-muted); margin-top: .1rem; }
    .trend-price-row {
      margin-top: .75rem; border-top: 1px solid rgba(0,0,0,0.05); padding-top: .75rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .trend-price-lbl { font-size: .68rem; letter-spacing: .15em; text-transform: uppercase; color: rgba(3,40,159,.45); font-weight: 600; }
    .trend-price-val { font-size: 1rem; font-weight: 700; color: var(--heading); }

    /* ── BUTTONS ───────────────────────────────────────────── */
    .pixel-btn {
      position: relative; width: 100%; height: 42px; border-radius: 12px;
      background: var(--btn); color: #fff; border: none; cursor: pointer;
      font-size: .85rem; font-weight: 600; font-family: 'Inter', sans-serif;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      overflow: hidden; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 25px rgba(3,40,159,0.15);
    }
    .pixel-btn span { position: absolute; transition: transform 0.5s ease, opacity 0.3s ease; display: flex; align-items: center; gap: 8px; }
    .btn-cart-icon { transform: translateX(-120%); opacity: 0; }
    .btn-text-done { transform: translateY(100%); opacity: 0; }
    .pixel-btn.animating { background: #22c55e; box-shadow: 0 8px 25px rgba(34,197,94,0.25); pointer-events: none; }
    .pixel-btn.animating .btn-text-add { transform: translateY(-100%); opacity: 0; }
    .pixel-btn.animating .btn-cart-icon { animation: cartDrive 1.2s forwards; opacity: 1; }
    .pixel-btn.animating .btn-text-done { animation: fadeDone 0.4s 1s forwards; }
    @@keyframes cartDrive { 0% { transform: translateX(-120%); } 30% { transform: translateX(0); } 70% { transform: translateX(0); } 100% { transform: translateX(120%); opacity: 0; } }
    @@keyframes fadeDone  { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .action-btn {
      width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,1); border: 1px solid var(--border); cursor: pointer;
      color: var(--text); transition: all .25s; box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .action-btn.liked  { color: #ff4757; border-color: #ff4757; background: rgba(255,71,87,0.1); }
    .action-btn.wished { color: var(--accent); border-color: var(--accent); background: rgba(237,163,18,0.1); }
    .action-btn.liked:hover  { background: #ff4757; color: #fff; }
    .action-btn.wished:hover { background: var(--accent); color: #fff; }
    .action-btn svg { width: 18px; height: 18px; transition: fill 0.3s ease; }

    /* ─────────────────────────────────────────────────────── */
    /* CTA                                                     */
    /* ─────────────────────────────────────────────────────── */
    .cta-wrap { padding: 5rem 4rem; }
    @@media(max-width:768px){ .cta-wrap { padding: 4rem 1.25rem; } }
    .cta-box {
      max-width: 900px;
      margin: 0 auto;
      border-radius: 36px;
      padding: 72px 56px;
      text-align: center;
      background: #03289F;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 80px rgba(3, 40, 159, .35);
      transition: all .4s;
    }
    .cta-box:hover { transform: translateY(-4px); }
    .cta-orb1 { position:absolute; width:280px; height:280px; border-radius:50%; background:rgba(237,163,18,.20); filter:blur(60px); top:-80px; right:-80px; pointer-events:none; }
    .cta-orb2 { position:absolute; width:220px; height:220px; border-radius:50%; background:rgba(107,155,230,.20); filter:blur(60px); bottom:-80px; left:-80px; pointer-events:none; }
    .cta-title {
      font-size: clamp(32px, 4vw, 52px);
      color: #ffffff;
      margin-bottom: 16px;
      position: relative;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
    }
    .cta-title .accent { color: inherit; }
    .cta-desc {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      color: rgba(255,255,255,.80);
      max-width: 500px;
      margin: 0 auto 40px;
      position: relative;
    }
    .cta-btns { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; position: relative; z-index: 2; }

    /* ─────────────────────────────────────────────────────── */
    /* FOOTER                                                  */
    /* ─────────────────────────────────────────────────────── */
    footer { margin-top: 88px; padding: 80px 64px 32px; background: #03289F; color: rgba(255, 255, 255, .7); }
    @@media(max-width:768px){ footer { padding: 3rem 1.25rem 2rem; } }
    .footer-grid { display: grid; grid-template-columns: 2fr repeat(3,1fr); gap: 2.5rem; }
    @@media(max-width:900px){ .footer-grid { grid-template-columns: 1fr 1fr; } }
    @@media(max-width:480px){ .footer-grid { grid-template-columns: 1fr; } }
    .footer-brand-desc { margin-top: 1rem; font-size: .85rem; color: rgba(255, 255, 255, .7); line-height: 1.7; max-width: 300px; }
    .footer-social { margin-top: 1.5rem; display: flex; gap: .65rem; }
    .footer-social a { width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; color: #fff; text-decoration: none; transition: border-color .2s, color .2s; }
    .footer-social a:hover { border-color: #EDA312; color: #EDA312; }
    .footer-col-title { font-size: .72rem; letter-spacing: .2em; text-transform: uppercase; color: #EDA312; font-weight: 600; }
    .footer-col ul { margin-top: 1.1rem; list-style: none; display: flex; flex-direction: column; gap: .65rem; }
    .footer-col ul a { text-decoration: none; font-size: .86rem; color: rgba(255,255,255,0.7); transition: color .2s; }
    .footer-col ul a:hover { color: #fff; }
    .footer-bottom { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.15); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; font-size: .78rem; color: rgba(255,255,255,.5); }
    .footer-bottom-links { display: flex; gap: 1.5rem; }
    .footer-bottom-links a { color: rgba(255,255,255,.5); text-decoration: none; transition: color .2s; }
    .footer-bottom-links a:hover { color: var(--heading); }
    .icon { display: inline-block; vertical-align: middle; }

    /* ── Empty state ───────────────────────────────────────── */
    .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-muted); grid-column: 1/-1; }
    .empty-state svg { opacity: .3; margin-bottom: 1rem; }
  </style>
</head>
