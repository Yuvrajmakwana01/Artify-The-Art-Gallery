        <div class="item-divider"></div>

        <!-- Artwork 2 -->
        <div class="artwork-item">
            <div class="artwork-thumb">
                <span class="k-icon k-i-image"></span>
            </div>
            <div class="artwork-info">
                <div class="artwork-name">Neon Cascade</div>
                <div class="artwork-artist">by Liam Torres</div>
                <span class="type-badge type-digital">Digital</span>
            </div>
            <div class="artwork-right">
                <span class="artwork-price">$100.00</span>
                <button class="download-btn">
                    <span class="k-icon k-i-download"></span> Download
