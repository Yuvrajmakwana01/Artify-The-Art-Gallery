        <!-- Artwork 1 -->
        <div class="artwork-item">
            <div class="artwork-thumb">
                <span class="k-icon k-i-image"></span>
            </div>
            <div class="artwork-info">
                <div class="artwork-name">Ethereal Bloom</div>
                <div class="artwork-artist">by Maya Chen</div>
