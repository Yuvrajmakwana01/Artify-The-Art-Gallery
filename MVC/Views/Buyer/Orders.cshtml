@{
    ViewBag.Title = "Order History";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --canvas:        #f5f0ea;
        --canvas-2:      #ffffff;
        --canvas-3:      #ede7df;
        --surface:       #faf7f3;
        --border:        rgba(0,0,0,0.06);
        --border-2:      rgba(0,0,0,0.10);
        --gold:          #9a6324;
        --gold-bright:   #c08b3f;
        --gold-light:    #dbb978;
        --gold-dim:      rgba(154,99,36,0.08);
        --gold-ring:     rgba(154,99,36,0.18);
        --text:          #1c1814;
        --text-2:        #5e554a;
        --text-3:        #9e9488;
        --success:       #15803d;
        --success-bg:    rgba(21,128,61,0.08);
        --warning-fg:    #92400e;
        --warning-bg:    rgba(245,158,11,0.08);
        --destructive:   #dc2626;
        --destructive-bg: rgba(220,38,38,0.08);
        --radius-sm:     10px;
        --radius-md:     16px;
        --radius-lg:     24px;
        --radius-xl:     36px;
        --shadow-sm:     0 1px 3px rgba(0,0,0,0.04);
        --shadow-md:     0 4px 16px rgba(0,0,0,0.06), 0 2px 4px rgba(0,0,0,0.03);
        --shadow-lg:     0 12px 40px rgba(0,0,0,0.08);
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--canvas); color: var(--text); }

    .orders-page {
        max-width: 940px; margin: 0 auto; padding: 3rem 2rem 5rem;
        opacity: 0; transform: translateY(20px);
        animation: fadeUp 0.6s cubic-bezier(0.22,1,0.36,1) forwards;
    }
    @@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    /* ── Header ── */
    .orders-header {
        display: flex; justify-content: space-between; align-items: flex-end;
        margin-bottom: 2rem; flex-wrap: wrap; gap: 1.25rem;
    }
    .orders-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem; font-weight: 700; color: var(--text);
        margin: 0; line-height: 1.1;
    }
    .orders-header p { color: var(--text-3); margin: 6px 0 0; font-size: .9rem; }

    .orders-stats { display: flex; gap: 2rem; }
    .orders-stat { text-align: right; }
    .orders-stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem; font-weight: 700;
    }
    .orders-stat-value.total { color: var(--text); }
    .orders-stat-value.spent { color: var(--success); }
    .orders-stat-label { font-size: .7rem; font-weight: 600; color: var(--text-3); letter-spacing: 1px; text-transform: uppercase; margin-top: 2px; }

    /* ── Order Cards ── */
    .order-card {
        background: var(--canvas-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        margin-bottom: 14px;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        text-decoration: none;
        display: block;
        color: inherit;
        position: relative;
    }
    .order-card::before {
        content: ''; position: absolute; left: 0; top: 0; bottom: 0;
        width: 0; background: linear-gradient(180deg, var(--gold-dim), transparent);
        transition: width 0.35s ease; border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    }
    .order-card:hover::before { width: 4px; }
    .order-card:hover {
        box-shadow: var(--shadow-md);
        border-color: rgba(154,99,36,0.2);
        transform: translateY(-3px);
    }
    .order-card-inner { display: flex; align-items: stretch; }

    /* Preview thumbnail column */
    .order-card-preview {
        width: 100px; display: none; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(154,99,36,0.06), rgba(219,185,120,0.08));
        flex-shrink: 0;
    }
    .order-card-preview .preview-icon {
        width: 60px; height: 60px; border-radius: var(--radius-sm);
        background: rgba(255,255,255,0.7);
        display: flex; align-items: center; justify-content: center;
        backdrop-filter: blur(4px); overflow: hidden;
        border: 1px solid var(--border);
    }
    .preview-icon img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-sm); }
    .preview-icon svg { color: var(--text-3); }

    .order-card-content {
        flex: 1; display: flex; align-items: center;
        justify-content: space-between; padding: 22px 24px; gap: 18px; min-width: 0;
    }
    .order-card-info { flex: 1; min-width: 0; }
    .order-id-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 8px; }
    .order-id { font-size: 1rem; font-weight: 700; color: var(--text); letter-spacing: -0.01em; }

    /* Status badges */
    .status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 12px; border-radius: 100px;
        font-size: .72rem; font-weight: 600; border: 1px solid;
        letter-spacing: 0.3px;
    }
    .status-delivered  { background: var(--success-bg); color: var(--success); border-color: rgba(21,128,61,0.15); }
    .status-processing { background: var(--warning-bg); color: var(--warning-fg); border-color: rgba(245,158,11,0.15); }
    .status-failed     { background: var(--destructive-bg); color: var(--destructive); border-color: rgba(220,38,38,0.15); }

    .order-preview-text {
        font-size: .88rem; color: var(--text-2); margin-bottom: 8px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .order-meta { display: flex; align-items: center; gap: 16px; font-size: .76rem; color: var(--text-3); flex-wrap: wrap; }
    .order-meta-item { display: flex; align-items: center; gap: 5px; }

    .order-card-right { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
    .order-total {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.15rem; font-weight: 700; color: var(--text);
        white-space: nowrap;
    }
    .order-chevron {
        color: var(--text-3);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        flex-shrink: 0;
    }
    .order-card:hover .order-chevron { transform: translateX(5px); color: var(--gold); }

    /* Loading */
    .loading-state { text-align: center; padding: 5rem 0; color: var(--text-3); }
    .loading-spinner {
        display: inline-block; width: 40px; height: 40px;
        border: 3px solid var(--border-2); border-top-color: var(--gold-bright);
        border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 18px;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Back link */
    .back-link {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: .85rem; font-weight: 600; color: var(--gold);
        text-decoration: none; transition: all .25s ease;
    }
    .back-link:hover { transform: translateX(-4px); color: var(--gold); }

    /* Empty state */
    .empty-state { text-align: center; padding: 5rem 0; }
    .empty-state svg { color: var(--text-3); opacity: 0.4; margin-bottom: 18px; }
    .empty-text { font-size: 1.1rem; font-weight: 500; color: var(--text-3); }

    @@media (min-width: 640px) { .order-card-preview { display: flex; } }
    @@media (max-width: 640px) {
        .orders-page { padding: 2rem 1rem 4rem; }
        .orders-header h2 { font-size: 1.8rem; }
        .order-card-content { padding: 16px; gap: 10px; }
        .order-card-right { gap: 8px; }
    }
</style>

<div class="orders-page">

    <div class="orders-header">
        <div>
            <a href="@Url.Action("Profile","Buyer")" class="back-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to Profile
            </a>
            <h2 style="margin-top:10px;">Order History</h2>
            <p>Track and manage your artwork purchases</p>
        </div>
        <div class="orders-stats">
            <div class="orders-stat">
                <div class="orders-stat-value total" id="statTotal">—</div>
                <div class="orders-stat-label">Total Orders</div>
            </div>
            <div class="orders-stat">
                <div class="orders-stat-value spent" id="statSpent">—</div>
                <div class="orders-stat-label">Total Spent</div>
            </div>
        </div>
    </div>

    <div id="ordersContent">
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading your orders...</p>
        </div>
    </div>

    <div id="emptyState" class="empty-state" style="display:none;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p class="empty-text" id="emptyText">No orders found</p>
    </div>
</div>

<script>
    // ── CHANGED: consistent 2% platform fee ──
    var PLATFORM_FEE_RATE = 0.02;

    var TOKEN = localStorage.getItem("token");
    if (!TOKEN) { window.location.href = "/Auth/Login"; }

    function formatAmount(n) {
        return '$' + (parseFloat(n) || 0).toLocaleString('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    // ── CHANGED: status badge helper ──
    function statusBadge(status) {
        var s   = (status || 'Processing').toLowerCase();
        var cls = s === 'delivered'  ? 'status-delivered'
                : s === 'failed'     ? 'status-failed'
                :                      'status-processing';
        var dot = s === 'delivered'
            ? '<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>'
            : s === 'failed'
            ? '<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
            : '<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
        return '<span class="status-badge ' + cls + '">' + dot + ' ' + (status || 'Processing') + '</span>';
    }

    // ── CHANGED: buildCard now uses all the CSS already defined ──
    function buildCard(order) {
        var oidStr   = 'ORD-' + String(order.orderId).padStart(8, '0');
        var date     = new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        var itemCount= (order.itemCount || 1) + ' item' + ((order.itemCount || 1) === 1 ? '' : 's');

        // ── CHANGED: grand total = totalAmount stored in DB (already includes fee from payment page) ──
        var grand    = formatAmount(order.totalAmount);

        // Thumbnail
        var thumb = order.firstPreviewPath
            ? '<img src="' + order.firstPreviewPath + '" loading="lazy" />'
            : '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>';

        // Artwork title preview (truncated)
        var titlePreview = order.previewTitles
            ? '<p class="order-preview-text">' + order.previewTitles + '</p>'
            : '';

        return '<a href="/Buyer/OrderDetail/' + order.orderId + '" class="order-card">' +
            '<div class="order-card-inner">' +

                // Left thumbnail column (hidden on mobile via CSS)
                '<div class="order-card-preview">' +
                    '<div class="preview-icon">' + thumb + '</div>' +
                '</div>' +

                // Main content
                '<div class="order-card-content">' +
                    '<div class="order-card-info">' +
                        '<div class="order-id-row">' +
                            '<span class="order-id">' + oidStr + '</span>' +
                            statusBadge(order.orderStatus) +
                        '</div>' +
                        titlePreview +
                        '<div class="order-meta">' +
                            '<span class="order-meta-item">' +
                                '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
                                date +
                            '</span>' +
                            '<span class="order-meta-item">' +
                                '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>' +
                                itemCount +
                            '</span>' +
                        '</div>' +
                    '</div>' +

                    // Right: total + chevron
                    '<div class="order-card-right">' +
                        '<span class="order-total">' + grand + '</span>' +
                        '<svg class="order-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>' +
                    '</div>' +
                '</div>' +

            '</div>' +
        '</a>';
    }

    async function loadOrders() {
        try {
            var res = await fetch('http://localhost:5183/api/BuyerOrder/GetOrders', {
                method: 'GET',
                headers: { 'Authorization': 'Bearer ' + TOKEN }
            });

            if (!res.ok) throw new Error('HTTP ' + res.status);

            var json   = await res.json();
            var orders = json.data || json;

            // Normalize to array
            if (orders && orders.$values) orders = orders.$values;
            if (!Array.isArray(orders))   orders = [];

            if (orders.length === 0) {
                document.getElementById('ordersContent').innerHTML = '';
                document.getElementById('emptyState').style.display = 'block';
                document.getElementById('statTotal').textContent = '0';
                document.getElementById('statSpent').textContent = '$0.00';
                return;
            }

            // ── CHANGED: sum totalAmount (already grand total stored by payment) ──
            var totalSpent = orders.reduce(function (sum, o) {
                return sum + (parseFloat(o.totalAmount) || 0);
            }, 0);

            document.getElementById('statTotal').textContent = orders.length;
            document.getElementById('statSpent').textContent = formatAmount(totalSpent);
            document.getElementById('ordersContent').innerHTML = orders.map(buildCard).join('');

        } catch (e) {
            console.error('loadOrders error:', e);
            document.getElementById('ordersContent').innerHTML =
                '<p style="text-align:center;color:#dc2626;padding:3rem 0;">Failed to load orders. Please try again.</p>';
        }
    }

    document.addEventListener('DOMContentLoaded', loadOrders);
</script>