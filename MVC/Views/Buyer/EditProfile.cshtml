                <div class="form-group">
                    <label class="form-label">
                        <span class="k-icon k-i-tell-a-friend"></span> Phone Number
                    </label>
                    <input type="text" name="Phone" class="form-input" value="+1 (555) 234-5678" placeholder="Enter your phone number" />
