@{
    ViewBag.Title = "Edit Profile";
    @* Layout = "_BuyerLayout"; *@
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

<style>
    :root {
        --canvas:        #f5f0ea;
        --canvas-2:      #ffffff;
        --canvas-3:      #ede7df;
        --surface:       #faf7f3;
        --border:        rgba(0,0,0,0.06);
        --border-2:      rgba(0,0,0,0.10);
        --gold:          #9a6324;
        --gold-bright:   #c08b3f;
        --gold-light:    #dbb978;
        --gold-dim:      rgba(154,99,36,0.08);
        --gold-ring:     rgba(154,99,36,0.18);
        --text:          #1c1814;
        --text-2:        #5e554a;
        --text-3:        #9e9488;
        --radius-sm:     10px;
        --radius-md:     16px;
        --radius-lg:     24px;
        --radius-xl:     36px;
        --shadow-md:     0 4px 16px rgba(0,0,0,0.06), 0 2px 4px rgba(0,0,0,0.03);
        --shadow-lg:     0 12px 40px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
        --shadow-gold:   0 8px 32px rgba(154,99,36,0.15);
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--canvas); color: var(--text); }

    .edit-page { max-width: 680px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

    .studio-card {
        background: var(--canvas-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    /* ── Section Divider ── */
    .section-divider {
        display: flex; align-items: center; gap: 14px;
        padding: 1.5rem 2.25rem 0.85rem;
    }
    .section-divider span {
        font-size: .65rem; font-weight: 700; letter-spacing: 2.5px;
        text-transform: uppercase; color: var(--gold);
        white-space: nowrap;
        background: linear-gradient(135deg, var(--gold), var(--gold-bright));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .section-divider::after {
        content: ''; flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--border-2), transparent);
    }

    /* ── Alert ── */
    #msgBox {
        margin: 0 2.25rem; padding: 14px 18px;
        border-radius: var(--radius-md); font-size: .88rem;
        display: none; font-weight: 500;
        backdrop-filter: blur(8px);
    }
    #msgBox.success { background: rgba(220,252,231,0.9); color: #166534; border: 1px solid #86efac; }
    #msgBox.error   { background: rgba(254,226,226,0.9); color: #991b1b; border: 1px solid #fca5a5; }

    /* ── Form Body ── */
    .form-body { padding: 0 2.25rem 2.25rem; }

    /* ── Avatar Section ── */
    .avatar-section {
        display: flex; align-items: center; gap: 28px;
        padding: 1.75rem 0 .75rem;
    }
    .avatar-wrapper { position: relative; flex-shrink: 0; width: 100px; height: 100px; }
    .avatar-circle {
        width: 100px; height: 100px; border-radius: 50%;
        background: linear-gradient(135deg, #2c221a, #5a4430);
        display: flex; align-items: center; justify-content: center;
        border: 4px solid var(--canvas-2);
        box-shadow: 0 0 0 3px var(--border-2), var(--shadow-md);
        overflow: hidden;
        transition: transform 0.3s;
    }
    .avatar-circle:hover { transform: scale(1.05); }
    .avatar-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }
    .avatar-circle i { font-size: 2.5rem; color: rgba(255,255,255,0.5); }
    .avatar-cam-btn {
        position: absolute; bottom: -2px; right: -2px;
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--canvas-2); border: 2px solid var(--border-2);
        display: flex; align-items: center; justify-content: center;
        box-shadow: var(--shadow-md); cursor: pointer;
        transition: all 0.25s;
    }
    .avatar-cam-btn:hover { transform: scale(1.15); background: var(--gold); border-color: var(--gold); }
    .avatar-cam-btn:hover i { color: #fff; }
    .avatar-cam-btn i { font-size: .8rem; color: var(--text-2); transition: color 0.25s; }

    .avatar-info strong { display: block; font-size: .95rem; color: var(--text); font-weight: 600; }
    .avatar-info .hint  { font-size: .76rem; color: var(--text-3); margin-top: 4px; line-height: 1.4; }
    .upload-btn {
        margin-top: 12px; display: inline-flex; align-items: center; gap: 7px;
        padding: 8px 18px; border-radius: 100px;
        border: 1px solid var(--border-2); background: var(--canvas-3);
        color: var(--text-2); font-size: .78rem; font-family: 'DM Sans', sans-serif;
        cursor: pointer; transition: all 0.3s; font-weight: 500;
    }
    .upload-btn:hover {
        background: var(--gold-dim); border-color: var(--gold-bright); color: var(--gold);
        box-shadow: 0 2px 12px var(--gold-ring);
    }

    /* ── Form Fields ── */
    .form-group { margin-bottom: 1.5rem; }
    .form-label {
        display: flex; align-items: center; gap: 7px;
        font-size: .65rem; font-weight: 700; letter-spacing: 2px;
        text-transform: uppercase; color: var(--text-3); margin-bottom: 8px;
    }
    .form-label i { font-size: .75rem; }
    .form-input {
        width: 100%; padding: 13px 16px;
        border-radius: var(--radius-sm);
        border: 1.5px solid var(--border-2);
        background: var(--canvas); font-size: .92rem; color: var(--text);
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box; appearance: none;
    }
    .form-input:focus {
        outline: none; border-color: var(--gold-bright);
        box-shadow: 0 0 0 4px var(--gold-dim);
        background: var(--canvas-2);
    }
    .form-input::placeholder { color: var(--text-3); }
    select.form-input { cursor: pointer; }

    /* ── Actions Footer ── */
    .edit-actions {
        display: flex; justify-content: flex-end; gap: 12px;
        padding: 1.5rem 2.25rem;
        background: linear-gradient(180deg, var(--surface) 0%, rgba(250,247,243,0.8) 100%);
        border-top: 1px solid var(--border);
    }
    .btn-amber {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 26px;
        background: linear-gradient(135deg, var(--gold-bright), var(--gold));
        color: #fff; border: none; border-radius: var(--radius-md);
        font-family: 'DM Sans', sans-serif;
        font-size: .86rem; font-weight: 600; letter-spacing: .3px;
        cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-amber:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-gold);
        filter: brightness(1.05);
    }
    .btn-amber:active { transform: translateY(0); }
    .btn-cancel-outline {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 24px;
        background: transparent; color: var(--text-2);
        border: 1.5px solid var(--border-2); border-radius: var(--radius-md);
        font-family: 'DM Sans', sans-serif;
        font-size: .86rem; font-weight: 500;
        cursor: pointer; transition: all 0.3s; text-decoration: none;
    }
    .btn-cancel-outline:hover { background: var(--canvas-3); color: var(--text); border-color: var(--text-3); }

    /* ── Fade-up ── */
    .sp-fade-up { opacity: 0; transform: translateY(24px); animation: fadeUp .55s cubic-bezier(0.22,1,0.36,1) forwards; }
    @@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    @@media (max-width: 640px) {
        .avatar-section { flex-direction: column; text-align: center; align-items: center; }
        .edit-actions { flex-direction: column; }
        .btn-amber, .btn-cancel-outline { width: 100%; justify-content: center; }
        .form-body { padding: 0 1.5rem 1.75rem; }
        .section-divider { padding-left: 1.5rem; padding-right: 1.5rem; }
        .edit-actions { padding: 1.25rem 1.5rem; }
        .edit-page { padding: 2rem 1rem 4rem; }
    }
</style>

<div class="edit-page sp-fade-up">
    <div class="studio-card">

        <div id="msgBox"></div>

        <!-- Avatar Section -->
        <div class="section-divider"><span>Profile Photo</span></div>
        <div class="form-body">
            <div class="avatar-section">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        @* <img id="avatarImg" src="" alt="Profile" /> *@
                        <img id="profileImg" src="/images/default.png" />
                        <i class="bi bi-person" id="avatarIcon"></i>
                    </div>
                    <div class="avatar-cam-btn" onclick="$('#fileInput').click()">
                        <i class="bi bi-camera"></i>
                    </div>
                </div>
                <div class="avatar-info">
                    <strong>Profile Photo</strong>
                    <p class="hint">JPG, PNG or GIF. Max 2MB.</p>
                    <input type="file" id="fileInput" accept="image/*" style="display:none;" />
                    <button type="button" class="upload-btn" onclick="$('#fileInput').click()">
                        <i class="bi bi-cloud-arrow-up"></i> Upload Photo
                    </button>
                </div>
            </div>
        </div>

        <!-- Personal Information -->
        <div class="section-divider"><span>Personal Information</span></div>
        <div class="form-body">

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-person"></i> Username
                </label>
                <input type="text" id="userName" class="form-input" placeholder="Enter your username" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-person-badge"></i> Full Name
                </label>
                <input type="text" id="fullName" class="form-input" placeholder="Enter your full name" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-telephone"></i> Mobile Number
                </label>
                <input type="text" id="mobile" class="form-input" placeholder="Enter your mobile number" />
            </div>

            <div class="form-group" style="margin-bottom:0;">
                <label class="form-label">
                    <i class="bi bi-gender-ambiguous"></i> Gender
                </label>
                <select id="gender" class="form-input">
                    <option value="">Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
            </div>

        </div>

        <!-- Actions -->
        <div class="edit-actions">
            <a href="@Url.Action("Profile", "Buyer")" class="btn-cancel-outline">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
            <button type="button" class="btn-amber" id="btnSaveBottom">
                <i class="bi bi-floppy-fill"></i> Save Changes
            </button>
        </div>

    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function showMsg(message, type = 'success') {
        Swal.fire({
            icon: type,              // success | error | warning | info
            title: message,
            confirmButtonColor: '#c08b3f'
        });
    }
    function getUserIdFromToken() {
        let token = localStorage.getItem("token");
        if (!token) return null;

        try {
            let payload = token.split('.')[1];
            let decoded = JSON.parse(atob(payload));
            return decoded["user_id"] || decoded["c_UserId"] || decoded["userId"] || decoded["sub"];
        } catch {
            return null;
        }
        // 👇 Check this key based on your backend
        return decoded["user_id"] || decoded["c_UserId"] || decoded["userId"] || decoded["sub"];
    }
    
    // ✅ FIX 1: safe userId
    var testUserId =  getUserIdFromToken();
    var currentImagePath = '';
    if (!testUserId) {
        showMsg("User not logged in", "warning");
        setTimeout(() => {
            window.location.href = "/Auth/UserLogin";
        }, 1500);
    }

    @* function showMsg(msg, type) {
        alert(msg);
    } *@
    


    // ✅ FIX 2: validation improved
    function validateForm() {
        const mobile = $('#mobile').val().trim();

        if (!$('#userName').val().trim()) {
            showMsg('Username required', 'error');
            return false;
        }

        if (!$('#fullName').val().trim()) {
            showMsg('Full name required', 'error');
            return false;
        }

        if (!/^[6-9]\d{9}$/.test(mobile)) {
            showMsg('Enter valid mobile number', 'error');
            return false;
        }

        return true;
    }
    
    function setProfileImage(imageName) {
        if (!imageName) {
            $('#profileImg').attr('src', '/images/default.png').show();
            $('#avatarIcon').show();
            return;
        }

        let finalPath = '';

        if (imageName.startsWith("/profile_images")) {
            finalPath = "https://localhost:5092" + imageName;
        } else {
            finalPath = "https://localhost:5092/UserImages/" + imageName;
        }

        $('#profileImg').attr('src', finalPath).show();
        $('#avatarIcon').hide();
    }
    
    $('#fileInput').change(function (e) {
        const file = e.target.files[0];
        if (file) {
            $('#profileImg').attr('src', URL.createObjectURL(file)).show();
            $('#avatarIcon').hide(); // icon hide
        }
    });
    function doSave() {
        if (!validateForm()) return;

        var fd = new FormData();
        @* fd.append("c_UserId", parseInt(testUserId)); *@


        fd.append("c_UserName", $('#userName').val());
        fd.append("c_FullName", $('#fullName').val());
        fd.append("c_Mobile", $('#mobile').val());
        fd.append("c_Gender", $('#gender').val());
        var file = $('#fileInput')[0].files[0];
        if (file) {
            fd.append("c_ImageFile", file);
        }
        

        $.ajax({
            url: 'http://localhost:5183/api/UserProfile/UpdateProfile',
            type: 'PUT',
            headers: {
                "Authorization": "Bearer " + localStorage.getItem("token")
            },
            data: fd,
            contentType: false,
            processData: false,

            success: function (res) {
                if (res.success) {
                    showMsg("Profile Updated Successfully");
                    setTimeout(() => {
                        window.location.href = '/Buyer/Profile';
                    }, 1500);
                } else {
                    showMsg(res.message, "error");
                }
            },
            error: function () {
                showMsg("Error saving profile", "error");
            }
        });
    }

    $(document).ready(function () {

        // Load profile with JWT token
        $.ajax({
            url: 'http://localhost:5183/api/UserProfile/GetProfile',
            type: 'GET',
            headers: {
                "Authorization": "Bearer " + localStorage.getItem("token")
            },
            success: function (res) {
                if (!res.success) return;

                let u = res.data;

                $('#userName').val(u.c_UserName);
                $('#fullName').val(u.c_FullName);
                $('#mobile').val(u.c_Mobile);
                $('#gender').val(u.c_Gender);

                @* currentImagePath = u.c_Image;

                if (u.c_Image) {
                    $('#avatarImg')
                        .attr('src', u.c_Image.startsWith('/uploads/')
                            ? u.c_Image
                            : '/uploads/' + u.c_Image)
                        .show();
                }
                if (u.c_Image) {
                    $('#avatarImg')
                        .attr('src', 'http://localhost:5183/' + u.c_Image)
                        .show();
                } *@
                setProfileImage(u.c_Image || u.c_ProfileImage);
                currentImagePath = u.c_Image || u.c_ProfileImage;
            },
            error: function () {
                showMsg("Session expired. Please login again.", "warning");
                setTimeout(() => {
                    window.location.href = "/Auth/UserLogin";
                }, 1500);
            }
        });

        $('#btnSaveBottom').click(doSave);


    });
</script>
}