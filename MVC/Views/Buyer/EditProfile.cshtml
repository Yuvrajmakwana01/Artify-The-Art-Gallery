        <!-- Personal Information -->
        <div class="edit-card">
            <div class="edit-card-header">
                <span class="k-icon k-i-user"></span>
                <h3>Personal Information</h3>
            </div>
            <div class="edit-card-body">
                <div class="form-group">
                    <label class="form-label">
                        <span class="k-icon k-i-user"></span> Full Name
                    </label>
                    <input type="text" name="FullName" class="form-input" value="Sarah Mitchell" placeholder="Enter your full name" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <span class="k-icon k-i-email"></span> Email Address
                    </label>
                    <input type="email" name="Email" class="form-input" value="sarah.mitchell@@email.com" placeholder="Enter your email" />
