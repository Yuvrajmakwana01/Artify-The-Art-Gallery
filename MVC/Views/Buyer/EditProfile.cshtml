<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="edit-page">
    <!-- Header -->
    <div class="edit-header">
        <button class="back-btn" onclick="window.location.href='@Url.Action("Profile", "Buyer")'">
            <span class="k-icon k-i-arrow-left"></span>
        </button>
        <div class="edit-header-text">
            <h1>Edit Profile</h1>
            <p>Update your personal information</p>
        </div>
    </div>

    <!-- Avatar Section -->
    <div class="edit-card">
        <div class="edit-card-body">
            <div class="avatar-section">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        <span class="k-icon k-i-user" id="avatarIcon"></span>
                        <img id="avatarImg" src="" alt="Profile"
                             style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:none;" />
                    </div>
                    <div class="avatar-cam-btn">
                        <span class="k-icon k-i-image"></span>
                    </div>
                </div>
                <div class="avatar-info">
                    <strong>Profile Photo</strong>
                    <p class="hint">JPG, PNG or GIF. Max 2MB.</p>
                    <button type="button" class="upload-btn">
                        <span class="k-icon k-i-image"></span> Upload Photo
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Personal Information -->
    <div class="edit-card">
        <div class="edit-card-header">
            <span class="k-icon k-i-user"></span>
            <h3>Personal Information</h3>
        </div>
        <div class="edit-card-body">
            <div class="form-group">
                <label class="form-label">
                    <span class="k-icon k-i-user"></span> Full Name
                </label>
                <input type="text" id="fullName" class="form-input" placeholder="Enter your full name" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <span class="k-icon k-i-email"></span> Email Address
                </label>
                <input type="email" id="email" class="form-input" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <span class="k-icon k-i-tell-a-friend"></span> Phone Number
                </label>
                <input type="text" id="mobile" class="form-input" placeholder="Enter your phone number" />
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">
                    <span class="k-icon k-i-palette"></span> Preferred Art Styles
                </label>
                <input type="text" id="preferredStyles" class="form-input" placeholder="e.g. Abstract, Modern, Digital" />
                <p class="form-hint">Separate styles with commas</p>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="edit-actions">
        <button type="button" class="btn-cancel" onclick="window.location.href='@Url.Action("Profile", "Buyer")'">
            <span class="k-icon k-i-close"></span> Cancel
        </button>
        <button type="button" class="btn-save" id="btnSave">
            <span class="k-icon k-i-save"></span> Save Changes
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // HARDCODED FOR TESTING - change to any valid c_user_id from your DB
        var testUserId = 8;

        $(document).ready(function () {

            // Load profile data into form
            $.ajax({
                url: 'http://localhost:5183/api/UserProfile/GetProfile/' + testUserId,
                type: 'GET',
                success: function (response) {
                    if (response.success) {
                        var u = response.data;

                        // Fill form fields
                        $('#fullName').val(u.c_FullName  || '');
                        $('#email').val(u.c_Email         || '');
                        $('#mobile').val(u.c_Mobile       || '');

                        // Avatar
                        if (u.c_Image) {
                            $('#avatarIcon').hide();
                            $('#avatarImg').attr('src', u.c_Image).show();
                        }
                    }
                },
                error: function () {
                    console.log('Failed to load profile data');
                }
            });

            $('#btnSave').click(function () {
                var formData = new FormData();
                
                // ✅ parseInt karo - string nahi integer bhejo
                formData.append("c_UserId",   parseInt(testUserId));
                formData.append("c_FullName", $('#fullName').val());
                formData.append("c_Email",    $('#email').val());
                formData.append("c_Mobile",   $('#mobile').val());

                $.ajax({
                    url: 'http://localhost:5183/api/UserProfile/UpdateProfile',
                    type: 'PUT',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        console.log("Response:", response);
                        if (response.success) {
                            alert('Profile updated successfully!');
                            window.location.href = '@Url.Action("Profile", "Buyer")';
                        } else {
                            alert('Failed: ' + response.message);
                        }
                    },
                    error: function (xhr) {
                        console.log("Error status:", xhr.status);
                        console.log("Error response:", xhr.responseText);
                        alert('Something went wrong. Please try again.');
                    }
                });
            });

        });
    </script>
}