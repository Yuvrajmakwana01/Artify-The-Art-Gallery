@{
    ViewData["Title"] = "Art Detail | Artify";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --background: hsl(36, 33%, 97%);
            --foreground: hsl(30, 10%, 15%);
            --card: hsl(36, 30%, 95%);
            --card-white: #ffffff;
            --primary: hsl(30, 45%, 25%);
            --primary-foreground: hsl(36, 33%, 97%);
            --secondary: hsl(32, 25%, 88%);
            --muted: hsl(30, 10%, 45%);
            --accent: hsl(38, 60%, 55%);
            --border: hsl(32, 20%, 85%);
            --wishlist: #DC4A4A;
            --discount: #e53e3e;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: var(--background); color: var(--foreground); line-height: 1.6; }
        h1,h2,h3,h4,h5,h6 { font-family: 'Playfair Display', serif; }

        /* Navbar */
        .navbar { position: sticky; top: 0; z-index: 50; background: hsla(36,33%,97%,0.85); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
        .navbar-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; }
        .logo { font-family: 'Playfair Display', serif; font-size: 1.875rem; font-weight: 700; color: var(--foreground); text-decoration: none; letter-spacing: -0.025em; transition: color 0.3s; }
        .logo:hover { color: var(--accent); }
        .nav-links { display: flex; gap: 2rem; }
        .nav-links a { font-size: 0.875rem; font-weight: 500; color: var(--muted); text-decoration: none; transition: color 0.3s; position: relative; padding-bottom: 2px; }
        .nav-links a::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background: var(--accent); transform: scaleX(0); transition: transform 0.25s; }
        .nav-links a:hover, .nav-links a.active { color: var(--foreground); }
        .nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }
        .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
        .icon-btn { position: relative; width: 38px; height: 38px; border-radius: 50%; border: none; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--muted); transition: all 0.2s; text-decoration: none; }
        .icon-btn:hover { background: var(--secondary); color: var(--foreground); }
        .badge { position: absolute; top: -2px; right: -2px; min-width: 18px; height: 18px; padding: 0 4px; border-radius: 9999px; background: var(--accent); color: #fff; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
        .badge.zero { display: none; }
        .avatar-btn { width: 38px; height: 38px; border-radius: 50%; border: none; background: var(--primary); color: var(--primary-foreground); cursor: pointer; display: flex; align-items: center; justify-content: center; text-decoration: none; }

        /* Breadcrumb */
        .breadcrumb-bar { background: var(--card-white); border-bottom: 1px solid var(--border); }
        .breadcrumb { max-width: 1200px; margin: 0 auto; padding: 12px 1.5rem; display: flex; align-items: center; justify-content: space-between; }
        .breadcrumb-links { display: flex; align-items: center; gap: 8px; font-size: 13px; }
        .breadcrumb-links a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
        .breadcrumb-links a:hover { color: var(--foreground); }
        .breadcrumb-links span { color: var(--muted); }
        .breadcrumb-links .current { color: var(--foreground); font-weight: 500; }
        .breadcrumb-nav { display: flex; align-items: center; gap: 6px; }
        .breadcrumb-nav button { width: 30px; height: 30px; border: 1px solid var(--border); border-radius: 6px; background: var(--card-white); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--muted); transition: all 0.2s; }
        .breadcrumb-nav button:hover { border-color: var(--accent); color: var(--foreground); }

        /* Product Layout */
        .product-section { max-width: 1200px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }

        /* Gallery */
        .gallery { position: relative; }
        .main-image-wrapper { position: relative; width: 100%; aspect-ratio: 1/1; overflow: hidden; border-radius: 1rem; background: var(--card); cursor: crosshair; border: 1px solid var(--border); }
        .main-image-wrapper img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .discount-badge { position: absolute; top: 16px; right: 16px; padding: 6px 14px; border-radius: 6px; background: var(--discount); color: #fff; font-size: 13px; font-weight: 700; z-index: 2; }
        .zoom-lens { position: absolute; width: 160px; height: 160px; border: 2px solid rgba(255,255,255,0.7); background: rgba(255,255,255,0.12); cursor: crosshair; display: none; z-index: 3; pointer-events: none; box-shadow: 0 0 0 9999px rgba(0,0,0,0.12); }
        .zoom-result { position: absolute; top: 0; left: calc(100% + 16px); width: 460px; height: 460px; border: 1px solid var(--border); border-radius: 1rem; background-repeat: no-repeat; background-color: var(--card-white); display: none; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
        .fullscreen-btn { position: absolute; bottom: 14px; right: 14px; width: 36px; height: 36px; border: 1px solid var(--border); border-radius: 8px; background: rgba(255,255,255,0.9); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--foreground); z-index: 2; transition: all 0.2s; }
        .fullscreen-btn:hover { background: white; }
        .img-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 36px; height: 36px; border: 1px solid var(--border); border-radius: 8px; background: rgba(255,255,255,0.88); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--foreground); z-index: 2; transition: all 0.2s; }
        .img-nav:hover { background: white; }
        .img-nav.prev { left: 12px; }
        .img-nav.next { right: 12px; }
        .thumbnails { display: flex; gap: 10px; margin-top: 12px; }
        .thumb { width: 78px; height: 78px; border-radius: 8px; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; flex-shrink: 0; }
        .thumb.active { border-color: var(--accent); }
        .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

        /* Product Info */
        .product-info { position: sticky; top: 80px; }
        .product-title { font-size: 1.75rem; font-weight: 700; line-height: 1.3; color: var(--foreground); }
        .seller-row { margin-top: 8px; font-size: 15px; color: var(--muted); }
        .seller-row a { color: var(--primary); font-weight: 600; text-decoration: none; }
        .seller-row a:hover { text-decoration: underline; }
        .price-row { margin-top: 16px; display: flex; align-items: baseline; gap: 12px; }
        .original-price { font-size: 1.05rem; color: var(--muted); text-decoration: line-through; }
        .sale-price { font-size: 1.6rem; font-weight: 700; color: var(--discount); }
        .divider { height: 1px; background: var(--border); margin: 20px 0; }
        .btn-add-cart { width: 100%; margin-top: 10px; padding: 14px; border-radius: 8px; border: none; background: var(--primary); color: var(--primary-foreground); font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.2s; letter-spacing: 0.05em; }
        .btn-add-cart:hover:not(:disabled) { opacity: 0.88; }
        .btn-add-cart.in-cart { opacity: 0.7; cursor: default; background: #16304f; }
        .btn-buy-now { width: 100%; margin-top: 10px; padding: 14px; border-radius: 8px; border: 1.5px solid var(--primary); background: transparent; color: var(--primary); font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.2s; letter-spacing: 0.05em; }
        .btn-buy-now:hover { background: var(--primary); color: var(--primary-foreground); }
        .btn-wishlist { width: 100%; margin-top: 10px; padding: 12px; border-radius: 8px; border: 1.5px solid var(--border); background: transparent; color: var(--muted); font-size: 14px; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-wishlist:hover { border-color: var(--wishlist); color: var(--wishlist); }
        .btn-wishlist.active { background: hsla(0,75%,58%,0.08); border-color: var(--wishlist); color: var(--wishlist); }

        /* Category tag */
        .cat-tag { display: inline-block; margin-top: 12px; padding: 4px 12px; border-radius: 9999px; background: hsla(38,60%,55%,0.12); color: var(--accent); font-size: 13px; font-weight: 500; }
        .stats-row { display: flex; gap: 1.5rem; margin-top: 12px; font-size: 13px; color: var(--muted); }
        .stats-row span { display: flex; align-items: center; gap: 4px; }

        /* Trust badges */
        .trust-badges { display: flex; gap: 20px; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); }
        .trust-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 11px; color: var(--muted); text-align: center; font-weight: 500; }
        .trust-item svg { color: var(--accent); }

        /* Accordion */
        .accordion { margin-top: 24px; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
        .accordion-item { border-bottom: 1px solid var(--border); }
        .accordion-item:last-child { border-bottom: none; }
        .accordion-header { width: 100%; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; font-size: 14px; font-weight: 600; background: white; border: none; cursor: pointer; text-align: left; font-family: 'Inter', sans-serif; color: var(--foreground); transition: background 0.2s; }
        .accordion-header:hover { background: var(--card); }
        .accordion-header .acc-icon { font-size: 20px; color: var(--muted); }
        .accordion-body { padding: 0 18px 16px; font-size: 14px; color: var(--muted); line-height: 1.75; display: none; background: white; }
        .accordion-body.open { display: block; }
        .accordion-header.open .acc-icon { }

        /* Description */
        .description-section { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem 4rem; }
        .desc-accordion { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: white; }

        /* Loading / Error */
        .loading-state { text-align: center; padding: 6rem 1.5rem; color: var(--muted); }
        .loading-spinner { display: inline-block; width: 44px; height: 44px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 1rem; }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .error-state { text-align: center; padding: 6rem 1.5rem; color: var(--muted); }

        /* Toast */
        .toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--foreground); color: var(--primary-foreground); padding: 12px 24px; border-radius: 9999px; font-size: 13px; font-weight: 500; font-family: 'Inter', sans-serif; z-index: 9999; opacity: 0; transition: all 0.35s cubic-bezier(0.4,0,0.2,1); pointer-events: none; white-space: nowrap; }
        .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

        @@media(max-width:1024px) { .product-section { grid-template-columns: 1fr; gap: 32px; } .zoom-result { display: none !important; } .product-info { position: static; } }
        @@media(max-width:768px) { .nav-links { display: none; } .product-title { font-size: 1.4rem; } }
        @@media(max-width:480px) { .trust-badges { flex-direction: column; gap: 16px; } }
    </style>
</head>
<body>

    <div class="toast" id="toast"></div>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/Buyer/ExploreArt" class="logo">Artify</a>
            <div class="nav-links">
                <a href="/Buyer/ExploreArt" class="active">Explore Arts</a>
                <a href="#">Categories</a>
                <a href="#">Trending</a>
            </div>
            <div class="nav-actions">
                <a href="/Wishlist/Index" class="icon-btn" title="Wishlist">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                    <span class="badge zero" id="wishlistBadge">0</span>
                </a>
                <a href="/Cart/Index" class="icon-btn" title="Cart">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    <span class="badge zero" id="cartBadge">0</span>
                </a>
                <a href="/Buyer/Profile" class="avatar-btn" title="Profile">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </a>
            </div>
        </div>
    </nav>

    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <div class="breadcrumb">
            <div class="breadcrumb-links">
                <a href="/Buyer/ExploreArt">Home</a>
                <span>›</span>
                <a href="/Buyer/ExploreArt" id="breadCat">Explore Art</a>
                <span>›</span>
                <span class="current" id="breadTitle">Loading...</span>
            </div>
            <div class="breadcrumb-nav">
                <button onclick="history.back()" title="Back">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button title="Grid view" onclick="window.location.href='/Buyer/ExploreArt'">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="loading-state">
        <div class="loading-spinner"></div>
        <p>Loading artwork details...</p>
    </div>

    <!-- Error State -->
    <div id="errorState" class="error-state" style="display:none;">
        <p id="errorMsg">Artwork not found.</p>
        <a href="/Buyer/ExploreArt" style="margin-top:1rem;display:inline-block;color:var(--accent);font-weight:600;">← Back to Explore</a>
    </div>

    <!-- Product Content — hidden until data loads -->
    <div id="productContent" style="display:none;">

        <div class="product-section">
            <!-- Gallery -->
            <div class="gallery">
                <div class="main-image-wrapper" id="mainImageWrapper">
                    <img id="mainImage" src="" alt="Artwork" />
                    <span class="discount-badge" id="discountBadge" style="display:none;"></span>
                    <div class="zoom-lens" id="zoomLens"></div>
                    <button class="img-nav prev" onclick="prevImage()" title="Previous">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button class="img-nav next" onclick="nextImage()" title="Next">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                    <button class="fullscreen-btn" onclick="openFullscreen()" title="Fullscreen">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                    </button>
                </div>
                <div class="zoom-result" id="zoomResult"></div>
                <div class="thumbnails" id="thumbnails"></div>
            </div>

            <!-- Product Info -->
            <div class="product-info">
                <h1 class="product-title" id="artTitle"></h1>
                <p class="seller-row">Sold by <a href="#" id="artArtist"></a></p>
                <span class="cat-tag" id="artCategory"></span>

                <div class="stats-row">
                    <span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        <span id="artLikes">0</span> likes
                    </span>
                    <span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                        <span id="artSells">0</span> sold
                    </span>
                </div>

                <div class="price-row">
                    <span class="original-price" id="originalPrice"></span>
                    <span class="sale-price" id="salePrice"></span>
                </div>

                <div class="divider"></div>

                <button class="btn-add-cart" id="addCartBtn" onclick="addToCart()">ADD TO CART</button>
                <button class="btn-buy-now" onclick="buyNow()">BUY IT NOW</button>
                <button class="btn-wishlist" id="wishlistBtn" onclick="toggleWishlist()">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="wishlistIcon">
                        <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                    </svg>
                    <span id="wishlistBtnText">Save to Wishlist</span>
                </button>

                <div class="trust-badges">
                    <div class="trust-item">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                        Secure Payment
                    </div>
                    <div class="trust-item">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                        Ready to Hang
                    </div>
                    <div class="trust-item">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        Fast Delivery
                    </div>
                </div>

                <div class="accordion">
                    <div class="accordion-item">
                        <button class="accordion-header open" onclick="toggleAccordion(this)">Product Highlights <span class="acc-icon">−</span></button>
                        <div class="accordion-body open"><p>High-definition printing with the latest technology delivers sharp, vibrant results that instantly bring life and character to your walls.</p></div>
                    </div>
                    <div class="accordion-item">
                        <button class="accordion-header" onclick="toggleAccordion(this)">Quality <span class="acc-icon">+</span></button>
                        <div class="accordion-body"><p>Premium archival-grade canvas with UV-resistant inks ensures your artwork stays vibrant for decades.</p></div>
                    </div>
                    <div class="accordion-item">
                        <button class="accordion-header" onclick="toggleAccordion(this)">Shipping &amp; Returns <span class="acc-icon">+</span></button>
                        <div class="accordion-body"><p>✓ Free shipping across India<br/>✓ Premium packaging<br/>✓ Delivery within 5–7 business days<br/>✓ 30-day return policy<br/>✓ Certificate of authenticity</p></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description Section -->
        <div class="description-section">
            <div class="desc-accordion">
                <div class="accordion-item">
                    <button class="accordion-header open" onclick="toggleAccordion(this)">Description <span class="acc-icon">−</span></button>
                    <div class="accordion-body open"><p id="artDesc"></p></div>
                </div>
            </div>
        </div>

    </div><!-- end #productContent -->

    <script>
        var API_BASE       = 'http://localhost:5183';
        var galleryImages  = [];
        var currentIndex   = 0;
        var currentArtworkId = null;
        var inCartFlag     = false;

        // ── Auth helpers ──────────────────────────────────────────────────
        function getToken()    { return localStorage.getItem('token'); }
        function isLoggedIn()  { return !!getToken(); }
        function requireLogin() {
            window.location.href = '/Auth/UserLogin?returnUrl=' + encodeURIComponent(window.location.pathname);
        }

        // ── Image URL helper ──────────────────────────────────────────────
        // API returns relative paths like "/uploads/art.jpg"
        // We prefix with API_BASE so the image is served from the API server
        function imageUrl(path) {
            if (!path) return 'https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=900';
            if (path.startsWith('http')) return path;
            return API_BASE + path;
        }

        // ── localStorage: Cart ────────────────────────────────────────────
        function getCart()          { try { return JSON.parse(localStorage.getItem('artify_cart') || '[]'); } catch(e) { return []; } }
        function saveCart(arr)      { localStorage.setItem('artify_cart', JSON.stringify(arr)); }
        function isInCart(id)       { return getCart().indexOf(id) !== -1; }

        // ── localStorage: Wishlist ────────────────────────────────────────
        function getWishlist()      { try { return JSON.parse(localStorage.getItem('artify_wishlist') || '[]'); } catch(e) { return []; } }
        function saveWishlist(arr)  { localStorage.setItem('artify_wishlist', JSON.stringify(arr)); }
        function isInWishlist(id)   { return getWishlist().indexOf(id) !== -1; }

        // ── Badges ────────────────────────────────────────────────────────
        function updateBadges() {
            var wSize = getWishlist().length, cSize = getCart().length;
            var wb = document.getElementById('wishlistBadge');
            var cb = document.getElementById('cartBadge');
            if (wb) { wb.textContent = wSize; wb.className = 'badge' + (wSize === 0 ? ' zero' : ''); }
            if (cb) { cb.textContent = cSize; cb.className = 'badge' + (cSize === 0 ? ' zero' : ''); }
        }

        // ── Toast ─────────────────────────────────────────────────────────
        var toastTimer = null;
        function showToast(msg) {
            var t = document.getElementById('toast');
            t.textContent = msg;
            t.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(function() { t.classList.remove('show'); }, 2200);
        }

        // ── Cart actions ──────────────────────────────────────────────────
        function addToCart() {
            if (!isLoggedIn()) { requireLogin(); return; }
            if (inCartFlag || !currentArtworkId) return;
            inCartFlag = true;

            var ct = getCart();
            if (ct.indexOf(currentArtworkId) === -1) { ct.push(currentArtworkId); saveCart(ct); }
            updateBadges();
            showToast('🛒 Added to Cart');

            var btn = document.getElementById('addCartBtn');
            btn.textContent = '✓ ADDED TO CART';
            btn.classList.add('in-cart');
            btn.disabled = true;

            // Backend call (fire-and-forget)
            fetch(API_BASE + '/api/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + getToken()
                },
                body: JSON.stringify({ artworkId: currentArtworkId })
            }).catch(function() {});
        }

        function buyNow() {
            addToCart();
            setTimeout(function() { window.location.href = '/Cart/Index'; }, 300);
        }

        // ── Wishlist actions ──────────────────────────────────────────────
        function toggleWishlist() {
            if (!isLoggedIn()) { requireLogin(); return; }
            if (!currentArtworkId) return;

            var wl = getWishlist();
            var idx = wl.indexOf(currentArtworkId);
            var nowWishlisted;
            if (idx === -1) { wl.push(currentArtworkId); nowWishlisted = true; }
            else            { wl.splice(idx, 1);         nowWishlisted = false; }
            saveWishlist(wl);
            updateBadges();
            showToast(nowWishlisted ? '♥ Saved to Wishlist' : 'Removed from Wishlist');
            updateWishlistBtn(nowWishlisted);
        }

        function updateWishlistBtn(isWishlisted) {
            var btn  = document.getElementById('wishlistBtn');
            var icon = document.getElementById('wishlistIcon');
            var txt  = document.getElementById('wishlistBtnText');
            if (isWishlisted) {
                btn.classList.add('active');
                icon.setAttribute('fill', 'currentColor');
                txt.textContent = 'Saved to Wishlist';
            } else {
                btn.classList.remove('active');
                icon.setAttribute('fill', 'none');
                txt.textContent = 'Save to Wishlist';
            }
        }

        // ── Gallery ───────────────────────────────────────────────────────
        function renderThumbnails() {
            document.getElementById('thumbnails').innerHTML = galleryImages.map(function(img, i) {
                return '<div class="thumb ' + (i === currentIndex ? 'active' : '') + '" onclick="selectThumb(' + i + ')">'
                     + '<img src="' + img + '" alt="View ' + (i + 1) + '" /></div>';
            }).join('');
        }

        function selectThumb(i) {
            currentIndex = i;
            document.getElementById('mainImage').src = galleryImages[i];
            renderThumbnails();
            updateZoomBackground();
        }

        function prevImage() {
            currentIndex = (currentIndex - 1 + galleryImages.length) % galleryImages.length;
            document.getElementById('mainImage').src = galleryImages[currentIndex];
            renderThumbnails();
            updateZoomBackground();
        }

        function nextImage() {
            currentIndex = (currentIndex + 1) % galleryImages.length;
            document.getElementById('mainImage').src = galleryImages[currentIndex];
            renderThumbnails();
            updateZoomBackground();
        }

        function openFullscreen() {
            var img = document.getElementById('mainImage');
            if (img.requestFullscreen) img.requestFullscreen();
            else if (img.webkitRequestFullscreen) img.webkitRequestFullscreen();
        }

        // ── Zoom ──────────────────────────────────────────────────────────
        function updateZoomBackground() {
            var zr = document.getElementById('zoomResult');
            if (galleryImages.length > 0)
                zr.style.backgroundImage = "url('" + galleryImages[currentIndex] + "')";
        }

        function initZoom() {
            var wrapper    = document.getElementById('mainImageWrapper');
            var lens       = document.getElementById('zoomLens');
            var zoomResult = document.getElementById('zoomResult');
            var zoomFactor = 2.5;

            updateZoomBackground();

            wrapper.addEventListener('mouseenter', function() {
                lens.style.display = 'block';
                zoomResult.style.display = 'block';
            });
            wrapper.addEventListener('mouseleave', function() {
                lens.style.display = 'none';
                zoomResult.style.display = 'none';
            });
            wrapper.addEventListener('mousemove', function(e) {
                var rect  = wrapper.getBoundingClientRect();
                var x     = e.clientX - rect.left;
                var y     = e.clientY - rect.top;
                var lW    = lens.offsetWidth, lH = lens.offsetHeight;
                var lX    = Math.max(0, Math.min(x - lW / 2, rect.width  - lW));
                var lY    = Math.max(0, Math.min(y - lH / 2, rect.height - lH));
                lens.style.left = lX + 'px';
                lens.style.top  = lY + 'px';
                var rX    = lX / (rect.width  - lW);
                var rY    = lY / (rect.height - lH);
                var zW    = zoomResult.offsetWidth, zH = zoomResult.offsetHeight;
                var bgW   = rect.width * zoomFactor, bgH = rect.height * zoomFactor;
                zoomResult.style.backgroundSize     = bgW + 'px ' + bgH + 'px';
                zoomResult.style.backgroundPosition = '-' + (rX * (bgW - zW)) + 'px -' + (rY * (bgH - zH)) + 'px';
            });
        }

        // ── Accordion ─────────────────────────────────────────────────────
        function toggleAccordion(header) {
            var body   = header.nextElementSibling;
            var icon   = header.querySelector('.acc-icon');
            var isOpen = body.classList.contains('open');
            if (isOpen) { body.classList.remove('open'); header.classList.remove('open'); icon.textContent = '+'; }
            else        { body.classList.add('open');    header.classList.add('open');    icon.textContent = '−'; }
        }

        // ── Get artwork ID from URL  (/Buyer/ArtworkDetail/5) ─────────────
        function getArtworkIdFromUrl() {
            var parts = window.location.pathname.split('/');
            var id    = parseInt(parts[parts.length - 1], 10);
            return isNaN(id) ? null : id;
        }

        // ── MAIN: Load artwork from API ───────────────────────────────────
        async function loadArtworkDetail() {

            var artworkId = getArtworkIdFromUrl();

            if (!artworkId) {
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('errorMsg').textContent = 'Invalid artwork ID in URL.';
                document.getElementById('errorState').style.display = 'block';
                return;
            }

            currentArtworkId = artworkId;

            try {
                // ── Fetch from API: GET /api/artwork/{id} ──────────────────
                // API returns: { success: true, data: { artworkId, title, artistName,
                //   categoryName, price, description, previewPath, originalPath,
                //   likesCount, sellCount, createdAt, ... } }
                var token   = getToken();
                var headers = { 'Content-Type': 'application/json' };
                if (token) headers['Authorization'] = 'Bearer ' + token;

                var res = await fetch(API_BASE + '/api/artwork/' + artworkId, { headers: headers });

                if (!res.ok) {
                    throw new Error(res.status === 404 ? 'Artwork not found.' : 'Server error ' + res.status);
                }

                var json = await res.json();

                // ✅ Your API wraps response in { success, data }
                // Handle both wrapped and direct response shapes
                var a = (json && json.data) ? json.data : json;

                if (!a || !a.artworkId) {
                    throw new Error('Artwork data missing in API response.');
                }

                // ── Populate all fields ────────────────────────────────────
                document.title = (a.title || 'Artwork') + ' | Artify';

                document.getElementById('artTitle').textContent   = a.title        || '—';
                document.getElementById('artArtist').textContent  = a.artistName   || '—';
                document.getElementById('artCategory').textContent = a.categoryName || '—';
                document.getElementById('breadTitle').textContent = a.title        || '—';
                document.getElementById('breadCat').textContent   = a.categoryName || 'Explore Art';
                document.getElementById('artLikes').textContent   = (a.likesCount  || 0).toLocaleString();
                document.getElementById('artSells').textContent   = (a.sellCount   || 0).toLocaleString();
                document.getElementById('artDesc').textContent    = a.description  || 'No description available.';

                // ── Price with discount ────────────────────────────────────
                var price         = parseFloat(a.price) || 0;
                var originalPrice = price > 0 ? Math.round(price / 0.77) : 0;
                var discountPct   = price > 0 ? Math.round((1 - price / originalPrice) * 100) : 0;

                document.getElementById('salePrice').textContent    = price > 0
                    ? '$' + price.toLocaleString('en-IN')
                    : 'Price unavailable';
                document.getElementById('originalPrice').textContent = originalPrice > 0
                    ? '$' + originalPrice.toLocaleString('en-IN')
                    : '';

                if (discountPct > 0) {
                    var db = document.getElementById('discountBadge');
                    db.textContent  = '-' + discountPct + '%';
                    db.style.display = 'block';
                }

                // ── Gallery images ─────────────────────────────────────────
                // Use originalPath as the primary image if available, else previewPath
                var primaryImg = imageUrl(a.originalPath || a.previewPath);
                var previewImg = imageUrl(a.previewPath  || a.originalPath);

                // Build gallery: original + preview (deduplicated)
                galleryImages = [primaryImg];
                if (previewImg && previewImg !== primaryImg) {
                    galleryImages.push(previewImg);
                }

                // Set main image and render thumbnails
                document.getElementById('mainImage').src = galleryImages[0];
                renderThumbnails();
                initZoom();

                // ── Cart button state from localStorage ────────────────────
                if (isInCart(artworkId)) {
                    inCartFlag = true;
                    var btn = document.getElementById('addCartBtn');
                    btn.textContent = '✓ ADDED TO CART';
                    btn.classList.add('in-cart');
                    btn.disabled = true;
                }

                // ── Wishlist button state from localStorage ────────────────
                updateWishlistBtn(isInWishlist(artworkId));

                // ── Update navbar badges ───────────────────────────────────
                updateBadges();

                // ── Show content, hide loader ──────────────────────────────
                document.getElementById('loadingState').style.display  = 'none';
                document.getElementById('productContent').style.display = 'block';

            } catch (err) {
                console.error('Failed to load artwork:', err);
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('errorMsg').textContent       = err.message || 'Failed to load artwork.';
                document.getElementById('errorState').style.display   = 'block';
            }
        }

        // ── Init ──────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function() {
            updateBadges();
            loadArtworkDetail();
        });
    </script>
</body>
</html>
