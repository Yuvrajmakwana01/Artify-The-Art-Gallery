@section Scripts {
    <script>
        $(document).ready(function () {

            // ⚠️ HARDCODED FOR TESTING - change this to any valid c_user_id from your DB
            var testUserId = 8;

            $.ajax({
                url: 'http://localhost:5183/api/UserProfile/GetProfile/' + testUserId,
                type: 'GET',
                success: function (response) {
                    if (response.success) {
                        var u = response.data;

                        // Hero
                        $('#profileName').text(u.c_FullName || u.c_UserName || '—');
                        $('#profileEmail').text(u.c_Email || '—');

                        // Avatar
                        if (u.c_Image) {
                            $('#avatarIcon').hide();
                            $('#avatarImg').attr('src', u.c_Image).show();
                        }

                        // Info card
                        $('#infoFullName').text(u.c_FullName || '—');
                        $('#infoEmail').text(u.c_Email       || '—');
                        $('#infoMobile').text(u.c_Mobile     || '—');
                        $('#infoGender').text(u.c_Gender     || '—');

                        // Member since
                        if (u.c_CreatedAt) {
                            var date = new Date(u.c_CreatedAt);
                            $('#memberSince').text(date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' }));
                        }
                    }
                },
                error: function () {
                    console.log('Failed to load profile data');
                }
            });

        });
    </script>
}