@{
    ViewData["Title"] = "Dashboard";
    Layout = null;

    var navItems = new[]
    {
        new { Icon = "grid", Label = "Dashboard", Active = true, Url = Url.Action("Profile", "Buyer") },
        new { Icon = "heart", Label = "Wishlist", Active = false, Url = Url.Action("Wishlist", "Buyer") },
        new { Icon = "shopping-bag", Label = "Orders", Active = false, Url = Url.Action("Orders", "Buyer") },
        new { Icon = "download", Label = "Download Arts", Active = false, Url = Url.Action("Downloads", "Buyer") },
        new { Icon = "user", Label = "Profile Management", Active = false, Url = Url.Action("EditProfile", "Buyer") },
        new { Icon = "settings", Label = "Settings", Active = false, Url = Url.Action("Settings", "Buyer") },
        new { Icon = "shield", Label = "Change Password", Active = false, Url = Url.Action("ChangePassword", "Buyer") },
    };

    var stats = new[]
    {
        new { Label = "Collected", Value = "26", Sub = "artworks" },
        new { Label = "Wishlist", Value = "9", Sub = "saved" },
        new { Label = "Spent", Value = "12.4 ETH", Sub = "≈ $34,720" },
        new { Label = "Top", Value = "#421", Sub = "collector rank" },
    };

    var trending = new[]
    {
        new { Id = 1, Title = "Neon Reverie", Artist = "Mara Soleil", Price = "0.45 ETH", Img = "/placeholder.svg" },
        new { Id = 2, Title = "Silent Wave", Artist = "Kano Ibuki", Price = "1.20 ETH", Img = "/placeholder.svg" },
        new { Id = 3, Title = "Urban Echo", Artist = "Leo Vance", Price = "0.80 ETH", Img = "/placeholder.svg" },
        new { Id = 4, Title = "Golden Hour", Artist = "Priya Arora", Price = "2.10 ETH", Img = "/placeholder.svg" },
        new { Id = 5, Title = "Terra Nova", Artist = "Dax Wren", Price = "0.60 ETH", Img = "/placeholder.svg" },
        new { Id = 6, Title = "Flux State", Artist = "Ela Storm", Price = "0.95 ETH", Img = "/placeholder.svg" },
        new { Id = 7, Title = "Pale Orbit", Artist = "Owen Kai", Price = "1.55 ETH", Img = "/placeholder.svg" },
        new { Id = 8, Title = "Deep Bloom", Artist = "Nadia Fern", Price = "0.35 ETH", Img = "/placeholder.svg" },
    };

    var collected = new[]
    {
        new { Id = 1, Title = "Celestial Drift", Artist = "Mara Soleil", Value = "1.8 ETH", Img = "/placeholder.svg" },
        new { Id = 2, Title = "Ember Code", Artist = "Kano Ibuki", Value = "0.6 ETH", Img = "/placeholder.svg" },
        new { Id = 3, Title = "Vantablack", Artist = "Leo Vance", Value = "3.2 ETH", Img = "/placeholder.svg" },
    };

    var wishlist = new[]
    {
        new { Id = 1, Title = "Sable Dream", Artist = "Priya Arora", Value = "2.4 ETH", Img = "/placeholder.svg" },
        new { Id = 2, Title = "Mirror Lake", Artist = "Dax Wren", Value = "0.9 ETH", Img = "/placeholder.svg" },
        new { Id = 3, Title = "Sky Fracture", Artist = "Ela Storm", Value = "1.1 ETH", Img = "/placeholder.svg" },
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Artify</title>
    <script src="https://unpkg.com/feather-icons"></script>
    <style>
        /* ─── Color Theme ─────────────────────────────────── */
        :root {
            --bg:      #DEE6E9;
            --brand:   #03289F;
            --heading: #EDA312;
            --subhead: #6B9BE6;
            --text:    #03289F;
            --white:   #ffffff;
            --shadow:  0 8px 40px rgba(3,40,159,.15);

            /* Derived helpers */
            --brand-soft:  rgba(3,40,159,.08);
            --brand-mid:   rgba(3,40,159,.18);
            --heading-soft:rgba(237,163,18,.15);
            --subhead-soft:rgba(107,155,230,.18);
            --border:      rgba(3,40,159,.14);
            --card-bg:     rgba(255,255,255,.70);
            --sidebar-bg:  rgba(255,255,255,.82);
        }

        /* ─── Reset & Base ────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        a { text-decoration: none; color: inherit; }
        button { cursor: pointer; border: none; background: none; font: inherit; }
        img { display: block; }

        /* ─── Layout ──────────────────────────────────────── */
        .layout { display: flex; width: 100%; }

        /* ─── Sidebar ─────────────────────────────────────── */
        .sidebar {
            width: 240px;
            flex-shrink: 0;
            background: var(--sidebar-bg);
            backdrop-filter: blur(14px);
            border-right: 1px solid var(--border);
            padding: 24px 16px;
            position: sticky;
            top: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            z-index: 20;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 36px;
            padding: 0 8px;
        }

        .logo-icon {
            height: 38px;
            width: 38px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--brand), var(--subhead));
            display: grid;
            place-items: center;
            font-weight: 900;
            font-size: 18px;
            color: var(--white);
            box-shadow: 0 4px 16px rgba(3,40,159,.30);
            letter-spacing: -1px;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 700;
            color: var(--brand);
            letter-spacing: -0.5px;
        }

        .sidebar-nav { flex: 1; display: flex; flex-direction: column; gap: 2px; }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            color: rgba(3,40,159,.55);
            transition: background .18s, color .18s, box-shadow .18s;
            width: 100%;
            text-align: left;
        }

        .nav-item:hover {
            background: var(--brand-soft);
            color: var(--brand);
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--brand), var(--subhead));
            color: var(--white);
            box-shadow: 0 4px 18px rgba(3,40,159,.28);
        }

        .nav-item svg { width: 16px; height: 16px; stroke-width: 2; flex-shrink: 0; }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            color: rgba(3,40,159,.50);
            transition: color .18s, background .18s;
        }

        .logout-btn:hover { color: var(--heading); background: var(--heading-soft); }
        .logout-btn svg { width: 16px; height: 16px; }

        /* ─── Main ────────────────────────────────────────── */
        .main { flex: 1; min-width: 0; }

        /* ─── Topbar ──────────────────────────────────────── */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 16px;
            background: rgba(222,230,233,.82);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            padding: 14px 32px;
            box-shadow: 0 2px 12px rgba(3,40,159,.07);
        }

        .search-wrap { position: relative; flex: 1; max-width: 480px; }

        .search-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(3,40,159,.40);
            width: 16px;
            height: 16px;
        }

        .search-input {
            width: 100%;
            border: 1px solid var(--border);
            background: rgba(255,255,255,.60);
            border-radius: 99px;
            padding: 10px 16px 10px 42px;
            font-size: 14px;
            color: var(--text);
            outline: none;
            transition: border-color .18s, box-shadow .18s;
        }

        .search-input::placeholder { color: rgba(3,40,159,.38); }

        .search-input:focus {
            border-color: var(--subhead);
            box-shadow: 0 0 0 3px rgba(107,155,230,.20);
        }

        .icon-btn {
            height: 40px;
            width: 40px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: rgba(255,255,255,.70);
            display: grid;
            place-items: center;
            color: var(--brand);
            transition: border-color .18s, box-shadow .18s;
        }

        .icon-btn:hover {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px var(--brand-soft);
        }

        .icon-btn svg { width: 16px; height: 16px; }

        .avatar {
            height: 40px;
            width: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand), var(--subhead));
            display: grid;
            place-items: center;
            font-weight: 700;
            font-size: 15px;
            color: var(--white);
            box-shadow: 0 3px 12px rgba(3,40,159,.25);
        }

        /* ─── Content ─────────────────────────────────────── */
        .content { padding: 32px; display: flex; flex-direction: column; gap: 36px; }

        /* ─── Welcome Banner ──────────────────────────────── */
        .welcome-banner {
            position: relative;
            overflow: hidden;
            border-radius: 24px;
            border: 1px solid rgba(3,40,159,.18);
            background: linear-gradient(135deg, rgba(3,40,159,.10) 0%, rgba(107,155,230,.12) 50%, rgba(255,255,255,.40) 100%);
            padding: 36px 40px;
            box-shadow: var(--shadow);
        }

        .welcome-blob {
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(107,155,230,.30), transparent 70%);
            pointer-events: none;
        }

        .welcome-blob2 {
            position: absolute;
            bottom: -40px;
            left: 30%;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(237,163,18,.18), transparent 70%);
            pointer-events: none;
        }

        .welcome-inner {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        @@media (min-width: 680px) {
            .welcome-inner { flex-direction: row; align-items: center; justify-content: space-between; }
        }

        .welcome-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .25em;
            color: var(--subhead);
            font-weight: 600;
        }

        .welcome-title {
            margin-top: 8px;
            font-size: clamp(26px, 4vw, 36px);
            font-weight: 800;
            color: var(--brand);
            letter-spacing: -1px;
        }

        .welcome-sub {
            margin-top: 8px;
            font-size: 14px;
            color: rgba(3,40,159,.60);
            max-width: 420px;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, var(--heading), #f5a623);
            color: var(--white);
            font-weight: 700;
            font-size: 14px;
            padding: 12px 28px;
            border-radius: 99px;
            box-shadow: 0 6px 22px rgba(237,163,18,.40);
            transition: transform .18s, box-shadow .18s;
            white-space: nowrap;
        }

        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(237,163,18,.50);
        }

        /* ─── Stats Grid ──────────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        @@media (min-width: 900px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }

        .stat-card {
            border-radius: 18px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            backdrop-filter: blur(8px);
            padding: 20px 22px;
            box-shadow: 0 4px 20px rgba(3,40,159,.07);
            transition: box-shadow .2s, transform .2s;
        }

        .stat-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .stat-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .18em;
            color: rgba(3,40,159,.50);
            font-weight: 600;
        }

        .stat-value {
            margin-top: 8px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--brand), var(--subhead));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .stat-sub {
            margin-top: 4px;
            font-size: 12px;
            color: rgba(3,40,159,.45);
        }

        /* ─── Section Header ──────────────────────────────── */
        .section-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .section-eyebrow {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .22em;
            color: var(--subhead);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .section-eyebrow svg { width: 13px; height: 13px; }

        .section-title {
            margin-top: 6px;
            font-size: clamp(20px, 3vw, 26px);
            font-weight: 800;
            color: var(--brand);
            letter-spacing: -0.5px;
        }

        .see-all {
            font-size: 13px;
            color: rgba(3,40,159,.55);
            font-weight: 500;
            transition: color .15s;
        }

        .see-all:hover { color: var(--heading); }

        /* ─── Art Cards Grid ──────────────────────────────── */
        .art-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        @@media (min-width: 640px)  { .art-grid { grid-template-columns: repeat(3, 1fr); } }
        @@media (min-width: 1100px) { .art-grid { grid-template-columns: repeat(4, 1fr); } }

        .art-card {
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid var(--border);
            background: var(--card-bg);
            box-shadow: 0 4px 18px rgba(3,40,159,.07);
            transition: border-color .2s, box-shadow .2s, transform .2s;
        }

        .art-card:hover {
            border-color: var(--subhead);
            box-shadow: 0 8px 32px rgba(3,40,159,.18);
            transform: translateY(-3px);
        }

        .art-thumb {
            aspect-ratio: 1;
            overflow: hidden;
            background: var(--brand-soft);
        }

        .art-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }

        .art-card:hover .art-thumb img { transform: scale(1.08); }

        .art-info { padding: 14px; }

        .art-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--brand);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .art-artist { font-size: 11px; color: rgba(3,40,159,.52); margin-top: 2px; }

        .art-price {
            margin-top: 8px;
            font-size: 13px;
            font-weight: 800;
            color: var(--heading);
        }

        /* ─── Bottom Two Columns ──────────────────────────── */
        .two-col {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @@media (min-width: 900px) { .two-col { grid-template-columns: 1fr 1fr; } }

        .list-card {
            border-radius: 22px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            backdrop-filter: blur(8px);
            padding: 24px;
            box-shadow: 0 4px 20px rgba(3,40,159,.07);
        }

        .list-card-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--brand);
        }

        .list-card-sub {
            font-size: 11px;
            color: rgba(3,40,159,.45);
            margin-top: 2px;
        }

        .list-items { margin-top: 18px; display: flex; flex-direction: column; gap: 10px; }

        .list-item {
            display: flex;
            align-items: center;
            gap: 14px;
            border-radius: 14px;
            padding: 12px;
            background: rgba(255,255,255,.55);
            transition: background .18s;
        }

        .list-item:hover { background: rgba(107,155,230,.12); }

        .list-item-thumb {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            object-fit: cover;
            background: var(--brand-soft);
            flex-shrink: 0;
        }

        .list-item-info { flex: 1; min-width: 0; }

        .list-item-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--brand);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .list-item-artist { font-size: 11px; color: rgba(3,40,159,.50); margin-top: 2px; }

        .list-item-value {
            font-size: 13px;
            font-weight: 800;
            color: var(--heading);
            white-space: nowrap;
        }
    </style>
</head>
<body>
<div class="layout">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <aside class="sidebar">
        <a href="/" class="logo">
            <div class="logo-icon">A</div>
            <span class="logo-text">Artify</span>
        </a>

        <nav class="sidebar-nav">
            @foreach (var item in navItems)
            {
                <a href="@item.Url" class="nav-item @(item.Active ? "active" : "")">
                    <i data-feather="@item.Icon"></i>
                    @item.Label
                </a>
            }
        </nav>

        <a href="#" class="logout-btn" id="logoutBtn">
            <i data-feather="log-out"></i>
            Logout
        </a>
    </aside>

    <!-- ══ MAIN ═════════════════════════════════════════════ -->
    <main class="main">

        <!-- Top bar -->
        <div class="topbar">
            <div class="search-wrap">
                <i data-feather="search" class="search-icon"></i>
                <input type="text" class="search-input" placeholder="Search artworks, artists, collections…" />
            </div>
            <button class="icon-btn" title="Notifications">
                <i data-feather="bell"></i>
            </button>
            <div class="avatar">A</div>
        </div>

        <!-- Content -->
        <div class="content">

            <!-- Welcome Banner -->
            <div class="welcome-banner">
                <div class="welcome-blob"></div>
                <div class="welcome-blob2"></div>
                <div class="welcome-inner">
                    <div>
                        <div class="welcome-label">Welcome back</div>
                        <h1 class="welcome-title">Hello, <span id="profileName">Alex</span></h1>
                        <p class="welcome-sub">12 new drops match your taste today. Step back into the gallery.</p>
                    </div>
                    <a href="#" class="cta-btn">Continue exploring →</a>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-grid">
                @foreach (var s in stats)
                {
                    <div class="stat-card">
                        <div class="stat-label">@s.Label</div>
                        <div class="stat-value">@s.Value</div>
                        <div class="stat-sub">@s.Sub</div>
                    </div>
                }
            </div>

            <!-- Recommended Artworks -->
            <section>
                <div class="section-header">
                    <div>
                        <div class="section-eyebrow">
                            <i data-feather="trending-up"></i> For you
                        </div>
                        <h2 class="section-title">Recommended artworks</h2>
                    </div>
                    <a href="#" class="see-all">See all</a>
                </div>

                <div class="art-grid">
                    @foreach (var t in trending)
                    {
                        <div class="art-card">
                            <div class="art-thumb">
                                <img src="@t.Img" alt="@t.Title" loading="lazy" />
                            </div>
                            <div class="art-info">
                                <div class="art-title">@t.Title</div>
                                <div class="art-artist">by @t.Artist</div>
                                <div class="art-price">@t.Price</div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- My Collection + Wishlist -->
            <div class="two-col">

                <!-- My Collection -->
                <div class="list-card">
                    <div class="list-card-title">My collection</div>
                    <div class="list-card-sub">Recently acquired</div>
                    <div class="list-items">
                        @foreach (var c in collected)
                        {
                            <div class="list-item">
                                <img src="@c.Img" alt="@c.Title" class="list-item-thumb" loading="lazy" />
                                <div class="list-item-info">
                                    <div class="list-item-title">@c.Title</div>
                                    <div class="list-item-artist">by @c.Artist</div>
                                </div>
                                <div class="list-item-value">@c.Value</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Wishlist -->
                <div class="list-card">
                    <div class="list-card-title">Wishlist</div>
                    <div class="list-card-sub">Pieces you're watching</div>
                    <div class="list-items">
                        @foreach (var w in wishlist)
                        {
                            <div class="list-item">
                                <img src="@w.Img" alt="@w.Title" class="list-item-thumb" loading="lazy" />
                                <div class="list-item-info">
                                    <div class="list-item-title">@w.Title</div>
                                    <div class="list-item-artist">by @w.Artist</div>
                                </div>
                                <div class="list-item-value">@w.Value</div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div><!-- /content -->
    </main>
</div>

<script>feather.replace();</script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $('#logoutBtn').on('click', function (e) {
            e.preventDefault();
            localStorage.removeItem("token");
            window.location.href = "@Url.Action("Logout", "Auth")"; // Ensure fallback or form submission if needed
        });

        var token = localStorage.getItem("token");

        if (!token) {
            alert("Please login first");
            window.location.href = "/Auth/UserLogin";
            return;
        }

        $.ajax({
            url: 'http://localhost:5183/api/UserProfile/GetProfile',
            type: 'GET',
            headers: {
                "Authorization": "Bearer " + token 
            },
            success: function (response) {
                if (response.success) {
                    var u = response.data;
                    var name = u.c_FullName || u.c_UserName || '—';
                    $('#profileName').text(name);
                    $('#profileEmail').text(u.c_Email || '—');
                    
                    if (u.c_Image) {
                        $('.avatar').html('<img src="' + u.c_Image + '" style="width:100%;height:100%;border-radius:50%;object-fit:cover;"/>');
                    }
                }
            },
            error: function () {
                alert("Session expired. Please login again.");
                window.location.href = "/Auth/UserLogin";
            }
        });
    });
</script>

</body>
</html>
