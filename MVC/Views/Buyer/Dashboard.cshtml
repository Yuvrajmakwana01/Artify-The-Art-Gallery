@{
    ViewData["Title"] = "Buyer Dashboard";
    Layout = null;

    var dashboardUrl = Url.Action("Dashboard", "Buyer") ?? "/Buyer/Dashboard";
    var exploreUrl = Url.Action("ExploreArt", "Buyer") ?? "/Buyer/ExploreArt";
    var wishlistUrl = Url.Action("Index", "Wishlist") ?? "/Wishlist/Index";
    var cartUrl = Url.Action("Index", "Cart") ?? "/Cart";
    var loginUrl = Url.Action("UserLogin", "Auth") ?? "/Auth/UserLogin";
    var logoutUrl = Url.Action("Logout", "Auth") ?? "/Auth/Logout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artify</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <script src="https://unpkg.com/feather-icons"></script>
    <style>
        :root {
            --bg: #eef3f8;
            --brand: #1637a8;
            --heading: #f6ad09;
            --subhead: #5d88e5;
            --text: #1637a8;
            --ink: #1d2433;
            --muted: #6f7f99;
            --white: #ffffff;
            --danger: #d64c41;
            --danger-soft: rgba(214, 76, 65, 0.08);
            --success: #15803d;
            --success-soft: rgba(21, 128, 61, 0.08);
            --warning: #a16207;
            --warning-soft: rgba(161, 98, 7, 0.08);
            --brand-soft: rgba(22, 55, 168, 0.08);
            --brand-mid: rgba(22, 55, 168, 0.18);
            --heading-soft: rgba(246, 173, 9, 0.16);
            --subhead-soft: rgba(93, 136, 229, 0.18);
            --border: rgba(22, 55, 168, 0.10);
            --card-bg: rgba(255, 255, 255, 0.96);
            --sidebar-bg: linear-gradient(180deg, #0e2d99 0%, #0a1d70 100%);
            --shadow: 0 18px 48px rgba(10, 30, 100, 0.12);
            --shadow-hover: 0 24px 56px rgba(10, 30, 100, 0.16);
            --radius: 24px;
            --radius-sm: 14px;
            --radius-xs: 10px;
            --transition: 0.22s ease;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background:
                radial-gradient(circle at top right, rgba(93, 136, 229, 0.18), transparent 22%),
                radial-gradient(circle at top left, rgba(246, 173, 9, 0.08), transparent 18%),
                var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            border: none;
            background: none;
            font: inherit;
            cursor: pointer;
        }

        img {
            display: block;
            max-width: 100%;
        }

        .layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 286px;
            flex-shrink: 0;
            background: var(--sidebar-bg);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            padding: 28px 18px;
            position: sticky;
            top: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            box-shadow: 20px 0 50px rgba(5, 18, 74, 0.18);
            z-index: 20;
            overflow: hidden;
            transition: width var(--transition), padding var(--transition), opacity var(--transition), border-color var(--transition), box-shadow var(--transition);
        }

        .layout.sidebar-collapsed .sidebar {
            width: 0;
            padding-left: 0;
            padding-right: 0;
            padding-top: 0;
            padding-bottom: 0;
            opacity: 0;
            border-right-color: transparent;
            box-shadow: none;
            pointer-events: none;
        }

        .logo {
            display: block;
            margin-bottom: 34px;
            padding: 0 12px 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .logo-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0b0c10;
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.24);
            margin-bottom: 14px;
        }

        .logo-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(2.65) translateX(3%);
        }

        .logo-text {
            display: block;
            color: var(--white);
            font-family: 'Playfair Display', serif;
            font-size: 34px;
            font-weight: 800;
            letter-spacing: -0.04em;
            line-height: 1;
        }

        .logo-text::after {
            content: "";
            display: inline-block;
            width: 10px;
            height: 10px;
            margin-left: 4px;
            border-radius: 50%;
            background: var(--heading);
            vertical-align: middle;
        }

        .logo-copy {
            display: block;
            margin-top: 10px;
            font-size: 13px;
            letter-spacing: 0.24em;
            color: rgba(255, 255, 255, 0.55);
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }

        .nav-item,
        .logout-btn {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 14px;
            color: rgba(255, 255, 255, 0.72);
            transition: background var(--transition), color var(--transition), transform var(--transition), box-shadow var(--transition);
            text-align: left;
        }

        .nav-item:hover,
        .logout-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            color: var(--white);
            transform: translateX(2px);
        }

        .nav-item.active {
            background: linear-gradient(135deg, #f6ad09, #ffbf33);
            color: #15285f;
            box-shadow: 0 16px 30px rgba(246, 173, 9, 0.24);
        }

        .nav-item.active svg {
            color: #15285f;
        }

        .nav-item svg,
        .logout-btn svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        .main {
            flex: 1;
            min-width: 0;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 12;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 18px 34px;
            border-bottom: 1px solid rgba(22, 55, 168, 0.06);
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 24px rgba(14, 45, 153, 0.04);
        }

        .sidebar-toggle-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 46px;
            height: 46px;
            border-radius: 14px;
            border: 1px solid rgba(22, 55, 168, 0.10);
            background: rgba(255, 255, 255, 0.96);
            color: var(--brand);
            box-shadow: 0 10px 22px rgba(22, 55, 168, 0.08);
            transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background var(--transition);
            flex-shrink: 0;
        }

        .sidebar-toggle-btn:hover {
            transform: translateY(-1px);
            border-color: rgba(22, 55, 168, 0.2);
            box-shadow: 0 12px 26px rgba(22, 55, 168, 0.12);
            background: var(--white);
        }

        .sidebar-toggle-btn svg {
            width: 18px;
            height: 18px;
        }

        .topbar-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--brand);
            letter-spacing: -0.03em;
            white-space: nowrap;
        }

        .search-wrap {
            position: relative;
            flex: 1;
            max-width: 420px;
            margin-left: auto;
        }

        .search-wrap i,
        .search-wrap svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(3, 40, 159, 0.42);
            width: 16px;
            height: 16px;
        }

        .search-input {
            width: 100%;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.72);
            padding: 11px 16px 11px 42px;
            font-size: 14px;
            color: var(--ink);
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition);
        }

        .search-input:focus {
            border-color: var(--subhead);
            box-shadow: 0 0 0 3px rgba(107, 155, 230, 0.18);
        }

        .search-input::placeholder {
            color: rgba(3, 40, 159, 0.42);
        }

        .icon-btn {
            position: relative;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.76);
            display: grid;
            place-items: center;
            color: var(--brand);
            transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
        }

        .icon-btn:hover {
            transform: translateY(-2px);
            border-color: var(--brand);
            box-shadow: 0 0 0 3px var(--brand-soft);
        }

        .icon-btn svg {
            width: 16px;
            height: 16px;
        }

        .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            min-width: 20px;
            height: 20px;
            padding: 0 5px;
            border-radius: 999px;
            background: var(--heading);
            color: var(--white);
            font-size: 11px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--white);
        }

        .badge.zero {
            display: none;
        }

        .avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            overflow: hidden;
            background: linear-gradient(135deg, var(--brand), var(--subhead));
            color: var(--white);
            font-weight: 700;
            box-shadow: 0 10px 22px rgba(3, 40, 159, 0.2);
        }

        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .content {
            padding: 38px 34px 34px;
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        .welcome-banner {
            position: relative;
            overflow: hidden;
            border-radius: var(--radius);
            border: 1px solid rgba(22, 55, 168, 0.06);
            background: linear-gradient(120deg, #1436aa 0%, #2249c4 45%, #6c97ea 100%);
            padding: 34px 38px;
            box-shadow: 0 18px 44px rgba(22, 55, 168, 0.18);
            margin-bottom: 18px;
        }

        .welcome-banner::before,
        .welcome-banner::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .welcome-banner::before {
            width: 190px;
            height: 190px;
            top: 26px;
            right: 58px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.10), transparent 70%);
        }

        .welcome-banner::after {
            width: 140px;
            height: 140px;
            bottom: -46px;
            right: 26px;
            left: auto;
            background: radial-gradient(circle, rgba(246, 173, 9, 0.16), transparent 72%);
        }

        .welcome-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }

        .welcome-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.24em;
            color: rgba(255, 255, 255, 0.7);
            font-weight: 700;
        }

        .welcome-title {
            margin-top: 8px;
            font-family: 'Playfair Display', serif;
            font-size: clamp(28px, 3.5vw, 40px);
            font-weight: 700;
            color: var(--white);
            line-height: 1.06;
            letter-spacing: -0.03em;
        }

        .welcome-title span {
            color: var(--heading);
        }

        .welcome-sub {
            margin-top: 10px;
            max-width: 560px;
            color: rgba(255, 255, 255, 0.82);
            font-size: 15px;
            line-height: 1.7;
        }

        .cta-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-amber,
        .btn-ghost,
        .btn-danger {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 999px;
            padding: 12px 22px;
            font-size: 14px;
            font-weight: 600;
            transition: transform var(--transition), box-shadow var(--transition), background var(--transition), color var(--transition), border-color var(--transition);
        }

        .btn-amber {
            background: linear-gradient(135deg, var(--heading), #ffbf33);
            color: #15285f;
            box-shadow: 0 14px 28px rgba(246, 173, 9, 0.28);
        }

        .btn-amber:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(237, 163, 18, 0.28);
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.94);
            color: var(--brand);
            border: 1px solid rgba(22, 55, 168, 0.08);
        }

        .btn-ghost:hover {
            transform: translateY(-2px);
            border-color: var(--brand);
            box-shadow: 0 0 0 3px var(--brand-soft);
        }

        .btn-danger {
            background: var(--danger-soft);
            color: var(--danger);
            border: 1px solid rgba(214, 76, 65, 0.18);
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            background: rgba(214, 76, 65, 0.12);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 18px;
        }

        .stat-card {
            position: relative;
            overflow: hidden;
            border-radius: 18px;
            background: var(--card-bg);
            border: 1px solid rgba(3, 40, 159, 0.08);
            box-shadow: var(--shadow);
            padding: 22px 20px;
            transition: transform var(--transition), box-shadow var(--transition);
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
        }

        .stat-card::before {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 86px;
            height: 86px;
            border-radius: 0 0 0 86px;
            opacity: 0.12;
        }

        .stat-card.s1::before { background: var(--brand); }
        .stat-card.s2::before { background: var(--heading); }
        .stat-card.s3::before { background: #10b981; }
        .stat-card.s4::before { background: #f59e0b; }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

        .stat-card.s1 .stat-icon {
            background: rgba(3, 40, 159, 0.1);
            color: var(--brand);
        }

        .stat-card.s2 .stat-icon {
            background: rgba(237, 163, 18, 0.12);
            color: var(--heading);
        }

        .stat-card.s3 .stat-icon {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
        }

        .stat-card.s4 .stat-icon {
            background: rgba(245, 158, 11, 0.12);
            color: #f59e0b;
        }

        .stat-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--muted);
            font-weight: 700;
        }

        .stat-value {
            margin-top: 10px;
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--ink);
            line-height: 1;
        }

        .stat-sub {
            margin-top: 8px;
            font-size: 12px;
            color: var(--muted);
        }

        .bottom-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 320px;
            gap: 20px;
        }

        .panel-card {
            border-radius: var(--radius);
            background: var(--card-bg);
            border: 1px solid rgba(22, 55, 168, 0.06);
            box-shadow: 0 16px 40px rgba(19, 41, 112, 0.08);
            padding: 28px;
        }

        .panel-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .panel-eyebrow {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.22em;
            color: var(--subhead);
            font-weight: 700;
        }

        .panel-title {
            margin-top: 8px;
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            font-weight: 700;
            color: var(--brand);
            line-height: 1.08;
            letter-spacing: -0.03em;
        }

        .panel-copy {
            margin-top: 8px;
            color: var(--muted);
            font-size: 14px;
            line-height: 1.7;
            max-width: 680px;
        }

        .panel-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.76);
            border: 1px solid var(--border);
            color: var(--brand);
            font-size: 13px;
            font-weight: 600;
        }

        .activity-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid rgba(3, 40, 159, 0.06);
        }

        .activity-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .activity-dot {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .activity-dot.order {
            background: rgba(3, 40, 159, 0.1);
            color: var(--brand);
        }

        .activity-dot.wishlist {
            background: rgba(214, 76, 65, 0.1);
            color: var(--danger);
        }

        .activity-dot.download {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
        }

        .activity-text {
            font-size: 14px;
            color: var(--ink);
            line-height: 1.55;
        }

        .activity-time {
            margin-top: 4px;
            font-size: 12px;
            color: var(--muted);
        }

        .quick-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .qa-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.74);
            border: 1px solid rgba(3, 40, 159, 0.08);
            color: var(--ink);
            transition: transform var(--transition), background var(--transition), color var(--transition), box-shadow var(--transition);
            text-align: left;
        }

        .qa-item:hover {
            transform: translateX(3px);
            background: var(--brand-soft);
            color: var(--brand);
            box-shadow: 0 10px 20px rgba(3, 40, 159, 0.1);
        }

        .qa-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 8px 18px rgba(3, 40, 159, 0.08);
            flex-shrink: 0;
        }

        .dashboard-section {
            display: none;
        }

        .dashboard-section.active {
            display: block;
        }

        .section-surface {
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.62);
            border: 1px solid rgba(3, 40, 159, 0.06);
            padding: 22px;
        }

        .loading-state,
        .empty-state {
            text-align: center;
            padding: 46px 22px;
            color: var(--muted);
        }

        .loading-spinner {
            display: inline-block;
            width: 38px;
            height: 38px;
            border: 3px solid rgba(3, 40, 159, 0.1);
            border-top-color: var(--heading);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-bottom: 14px;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        .message-box {
            display: none;
            padding: 14px 16px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .message-box.show {
            display: block;
        }

        .message-box.success {
            background: rgba(220, 252, 231, 0.9);
            color: #166534;
            border: 1px solid #86efac;
        }

        .message-box.error {
            background: rgba(254, 226, 226, 0.92);
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .message-box.warning {
            background: rgba(254, 243, 199, 0.9);
            color: #92400e;
            border: 1px solid #fcd34d;
        }

        .profile-layout {
            display: block;
        }

        .profile-panel {
            display: none;
            max-width: 1020px;
        }

        .profile-panel.active {
            display: block;
        }

        .profile-view-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 22px;
            align-items: start;
        }

        .profile-summary-card,
        .profile-form-card,
        .profile-main-card,
        .settings-card {
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.74);
            border: 1px solid rgba(3, 40, 159, 0.08);
            padding: 22px;
        }

        .profile-main-card {
            min-height: 100%;
            max-width: 960px;
        }

        .profile-hero {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 18px;
        }

        .profile-photo-shell,
        .avatar-circle {
            width: 92px;
            height: 92px;
            border-radius: 24px;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(3, 40, 159, 0.18), rgba(107, 155, 230, 0.24));
            display: grid;
            place-items: center;
            box-shadow: 0 16px 28px rgba(3, 40, 159, 0.12);
            position: relative;
        }

        .profile-photo-shell img,
        .avatar-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-fallback,
        #avatarIcon {
            color: var(--white);
            font-size: 26px;
            font-weight: 700;
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--brand);
            line-height: 1.08;
        }

        .profile-email {
            margin-top: 6px;
            color: var(--muted);
            font-size: 14px;
        }

        .profile-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            padding: 8px 12px;
            border-radius: 999px;
            background: var(--heading-soft);
            color: #9a6324;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.03em;
        }

        .detail-list {
            display: grid;
            gap: 12px;
            margin-top: 16px;
        }

        .detail-item {
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(222, 230, 233, 0.52);
        }

        .detail-item label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--muted);
            font-weight: 700;
            margin-bottom: 6px;
        }

        .detail-item span {
            color: var(--ink);
            font-size: 14px;
            font-weight: 600;
            word-break: break-word;
        }

        .summary-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 18px;
        }

        .profile-summary-card .summary-actions {
            margin-top: 22px;
        }

        .section-divider {
            margin: 18px -22px 18px;
            padding: 0 22px;
            position: relative;
        }

        .section-divider span {
            display: inline-block;
            padding: 0 12px;
            background: rgba(255, 255, 255, 0.74);
            color: var(--brand);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.18em;
            position: relative;
            z-index: 1;
        }

        .section-divider::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 22px;
            right: 22px;
            height: 1px;
            background: rgba(3, 40, 159, 0.08);
        }

        .avatar-section {
            display: flex;
            align-items: center;
            gap: 18px;
            flex-wrap: wrap;
        }

        .avatar-wrapper {
            position: relative;
        }

        .avatar-cam-btn {
            position: absolute;
            right: -4px;
            bottom: -4px;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--heading), #f1b533);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 18px rgba(237, 163, 18, 0.22);
        }

        .avatar-info strong {
            color: var(--ink);
            font-size: 16px;
        }

        .avatar-info .hint {
            margin-top: 4px;
            color: var(--muted);
            font-size: 13px;
        }

        .upload-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 12px;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.82);
            border: 1px solid rgba(3, 40, 159, 0.12);
            color: var(--brand);
            font-size: 13px;
            font-weight: 600;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--muted);
            font-weight: 700;
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            padding: 13px 16px;
            border-radius: 14px;
            border: 1.5px solid rgba(3, 40, 159, 0.12);
            background: rgba(255, 255, 255, 0.8);
            color: var(--ink);
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
        }

        .form-input:focus {
            border-color: var(--subhead);
            background: var(--white);
            box-shadow: 0 0 0 4px rgba(107, 155, 230, 0.18);
        }

        .form-input.is-error {
            border-color: #e53e3e;
            box-shadow: 0 0 0 4px rgba(229, 62, 62, 0.12);
        }

        .edit-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .orders-shell {
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.62);
            border: 1px solid rgba(3, 40, 159, 0.06);
            padding: 22px;
        }

        .orders-mode {
            display: none;
        }

        .orders-mode.active {
            display: block;
        }

        .orders-layout {
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(340px, 0.95fr);
            gap: 20px;
            align-items: start;
        }

        .orders-list-col {
            min-width: 0;
        }

        .order-detail-panel {
            min-width: 0;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(3, 40, 159, 0.08);
            box-shadow: 0 12px 28px rgba(3, 40, 159, 0.08);
            padding: 22px;
            position: sticky;
            top: 96px;
        }

        .order-detail-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .order-detail-code {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            color: var(--brand);
            line-height: 1.05;
        }

        .order-detail-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 10px;
            color: var(--muted);
            font-size: 12px;
        }

        .order-detail-meta-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .order-detail-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .order-detail-back {
            margin-bottom: 18px;
        }

        .order-detail-card {
            border-radius: 18px;
            background: rgba(222, 230, 233, 0.42);
            border: 1px solid rgba(3, 40, 159, 0.08);
            padding: 18px;
        }

        .order-detail-card + .order-detail-card {
            margin-top: 16px;
        }

        .order-detail-card-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--brand);
            margin-bottom: 14px;
        }

        .order-detail-items {
            display: flex;
            flex-direction: column;
        }

        .order-detail-item {
            display: grid;
            grid-template-columns: 68px minmax(0, 1fr) auto;
            gap: 14px;
            align-items: center;
            padding: 14px 0;
            border-bottom: 1px solid rgba(3, 40, 159, 0.08);
        }

        .order-detail-item:first-child {
            padding-top: 0;
        }

        .order-detail-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .order-detail-thumb {
            width: 68px;
            height: 68px;
            border-radius: 16px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.85);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            border: 1px solid rgba(3, 40, 159, 0.08);
        }

        .order-detail-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .order-detail-name {
            font-size: 15px;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.3;
        }

        .order-detail-artist {
            margin-top: 4px;
            font-size: 13px;
            color: var(--muted);
        }

        .order-detail-tag {
            display: inline-flex;
            margin-top: 8px;
            padding: 6px 10px;
            border-radius: 999px;
            background: rgba(3, 40, 159, 0.08);
            color: var(--brand);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .order-detail-item-actions {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
            min-width: 150px;
        }

        .order-detail-summary-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(3, 40, 159, 0.08);
            color: var(--ink);
            font-size: 14px;
        }

        .order-detail-summary-row:last-child {
            border-bottom: none;
        }

        .order-detail-summary-row.total {
            margin-top: 4px;
            padding-top: 14px;
            border-top: 2px solid rgba(3, 40, 159, 0.08);
            border-bottom: none;
            font-size: 17px;
            font-weight: 700;
        }

        .order-detail-summary-row.fee span:last-child {
            color: #9a6324;
            font-weight: 700;
        }

        .order-detail-info-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .order-detail-info-item {
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.72);
        }

        .order-detail-info-item label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--muted);
            font-weight: 700;
            margin-bottom: 6px;
        }

        .order-detail-info-item span {
            color: var(--ink);
            font-size: 14px;
            font-weight: 600;
            word-break: break-word;
        }

        .orders-stats {
            display: flex;
            gap: 22px;
            flex-wrap: wrap;
        }

        .orders-stat {
            text-align: right;
        }

        .orders-stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--brand);
            line-height: 1;
        }

        .orders-stat-label {
            margin-top: 4px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--muted);
            font-weight: 700;
        }

        .order-card {
            display: block;
            color: inherit;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(3, 40, 159, 0.08);
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 8px 22px rgba(3, 40, 159, 0.08);
            margin-bottom: 14px;
            transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
        }

        .order-card:hover {
            transform: translateY(-3px);
            border-color: rgba(237, 163, 18, 0.24);
            box-shadow: 0 18px 34px rgba(3, 40, 159, 0.12);
        }

        .order-card.is-active {
            border-color: rgba(237, 163, 18, 0.4);
            box-shadow: 0 0 0 3px rgba(237, 163, 18, 0.14), 0 18px 34px rgba(3, 40, 159, 0.12);
            transform: translateY(-2px);
        }

        .order-card-inner {
            display: flex;
            align-items: stretch;
        }

        .order-card-preview {
            width: 100px;
            display: none;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(3, 40, 159, 0.06), rgba(237, 163, 18, 0.08));
            flex-shrink: 0;
        }

        .preview-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.92);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
        }

        .preview-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .order-card-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 20px 22px;
            min-width: 0;
        }

        .order-card-info {
            flex: 1;
            min-width: 0;
        }

        .order-id-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 7px;
        }

        .order-id {
            font-size: 16px;
            font-weight: 700;
            color: var(--ink);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 999px;
            border: 1px solid;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .status-delivered {
            background: var(--success-soft);
            color: var(--success);
            border-color: rgba(21, 128, 61, 0.14);
        }

        .status-processing {
            background: var(--warning-soft);
            color: var(--warning);
            border-color: rgba(161, 98, 7, 0.16);
        }

        .status-failed {
            background: rgba(185, 28, 28, 0.08);
            color: #b91c1c;
            border-color: rgba(185, 28, 28, 0.16);
        }

        .order-preview-text {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 8px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .order-meta {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            color: var(--muted);
            font-size: 12px;
        }

        .order-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .order-card-right {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }

        .order-total {
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
        }

        .order-chevron {
            color: var(--muted);
            transition: transform var(--transition), color var(--transition);
        }

        .order-card:hover .order-chevron {
            transform: translateX(4px);
            color: var(--heading);
        }

        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .wish-card {
            border-radius: 22px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(3, 40, 159, 0.08);
            box-shadow: 0 12px 24px rgba(3, 40, 159, 0.08);
            transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
        }

        .wish-card:hover {
            transform: translateY(-3px);
            border-color: rgba(237, 163, 18, 0.24);
            box-shadow: 0 18px 34px rgba(3, 40, 159, 0.12);
        }

        .wish-image-wrap {
            position: relative;
            aspect-ratio: 1;
            overflow: hidden;
            background: rgba(222, 230, 233, 0.64);
        }

        .wish-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .wish-card:hover .wish-image-wrap img {
            transform: scale(1.06);
        }

        .wish-category {
            position: absolute;
            top: 14px;
            left: 14px;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.9);
            color: var(--brand);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.04em;
        }

        .wish-body {
            padding: 18px;
        }

        .wish-title {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            color: var(--brand);
            line-height: 1.1;
        }

        .wish-artist {
            margin-top: 6px;
            color: var(--muted);
            font-size: 14px;
        }

        .wish-meta {
            margin-top: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .wish-price {
            color: var(--heading);
            font-size: 18px;
            font-weight: 700;
        }

        .wish-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 14px;
        }

        .wish-actions .btn-ghost,
        .wish-actions .btn-danger {
            flex: 1;
            min-width: 0;
            padding: 11px 16px;
            border-radius: 14px;
        }

        .downloads-shell {
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.62);
            border: 1px solid rgba(3, 40, 159, 0.06);
            padding: 22px;
        }

        .download-banner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 18px;
            background: rgba(237, 163, 18, 0.08);
            border: 1px solid rgba(237, 163, 18, 0.18);
            color: #9a6324;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .download-banner strong {
            display: block;
            font-size: 14px;
        }

        .download-banner span {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            color: var(--muted);
        }

        .dl-progress-wrap {
            display: none;
            height: 6px;
            border-radius: 999px;
            background: rgba(3, 40, 159, 0.08);
            overflow: hidden;
            margin-bottom: 18px;
        }

        .dl-progress-bar {
            width: 0;
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--heading), #f1b533);
            transition: width 0.4s ease;
        }

        .download-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .download-row {
            display: grid;
            grid-template-columns: 80px minmax(0, 1fr) auto;
            gap: 16px;
            align-items: center;
            padding: 16px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(3, 40, 159, 0.08);
        }

        .download-thumb {
            width: 80px;
            height: 80px;
            border-radius: 16px;
            overflow: hidden;
            background: rgba(222, 230, 233, 0.72);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
        }

        .download-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .download-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.2;
        }

        .download-meta {
            margin-top: 6px;
            font-size: 13px;
            color: var(--muted);
            line-height: 1.6;
        }

        .download-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(3, 40, 159, 0.08);
            color: var(--brand);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .download-actions {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
            min-width: 150px;
        }

        .download-price {
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
        }

        .dl-counter {
            font-size: 12px;
            color: var(--muted);
        }

        .dl-counter.maxed {
            color: var(--danger);
            font-weight: 700;
        }

        .btn-disabled {
            opacity: 0.6;
            cursor: not-allowed;
            pointer-events: none;
            box-shadow: none;
            transform: none;
        }

        .pw-input-wrap {
            position: relative;
        }

        .form-input.pad-right {
            padding-right: 48px;
        }

        .eye-btn {
            position: absolute;
            top: 50%;
            right: 14px;
            transform: translateY(-50%);
            color: var(--muted);
            line-height: 1;
        }

        .strength-bar {
            display: flex;
            gap: 5px;
            margin-top: 10px;
        }

        .strength-seg {
            height: 4px;
            flex: 1;
            border-radius: 999px;
            background: rgba(3, 40, 159, 0.12);
        }

        .strength-seg.weak { background: #e53e3e; }
        .strength-seg.fair { background: #dd6b20; }
        .strength-seg.good { background: #d69e2e; }
        .strength-seg.strong { background: #38a169; }

        .strength-label {
            margin-top: 6px;
            font-size: 12px;
            font-weight: 700;
        }

        @@media (min-width: 640px) {
            .order-card-preview {
                display: flex;
            }
        }

        @@media (max-width: 1180px) {
            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .wishlist-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 1040px) {
            .profile-view-grid,
            .orders-layout,
            .bottom-grid {
                grid-template-columns: 1fr;
            }

            .order-detail-panel {
                position: static;
            }

            .download-row {
                grid-template-columns: 80px minmax(0, 1fr);
            }

            .download-actions {
                grid-column: 1 / -1;
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
                width: 100%;
            }
        }

        @@media (max-width: 860px) {
            .sidebar {
                display: none;
            }

            .sidebar-toggle-btn {
                display: none;
            }

            .content,
            .topbar {
                padding-left: 18px;
                padding-right: 18px;
            }

            .wishlist-grid,
            .stats-grid,
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .content {
                padding-top: 18px;
                gap: 18px;
            }

            .welcome-banner,
            .panel-card,
            .orders-shell,
            .downloads-shell {
                padding: 18px;
            }

            .panel-title {
                font-size: 24px;
            }

            .order-card-content {
                flex-direction: column;
                align-items: flex-start;
            }

            .order-card-right {
                width: 100%;
                justify-content: space-between;
            }

            .order-detail-item {
                grid-template-columns: 1fr;
            }

            .order-detail-thumb {
                width: 100%;
                height: 220px;
            }

            .order-detail-item-actions {
                align-items: stretch;
                min-width: 0;
            }

            .order-detail-info-grid {
                grid-template-columns: 1fr;
            }

            .download-row {
                grid-template-columns: 1fr;
            }

            .download-thumb {
                width: 100%;
                height: 220px;
            }

            .download-actions {
                flex-direction: column;
                align-items: stretch;
            }

            .edit-actions,
            .summary-actions,
            .panel-actions,
            .cta-group {
                flex-direction: column;
                align-items: stretch;
            }

            .btn-amber,
            .btn-ghost,
            .btn-danger,
            .wish-actions .btn-ghost,
            .wish-actions .btn-danger {
                width: 100%;
            }
        }
    </style>
</head>
