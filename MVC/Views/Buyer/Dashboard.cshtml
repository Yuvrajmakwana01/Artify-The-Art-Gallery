                    activities.push({
                        type: 'order',
                        text: 'Order ORD-' + String(order.orderId).padStart(8, '0') + ' is ' + (order.orderStatus || 'Processing') + '.',
                        time: formatDate(order.createdAt)
                    });
                });

                if (getWishlist().length > 0) {
                    activities.push({
                        type: 'wishlist',
                        text: getWishlist().length + ' artwork' + (getWishlist().length === 1 ? '' : 's') + ' currently saved in your wishlist.',
                        time: 'Synced from your local wishlist'
                    });
                }

                if (state.downloadItems.length > 0) {
                    activities.push({
                        type: 'download',
                        text: state.downloadItems.length + ' purchased artwork' + (state.downloadItems.length === 1 ? '' : 's') + ' available in Download Arts.',
                        time: 'Ready when you are'
                    });
