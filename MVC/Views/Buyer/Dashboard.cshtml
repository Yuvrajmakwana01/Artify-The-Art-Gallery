            function showOrdersMode(mode) {
                var listPanel = document.getElementById('ordersListPanel');
                var detailPanel = document.getElementById('ordersDetailPanel');
                var targetMode = mode === 'detail' ? 'detail' : 'list';

                state.ordersMode = targetMode;

                if (listPanel) {
                    listPanel.classList.toggle('active', targetMode === 'list');
                }

                if (detailPanel) {
                    detailPanel.classList.toggle('active', targetMode === 'detail');
                }
