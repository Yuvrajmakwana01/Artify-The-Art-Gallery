                    document.getElementById('profileHeroImg').src = localPreview;
                    document.getElementById('profileHeroImg').style.display = '';
                    document.getElementById('profileHeroFallback').style.display = 'none';
                    setAvatar((state.profile && (state.profile.c_FullName || state.profile.c_UserName || 'A').charAt(0).toUpperCase()) || 'A', localPreview);
                });

                document.getElementById('ordersContent').addEventListener('click', function (e) {
                    var card = e.target.closest('.order-card[data-order-id]');
                    if (!card) return;
                    e.preventDefault();
                    loadOrderDetail(card.getAttribute('data-order-id'));
                });

                document.getElementById('clearWishlistBtn').addEventListener('click', clearAllWishlist);
                document.getElementById('btnUpdate').addEventListener('click', updatePassword);
                document.getElementById('settingsResetBtn').addEventListener('click', resetPasswordForm);
            }

            window.removeWishlistItem = removeFromWishlist;
            window.addWishlistItemToCart = addToCart;
            window.toggleEye = toggleEye;
            window.checkStrength = checkStrength;
            window.dashboardOpenSection = function (section) {
                if (section === 'profile') {
                    showProfileMode('view');
                }
                if (section === 'orders') {
                    showOrdersMode('list');
                }
                setActiveSection(section, true);
            };
            window.dashboardShowOrdersList = function () {
                showOrdersMode('list');
            };
            window.dashboardDownloadOne = function (artworkId, orderId, title) {
                doDownload(artworkId, orderId, title, true);
            };
            window.downloadAllDashboard = function () {
                if (state.downloadingAll || state.downloadItems.length === 0) return;

                var eligible = state.downloadItems.filter(function (item) {
                    var status = state.downloadStatus[item.artworkId] || { canDownload: true, left: MAX_DL };
                    return status.canDownload && status.left > 0;
                });

                if (eligible.length === 0) {
                    document.getElementById('downloadCountPill').textContent = 'All downloads already used';
                    return;
                }

                state.downloadingAll = true;

                var button = document.getElementById('dlAllBtn');
                var wrap = document.getElementById('dlProgressWrap');
                var bar = document.getElementById('dlProgressBar');

                button.classList.add('btn-disabled');
                button.textContent = 'Downloading...';
                wrap.style.display = 'block';

                var chain = Promise.resolve();
                eligible.forEach(function (item, index) {
                    chain = chain.then(function () {
                        return doDownload(item.artworkId, item.orderId, item.title, false).then(function () {
                            bar.style.width = Math.round(((index + 1) / eligible.length) * 100) + '%';
                            if (index < eligible.length - 1) {
                                return new Promise(function (resolve) {
                                    setTimeout(resolve, 350);
                                });
                            }
                        });
                    });
                });

                chain.finally(function () {
                    state.downloadingAll = false;
                    button.classList.remove('btn-disabled');
                    button.innerHTML = '<span>Download All</span>';
                    setTimeout(function () {
                        wrap.style.display = 'none';
                        bar.style.width = '0%';
                    }, 1200);
                });
            };

            function init() {
                setSidebarCollapsed(loadSidebarPreference());
                feather.replace();
                bindSectionNavigation();
                bindStaticActions();
                updateBadges();
                showProfileMode('view');

                if (!getToken() || !getUserIdFromToken()) {
                    window.location.href = LOGIN_URL;
                    return;
                }

                setActiveSection(getRequestedSection(), false);

                Promise.all([
                    loadProfile(),
                    loadOrders(),
                    loadWishlist()
                ]).then(function () {
                    return loadDownloads();
                }).then(function () {
                    updateOverviewStats();
                    renderActivity();
                });
            }

            init();
        })();
    </script>
</body>
</html>
