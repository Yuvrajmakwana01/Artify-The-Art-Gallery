    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            var API_BASE = 'http://localhost:5183';
            var PROFILE_IMAGE_BASE = window.location.origin;
            var DASHBOARD_URL = '@dashboardUrl';
            var EXPLORE_URL = '@exploreUrl';
            var LOGIN_URL = '@loginUrl';
            var LOGOUT_URL = '@logoutUrl';
            var SIDEBAR_STATE_KEY = 'artify_dashboard_sidebar_collapsed';
            var MAX_DL = 1;
            var VALID_SECTIONS = ['dashboard', 'profile', 'orders', 'wishlist', 'downloads', 'settings'];

            var state = {
                profile: null,
                orders: [],
                wishlistItems: [],
                downloadItems: [],
                downloadStatus: {},
                orderDetailCache: {},
                activeOrderId: null,
                activeOrderDetail: null,
                ordersMode: 'list',
                search: '',
                downloadingAll: false,
                profileMode: 'view'
            };

            var currentImagePath = '';

            function getToken() {
                return localStorage.getItem('token');
            }

            function getUserIdFromToken() {
                var token = getToken();
                if (!token) return null;

                try {
                    var payload = token.split('.')[1];
                    var decoded = JSON.parse(atob(payload));
                    return decoded['user_id'] || decoded['c_UserId'] || decoded['userId'] || decoded['sub'];
                } catch (e) {
                    return null;
                }
            }

            function authFetch(url, options) {
                options = options || {};
                var token = getToken();
                return fetch(url, Object.assign({}, options, {
                    headers: Object.assign(
                        { 'Content-Type': 'application/json' },
                        token ? { 'Authorization': 'Bearer ' + token } : {},
                        options.headers || {}
                    )
                }));
            }

            function normalizeArray(data) {
                if (Array.isArray(data)) return data;
                if (data && Array.isArray(data.$values)) return data.$values;
                if (data && Array.isArray(data.data)) return data.data;
                if (data && data.data && Array.isArray(data.data.$values)) return data.data.$values;
                if (data && Array.isArray(data.items)) return data.items;
                return [];
            }

            function escapeHtml(text) {
                return (text || '')
                    .toString()
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function formatAmount(n) {
                return '$' + (parseFloat(n) || 0).toLocaleString('en-US', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }

            function formatDate(dateValue) {
                if (!dateValue) return '-';
                return new Date(dateValue).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                });
            }

            function artworkImageUrl(path) {
                if (!path) return 'https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=600';
                if (path.indexOf('http') === 0) return path;
                return window.location.origin + path;
            }

            function profileImageUrl(imageName) {
                if (!imageName) return '';
                var normalized = imageName.toString().trim().replace(/\\/g, '/');
                if (!normalized) return '';
                if (normalized.indexOf('http://') === 0 || normalized.indexOf('https://') === 0) return normalized;
                if (normalized.indexOf('profile_images/') === 0 || normalized.indexOf('UserImages/') === 0) {
                    normalized = '/' + normalized;
                }
                if (normalized.indexOf('/profile_images/') === 0 || normalized.indexOf('/UserImages/') === 0) {
                    return PROFILE_IMAGE_BASE + normalized;
                }
                if (normalized.charAt(0) === '/') {
                    return PROFILE_IMAGE_BASE + normalized;
                }
                return PROFILE_IMAGE_BASE + '/UserImages/' + normalized.replace(/^\/+/, '');
            }

            function setMessage(id, text, type) {
                var box = document.getElementById(id);
                if (!box) return;
                box.textContent = text;
                box.className = 'message-box show ' + (type || 'success');
            }

            function clearMessage(id) {
                var box = document.getElementById(id);
                if (!box) return;
                box.className = 'message-box';
                box.textContent = '';
            }

            function setText(id, value) {
                var el = document.getElementById(id);
                if (!el) return;
                el.textContent = value;
            }

            function showSuccessAlert(title, text) {
                if (window.Swal && typeof window.Swal.fire === 'function') {
                    return window.Swal.fire({
                        icon: 'success',
                        title: title,
                        text: text || '',
                        confirmButtonColor: '#03289F'
                    });
                }

                if (text) {
                    window.alert(title + '\n' + text);
                } else {
                    window.alert(title);
                }

                return Promise.resolve();
            }

            function setAvatar(initial, imageUrl) {
                var topbarAvatar = document.getElementById('topbarAvatar');
                if (!topbarAvatar) return;

                if (imageUrl) {
                    topbarAvatar.innerHTML = '<img src="' + imageUrl + '" alt="Profile" />';
                } else {
                    topbarAvatar.textContent = initial || 'A';
                }
            }

            function setProfileImages(imageName, fallbackLetter) {
                var imgSrc = profileImageUrl(imageName);
                var heroImg = document.getElementById('profileHeroImg');
                var profileImg = document.getElementById('profileImg');
                var heroFallback = document.getElementById('profileHeroFallback');
                var avatarIcon = document.getElementById('avatarIcon');

                if (imgSrc) {
                    if (heroImg) {
                        heroImg.src = imgSrc;
                        heroImg.style.display = '';
                    }
                    if (profileImg) {
                        profileImg.src = imgSrc;
                        profileImg.style.display = '';
                    }
                    if (heroFallback) {
                        heroFallback.style.display = 'none';
                    }
                    if (avatarIcon) {
                        avatarIcon.style.display = 'none';
                    }
                    setAvatar(fallbackLetter, imgSrc);
                } else {
                    if (heroImg) {
                        heroImg.style.display = 'none';
                    }
                    if (profileImg) {
                        profileImg.style.display = 'none';
                    }
                    if (heroFallback) {
                        heroFallback.style.display = '';
                        heroFallback.textContent = fallbackLetter || 'A';
                    }
                    if (avatarIcon) {
                        avatarIcon.style.display = '';
                    }
                    setAvatar(fallbackLetter, '');
                }
            }

            function showProfileMode(mode) {
                var viewPanel = document.getElementById('profileViewPanel');
                var editPanel = document.getElementById('profileEditPanel');
                var targetMode = mode === 'edit' ? 'edit' : 'view';

                state.profileMode = targetMode;

                if (viewPanel) {
                    viewPanel.classList.toggle('active', targetMode === 'view');
                }

                if (editPanel) {
                    editPanel.classList.toggle('active', targetMode === 'edit');
                }

                if (targetMode === 'edit') {
                    resetProfileForm();
                } else {
                    clearMessage('profileMsgBox');
                    if (state.profile) {
                        if (document.getElementById('fileInput')) {
                            document.getElementById('fileInput').value = '';
                        }
                        setProfileImages(currentImagePath, (state.profile.c_FullName || state.profile.c_UserName || 'A').charAt(0).toUpperCase());
                    }
