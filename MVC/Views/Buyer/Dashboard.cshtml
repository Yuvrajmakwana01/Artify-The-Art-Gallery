                document.querySelectorAll('[data-section]').forEach(function (item) {
                    item.classList.toggle('active', item.getAttribute('data-section') === section);
                });

                document.querySelectorAll('.nav-item').forEach(function (item) {
                    item.classList.toggle('active', item.getAttribute('data-section') === section);
                });

                history.replaceState({}, '', section === 'dashboard' ? DASHBOARD_URL : DASHBOARD_URL + '#' + section);

                if (shouldScroll) {
                    var target = document.querySelector('.dashboard-section[data-section="' + section + '"]');
                    if (target) {
