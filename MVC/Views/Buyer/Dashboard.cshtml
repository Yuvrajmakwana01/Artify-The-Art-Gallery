            function fetchDownloadStatus(artworkId) {
                return fetch(API_BASE + '/api/DownloadApi/status/' + artworkId, {
                    headers: {
                        'Authorization': 'Bearer ' + getToken()
                    }
                }).then(function (res) {
                    if (!res.ok) {
                        return { used: 0, left: MAX_DL, canDownload: true };
                    }
                    return res.json().then(function (d) {
                        return {
                            used: d.downloadCount || 0,
                            left: d.downloadsLeft || 0,
                            canDownload: d.canDownload !== false
                        };
                    });
                }).catch(function () {
                    return { used: 0, left: MAX_DL, canDownload: true };
                });
            }

            function updateDownloadRows(artworkId) {
                var status = state.downloadStatus[artworkId] || { used: 0, left: MAX_DL, canDownload: true };
                var rows = document.querySelectorAll('[data-download-row][data-artwork-id="' + artworkId + '"]');

                rows.forEach(function (row) {
                    var btn = row.querySelector('[data-download-btn]');
                    var counter = row.querySelector('[data-download-counter]');

                    if (!btn || !counter) return;

                    if (!status.canDownload || status.left <= 0) {
                        btn.className = 'btn-ghost btn-disabled';
                        btn.innerHTML = 'Limit Reached';
                        counter.textContent = MAX_DL + '/' + MAX_DL + ' used';
                        counter.className = 'dl-counter maxed';
                    } else {
                        btn.className = 'btn-ghost';
                        btn.innerHTML = 'Download';
                        counter.textContent = status.used + '/' + MAX_DL + ' used';
                        counter.className = 'dl-counter';
                    }
                });
            }

            function doDownload(artworkId, orderId, title, showSpinner) {
                var status = state.downloadStatus[artworkId] || { used: 0, left: MAX_DL, canDownload: true };
                if (!status.canDownload || status.left <= 0) {
                    return Promise.resolve(false);
                }

                var rows = document.querySelectorAll('[data-download-row][data-artwork-id="' + artworkId + '"]');
                if (showSpinner) {
                    rows.forEach(function (row) {
                        var btn = row.querySelector('[data-download-btn]');
                        if (btn) {
                            btn.classList.add('btn-disabled');
                            btn.textContent = 'Downloading...';
                        }
                    });
                }

                return fetch(API_BASE + '/api/DownloadApi/' + artworkId + '?orderId=' + orderId, {
                    headers: {
                        'Authorization': 'Bearer ' + getToken()
                    }
                }).then(function (res) {
                    if (res.status === 400) {
                        return res.json().catch(function () { return {}; }).then(function (err) {
                            if (err.limitReached) {
                                state.downloadStatus[artworkId] = { used: MAX_DL, left: 0, canDownload: false };
                                updateDownloadRows(artworkId);
                            }
                            return false;
                        });
                    }

                    if (!res.ok) {
                        throw new Error('Download failed.');
                    }

                    var used = parseInt(res.headers.get('X-Downloads-Used') || '0', 10);
                    var left = parseInt(res.headers.get('X-Downloads-Remaining') || '0', 10);
                    state.downloadStatus[artworkId] = { used: used, left: left, canDownload: left > 0 };

                    return res.blob().then(function (blob) {
                        var url = window.URL.createObjectURL(blob);
                        var link = document.createElement('a');
                        var mime = blob.type || '';
                        var ext = mime.indexOf('png') !== -1 ? '.png'
                            : mime.indexOf('gif') !== -1 ? '.gif'
                                : mime.indexOf('webp') !== -1 ? '.webp'
                                    : '.jpg';

                        link.href = url;
                        link.download = (title || 'artwork') + ext;
                        document.body.appendChild(link);
                        link.click();
                        link.remove();
                        window.URL.revokeObjectURL(url);
                        return true;
                    });
                }).catch(function () {
                    return fetchDownloadStatus(artworkId).then(function (fresh) {
                        state.downloadStatus[artworkId] = fresh;
                        return false;
                    });
                }).finally(function () {
                    updateDownloadRows(artworkId);
                });
            }

            function renderDownloads() {
                var items = filterBySearch(state.downloadItems, function (item) {
                    return [
                        item.title,
                        item.artistName,
                        item.categoryName,
                        item.orderId,
                        item.orderStatus
                    ].join(' ');
                });

                if (state.downloadItems.length === 0) {
                    document.getElementById('downloadsContent').innerHTML = '<div class="empty-state"><p>No purchased artwork files found yet.</p></div>';
                    return;
                }

                if (items.length === 0) {
                    document.getElementById('downloadsContent').innerHTML = '<div class="empty-state"><p>No download items match your search.</p></div>';
                    return;
                }

                document.getElementById('downloadsContent').innerHTML =
                    '<div class="download-list">'
                    + items.map(function (item) {
                        return ''
                            + '<div class="download-row" data-download-row data-artwork-id="' + item.artworkId + '">'
                            + '  <div class="download-thumb">'
                            +        (item.previewPath
                                ? '<img src="' + artworkImageUrl(item.previewPath) + '" alt="' + escapeHtml(item.title) + '" loading="lazy" />'
                                : '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>')
                            + '  </div>'
                            + '  <div>'
                            + '      <div class="download-title">' + escapeHtml(item.title) + '</div>'
                            + '      <div class="download-meta">Order ORD-' + String(item.orderId).padStart(8, '0') + ' | ' + escapeHtml(item.orderStatus || 'Processing') + ' | ' + escapeHtml(formatDate(item.createdAt)) + '</div>'
                            +        (item.categoryName ? '<div class="download-tag">' + escapeHtml(item.categoryName) + '</div>' : '')
                            + '  </div>'
                            + '  <div class="download-actions">'
                            + '      <div class="download-price">' + formatAmount(item.priceAtPurchase) + '</div>'
                            + '      <button type="button" class="btn-ghost" data-download-btn onclick="dashboardDownloadOne(' + item.artworkId + ',' + item.orderId + ',\'' + escapeJs(item.title) + '\')">Download</button>'
                            + '      <span class="dl-counter" data-download-counter>Loading...</span>'
                            + '  </div>'
                            + '</div>';
                    }).join('')
                    + '</div>';

                var uniqueIds = [];
                state.downloadItems.forEach(function (item) {
                    if (uniqueIds.indexOf(item.artworkId) === -1) {
                        uniqueIds.push(item.artworkId);
                    }
                });

                Promise.all(uniqueIds.map(function (artworkId) {
                    return fetchDownloadStatus(artworkId).then(function (status) {
                        state.downloadStatus[artworkId] = status;
                        updateDownloadRows(artworkId);
                    });
                })).then(function () {
                    updateOverviewStats();
                });
            }

            function loadDownloads() {
                if (state.orders.length === 0) {
                    state.downloadItems = [];
                    renderDownloads();
                    updateOverviewStats();
                    return Promise.resolve();
                }

                return Promise.all(state.orders.map(function (order) {
                    return fetch(API_BASE + '/api/BuyerOrder/GetOrderDetail/' + order.orderId, {
                        headers: {
                            'Authorization': 'Bearer ' + getToken()
                        }
                    }).then(function (res) {
                        if (!res.ok) return null;
                        return res.json();
                    }).then(function (detail) {
                        if (!detail || !detail.order) return [];
                        var items = normalizeArray(detail.items);
                        return items.map(function (item) {
                            return {
                                artworkId: item.artworkId,
                                title: item.title,
                                artistName: item.artistName,
                                categoryName: item.categoryName,
                                priceAtPurchase: item.priceAtPurchase,
                                previewPath: item.previewPath,
                                orderId: detail.order.orderId,
                                orderStatus: detail.order.orderStatus,
                                createdAt: detail.order.createdAt
                            };
                        });
                    }).catch(function () {
                        return [];
                    });
                })).then(function (all) {
                    state.downloadItems = all.reduce(function (flat, items) {
                        return flat.concat(items || []);
                    }, []);
                    renderDownloads();
                    updateOverviewStats();
                    renderActivity();
                }).catch(function () {
                    document.getElementById('downloadsContent').innerHTML = '<div class="empty-state"><p>Failed to load download items.</p></div>';
                });
            }

            function escapeJs(text) {
                return (text || '')
                    .replace(/\\/g, '\\\\')
