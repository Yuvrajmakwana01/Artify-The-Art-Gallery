            function resetProfileForm() {
                if (!state.profile) return;
                clearMessage('profileMsgBox');
                document.getElementById('userName').value = state.profile.c_UserName || '';
                document.getElementById('fullName').value = state.profile.c_FullName || '';
                document.getElementById('mobile').value = state.profile.c_Mobile || '';
                document.getElementById('gender').value = state.profile.c_Gender || '';
                document.getElementById('profileEditEmail').value = state.profile.c_Email || '';
                document.getElementById('fileInput').value = '';
                setProfileImages(currentImagePath, (state.profile.c_FullName || state.profile.c_UserName || 'A').charAt(0).toUpperCase());
            }

            function validateProfileForm() {
                var userName = document.getElementById('userName');
                var fullName = document.getElementById('fullName');
                var mobile = document.getElementById('mobile');

                [userName, fullName, mobile].forEach(function (el) {
                    el.classList.remove('is-error');
                });

                if (!userName.value.trim()) {
                    userName.classList.add('is-error');
                    setMessage('profileMsgBox', 'Username required.', 'error');
                    return false;
                }

                if (!fullName.value.trim()) {
                    fullName.classList.add('is-error');
                    setMessage('profileMsgBox', 'Full name required.', 'error');
                    return false;
                }

                if (!/^[6-9]\d{9}$/.test(mobile.value.trim())) {
                    mobile.classList.add('is-error');
                    setMessage('profileMsgBox', 'Enter a valid mobile number.', 'error');
                    return false;
                }

                clearMessage('profileMsgBox');
                return true;
            }

            function loadProfile() {
                return new Promise(function (resolve) {
                    $.ajax({
                        url: 'http://localhost:5183/api/UserProfile/GetProfile',
                        type: 'GET',
                        headers: {
                            'Authorization': 'Bearer ' + getToken()
                        },
                        success: function (res) {
                            if (!res.success) {
                                setMessage('profileMsgBox', 'Failed to load profile.', 'error');
                                resolve();
                                return;
                            }

                            state.profile = res.data;
                            renderProfile(state.profile);
                            resolve();
                        },
                        error: function () {
                            setMessage('profileMsgBox', 'Session expired. Please login again.', 'warning');
                            setTimeout(function () {
                                window.location.href = LOGIN_URL;
                            }, 1200);
                            resolve();
                        }
                    });
                });
            }

            function saveProfile() {
                if (!validateProfileForm()) return;

                var button = $('#btnSaveBottom');
                var fd = new FormData();
                fd.append('c_UserName', $('#userName').val());
                fd.append('c_FullName', $('#fullName').val());
                fd.append('c_Mobile', $('#mobile').val());
                fd.append('c_Gender', $('#gender').val());

                var file = $('#fileInput')[0].files[0];
                if (file) {
                    fd.append('c_ImageFile', file);
                }

                button.prop('disabled', true).addClass('btn-disabled');

                $.ajax({
                    url: 'http://localhost:5183/api/UserProfile/UpdateProfile',
                    type: 'PUT',
                    headers: {
                        'Authorization': 'Bearer ' + getToken()
                    },
                    data: fd,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        if (res.success) {
                            loadProfile().then(function () {
                                showProfileMode('view');
                                return showSuccessAlert('Profile updated', 'Your profile details were updated successfully.');
                            });
                        } else {
                            setMessage('profileMsgBox', res.message || 'Could not update profile.', 'error');
                        }
                    },
                    error: function () {
                        setMessage('profileMsgBox', 'Error saving profile.', 'error');
                    },
                    complete: function () {
                        button.prop('disabled', false).removeClass('btn-disabled');
                    }
                });
            }

