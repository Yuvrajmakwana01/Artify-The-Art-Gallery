            function checkStrength(value) {
                var score = 0;
                if (value.length >= 6) score++;
                if (value.length >= 10) score++;
                if (/[A-Z]/.test(value) && /[0-9]/.test(value)) score++;
                if (/[^A-Za-z0-9]/.test(value)) score++;

                var colorMap = { 1: 'weak', 2: 'fair', 3: 'good', 4: 'strong' };
                var labelMap = { 1: 'Weak', 2: 'Fair', 3: 'Good', 4: 'Strong' };
                var colorHex = { 1: '#e53e3e', 2: '#dd6b20', 3: '#d69e2e', 4: '#38a169' };

                for (var i = 1; i <= 4; i++) {
                    document.getElementById('seg' + i).className = 'strength-seg ' + (i <= score ? colorMap[score] : '');
                }

                var label = document.getElementById('strengthLabel');
                label.textContent = value.length > 0 ? (labelMap[score] || '') : '';
                label.style.color = value.length > 0 ? (colorHex[score] || 'var(--muted)') : 'var(--muted)';
            }

            function resetPasswordForm() {
                clearMessage('passwordMsgBox');
                document.getElementById('currentPwd').value = '';
                document.getElementById('newPwd').value = '';
                document.getElementById('confirmPwd').value = '';
                checkStrength('');
                $('#currentPwd, #newPwd, #confirmPwd').removeClass('is-error');
            }

            function updatePassword() {
                clearMessage('passwordMsgBox');

                var currentPwd = $('#currentPwd').val().trim();
                var newPwd = $('#newPwd').val().trim();
                var confirmPwd = $('#confirmPwd').val().trim();

                $('#currentPwd, #newPwd, #confirmPwd').removeClass('is-error');

                if (!currentPwd || !newPwd || !confirmPwd) {
                    setMessage('passwordMsgBox', 'Please fill in all fields.', 'error');
                    if (!currentPwd) $('#currentPwd').addClass('is-error');
                    if (!newPwd) $('#newPwd').addClass('is-error');
                    if (!confirmPwd) $('#confirmPwd').addClass('is-error');
                    return;
                }

                if (newPwd.length < 6) {
                    setMessage('passwordMsgBox', 'New password must be at least 6 characters.', 'error');
                    $('#newPwd').addClass('is-error');
                    return;
                }

                if (newPwd !== confirmPwd) {
                    setMessage('passwordMsgBox', 'New passwords do not match.', 'error');
                    $('#confirmPwd').addClass('is-error');
                    return;
                }

                var button = $('#btnUpdate');
                button.prop('disabled', true).addClass('btn-disabled');

                $.ajax({
                    url: 'http://localhost:5183/api/UserProfile/change-password',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'Authorization': 'Bearer ' + getToken()
                    },
                    data: JSON.stringify({
                        c_CurrentPassword: currentPwd,
                        c_NewPassword: newPwd,
                        c_ConfirmPassword: confirmPwd
                    }),
                    success: function (res) {
                        if (res.success) {
                            setMessage('passwordMsgBox', 'Password updated successfully.', 'success');
                            resetPasswordForm();
                            showSuccessAlert('Password updated', 'Your password has been changed successfully.');
                        } else {
                            setMessage('passwordMsgBox', res.message || 'Incorrect current password.', 'error');
                            $('#currentPwd').addClass('is-error');
                        }
                    },
                    error: function (xhr) {
                        var message = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : 'Server error. Please try again.';
                        setMessage('passwordMsgBox', message, 'error');
                    },
                    complete: function () {
                        button.prop('disabled', false).removeClass('btn-disabled');
                    }
                });
            }

