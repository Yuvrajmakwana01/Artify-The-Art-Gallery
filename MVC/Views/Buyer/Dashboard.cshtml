                document.getElementById('profileEditTrigger').addEventListener('click', function () {
                    showProfileMode('edit');
                });

                document.getElementById('profileCancelBtn').addEventListener('click', function () {
                    showProfileMode('view');
                });

                document.getElementById('btnSaveBottom').addEventListener('click', saveProfile);
                document.getElementById('profileUploadBtn').addEventListener('click', function () {
                    document.getElementById('fileInput').click();
                });
                document.getElementById('fileInput').addEventListener('change', function (e) {
                    var file = e.target.files[0];
                    if (!file) return;

                    var localPreview = URL.createObjectURL(file);
                    document.getElementById('profileImg').src = localPreview;
                    document.getElementById('profileImg').style.display = '';
