            function loadOrderDetail(orderId) {
                var parsedId = parseInt(orderId, 10);
                if (!parsedId) {
                    renderOrderDetailEmpty('Invalid order selected.');
                    return Promise.resolve();
                }

                state.activeOrderId = parsedId;
                syncActiveOrderCard();
                renderOrderDetailLoading();

                if (state.orderDetailCache[parsedId]) {
                    renderOrderDetail(state.orderDetailCache[parsedId]);
                    return Promise.resolve(state.orderDetailCache[parsedId]);
                }

                return fetch(API_BASE + '/api/BuyerOrder/GetOrderDetail/' + parsedId, {
                    headers: {
                        'Authorization': 'Bearer ' + getToken()
                    }
                }).then(function (res) {
                    if (!res.ok) throw new Error('Failed');
                    return res.json();
                }).then(function (detail) {
                    state.orderDetailCache[parsedId] = detail;
                    renderOrderDetail(detail);
                    return detail;
                }).catch(function () {
                    renderOrderDetailEmpty('Failed to load this order. Please try again.');
                });
            }

            function buildOrderCard(order) {
                var orderNumber = 'ORD-' + String(order.orderId).padStart(8, '0');
                var date = formatDate(order.createdAt);
                var itemCount = (order.itemCount || 1) + ' item' + ((order.itemCount || 1) === 1 ? '' : 's');
                var grand = formatAmount(order.totalAmount);
