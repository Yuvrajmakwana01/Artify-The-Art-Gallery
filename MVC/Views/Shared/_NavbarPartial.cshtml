
<style>
    /* Navbar specific styles from reference */
    .artify-new-nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 4rem;
      background: rgba(223, 230, 233, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(3,40,159,.08);
      font-family: 'Inter', sans-serif;
    }
    .artify-new-nav .nav-logo { display: flex; align-items: center; gap: .7rem; text-decoration: none; }
    .artify-new-nav .nav-logo-icon {
      height: 40px; width: 40px; border-radius: 12px;
      background: #03289F; display: grid; place-items: center;
      font-weight: 900; color: #fff; font-size: 1.2rem;
    }
    .artify-new-nav .nav-logo span { font-size: 1.4rem; font-weight: 700; color: #1a1a1a; letter-spacing: -.02em; font-family: 'Playfair Display', serif; }

    .artify-new-nav .nav-links { display: flex; gap: 2.5rem; list-style: none; margin: 0; padding: 0; }
    .artify-new-nav .nav-links a {
      text-decoration: none; font-size: .88rem; color: #1a1a1a;
      opacity: .7; transition: opacity .2s, color .2s;
    }
    .artify-new-nav .nav-links a:hover { opacity: 1; color: #6B9BE6; }

    .artify-new-nav .nav-actions { display: flex; align-items: center; gap: 1rem; }
    .artify-new-nav .nav-icon-btn {
      position: relative; display: grid; place-items: center;
      height: 40px; width: 40px; border-radius: 50%;
      border: 1.5px solid rgba(3,40,159,.08);
      background: rgba(255,255,255,.5); cursor: pointer;
      color: #1a1a1a; transition: background .2s, border-color .2s, transform .2s;
      text-decoration: none;
    }
    .artify-new-nav .nav-icon-btn:hover { background: #03289F; color: #ffffff; border-color: #03289F; transform: scale(1.08); }
    .artify-new-nav .nav-badge {
      position: absolute; top: -4px; right: -4px;
      height: 16px; min-width: 16px; padding: 0 3px;
      background: #6B9BE6; color: #fff; border-radius: 999px;
      font-size: .62rem; font-weight: 700; display: flex; align-items: center; justify-content: center;
    }
    .artify-new-nav .nav-signin {
      font-size: .88rem; color: #1a1a1a; text-decoration: none;
      opacity: .8; transition: opacity .2s, color .2s;
    }
    .artify-new-nav .nav-signin:hover { opacity: 1; color: #6B9BE6; }

    @@media(max-width:768px) {
      .artify-new-nav { padding: 1rem 1.25rem; }
      .artify-new-nav .nav-links { display: none; }
    }

    /* Keep old notification styles */
    .buyer-notification-wrap { position: relative; }
    .buyer-notification-count {
        position: absolute; top: -4px; right: -4px;
        min-width: 18px; height: 18px; padding: 0 5px;
        border-radius: 999px; background: #d9485f; color: #fff;
        font-size: 11px; font-weight: 700; display: none;
        align-items: center; justify-content: center;
        box-shadow: 0 6px 18px rgba(217, 72, 95, 0.32);
    }
    .buyer-notification-count.visible { display: inline-flex; }
    .buyer-notification-panel {
        position: absolute; top: calc(100% + 12px); right: 0;
        width: 360px; max-width: calc(100vw - 24px);
        background: #ffffff; border: 1px solid rgba(192, 139, 63, 0.18);
        border-radius: 18px; box-shadow: 0 22px 46px rgba(40, 30, 20, 0.18);
        padding: 12px; display: none; z-index: 1200;
    }
    .buyer-notification-wrap.open .buyer-notification-panel { display: block; }
    .buyer-notification-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 4px 4px 10px; border-bottom: 1px solid rgba(192, 139, 63, 0.14); }
    .buyer-notification-head strong { color: #1f1a14; font-size: 14px; font-weight: 700; }
    .buyer-notification-clear { border: none; background: transparent; color: #c08b3f; font-size: 12px; font-weight: 700; padding: 0; }
    .buyer-notification-clear:hover { color: #4a3524; }
    .buyer-notification-list { display: flex; flex-direction: column; gap: 10px; max-height: 360px; overflow-y: auto; padding: 10px 2px 2px; }
    .buyer-notification-item { background: #faf6ef; border-radius: 14px; padding: 12px; border: 1px solid rgba(31, 26, 20, 0.08); box-shadow: 0 8px 18px rgba(31, 26, 20, 0.05); border-left: 4px solid #c08b3f; }
    .buyer-notification-item.payment { border-left-color: #3aa76d; }
    .buyer-notification-item-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 6px; }
    .buyer-notification-type { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #c08b3f; }
    .buyer-notification-time { color: #6f6559; font-size: 11px; white-space: nowrap; }
    .buyer-notification-title { color: #1f1a14; font-size: 13px; font-weight: 700; margin-bottom: 4px; }
    .buyer-notification-message { color: #6f6559; font-size: 12px; line-height: 1.5; margin: 0; }
    .buyer-notification-actions { display: flex; justify-content: flex-end; margin-top: 10px; }
    .buyer-notification-read { border: none; background: rgba(192, 139, 63, 0.12); color: #4a3524; font-size: 11px; font-weight: 700; padding: 6px 10px; border-radius: 999px; cursor: pointer; transition: background 0.2s ease, color 0.2s ease, opacity 0.2s ease; }
    .buyer-notification-read:hover { background: rgba(192, 139, 63, 0.2); }
    .buyer-notification-empty, .buyer-notification-error { padding: 18px 14px; border-radius: 14px; text-align: center; font-size: 12px; }
    .buyer-notification-empty { background: rgba(255, 255, 255, 0.9); color: #6f6559; border: 1px dashed rgba(31, 26, 20, 0.12); }
    .buyer-notification-error { background: #fff1f2; color: #b4233d; border: 1px solid rgba(217, 72, 95, 0.16); }
    
    @@media (max-width: 640px) {
        .buyer-notification-panel { right: -32px; width: min(360px, calc(100vw - 16px)); }
    }
</style>

<nav class="artify-new-nav">
  <a class="nav-logo" asp-controller="Buyer" asp-action="ExploreArt">
    <div class="nav-logo-icon">A</div>
    <span>Artify</span>
  </a>

  <ul class="nav-links">
    <li><a asp-controller="Buyer" asp-action="ExploreArt">Explore Arts</a></li>
    <li><a asp-controller="Buyer" asp-action="ExploreArt" asp-fragment="categories">Categories</a></li>
    <li><a asp-controller="Artist" asp-action="Index">Artists</a></li>
  </ul>

  <div class="nav-actions">
    <!-- Wishlist / Bookmark icon -->
    <a asp-controller="Wishlist" asp-action="Index" class="nav-icon-btn" title="Wishlist" aria-label="Wishlist">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="nav-badge" id="wishlistBadge" style="background:#EDA312; display: none;">0</span>
    </a>
    
    <!-- Cart icon -->
    <a asp-controller="Cart" asp-action="Index" class="nav-icon-btn" title="Cart" aria-label="Cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      <span class="nav-badge" id="cartBadge" style="display: none;">0</span>
    </a>

    <!-- Notifications -->
    <div class="buyer-notification-wrap" id="buyerNotificationWrap">
        <button type="button" class="nav-icon-btn buyer-notification-btn" id="buyerNotificationBtn" title="Notifications" aria-expanded="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5" />
                <path d="M9 17a3 3 0 0 0 6 0" />
            </svg>
            <span class="buyer-notification-count" id="buyerNotificationCount">0</span>
        </button>
        <div class="buyer-notification-panel" id="buyerNotificationPanel">
            <div class="buyer-notification-head">
                <strong>Notifications</strong>
                <button type="button" class="buyer-notification-clear" id="buyerNotificationClear">Mark all read</button>
            </div>
            <div class="buyer-notification-list" id="buyerNotificationList">
                <div class="buyer-notification-empty">No notifications yet.</div>
            </div>
        </div>
    </div>

    <!-- Profile -->
    <a asp-controller="Buyer" asp-action="Profile" class="nav-icon-btn" title="My Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
        </svg>
    </a>

    <!-- Logout -->
    <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
        @Html.AntiForgeryToken()
        <button type="submit" class="nav-icon-btn logout-btn" title="Logout" style="border:none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
        </button>
    </form>
  </div>
</nav>

<style>.zero { display: none !important; }</style>
<script>
    (function() {
        var BUYER_API_BASE = "http://localhost:5183/api/BuyerApi";
        var buyerNotificationPollHandle = window.artifyBuyerNotificationPollHandle || null;

        function buyerAuthToken() {
            return localStorage.getItem("token");
        }

        function buyerAuthHeaders() {
            var token = buyerAuthToken();
            return token ? { "Authorization": "Bearer " + token } : {};
        }

        function escapeBuyerNotificationHtml(value) {
            if (!value) return "";
            return String(value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#39;");
        }

        function buyerNotificationHeading(type) {
            var kind = (type || "").toLowerCase();
            if (kind === "payment" || kind === "payment_received") return "Payment successful";
            return "Notification";
        }

        function buyerNotificationCardClass(type) {
            var kind = (type || "").toLowerCase();
            if (kind.indexOf("payment") !== -1) return "payment";
            return "general";
        }

        function formatBuyerNotificationTime(value) {
            if (!value) return "";

            var date = new Date(value);
            if (isNaN(date.getTime())) return "";

            var diffMs = Date.now() - date.getTime();
            var diffMinutes = Math.floor(diffMs / 60000);

            if (diffMinutes < 1) return "Just now";
            if (diffMinutes < 60) return diffMinutes + "m ago";

            var diffHours = Math.floor(diffMinutes / 60);
            if (diffHours < 24) return diffHours + "h ago";

            var diffDays = Math.floor(diffHours / 24);
            if (diffDays < 7) return diffDays + "d ago";

            return date.toLocaleString("en-IN", {
                day: "numeric",
                month: "short",
                hour: "numeric",
                minute: "2-digit"
            });
        }

        function updateBuyerNotificationCount(count) {
            var badge = document.getElementById("buyerNotificationCount");
            if (!badge) return;

            var safeCount = parseInt(count, 10) || 0;
            if (safeCount > 0) {
                badge.textContent = safeCount > 99 ? "99+" : safeCount;
                badge.classList.add("visible");
            } else {
                badge.textContent = "0";
                badge.classList.remove("visible");
            }
        }

        function renderBuyerNotifications(items) {
            var list = document.getElementById("buyerNotificationList");
            if (!list) return;

            if (!items || !items.length) {
                list.innerHTML = '<div class="buyer-notification-empty">No notifications yet.</div>';
                return;
            }

            list.innerHTML = items.map(function(item) {
                var titleHtml = item.title
                    ? '<div class="buyer-notification-title">' + escapeBuyerNotificationHtml(item.title) + '</div>'
                    : "";
                var notificationId = escapeBuyerNotificationHtml(item.id || "");
                var actionsHtml = notificationId
                    ? '<div class="buyer-notification-actions">' +
                        '<button type="button" class="buyer-notification-read" data-notification-id="' + notificationId + '">Mark as read</button>' +
                      '</div>'
                    : "";

                return '' +
                    '<article class="buyer-notification-item ' + buyerNotificationCardClass(item.type) + '" data-notification-id="' + notificationId + '">' +
                        '<div class="buyer-notification-item-head">' +
                            '<span class="buyer-notification-type">' + escapeBuyerNotificationHtml(buyerNotificationHeading(item.type)) + '</span>' +
                            '<span class="buyer-notification-time">' + escapeBuyerNotificationHtml(formatBuyerNotificationTime(item.createdAtUtc)) + '</span>' +
                        '</div>' +
                        titleHtml +
                        '<p class="buyer-notification-message">' + escapeBuyerNotificationHtml(item.message || "") + '</p>' +
                        actionsHtml +
                    '</article>';
            }).join("");
        }

        function closeBuyerNotificationPanel() {
            var wrap = document.getElementById("buyerNotificationWrap");
            var btn = document.getElementById("buyerNotificationBtn");
            if (wrap) wrap.classList.remove("open");
            if (btn) btn.setAttribute("aria-expanded", "false");
        }

        function buyerApiRequest(path, options) {
            options = options || {};
            return fetch(BUYER_API_BASE + path, {
                method: options.method || "GET",
                headers: Object.assign({ "Content-Type": "application/json" }, buyerAuthHeaders(), options.headers || {})
            }).then(function(response) {
                if (response.status === 401) {
                    updateBuyerNotificationCount(0);
                    throw new Error("Unauthorized");
                }

                return response.json().then(function(data) {
                    if (!response.ok) {
                        throw new Error((data && data.message) || "Request failed");
                    }
                    return data;
                });
            });
        }

        function markBuyerNotificationsRead() {
            var token = buyerAuthToken();
            if (!token) return Promise.resolve();

            return buyerApiRequest("/notifications/read", { method: "POST" })
                .then(function() {
                    updateBuyerNotificationCount(0);
                    renderBuyerNotifications([]);
                });
        }

        function markBuyerNotificationRead(notificationId) {
            var token = buyerAuthToken();
            if (!token || !notificationId) return Promise.reject(new Error("Missing notification id"));

            return buyerApiRequest("/notifications/" + encodeURIComponent(notificationId) + "/read", {
                method: "POST"
            });
        }

        function loadBuyerNotifications() {
            var token = buyerAuthToken();
            if (!token) {
                updateBuyerNotificationCount(0);
                return;
            }

            buyerApiRequest("/notifications?take=10")
                .then(function(res) {
                    renderBuyerNotifications((res && res.data) || []);
                    updateBuyerNotificationCount((res && res.unreadCount) || 0);
                })
                .catch(function(err) {
                    if (err.message === "Unauthorized") return;

                    var list = document.getElementById("buyerNotificationList");
                    if (list) {
                        list.innerHTML = '<div class="buyer-notification-error">Unable to load notifications right now.</div>';
                    }
                });
        }

        var wrap = document.getElementById("buyerNotificationWrap");
        var button = document.getElementById("buyerNotificationBtn");
        var clearButton = document.getElementById("buyerNotificationClear");
        var list = document.getElementById("buyerNotificationList");

        if (!wrap || !button) return;

        button.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();

            var isOpen = wrap.classList.toggle("open");
            button.setAttribute("aria-expanded", isOpen ? "true" : "false");

            if (isOpen) {
                loadBuyerNotifications();
            }
        });

        if (clearButton) {
            clearButton.addEventListener("click", function(e) {
                e.preventDefault();
                e.stopPropagation();
                markBuyerNotificationsRead();
            });
        }

        if (list) {
            list.addEventListener("click", function(e) {
                var readButton = e.target.closest(".buyer-notification-read");
                if (!readButton) return;

                e.preventDefault();
                e.stopPropagation();

                var notificationId = readButton.getAttribute("data-notification-id");
                if (!notificationId) return;

                readButton.disabled = true;
                readButton.textContent = "Marking...";

                markBuyerNotificationRead(notificationId)
                    .then(function(res) {
                        updateBuyerNotificationCount((res && res.unreadCount) || 0);
                        loadBuyerNotifications();
                    })
                    .catch(function() {
                        readButton.disabled = false;
                        readButton.textContent = "Mark as read";
                    });
            });
        }

        document.addEventListener("click", function(e) {
            if (!wrap.contains(e.target)) {
                closeBuyerNotificationPanel();
            }
        });

        loadBuyerNotifications();

        if (buyerNotificationPollHandle) {
            window.clearInterval(buyerNotificationPollHandle);
        }

        buyerNotificationPollHandle = window.setInterval(function() {
            loadBuyerNotifications();
        }, 30000);

        window.artifyBuyerNotificationPollHandle = buyerNotificationPollHandle;
    })();
</script>
