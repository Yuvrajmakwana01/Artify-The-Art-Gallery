<style>
    .artify-buyer-navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--background, #faf6ef) 88%, transparent);
        backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--border, rgba(0, 0, 0, 0.08));
    }

    .artify-buyer-navbar .navbar-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
    }

    .artify-buyer-navbar .logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--foreground, #1f1a14);
        text-decoration: none;
        letter-spacing: -0.025em;
        transition: color 0.3s ease;
    }

    .artify-buyer-navbar .logo:hover {
        color: var(--accent, #c08b3f);
    }

    .artify-buyer-navbar .nav-links {
        display: flex;
        gap: 2rem;
    }

    .artify-buyer-navbar .nav-links a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--muted, #6f6559);
        text-decoration: none;
        transition: color 0.3s ease;
        position: relative;
        padding-bottom: 2px;
    }

    .artify-buyer-navbar .nav-links a::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--accent, #c08b3f);
        transform: scaleX(0);
        transition: transform 0.25s ease;
    }

    .artify-buyer-navbar .nav-links a:hover,
    .artify-buyer-navbar .nav-links a.active {
        color: var(--foreground, #1f1a14);
    }

    .artify-buyer-navbar .nav-links a:hover::after,
    .artify-buyer-navbar .nav-links a.active::after {
        transform: scaleX(1);
    }

    .artify-buyer-navbar .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        position: relative;
    }

    .artify-buyer-navbar .icon-btn {
        position: relative;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: none;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted, #6f6559);
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .artify-buyer-navbar .icon-btn:hover {
        background: var(--secondary, #efe4d5);
        color: var(--foreground, #1f1a14);
    }

    .artify-buyer-navbar .badge {
        position: absolute;
        top: -2px;
        right: -2px;
        min-width: 18px;
        height: 18px;
        padding: 0 4px;
        border-radius: 9999px;
        background: var(--accent, #c08b3f);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .artify-buyer-navbar .badge.zero {
        display: none;
    }

    .artify-buyer-navbar .avatar-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: none;
        background: var(--primary, #4a3524);
        color: var(--primary-foreground, #fffaf4);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: opacity 0.2s ease;
    }

    .artify-buyer-navbar .avatar-btn:hover {
        opacity: 0.88;
    }

    .buyer-notification-wrap {
        position: relative;
    }

    .buyer-notification-btn {
        position: relative;
    }

    .buyer-notification-count {
        position: absolute;
        top: -4px;
        right: -4px;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        background: #d9485f;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        display: none;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 18px rgba(217, 72, 95, 0.32);
    }

    .buyer-notification-count.visible {
        display: inline-flex;
    }

    .buyer-notification-panel {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        width: 360px;
        max-width: calc(100vw - 24px);
        background: var(--card-white, #ffffff);
        border: 1px solid rgba(192, 139, 63, 0.18);
        border-radius: 18px;
        box-shadow: 0 22px 46px rgba(40, 30, 20, 0.18);
        padding: 12px;
        display: none;
        z-index: 1200;
    }

    .buyer-notification-wrap.open .buyer-notification-panel {
        display: block;
    }

    .buyer-notification-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 4px 4px 10px;
        border-bottom: 1px solid rgba(192, 139, 63, 0.14);
    }

    .buyer-notification-head strong {
        color: var(--foreground, #1f1a14);
        font-size: 14px;
        font-weight: 700;
    }

    .buyer-notification-clear {
        border: none;
        background: transparent;
        color: var(--accent, #c08b3f);
        font-size: 12px;
        font-weight: 700;
        padding: 0;
    }

    .buyer-notification-clear:hover {
        color: var(--primary, #4a3524);
    }

    .buyer-notification-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 360px;
        overflow-y: auto;
        padding: 10px 2px 2px;
    }

    .buyer-notification-item {
        background: var(--background, #faf6ef);
        border-radius: 14px;
        padding: 12px;
        border: 1px solid rgba(31, 26, 20, 0.08);
        box-shadow: 0 8px 18px rgba(31, 26, 20, 0.05);
        border-left: 4px solid var(--accent, #c08b3f);
    }

    .buyer-notification-item.payment {
        border-left-color: #3aa76d;
    }

    .buyer-notification-item-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 6px;
    }

    .buyer-notification-type {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent, #c08b3f);
    }

    .buyer-notification-time {
        color: var(--muted, #6f6559);
        font-size: 11px;
        white-space: nowrap;
    }

    .buyer-notification-title {
        color: var(--foreground, #1f1a14);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .buyer-notification-message {
        color: var(--muted, #6f6559);
        font-size: 12px;
        line-height: 1.5;
        margin: 0;
    }

    .buyer-notification-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 10px;
    }

    .buyer-notification-read {
        border: none;
        background: rgba(192, 139, 63, 0.12);
        color: var(--primary, #4a3524);
        font-size: 11px;
        font-weight: 700;
        padding: 6px 10px;
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, opacity 0.2s ease;
    }

    .buyer-notification-read:hover {
        background: rgba(192, 139, 63, 0.2);
    }

    .buyer-notification-read:disabled {
        opacity: 0.6;
        cursor: wait;
    }

    .buyer-notification-empty,
    .buyer-notification-error {
        padding: 18px 14px;
        border-radius: 14px;
        text-align: center;
        font-size: 12px;
    }

    .buyer-notification-empty {
        background: rgba(255, 255, 255, 0.9);
        color: var(--muted, #6f6559);
        border: 1px dashed rgba(31, 26, 20, 0.12);
    }

    .buyer-notification-error {
        background: #fff1f2;
        color: #b4233d;
        border: 1px solid rgba(217, 72, 95, 0.16);
    }

    @@media (max-width: 768px) {
        .artify-buyer-navbar .nav-links {
            display: none;
        }
    }

    @@media (max-width: 640px) {
        .buyer-notification-panel {
            right: -32px;
            width: min(360px, calc(100vw - 16px));
        }
    }
</style>

<nav class="navbar artify-buyer-navbar">
    <div class="navbar-inner">
        <a asp-controller="Buyer" asp-action="ExploreArt" class="logo">Artify</a>

        <div class="nav-links">
            <a asp-controller="Buyer" asp-action="ExploreArt" class="active">Explore Arts</a>
            <a asp-controller="Buyer" asp-action="ExploreArt" asp-fragment="categories">Categories</a>
            <a asp-controller="Artist" asp-action="Index">Artists</a>
        </div>

        <div class="nav-actions">
            <a asp-controller="Wishlist" asp-action="Index" class="icon-btn" title="Wishlist">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                </svg>
                <span class="badge zero" id="wishlistBadge">0</span>
            </a>

            <a asp-controller="Cart" asp-action="Index" class="icon-btn" title="Cart">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                </svg>
                <span class="badge zero" id="cartBadge">0</span>
            </a>

            <div class="buyer-notification-wrap" id="buyerNotificationWrap">
                <button type="button"
                        class="icon-btn buyer-notification-btn"
                        id="buyerNotificationBtn"
                        title="Notifications"
                        aria-expanded="false">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5" />
                        <path d="M9 17a3 3 0 0 0 6 0" />
                    </svg>
                    <span class="buyer-notification-count" id="buyerNotificationCount">0</span>
                </button>
                <div class="buyer-notification-panel" id="buyerNotificationPanel">
                    <div class="buyer-notification-head">
                        <strong>Notifications</strong>
                        <button type="button" class="buyer-notification-clear" id="buyerNotificationClear">
                            Mark all read
                        </button>
                    </div>
                    <div class="buyer-notification-list" id="buyerNotificationList">
                        <div class="buyer-notification-empty">No notifications yet.</div>
                    </div>
                </div>
            </div>

            <a asp-controller="Buyer" asp-action="Profile" class="avatar-btn" title="My Account">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </a>

            <!-- Logout Button -->
            <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="icon-btn logout-btn" title="Logout">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</nav>

<script>
    (function() {
        var BUYER_API_BASE = "http://localhost:5183/api/BuyerApi";
        var buyerNotificationPollHandle = window.artifyBuyerNotificationPollHandle || null;

        function buyerAuthToken() {
            return localStorage.getItem("token");
        }

        function buyerAuthHeaders() {
            var token = buyerAuthToken();
            return token ? { "Authorization": "Bearer " + token } : {};
        }

        function escapeBuyerNotificationHtml(value) {
            if (!value) return "";
            return String(value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#39;");
        }

        function buyerNotificationHeading(type) {
            var kind = (type || "").toLowerCase();
            if (kind === "payment" || kind === "payment_received") return "Payment successful";
            return "Notification";
        }

        function buyerNotificationCardClass(type) {
            var kind = (type || "").toLowerCase();
            if (kind.indexOf("payment") !== -1) return "payment";
            return "general";
        }

        function formatBuyerNotificationTime(value) {
            if (!value) return "";

            var date = new Date(value);
            if (isNaN(date.getTime())) return "";

            var diffMs = Date.now() - date.getTime();
            var diffMinutes = Math.floor(diffMs / 60000);

            if (diffMinutes < 1) return "Just now";
            if (diffMinutes < 60) return diffMinutes + "m ago";

            var diffHours = Math.floor(diffMinutes / 60);
            if (diffHours < 24) return diffHours + "h ago";

            var diffDays = Math.floor(diffHours / 24);
            if (diffDays < 7) return diffDays + "d ago";

            return date.toLocaleString("en-IN", {
                day: "numeric",
                month: "short",
                hour: "numeric",
                minute: "2-digit"
            });
        }

        function updateBuyerNotificationCount(count) {
            var badge = document.getElementById("buyerNotificationCount");
            if (!badge) return;

            var safeCount = parseInt(count, 10) || 0;
            if (safeCount > 0) {
                badge.textContent = safeCount > 99 ? "99+" : safeCount;
                badge.classList.add("visible");
            } else {
                badge.textContent = "0";
                badge.classList.remove("visible");
            }
        }

        function renderBuyerNotifications(items) {
            var list = document.getElementById("buyerNotificationList");
            if (!list) return;

            if (!items || !items.length) {
                list.innerHTML = '<div class="buyer-notification-empty">No notifications yet.</div>';
                return;
            }

            list.innerHTML = items.map(function(item) {
                var titleHtml = item.title
                    ? '<div class="buyer-notification-title">' + escapeBuyerNotificationHtml(item.title) + '</div>'
                    : "";
                var notificationId = escapeBuyerNotificationHtml(item.id || "");
                var actionsHtml = notificationId
                    ? '<div class="buyer-notification-actions">' +
                        '<button type="button" class="buyer-notification-read" data-notification-id="' + notificationId + '">Mark as read</button>' +
                      '</div>'
                    : "";

                return '' +
                    '<article class="buyer-notification-item ' + buyerNotificationCardClass(item.type) + '" data-notification-id="' + notificationId + '">' +
                        '<div class="buyer-notification-item-head">' +
                            '<span class="buyer-notification-type">' + escapeBuyerNotificationHtml(buyerNotificationHeading(item.type)) + '</span>' +
                            '<span class="buyer-notification-time">' + escapeBuyerNotificationHtml(formatBuyerNotificationTime(item.createdAtUtc)) + '</span>' +
                        '</div>' +
                        titleHtml +
                        '<p class="buyer-notification-message">' + escapeBuyerNotificationHtml(item.message || "") + '</p>' +
                        actionsHtml +
                    '</article>';
            }).join("");
        }

        function closeBuyerNotificationPanel() {
            var wrap = document.getElementById("buyerNotificationWrap");
            var btn = document.getElementById("buyerNotificationBtn");
            if (wrap) wrap.classList.remove("open");
            if (btn) btn.setAttribute("aria-expanded", "false");
        }

        function buyerApiRequest(path, options) {
            options = options || {};
            return fetch(BUYER_API_BASE + path, {
                method: options.method || "GET",
                headers: Object.assign({ "Content-Type": "application/json" }, buyerAuthHeaders(), options.headers || {})
            }).then(function(response) {
                if (response.status === 401) {
                    updateBuyerNotificationCount(0);
                    throw new Error("Unauthorized");
                }

                return response.json().then(function(data) {
                    if (!response.ok) {
                        throw new Error((data && data.message) || "Request failed");
                    }
                    return data;
                });
            });
        }

        function markBuyerNotificationsRead() {
            var token = buyerAuthToken();
            if (!token) return Promise.resolve();

            return buyerApiRequest("/notifications/read", { method: "POST" })
                .then(function() {
                    updateBuyerNotificationCount(0);
                    renderBuyerNotifications([]);
                });
        }

        function markBuyerNotificationRead(notificationId) {
            var token = buyerAuthToken();
            if (!token || !notificationId) return Promise.reject(new Error("Missing notification id"));

            return buyerApiRequest("/notifications/" + encodeURIComponent(notificationId) + "/read", {
                method: "POST"
            });
        }

        function loadBuyerNotifications() {
            var token = buyerAuthToken();
            if (!token) {
                updateBuyerNotificationCount(0);
                return;
            }

            buyerApiRequest("/notifications?take=10")
                .then(function(res) {
                    renderBuyerNotifications((res && res.data) || []);
                    updateBuyerNotificationCount((res && res.unreadCount) || 0);
                })
                .catch(function(err) {
                    if (err.message === "Unauthorized") return;

                    var list = document.getElementById("buyerNotificationList");
                    if (list) {
                        list.innerHTML = '<div class="buyer-notification-error">Unable to load notifications right now.</div>';
                    }
                });
        }

        var wrap = document.getElementById("buyerNotificationWrap");
        var button = document.getElementById("buyerNotificationBtn");
        var clearButton = document.getElementById("buyerNotificationClear");
        var list = document.getElementById("buyerNotificationList");

        if (!wrap || !button) return;

        button.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();

            var isOpen = wrap.classList.toggle("open");
            button.setAttribute("aria-expanded", isOpen ? "true" : "false");

            if (isOpen) {
                loadBuyerNotifications();
            }
        });

        if (clearButton) {
            clearButton.addEventListener("click", function(e) {
                e.preventDefault();
                e.stopPropagation();
                markBuyerNotificationsRead();
            });
        }

        if (list) {
            list.addEventListener("click", function(e) {
                var readButton = e.target.closest(".buyer-notification-read");
                if (!readButton) return;

                e.preventDefault();
                e.stopPropagation();

                var notificationId = readButton.getAttribute("data-notification-id");
                if (!notificationId) return;

                readButton.disabled = true;
                readButton.textContent = "Marking...";

                markBuyerNotificationRead(notificationId)
                    .then(function(res) {
                        updateBuyerNotificationCount((res && res.unreadCount) || 0);
                        loadBuyerNotifications();
                    })
                    .catch(function() {
                        readButton.disabled = false;
                        readButton.textContent = "Mark as read";
                    });
            });
        }

        document.addEventListener("click", function(e) {
            if (!wrap.contains(e.target)) {
                closeBuyerNotificationPanel();
            }
        });

        loadBuyerNotifications();

        if (buyerNotificationPollHandle) {
            window.clearInterval(buyerNotificationPollHandle);
        }

        buyerNotificationPollHandle = window.setInterval(function() {
            loadBuyerNotifications();
        }, 30000);

        window.artifyBuyerNotificationPollHandle = buyerNotificationPollHandle;
    })();
</script>
