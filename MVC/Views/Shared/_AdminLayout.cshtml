@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artify Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/adminsite.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
</head>

<body>

    <!-- SIDEBAR -->
    <nav id="sidebar">

        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="sidebar-logo">
                <i class="bi bi-layers-fill"></i>
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">Artify</span>
                <span class="sidebar-brand-tag">Admin Dashboard</span>
            </div>
        </div>

        <!-- FLEX WRAPPER -->
        <div class="sidebar-content d-flex flex-column h-100">

            <!-- MAIN NAV -->
            <div>
                <span class="nav-section-label">Main</span>
                <ul class="nav flex-column sidebar-nav">

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Artists" ? "active" : "")"
                               asp-controller="Admin" asp-action="Artists">
                            <i class="bi bi-person"></i>
                            <span>Artists</span>
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Artworks" ? "active" : "")"
                               asp-controller="Admin" asp-action="Artworks">
                            <i class="bi bi-bar-chart"></i>
                            <span>Artworks</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                               asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-people"></i>
                            <span>Users</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")"
                               asp-controller="Admin" asp-action="Categories">
                            <i class="bi bi-tags"></i>
                            <span>Categories</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payouts" ? "active" : "")"
                               asp-controller="Admin" asp-action="Payouts">
                            <i class="bi bi-cash-stack"></i>
                            <span>Payout Details</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")"
                               asp-controller="Admin" asp-action="Orders">
                            <i class="bi bi-cart"></i>
                            <span>Orders Details</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SalesSummary" ? "active" : "")"
                               asp-controller="Admin" asp-action="SalesSummary">
                            <i class="bi bi-bar-chart"></i>
                            <span>Sales / Analytics</span>
                        </a>
                    </li>

                </ul>
            </div>

            <!-- ACCOUNT NAV (BOTTOM) -->
            <div class="mt-auto">
                <span class="nav-section-label">Account</span>
                <ul class="nav flex-column sidebar-nav">

                    <li class="nav-item">
                        <a class="nav-link" href="javascript:void(0)" onclick="logout()">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Setting">
                            <i class="bi bi-gear"></i>
                            <span>Setting</span>
                        </a>
                    </li>

                </ul>
            </div>

        </div>

    </nav>


    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">

            <!-- LEFT: PAGE TITLE -->
            <div class="topbar-left">
            </div>

            <!-- RIGHT: ACTIONS -->
            <div class="topbar-actions">

                <!-- Notification -->
                <!-- Admin Notifications -->
                <div class="admin-notif-wrap" id="adminNotifWrap" style="position:relative;">
                    <button type="button" class="icon-btn position-relative"
                            id="adminNotifBtn" title="Notifications" aria-expanded="false">
                        <i class="bi bi-bell"></i>
                        <span class="admin-notif-count" id="adminNotifCount"
                            style="display:none; position:absolute; top:-4px; right:-4px;
                                    background:#ef4444; color:#fff; border-radius:50%;
                                    font-size:10px; font-weight:700; min-width:16px;
                                    height:16px; line-items:center; text-align:center;
                                    padding:0 3px; line-height:16px;">0</span>
                    </button>
                    <div class="admin-notif-panel" id="adminNotifPanel"
                        style="display:none; position:absolute; right:0; top:44px; width:320px;
                                background:#fff; border:1px solid #e8eaed; border-radius:12px;
                                box-shadow:0 8px 24px rgba(0,0,0,0.12); z-index:9999; overflow:hidden;">
                        <div style="display:flex; justify-content:space-between; align-items:center;
                                    padding:12px 16px; border-bottom:1px solid #e8eaed;">
                            <strong style="font-size:14px;">Notifications</strong>
                            <button type="button" id="adminNotifClear"
                                    style="background:none; border:none; font-size:12px;
                                        color:#f97316; cursor:pointer; font-weight:600;">
                                Mark all read
                            </button>
                        </div>
                        <div id="adminNotifList"
                            style="max-height:360px; overflow-y:auto; padding:8px 0;">
                            <div style="padding:24px; text-align:center; color:#9ca3af; font-size:13px;">
                                No notifications yet.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="topbar-divider"></div>

                <!-- Profile -->
                <div class="topbar-profile">
                    <div class="topbar-avatar">AA</div>
                </div>

            </div>

        </header>


        <!-- PAGE CONTENT -->
        <main class="content-area">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="site-footer">
            <div class="container-fluid">
                &copy; 2026 - Artify
            </div>
        </footer>

    </div>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script>
        window.__adminConfiguredApiBaseUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Configuration["ApiBaseUrl"]));

        window.getAdminApiBaseCandidates = function () {
            var configured = window.__adminConfiguredApiBaseUrl;
            var fromStorage = [
                window.localStorage ? window.localStorage.getItem("ApiBaseUrl") : null,
                window.localStorage ? window.localStorage.getItem("apiBaseUrl") : null
            ].filter(Boolean);

            var localhostCandidates = [];
            if (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1") {
                localhostCandidates.push(
                    window.location.protocol + "//localhost:5183",
                    "http://localhost:5183",
                    window.location.protocol + "//localhost:7077",
                    "https://localhost:7077"
                );
            }

            var unique = [];
            [configured].concat(fromStorage, localhostCandidates).forEach(function (url) {
                var normalized = String(url || "").trim().replace(/\/+$/, "");
                if (normalized && unique.indexOf(normalized) === -1) {
                    unique.push(normalized);
                }
            });

            return unique;
        };

        window.adminApiRequest = async function (path, options) {
            var candidates = window.getAdminApiBaseCandidates();
            var lastError = null;

            if (!candidates.length) {
                throw new Error("Admin API base URL is not configured.");
            }

            for (var i = 0; i < candidates.length; i++) {
                try {
                    var requestOptions = Object.assign({}, options || {});
                    requestOptions.url = candidates[i] + path;

                    if (options && options.headers) {
                        requestOptions.headers = Object.assign({}, options.headers);
                    }

                    return await $.ajax(requestOptions);
                } catch (err) {
                    lastError = err;

                    var status = Number(err && err.status || 0);
                    var shouldRetry = (status === 0 || status === 404) && i < candidates.length - 1;

                    if (!shouldRetry) {
                        throw err;
                    }
                }
            }

            throw lastError || new Error("Admin API request failed.");
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            function logout() {
                localStorage.removeItem("adminToken");
                localStorage.removeItem("adminExpiry");   
                localStorage.removeItem("adminData");

                window.location.href = "/Home/Landingpage";
            }
    </script>
    <script>
            (function () {
                const token = localStorage.getItem("adminToken");
                const expiry = localStorage.getItem("adminExpiry");

                // ❌ No token or expiry
                if (!token || !expiry) {
                    localStorage.clear();
                    window.location.href = "/Admin/Login";
                    return;
                }

                // ❌ Expired token
                if (Date.now() > expiry * 1000) {
                    localStorage.clear();
                    window.location.href = "/Admin/Login";
                    return;
                }

                // ❌ Invalid token format
                if (!token.includes(".")) {
                    localStorage.clear();
                    window.location.href = "/Admin/Login";
                }
            })();
    </script>
    
    <script>
        /* ── ADMIN NOTIFICATIONS ── */
        function adminToken() { return localStorage.getItem("adminToken"); }
        function adminAuthHeaders() {
            var t = adminToken();
            return t ? { "Authorization": "Bearer " + t } : {};
        }

        function escapeHtml(v) {
            return String(v||"").replace(/&/g,"&amp;").replace(/</g,"&lt;")
                                .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
        }

        function formatAdminNotifTime(iso) {
            var d = new Date(iso.endsWith("Z") ? iso : iso + "Z"); 
        }
          
        function buildAdminNotifItem(n) {
            var cls = (n.type||"").indexOf("artist") !== -1 ? "#8b5cf6"
                    : (n.type||"").indexOf("user")   !== -1 ? "#3b82f6"
                    : "#f97316";
            return '<div class="admin-notif-item" data-id="' + escapeHtml(n.id) + '" '
                + 'style="padding:12px 16px; border-left:3px solid ' + cls + '; '
                + 'border-bottom:1px solid #f3f4f6; cursor:default;">'
                + '<div style="display:flex;justify-content:space-between;margin-bottom:4px;">'
                + '<span style="font-size:12px;font-weight:600;color:' + cls + ';">'
                + escapeHtml(n.type||"notification") + '</span>'
                + '<span style="font-size:11px;color:#9ca3af;">'
                + formatAdminNotifTime(n.createdAtUtc) + '</span></div>'
                + '<div style="font-size:13px;font-weight:600;margin-bottom:2px;">'
                + escapeHtml(n.title) + '</div>'
                + '<div style="font-size:12px;color:#6b7280;">' + escapeHtml(n.message) + '</div>'
                + '<button onclick="markAdminNotifRead(\'' + escapeHtml(n.id) + '\')" '
                + 'style="margin-top:6px;padding:2px 8px;font-size:11px;border:1px solid #e8eaed;'
                + 'border-radius:4px;background:#f9fafb;cursor:pointer;">Mark read</button>'
                + '</div>';
        }

        async function loadAdminNotifications() {
            try {
                var res = await window.adminApiRequest("/api/AdminApi/notifications?take=20", {
                    headers: adminAuthHeaders()
                });

                if (!res.success) return;

                var count = res.unreadCount || 0;
                var $cnt  = $("#adminNotifCount");
                if (count > 0) {
                    $cnt.text(count > 99 ? "99+" : count).show();
                } else {
                    $cnt.hide();
                }
                var $list = $("#adminNotifList");
                if (!res.data || res.data.length === 0) {
                    $list.html('<div style="padding:24px;text-align:center;color:#9ca3af;font-size:13px;">No notifications yet.</div>');
                    return;
                }
                var html = "";
                res.data.forEach(function(n) { html += buildAdminNotifItem(n); });
                $list.html(html);
            } catch (err) {
                $("#adminNotifCount").hide();
            }
        }

        async function markAdminNotifRead(notifId) {
            try {
                await window.adminApiRequest("/api/AdminApi/notifications/" + encodeURIComponent(notifId) + "/read", {
                    type: "POST",
                    headers: adminAuthHeaders()
                });
            } finally {
                loadAdminNotifications();
            }
        }

        $("#adminNotifBtn").on("click", function(e) {
            e.stopPropagation();
            var $panel = $("#adminNotifPanel");
            var opening = $panel.is(":hidden");
            $panel.toggle();
            $(this).attr("aria-expanded", opening);
            if (opening) loadAdminNotifications();
        });

        $("#adminNotifClear").on("click", async function(e) {
            e.stopPropagation();
            try {
                await window.adminApiRequest("/api/AdminApi/notifications/read", {
                    type: "POST",
                    headers: adminAuthHeaders()
                });
            } finally {
                loadAdminNotifications();
            }
        });

        $(document).on("click", function(e) {
            if (!$(e.target).closest("#adminNotifWrap").length) {
                $("#adminNotifPanel").hide();
                $("#adminNotifBtn").attr("aria-expanded", "false");
            }
        });

        // Poll every 30 seconds for new notifications
        loadAdminNotifications();
        setInterval(loadAdminNotifications, 30000);
    </script>
</body>

</html>
