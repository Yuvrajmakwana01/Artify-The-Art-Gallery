<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artify Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/adminsite.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
</head>
<body>

    <!-- ── SIDEBAR ────────────────────────────────────────────────────────── -->
    <nav id="sidebar">

        <div class="sidebar-brand">
            <div class="sidebar-logo"><i class="bi bi-layers-fill"></i></div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">Artify</span>
                <span class="sidebar-brand-tag">Admin Dashboard</span>
            </div>
        </div>

        <span class="nav-section-label">Main</span>
        <ul class="nav flex-column sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Artists" ? "active" : "")"
                   asp-controller="Artists" asp-action="Index">
                    <i class="bi bi-person"></i><span>Artists</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminArtworkModerationMvc" ? "active" : "")"
                   asp-controller="AdminArtworkModerationMvc" asp-action="Index">
                    <i class="bi bi-image"></i><span>Artworks</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sales" ? "active" : "")"
                   asp-controller="Sales" asp-action="Index">
                    <i class="bi bi-cart"></i><span>Sales</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")"
                   asp-controller="Analytics" asp-action="Index">
                    <i class="bi bi-bar-chart"></i><span>Analytics</span>
                </a>
            </li>
        </ul>

        <span class="nav-section-label">Account</span>
        <ul class="nav flex-column sidebar-nav">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Account" asp-action="Setting">
                    <i class="bi bi-gear"></i><span>Settings</span>
                </a>
            </li>
            <li class="nav-item">
                {{!-- Logout: clears localStorage then redirects --}}
                <a class="nav-link" href="#" id="logoutBtn">
                    <i class="bi bi-box-arrow-right"></i><span>Logout</span>
                </a>
            </li>
        </ul>

        <!-- Admin name + initials filled by JS from localStorage -->
        <div class="sidebar-user">
            <div class="sidebar-avatar" id="sidebarInitials">--</div>
            <div class="sidebar-user-info">
                <span class="sidebar-user-name" id="sidebarName">Admin</span>
                <span class="sidebar-user-role">Super Admin</span>
            </div>
        </div>

    </nav>

    <!-- ── MAIN WRAPPER ───────────────────────────────────────────────────── -->
    <div class="main-wrapper">

        <header class="topbar">
            <div class="topbar-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search anything..." />
            </div>
            <div class="topbar-actions">
                <div class="icon-btn position-relative">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="icon-btn">
                    <i class="bi bi-person-circle"></i>
                </div>
                <a class="icon-btn" href="#" id="topbarLogoutBtn" title="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
                <div class="topbar-avatar" id="topbarInitials">--</div>
            </div>
        </header>

        <main class="content-area">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="container-fluid">&copy; 2026 - Artify Admin</div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ── Auth guard — checking localStorage ───
        var adminToken = localStorage.getItem("adminToken");
        if (!adminToken) {
            window.location.href = "/Admin/Login";
        }

        // ── Populate admin name and initials from localStorage ─────────────────
        var adminData = JSON.parse(localStorage.getItem("adminData") || "{}");
        var adminName = adminData.c_AdminName || "Admin";
        var words = adminName.trim().split(" ");
        var initials = words.map(function (w) { return w[0]; }).join("").toUpperCase().slice(0, 2);

        document.getElementById("sidebarName").textContent = adminName;
        document.getElementById("sidebarInitials").textContent = initials;
        document.getElementById("topbarInitials").textContent = initials;

        // ── Logout — clears localStorage then goes to /Admin/Logout ───────────
        // /Admin/Logout also calls Session.Clear() on the server side
        function doLogout() {
            localStorage.removeItem("adminToken");
            localStorage.removeItem("adminData");
            window.location.href = "/Admin/Logout";
        }

        document.getElementById("logoutBtn").addEventListener("click", function (e) {
            e.preventDefault();
            if (confirm("Are you sure you want to logout?")) doLogout();
        });

        document.getElementById("topbarLogoutBtn").addEventListener("click", function (e) {
            e.preventDefault();
            if (confirm("Are you sure you want to logout?")) doLogout();
        });
    </script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
