<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artify Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/adminsite.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
</head>

<body>

    <!-- SIDEBAR -->
    <nav id="sidebar">

        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="sidebar-logo">
                <i class="bi bi-layers-fill"></i>
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">Artify</span>
                <span class="sidebar-brand-tag">Admin Dashboard</span>
            </div>
        </div>

        <!-- FLEX WRAPPER -->
        <div class="sidebar-content d-flex flex-column h-100">

            <!-- MAIN NAV -->
            <div>
                <span class="nav-section-label">Main</span>
                <ul class="nav flex-column sidebar-nav">

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Artists" ? "active" : "")"
                           asp-controller="Admin" asp-action="Artists">
                            <i class="bi bi-person"></i>
                            <span>Artists</span>
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Artworks" ? "active" : "")"
                           asp-controller="Admin" asp-action="Artworks">
                            <i class="bi bi-bar-chart"></i>
                            <span>Artworks</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                           asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-people"></i>
                            <span>Users</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")"
                           asp-controller="Admin" asp-action="Categories">
                            <i class="bi bi-tags"></i>
                            <span>Categories</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payouts" ? "active" : "")"
                           asp-controller="Admin" asp-action="Payouts">
                            <i class="bi bi-cash-stack"></i>
                            <span>Payout Details</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")"
                           asp-controller="Admin" asp-action="Orders">
                            <i class="bi bi-cart"></i>
                            <span>Orders Details</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SalesSummary" ? "active" : "")"
                           asp-controller="Admin" asp-action="SalesSummary">
                            <i class="bi bi-bar-chart"></i>
                            <span>Sales / Analytics</span>
                        </a>
                    </li>

                </ul>
            </div>

            <!-- ACCOUNT NAV (BOTTOM) -->
            <div class="mt-auto">
                <span class="nav-section-label">Account</span>
                <ul class="nav flex-column sidebar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Setting">
                            <i class="bi bi-gear"></i>
                            <span>Setting</span>
                        </a>
                    </li>

                </ul>
            </div>

        </div>

    </nav>


    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">

    <!-- LEFT: PAGE TITLE -->
    <div class="topbar-left">
    </div>

    <!-- RIGHT: ACTIONS -->
    <div class="topbar-actions">

        <!-- Notification -->
        <div class="icon-btn position-relative">
            <i class="bi bi-bell"></i>
            <span class="notif-dot"></span>
        </div>

        <!-- Divider -->
        <div class="topbar-divider"></div>

        <!-- Profile -->
        <div class="topbar-profile">
            <div class="topbar-avatar">AA</div>
        </div>

    </div>

</header>


        <!-- PAGE CONTENT -->
        <main class="content-area">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="site-footer">
            <div class="container-fluid">
                &copy; 2026 - Artify
            </div>
        </footer>

    </div>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>