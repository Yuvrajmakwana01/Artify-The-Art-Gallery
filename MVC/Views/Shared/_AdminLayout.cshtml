<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artify Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/adminsite.css" asp-append-version="true" />
</head>
<body>

    <!-- SIDEBAR -->
    <nav id="sidebar">

        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="sidebar-logo">
                <i class="bi bi-layers-fill"></i>
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">Artify</span>
                <span class="sidebar-brand-tag">Admin Dashboard</span>
            </div>
        </div>

        <!-- Main Nav -->
        <span class="nav-section-label">Main</span>
        <ul class="nav flex-column sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Artists" ? "active" : "")"
                   asp-controller="Artists" asp-action="Index">
                    <i class="bi bi-person"></i>
                    <span>Artists</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Artworks" ? "active" : "")"
                   asp-controller="Artworks" asp-action="Index">
                    <i class="bi bi-image"></i>
                    <span>Artworks</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sales" ? "active" : "")"
                   asp-controller="Admin" asp-action="PaymentDetails">
                    <i class="bi bi-cart"></i>
                    <span>Payment Details</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")"
                   asp-controller="Analytics" asp-action="Index">
                    <i class="bi bi-bar-chart"></i>
                    <span>Analytics</span>
                </a>
            </li>
        </ul>

        <!-- Account Nav -->
        <span class="nav-section-label">Account</span>
        <ul class="nav flex-column sidebar-nav">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-in-left"></i>
                    <span>Logout</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Account" asp-action="Setting">
                    <i class="bi bi-gear"></i>
                    <span>Setting</span>
                </a>
            </li>
        </ul>

        <!-- User Footer -->
        <div class="sidebar-user">
            <div class="sidebar-avatar">AA</div>
            <div class="sidebar-user-info">
                <span class="sidebar-user-name">Admin</span>
                <span class="sidebar-user-role">Super admin</span>
            </div>
        </div>

    </nav>

    <!-- WRAPPER: topbar + content -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search anything..." />
            </div>
            <div class="topbar-actions">
                <div class="icon-btn position-relative">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </div>
                <div class="icon-btn">
                    <i class="bi bi-gear"></i>
                </div>
                <div class="topbar-avatar">AA</div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="content-area">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="site-footer">
            <div class="container-fluid">
                &copy; 2026 - Artify
            </div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>