<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Artify" : "Artify Studio")</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Kendo UI -->
    <link href="https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.default-v2.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Studio Paper CSS (single source of truth) -->
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        .top-navbar { overflow: visible; }
        .nav-actions { position: relative; }
        .artist-notification-wrap { position: relative; }
        .artist-notification-btn { position: relative; }
        .artist-notification-count {
            position: absolute;
            top: -4px;
            right: -4px;
            min-width: 18px;
            height: 18px;
            padding: 0 5px;
            border-radius: 999px;
            background: #d9485f;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            display: none;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 18px rgba(217, 72, 95, 0.32);
        }
        .artist-notification-count.visible { display: inline-flex; }
        .artist-notification-panel {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            width: 360px;
            max-width: calc(100vw - 24px);
            background: #fffaf2;
            border: 1px solid rgba(200, 135, 58, 0.18);
            border-radius: 18px;
            box-shadow: 0 22px 46px rgba(40, 30, 20, 0.18);
            padding: 12px;
            display: none;
            z-index: 1200;
        }
        .artist-notification-wrap.open .artist-notification-panel { display: block; }
        .artist-notification-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 4px 4px 10px;
            border-bottom: 1px solid rgba(200, 135, 58, 0.14);
        }
        .artist-notification-head strong {
            color: #2f2921;
            font-size: 14px;
            font-weight: 700;
        }
        .artist-notification-clear {
            border: none;
            background: transparent;
            color: #c8873a;
            font-size: 12px;
            font-weight: 700;
            padding: 0;
        }
        .artist-notification-clear:hover { color: #a56b22; }
        .artist-notification-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 360px;
            overflow-y: auto;
            padding: 10px 2px 2px;
        }
        .artist-notification-item {
            background: #ffffff;
            border-radius: 14px;
            padding: 12px;
            border: 1px solid rgba(47, 41, 33, 0.08);
            box-shadow: 0 8px 18px rgba(47, 41, 33, 0.05);
        }
        .artist-notification-item.approved { border-left: 4px solid #3aa76d; }
        .artist-notification-item.rejected { border-left: 4px solid #d9485f; }
        .artist-notification-item.general  { border-left: 4px solid #c8873a; }
        .artist-notification-item-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 6px;
        }
        .artist-notification-type {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #8c5a20;
        }
        .artist-notification-time {
            color: #8d867b;
            font-size: 11px;
            white-space: nowrap;
        }
        .artist-notification-title {
            color: #2f2921;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .artist-notification-message {
            color: #5d564c;
            font-size: 12px;
            line-height: 1.5;
            margin: 0;
        }
        .artist-notification-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: 10px;
        }
        .artist-notification-read {
            border: none;
            background: rgba(200, 135, 58, 0.12);
            color: #8c5a20;
            font-size: 11px;
            font-weight: 700;
            padding: 6px 10px;
            border-radius: 999px;
            cursor: pointer;
            transition: background 0.2s ease, color 0.2s ease, opacity 0.2s ease;
        }
        .artist-notification-read:hover {
            background: rgba(200, 135, 58, 0.2);
            color: #6f4315;
        }
        .artist-notification-read:disabled {
            opacity: 0.6;
            cursor: wait;
        }
        .artist-notification-empty,
        .artist-notification-error {
            padding: 18px 14px;
            border-radius: 14px;
            text-align: center;
            font-size: 12px;
        }
        .artist-notification-empty {
            background: rgba(255, 255, 255, 0.9);
            color: #8d867b;
            border: 1px dashed rgba(47, 41, 33, 0.12);
        }
        .artist-notification-error {
            background: #fff1f2;
            color: #b4233d;
            border: 1px solid rgba(217, 72, 95, 0.16);
        }
        @@media (max-width: 640px) {
            .artist-notification-panel {
                right: -32px;
                width: min(360px, calc(100vw - 16px));
            }
        }
    </style>
</head>

<body>

<!-- Mobile sidebar overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-container">

    <!-- ══════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">

        <!-- Logo -->
        <a class="logo" href="/Dashboard">
            <div class="logo-icon">
                <i class="bi bi-palette2" style="color:#fff;font-size:16px"></i>
            </div>
            <span class="logo-text">Artify</span>
        </a>

        <div class="sidebar-divider"></div>

        <span class="nav-label">Studio</span>

        <!-- Kendo Vertical Menu -->
        <ul id="sidebarMenu"></ul>

        <!-- Profile card -->
        <div class="sidebar-footer">
            <div class="profile-card">
                <img src="/images/user.png" alt="Artist" onerror="this.src='https://ui-avatars.com/api/?name=Artist&background=2e2d29&color=e8a857&size=34'" />
                <div>
                    <h6>Artist Name</h6>
                    <small>Pro Member</small>
                </div>
            </div>
        </div>

    </aside>

    <!-- ══════════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════════ -->
    <div class="main-content">

        <!-- TOP NAVBAR -->
        <nav class="top-navbar">

            <!-- Mobile menu toggle -->
            <button class="mobile-menu-btn me-3" id="mobileMenuBtn" aria-label="Open menu">
                <i class="bi bi-list"></i>
            </button>

            <!-- Search -->
            <div class="search-bar-container">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search artwork, artists…" autocomplete="off" />
            </div>



            <!-- Actions -->
            <div class="nav-actions">
                <div class="artist-notification-wrap" id="artistNotificationWrap">
                    <button type="button"
                            class="nav-icon-btn notification-trigger artist-notification-btn"
                            id="artistNotificationBtn"
                            title="Notifications"
                            aria-expanded="false">
                        <i class="bi bi-bell"></i>
                        <span class="artist-notification-count" id="artistNotificationCount">0</span>
                    </button>
                    <div class="artist-notification-panel" id="artistNotificationPanel">
                        <div class="artist-notification-head">
                            <strong>Notifications</strong>
                            <button type="button" class="artist-notification-clear" id="artistNotificationClear">
                                Mark all read
                            </button>
                        </div>
                        <div class="artist-notification-list" id="artistNotificationList">
                            <div class="artist-notification-empty">No notifications yet.</div>
                        </div>
                    </div>
                </div>
                <div class="v-divider"></div>
                <img src="/images/user.png"
                     class="nav-avatar"
                     alt="Profile"
                     onerror="this.src='https://ui-avatars.com/api/?name=Artist&background=e8e5dd&color=c8873a&size=34'" />
            </div>

            

        </nav>

        <!-- PAGE CONTENT -->
        <div class="content-body">
            @RenderBody()
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════
     SCRIPTS
══════════════════════════════════════ -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://kendo.cdn.telerik.com/2024.1.130/js/kendo.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    /* ── SIDEBAR NAVIGATION ── */
    $("#sidebarMenu").kendoMenu({
        orientation: "vertical",
        openOnClick: true,
        dataSource: [
            { text: "Dashboard",  spriteCssClass: "bi bi-house",         url: "/Artist/Dashboard"       },
            { text: "Explore Art", spriteCssClass: "bi bi-grid",          url: "/Artist/Index"         },
            { text: "My Artwork",  spriteCssClass: "bi bi-image",         url: "/Artist/Gallery"  },
            { text: "Upload",      spriteCssClass: "bi bi-cloud-arrow-up", url: "/Artist/Upload"         },
            { text: "Analytics",   spriteCssClass: "bi bi-bar-chart",     url: "/Artist/Sales_Earnings"       },
            { text: "Profile",      spriteCssClass: "bi bi-person", url: "/Artist/MyProfile"        },
            { text: "Manage Profile",     spriteCssClass: "bi bi-person-gear",        url: "/Artist/Profile"         },
            { text: "Settings",    spriteCssClass: "bi bi-gear",          url: "/Artist/Settings"        },
            { text: "Logout",      spriteCssClass: "bi bi-box-arrow-right", url: "/Artist/Logout"        }



        ]
    });

    /* ── ACTIVE LINK HIGHLIGHT ── */
    (function() {
        var path = window.location.pathname.toLowerCase();
        $("#sidebarMenu .k-link").each(function() {
            var href = ($(this).attr("href") || "").toLowerCase();
            if (href && path.startsWith(href) && href !== "/") {
                $(this).closest(".k-item").addClass("k-state-selected");
            }
        });
    })();

    /* ── MOBILE SIDEBAR TOGGLE ── */
    $("#mobileMenuBtn").on("click", function() {
        $("#sidebar").toggleClass("open");
        $("#sidebarOverlay").toggleClass("visible");
    });

    $("#sidebarOverlay").on("click", function() {
        $("#sidebar").removeClass("open");
        $("#sidebarOverlay").removeClass("visible");
    });

    /* ── SCROLL-AWARE CONTENT BODY ── */
    $(".content-body").on("scroll", function() {
        var scrolled = $(this).scrollTop() > 10;
        $(".top-navbar").toggleClass("scrolled", scrolled);
    });

    /* ── ARTIST NOTIFICATIONS ── */
    var ARTIST_API_BASE = "http://localhost:5183/api/ArtistApi";
    var artistNotificationPollHandle = null;

    function artistAuthToken() {
        return localStorage.getItem("authToken");
    }

    function artistAuthHeaders() {
        var token = artistAuthToken();
        return token ? { "Authorization": "Bearer " + token } : {};
    }

    function escapeNotificationHtml(value) {
        if (!value) return "";
        return String(value)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/\"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function notificationHeading(type) {
        var kind = (type || "").toLowerCase();
        if (kind === "artwork_approved") return "Artwork approved";
        if (kind === "artwork_rejected") return "Artwork rejected";
        if (kind === "like") return "New like";
        if (kind === "payment" || kind === "payment_received") return "Payment received";
        return "Notification";
    }

    function notificationCardClass(type) {
        var kind = (type || "").toLowerCase();
        if (kind.indexOf("approved") !== -1) return "approved";
        if (kind.indexOf("rejected") !== -1) return "rejected";
        return "general";
    }

    function formatNotificationTime(value) {
        if (!value) return "";

        var date = new Date(value);
        if (isNaN(date.getTime())) return "";

        var diffMs = Date.now() - date.getTime();
        var diffMinutes = Math.floor(diffMs / 60000);

        if (diffMinutes < 1) return "Just now";
        if (diffMinutes < 60) return diffMinutes + "m ago";

        var diffHours = Math.floor(diffMinutes / 60);
        if (diffHours < 24) return diffHours + "h ago";

        var diffDays = Math.floor(diffHours / 24);
        if (diffDays < 7) return diffDays + "d ago";

        return date.toLocaleString("en-IN", {
            day: "numeric",
            month: "short",
            hour: "numeric",
            minute: "2-digit"
        });
    }

    function updateArtistNotificationCount(count) {
        var badge = document.getElementById("artistNotificationCount");
        if (!badge) return;

        var safeCount = parseInt(count, 10) || 0;
        if (safeCount > 0) {
            badge.textContent = safeCount > 99 ? "99+" : safeCount;
            badge.classList.add("visible");
        } else {
            badge.textContent = "0";
            badge.classList.remove("visible");
        }
    }

    function renderArtistNotifications(items) {
        var list = document.getElementById("artistNotificationList");
        if (!list) return;

        if (!items || !items.length) {
            list.innerHTML = '<div class="artist-notification-empty">No notifications yet.</div>';
            return;
        }

        list.innerHTML = items.map(function(item) {
            var titleHtml = item.title
                ? '<div class="artist-notification-title">' + escapeNotificationHtml(item.title) + '</div>'
                : '';
            var notificationId = escapeNotificationHtml(item.id || '');
            var actionsHtml = notificationId
                ? '<div class="artist-notification-actions">' +
                    '<button type="button" class="artist-notification-read" data-notification-id="' + notificationId + '">Mark as read</button>' +
                  '</div>'
                : '';

            return '' +
                '<article class="artist-notification-item ' + notificationCardClass(item.type) + '" data-notification-id="' + notificationId + '">' +
                    '<div class="artist-notification-item-head">' +
                        '<span class="artist-notification-type">' + escapeNotificationHtml(notificationHeading(item.type)) + '</span>' +
                        '<span class="artist-notification-time">' + escapeNotificationHtml(formatNotificationTime(item.createdAtUtc)) + '</span>' +
                    '</div>' +
                    titleHtml +
                    '<p class="artist-notification-message">' + escapeNotificationHtml(item.message || '') + '</p>' +
                    actionsHtml +
                '</article>';
        }).join("");
    }

    function closeArtistNotificationPanel() {
        var wrap = document.getElementById("artistNotificationWrap");
        var btn = document.getElementById("artistNotificationBtn");
        if (wrap) wrap.classList.remove("open");
        if (btn) btn.setAttribute("aria-expanded", "false");
    }

    function markArtistNotificationsRead() {
        var token = artistAuthToken();
        if (!token) return $.Deferred().resolve().promise();

        return $.ajax({
            url: ARTIST_API_BASE + "/notifications/read",
            method: "POST",
            headers: artistAuthHeaders()
        }).done(function() {
            updateArtistNotificationCount(0);
            renderArtistNotifications([]);
        });
    }

    function markArtistNotificationRead(notificationId) {
        var token = artistAuthToken();
        if (!token || !notificationId) return $.Deferred().reject().promise();

        return $.ajax({
            url: ARTIST_API_BASE + "/notifications/" + encodeURIComponent(notificationId) + "/read",
            method: "POST",
            headers: artistAuthHeaders()
        });
    }

    function loadArtistNotifications() {
        var token = artistAuthToken();
        if (!token) return;

        $.ajax({
            url: ARTIST_API_BASE + "/notifications",
            method: "GET",
            headers: artistAuthHeaders(),
            data: { take: 10 }
        }).done(function(res) {
            renderArtistNotifications((res && res.data) || []);
            updateArtistNotificationCount((res && res.unreadCount) || 0);
        }).fail(function(xhr) {
            if (xhr.status === 401) {
                updateArtistNotificationCount(0);
                return;
            }

            var list = document.getElementById("artistNotificationList");
            if (list) {
                list.innerHTML = '<div class="artist-notification-error">Unable to load notifications right now.</div>';
            }
        });
    }

    $(function() {
        var wrap = document.getElementById("artistNotificationWrap");
        var button = document.getElementById("artistNotificationBtn");
        var clearButton = document.getElementById("artistNotificationClear");
        var list = document.getElementById("artistNotificationList");

        if (!wrap || !button) return;

        button.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();

            var isOpen = wrap.classList.toggle("open");
            button.setAttribute("aria-expanded", isOpen ? "true" : "false");

            if (isOpen) {
                loadArtistNotifications();
            }
        });

        if (clearButton) {
            clearButton.addEventListener("click", function(e) {
                e.preventDefault();
                e.stopPropagation();
                markArtistNotificationsRead();
            });
        }

        if (list) {
            list.addEventListener("click", function(e) {
                var readButton = e.target.closest(".artist-notification-read");
                if (!readButton) return;

                e.preventDefault();
                e.stopPropagation();

                var notificationId = readButton.getAttribute("data-notification-id");
                if (!notificationId) return;

                readButton.disabled = true;
                readButton.textContent = "Marking...";

                markArtistNotificationRead(notificationId)
                    .done(function(res) {
                        updateArtistNotificationCount((res && res.unreadCount) || 0);
                        loadArtistNotifications();
                    })
                    .fail(function() {
                        readButton.disabled = false;
                        readButton.textContent = "Mark as read";
                    });
            });
        }

        document.addEventListener("click", function(e) {
            if (!wrap.contains(e.target)) {
                closeArtistNotificationPanel();
            }
        });

        loadArtistNotifications();

        if (artistNotificationPollHandle) {
            window.clearInterval(artistNotificationPollHandle);
        }

        artistNotificationPollHandle = window.setInterval(function() {
            loadArtistNotifications();
        }, 30000);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
