<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Artify" : "Artify Studio")</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Kendo UI -->
    <link href="https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.default-v2.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Studio Paper CSS (single source of truth) -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

<!-- Mobile sidebar overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-container">

    <!-- ══════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">

        <!-- Logo -->
        <a class="logo" href="/Dashboard">
            <div class="logo-icon">
                <i class="bi bi-palette2" style="color:#fff;font-size:16px"></i>
            </div>
            <span class="logo-text">Artify</span>
        </a>

        <div class="sidebar-divider"></div>

        <span class="nav-label">Studio</span>

        <!-- Kendo Vertical Menu -->
        <ul id="sidebarMenu"></ul>

        <!-- Profile card -->
        <div class="sidebar-footer">
            <div class="profile-card">
                <img src="/images/user.png" alt="Artist" onerror="this.src='https://ui-avatars.com/api/?name=Artist&background=2e2d29&color=e8a857&size=34'" />
                <div>
                    <h6>Artist Name</h6>
                    <small>Pro Member</small>
                </div>
            </div>
        </div>

    </aside>

    <!-- ══════════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════════ -->
    <div class="main-content">

        <!-- TOP NAVBAR -->
        <nav class="top-navbar">

            <!-- Mobile menu toggle -->
            <button class="mobile-menu-btn me-3" id="mobileMenuBtn" aria-label="Open menu">
                <i class="bi bi-list"></i>
            </button>

            <!-- Search -->
            <div class="search-bar-container">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search artwork, artists…" autocomplete="off" />
            </div>



            <!-- Actions -->
            <div class="nav-actions">
                <button class="nav-icon-btn has-notif notification-trigger" title="Notifications">
                    <i class="bi bi-bell"></i>
                </button>
                <div class="v-divider"></div>
                <img src="/images/user.png"
                     class="nav-avatar"
                     alt="Profile"
                     onerror="this.src='https://ui-avatars.com/api/?name=Artist&background=e8e5dd&color=c8873a&size=34'" />
            </div>

            

        </nav>

        <!-- PAGE CONTENT -->
        <div class="content-body">
            @RenderBody()
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════
     SCRIPTS
══════════════════════════════════════ -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://kendo.cdn.telerik.com/2024.1.130/js/kendo.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    /* ── SIDEBAR NAVIGATION ── */
    $("#sidebarMenu").kendoMenu({
        orientation: "vertical",
        openOnClick: true,
        dataSource: [
            { text: "Dashboard",  spriteCssClass: "bi bi-house",         url: "/Artist/Dashboard"       },
            { text: "Explore Art", spriteCssClass: "bi bi-grid",          url: "/Artist/Index"         },
            { text: "My Artwork",  spriteCssClass: "bi bi-image",         url: "/Artist/Gallery"  },
            { text: "Upload",      spriteCssClass: "bi bi-cloud-arrow-up", url: "/Artist/Upload"         },
            { text: "Analytics",   spriteCssClass: "bi bi-bar-chart",     url: "/Artist/Sales_Earnings"       },
            { text: "Profile",      spriteCssClass: "bi bi-person", url: "/Artist/MyProfile"        },
            { text: "Manage Profile",     spriteCssClass: "bi bi-person-gear",        url: "/Artist/Profile"         },
            { text: "Settings",    spriteCssClass: "bi bi-gear",          url: "/Artist/Settings"        },
            { text: "Logout",      spriteCssClass: "bi bi-box-arrow-right", url: "/Artist/Logout"        }



        ]
    });

    /* ── ACTIVE LINK HIGHLIGHT ── */
    (function() {
        var path = window.location.pathname.toLowerCase();
        $("#sidebarMenu .k-link").each(function() {
            var href = ($(this).attr("href") || "").toLowerCase();
            if (href && path.startsWith(href) && href !== "/") {
                $(this).closest(".k-item").addClass("k-state-selected");
            }
        });
    })();

    /* ── MOBILE SIDEBAR TOGGLE ── */
    $("#mobileMenuBtn").on("click", function() {
        $("#sidebar").toggleClass("open");
        $("#sidebarOverlay").toggleClass("visible");
    });

    $("#sidebarOverlay").on("click", function() {
        $("#sidebar").removeClass("open");
        $("#sidebarOverlay").removeClass("visible");
    });

    /* ── SCROLL-AWARE CONTENT BODY ── */
    $(".content-body").on("scroll", function() {
        var scrolled = $(this).scrollTop() > 10;
        $(".top-navbar").toggleClass("scrolled", scrolled);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
