<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Artist</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- TOP NAVBAR (UNCHANGED) -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-3">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" asp-controller="Artist" asp-action="Index">
                    Artify
                </a>

                <div class="flex-grow-1 mx-4">
                    <input type="text" class="form-control rounded-pill px-4"
                           placeholder="Search artworks, orders, messages..." />
                </div>

                <ul class="navbar-nav align-items-center gap-3">

                    <li class="nav-item">
                        <a class="nav-link position-relative" href="#">
                            🔔
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link position-relative" href="#">
                            💬
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">2</span>
                        </a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                            <div class="bg-warning text-white rounded-circle d-flex justify-content-center align-items-center"
                                 style="width:35px;height:35px;">M</div>
                            <span class="ms-2">Maya</span>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">Profile</a></li>
                            <li><a class="dropdown-item" href="#">Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">Logout</a></li>
                        </ul>
                    </li>

                </ul>

            </div>
        </nav>
    </header>

    <!-- MAIN LAYOUT -->
    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-light border-end" style="width:250px; min-height:100vh;">

            <div class="p-3">

                <h6 class="text-muted">WORKSPACE</h6>
                <ul class="nav flex-column mb-3">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Artist" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Upload Artwork</a>
                    </li>
                </ul>

                <h6 class="text-muted">GALLERY</h6>
                <ul class="nav flex-column mb-3">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">My Artworks</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Collections</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Exhibitions</a>
                    </li>
                </ul>

                <h6 class="text-muted">SALES</h6>
                <ul class="nav flex-column mb-3">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Orders</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Earnings</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Payouts</a>
                    </li>
                </ul>

                <h6 class="text-muted">COMMUNITY</h6>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Messages</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Notifications</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#">Reviews</a>
                    </li>
                </ul>

            </div>
        </div>

        <!-- CONTENT AREA -->
        <div class="flex-grow-1 p-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MVC - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
