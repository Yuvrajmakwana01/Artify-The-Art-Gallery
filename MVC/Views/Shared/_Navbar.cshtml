<style>
    /* ─────────────────────────────────────────────────────── */
    /* NAVBAR (Floating)                                       */
    /* ─────────────────────────────────────────────────────── */
    .floating-nav { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); z-index: 220; width: min(92vw, 860px); display: grid; place-items: center; pointer-events: none; }
    .floating-nav-trigger, .floating-nav-panel { grid-area: 1 / 1; }
    .floating-nav-trigger, .floating-nav-panel, .floating-nav-logo, .floating-nav-link, .floating-nav-toggle, .nav-icon-btn { pointer-events: auto; }
    .floating-nav-trigger { border: none; border-radius: 18px; min-width: 150px; min-height: 58px; padding: 0 30px; background: #111111; color: #ffffff; font-family: 'DM Sans', sans-serif; font-size: 24px; font-weight: 600; cursor: pointer; box-shadow: 0 18px 40px rgba(0, 0, 0, .22); transition: opacity .28s ease, transform .34s cubic-bezier(.16, 1, .3, 1), box-shadow .25s ease; }
    .floating-nav-trigger:hover { box-shadow: 0 22px 48px rgba(0, 0, 0, .28); }
    .floating-nav.is-open .floating-nav-trigger { opacity: 0; transform: translateY(10px) scale(.88); pointer-events: none; }
    .floating-nav-panel { width: 100%; display: grid; grid-template-columns: 68px minmax(0, 1fr) 68px; align-items: center; gap: 18px; opacity: 0; transform: translateY(10px) scale(.96); transform-origin: bottom center; transition: opacity .32s ease, transform .42s cubic-bezier(.16, 1, .3, 1); pointer-events: none; }
    .floating-nav.is-open .floating-nav-panel { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
    .floating-nav-logo { width: 68px; height: 68px; display: flex; align-items: center; justify-content: center; text-decoration: none; filter: drop-shadow(0 18px 34px rgba(0, 0, 0, .18)); overflow: hidden; border-radius: 25%; background: #0b0c10; }
    .floating-nav-logo img { width: 68px; height: 68px; display: block; object-fit: cover; transform: scale(2.65) translateX(3%); }
    .floating-nav-links { min-width: 0; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 16px; border-radius: 20px; background: rgba(246, 247, 249, .96); border: 1px solid rgba(17, 17, 17, .05); box-shadow: 0 18px 40px rgba(15, 23, 42, .14); backdrop-filter: blur(16px); }
    .floating-nav-link { flex: 0 0 auto; padding: 13px 22px; border-radius: 999px; color: #151515; font-size: 15px; font-weight: 700; line-height: 1; text-decoration: none; transition: background .22s ease, color .22s ease, transform .22s ease; }
    .floating-nav-link.is-active, .floating-nav-link:hover, .floating-nav-link:focus-visible { background: #111111; color: #ffffff; }
    .floating-nav-logo:focus-visible, .floating-nav-trigger:focus-visible, .floating-nav-link:focus-visible { outline: 2px solid var(--subhead); outline-offset: 4px; }
    .floating-nav-toggle { position: relative; width: 68px; height: 68px; border: none; border-radius: 18px; background: #111111; box-shadow: 0 18px 34px rgba(0, 0, 0, .18); cursor: default; }
    .floating-nav-toggle::before, .floating-nav-toggle::after { content: ""; position: absolute; top: 50%; width: 16px; height: 16px; border-radius: 50%; transform: translateY(-50%); }
    .floating-nav-toggle::before { left: 21px; background: rgba(221, 214, 204, .42); }
    .floating-nav-toggle::after { left: 31px; background: #ffffff; }
    .nav-actions { display: flex; align-items: center; gap: 6px; margin-left: auto; }
    .nav-icon-btn { position: relative; display: grid; place-items: center; height: 40px; width: 40px; border-radius: 50%; border: 1.5px solid var(--border); background: rgba(255,255,255,.5); cursor: pointer; color: var(--text); transition: background .2s, border-color .2s, transform .2s; text-decoration: none; }
    .nav-icon-btn:hover { background: #111111; color: #ffffff; border-color: #111111; transform: scale(1.08); }
    .nav-badge { position: absolute; top: -4px; right: -4px; height: 16px; min-width: 16px; padding: 0 3px; background: var(--heading); color: #fff; border-radius: 999px; font-size: .62rem; font-weight: 700; display: grid; place-items: center; }
    @@media(max-width:950px) {
        .floating-nav-links { justify-content: flex-start; overflow-x: auto; padding: 8px; gap: 6px; scrollbar-width: none; }
        .floating-nav-links::-webkit-scrollbar { display: none; }
        .floating-nav-link { padding: 11px 16px; font-size: 13px; }
    }
</style>

<div class="floating-nav" id="floatingNav">
    <button class="floating-nav-trigger" id="floatingNavTrigger" aria-expanded="false" aria-controls="floatingNavPanel">Menu</button>

    <div class="floating-nav-panel" id="floatingNavPanel">
        <a href="/" class="floating-nav-logo" aria-label="Artify home">
            <img src="/images/Untitled design.png" alt="" aria-hidden="true" />
        </a>

        <nav class="floating-nav-links" aria-label="Primary">
            <a href="/Buyer/ExploreArt" class="floating-nav-link is-active" data-nav-link>Explore</a>
            <a href="/Buyer/ExploreArt#trending" class="floating-nav-link" data-nav-link>Trending</a>
            <a href="/Buyer/ExploreArt#about" class="floating-nav-link" data-nav-link>About</a>
            
            <div class="nav-actions" style="margin-left: 10px;">
                <a href="/Wishlist/Index" class="nav-icon-btn" title="Wishlist" aria-label="Wishlist">
                  <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                  </svg>
                  <span class="nav-badge" id="wishBadge" style="background:#EDA312; display:none;">0</span>
                </a>
                <a href="/Cart/Index" class="nav-icon-btn" title="Cart" aria-label="Cart">
                  <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                  </svg>
                  <span class="nav-badge" id="cartBadge" style="display:none;">0</span>
                </a>
                <a href="/Buyer/Dashboard#profile" class="nav-icon-btn" title="Profile" aria-label="Profile">
                  <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </a>
            </div>
        </nav>

        <button class="floating-nav-toggle" type="button" aria-hidden="true" tabindex="-1"></button>
    </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
      var nav = document.getElementById('floatingNav');
      var trigger = document.getElementById('floatingNavTrigger');
      var panel = document.getElementById('floatingNavPanel');
      var links = Array.prototype.slice.call(document.querySelectorAll('[data-nav-link]'));
      var defaultLink = links[0];
      var closeTimer = null;
      var isOpen = false;

      if (!nav || !trigger || !panel) return;

      function clearCloseTimer() {
          if (closeTimer) { window.clearTimeout(closeTimer); closeTimer = null; }
      }
      function setActive(link) {
          links.forEach(function (item) { item.classList.toggle('is-active', item === link); });
      }
      function openNav() {
          clearCloseTimer();
          if (isOpen) return;
          isOpen = true;
          nav.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
      }
      function closeNav() {
          clearCloseTimer();
          if (!isOpen) return;
          isOpen = false;
          nav.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
          if (defaultLink) setActive(defaultLink);
      }
      function scheduleClose() {
          clearCloseTimer();
          closeTimer = window.setTimeout(closeNav, 120);
      }

      trigger.addEventListener('mouseenter', openNav);
      trigger.addEventListener('focus', openNav);
      trigger.addEventListener('click', function () { if (isOpen) closeNav(); else openNav(); });

      nav.addEventListener('mouseenter', clearCloseTimer);
      nav.addEventListener('mouseleave', scheduleClose);
      panel.addEventListener('focusin', openNav);
      nav.addEventListener('focusout', function (event) { if (!nav.contains(event.relatedTarget)) scheduleClose(); });

      links.forEach(function (link) {
          link.addEventListener('mouseenter', function () { setActive(link); });
          link.addEventListener('focus', function () { setActive(link); openNav(); });
          link.addEventListener('click', closeNav);
      });

      document.addEventListener('click', function (event) { if (!nav.contains(event.target)) closeNav(); });
      document.addEventListener('keydown', function (event) { if (event.key === 'Escape') closeNav(); });
  });
</script>
<script src="/js/globalBadges.js"></script>
