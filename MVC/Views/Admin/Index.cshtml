    </div>
  <!-- Recent Activity -->
  <div class="card">
    <div class="activity-header">
      <div class="card-title">Recent Activity</div>
      <a href="#" class="view-all">View All</a>
    </div>
      <div id="activityContainer"></div>
   
  </div>
  
</div>


@section Scripts{
   <link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.common.min.css" />
    <link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.default.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.2.616/js/kendo.all.min.js"></script>
<script>

  const API_BASE = "http://localhost:5183/api/AdminApi";
  
  function checkAuth() {
    const token = localStorage.getItem("adminToken");
    const expiry = localStorage.getItem("adminExpiry");

    if (!token || !expiry) {
        window.location.href = "/Admin/Login";
        return false;
    }

    if (Date.now() > expiry * 1000) {
        localStorage.removeItem("adminToken");
        localStorage.removeItem("adminExpiry");

        window.location.href = "/Admin/Login";
        return false;
    }

    return true;
    }

    function authHeader() {
        if (!checkAuth()) return {};

        const token = localStorage.getItem("adminToken");

        return {
            "Authorization": "Bearer " + token
        };
    }

$(document).ready(function () {

    var type = $("#filter").val();

   loadChart(type);
   loadUserGrowthChart("weekly");
   loadUserPieChart();
   loadCategoryChart();
   loadDashboardStats();
   loadTopArtists();
   loadRecentActivity();
});

function loadDashboardStats() 
{ $.ajax({
   url: API_BASE + "/dashboard", type: "GET", headers: authHeader(),
   success: function (data) { 
      $(".stat-card").eq(0).find(".stat-value").text(data.c_TotalUsers);
      $(".stat-card").eq(1).find(".stat-value").text(data.c_TotalArtists);
      $(".stat-card").eq(2).find(".stat-value").text(data.c_TotalArts);
      $(".stat-card").eq(3).find(".stat-value").text(data.c_TotalSales);
      $(".stat-card").eq(4).find(".stat-value").text("$" + data.c_TotalRevenue);
    },
   error: function (err)
      { 
      console.error("Dashboard error", err);
      } 
  });
 }

function loadChart(type) {

    $.ajax({
        url: API_BASE + "/revenue?type=" + type.toUpperCase(),
        type: "GET",
        headers: authHeader(),
        success: function (res) {
            console.log(res);
            let result = {
                categories: [],
                gross: [],
                platform: [],
                artist: []
            };

            res.forEach(item => {
                result.categories.push(item.label);
                result.gross.push(item.grossRevenue);
                result.platform.push(item.platformRevenue);
                result.artist.push(item.artistRevenue);
            });

            renderChart(result);
        },
        error: function (err) {
            console.log(err);
        }
    });
}

function renderChart(result) {

    $("#sales-chart").data("kendoChart")?.destroy();
    $("#sales-chart").empty();

    $("#sales-chart").kendoChart({
        title: {
            text: "Sales Trend"
        },
        seriesDefaults: {
            type: "line",
            markers: {
                visible: true,
                size: 5
            }
        },
        series: [
            {
                name: "Gross Revenue",
                data: result.gross,
                width: 3
            },
            {
                name: "Platform Revenue",
                data: result.platform,
                dashType: "dash"
            },
            {
                name: "Artist Revenue",
                data: result.artist,
                dashType: "dot"
            }
        ],
        categoryAxis: {
            categories: result.categories
        },
        valueAxis: {
            title: { text: "Revenue (₹)" }
        },
        tooltip: {
            visible: true,
            shared: true,   // 🔥 shows all values together
            format: "₹{0}"
        },
        legend: {
            position: "bottom"
        },
        transitions: true
    });
} 
  
function loadUserGrowthChart(type) {

         $.ajax({
        url: API_BASE + "/users-count?type=" + type.toUpperCase(),
        type: "GET",
        headers: authHeader(),
        success: function (res) {
          console.log(res)
            let result = {
                categories: [],
                userCount: [],
                artistCount: []
            };

            res.forEach(item => {
                result.categories.push(item.label);
                result.userCount.push(item.userCount);
                result.artistCount.push(item.artistCount);
            });

            renderUserGrowthChart(result);
        },
        error: function (err) {
            console.log(err);
        }
    });
    }

function renderUserGrowthChart(result) {

    // 🔥 destroy old chart (important)
    $("#userGrowthChart").data("kendoChart")?.destroy();
    $("#userGrowthChart").empty();

     $("#userGrowthChart").kendoChart({
            title: {
                text: "User Growth (Buyers vs Artists)"
            },
            legend: {
                position: "top"
            },
            seriesDefaults: {
                type: "column"   
            },
            series: [
                {
                    name: "Buyers",
                    data: result.userCount
                },
                {
                    name: "Artists",
                    data: result.artistCount
                }
            ],
            categoryAxis: {
                categories: result.categories,
                title: {
                    text: "Time"
                }
            },
            valueAxis: {
                title: {
                    text: "Users Count"
                }
            },
            tooltip: {
                visible: true,
                format: "{0}"
            }
        });
   
} 
  
function loadUserPieChart() {

    $.ajax({
        url: API_BASE + "/total-count",
        type: "GET",
        headers: authHeader(),
        success: function (res) {
            console.log(res);
            $("#userPieChart").kendoChart({
                title: {
                    text: "User Split"
                },
                series: [{
                    type: "pie",
                    data: [
                        { category: "Buyers", value: res.userTotalCount },
                        { category: "Artists", value: res.artistTotalCount }
                    ]
                }],
                tooltip: {
                    visible: true,
                    template: "#= category #: #= value #"
                },
                legend: {
                    position: "bottom"
                }
            });

        },
        error: function (err) {
            console.log("Pie chart error", err);
        }
    });
}

function loadCategoryChart() {

    $.ajax({
        url: API_BASE + "/top-category",
        type: "GET",
        headers: authHeader(),
        success: function (res) {
            console.log(res);
            let categories = [];
            let data = [];

            res.forEach(item => {
                categories.push(item.category);
                data.push(item.totalSales);
            });

            $("#categoryChart").kendoChart({
                title: {
                    text: "Top Selling Categories"
                },
                series: [{
                    type: "bar",
                    data: data
                }],
                categoryAxis: {
                    categories: categories
                },
                tooltip: {
                    visible: true
                }
            });

        },
        error: function (err) {
            console.log("Category chart error", err);
        }
    });
}

function loadTopArtists() {
    $.ajax({
        url: API_BASE + "/top-artists", 
        type: "GET",
        headers: authHeader(),
        success: function (data) {
            let html = "";
            console.log("data",data);
            data.forEach((artist, index) => {

                // First letter for avatar
                let avatar = artist.name ? artist.name.charAt(0).toUpperCase() : "A";

                html += `
                    <div class="artist-item">
                        <div class="artist-avatar">${avatar}</div>

                        <div class="artist-info">
                            <div class="artist-name">${artist.name}</div>
                            <div class="artist-genre">Top Performer</div>
                        </div>

                        <div class="artist-stats">
                            <div class="artist-revenue">₹ ${artist.totalRevenue.toLocaleString()}</div>
                            <div class="artist-sales">${artist.totalSales} Sales</div>
                        </div>
                    </div>
                `;
            });

            $("#topArtistsContainer").html(html);
        },
        error: function (err) {
            console.error("Error loading top artists", err);
        }
    });
  }

function loadRecentActivity() {
    $.ajax({
        url: API_BASE+"/recent-activity", 
        type: "GET",
        headers: authHeader(),
        success: function (data) {

            let html = "";

            data.forEach(activity => {

                let iconClass = getIconClass(activity.activity_Type);
                let iconEmoji = getIconEmoji(activity.activity_Type);
                let timeAgo = formatTimeAgo(activity.created_At);

                html += `
                    <div class="activity-item">
                        <div class="act-icon ${iconClass}">${iconEmoji}</div>
                        <div>
                            <div class="act-title">${activity.activity_Type}</div>
                            <div class="act-desc">${activity.description}</div>
                            <div class="act-time">${timeAgo}</div>
                        </div>
                    </div>
                `;
            });

            $("#activityContainer").html(html);
        },
        error: function (err) {
            console.error("Error loading activity", err);
        }
    });
}

function getIconClass(type) {
    switch (type?.toLowerCase()) {
        case "sale": return "act-blue";
        case "user": return "act-green";
        case "artist": return "act-purple";
        case "order": return "act-orange";
        default: return "act-gray";
    }
}

function getIconEmoji(type) {
    switch (type?.toLowerCase()) {
        case "sale": return "🛒";
        case "user": return "👤";
        case "artist": return "🎨";
        case "order": return "📦";
        default: return "⚡";
    }
}

function formatTimeAgo(dateString) {
    let date = new Date(dateString);
    let now = new Date();

    let diff = Math.floor((now - date) / 1000);

    if (diff < 60) return diff + " SECONDS AGO";
    if (diff < 3600) return Math.floor(diff / 60) + " MINUTES AGO";
    if (diff < 86400) return Math.floor(diff / 3600) + " HOURS AGO";

    return Math.floor(diff / 86400) + " DAYS AGO";
}
$("#filter").change(function () {
    let type = $(this).val();
    loadChart(type);
});
$("#growthType").change(function () {
    loadUserGrowthChart($(this).val());
});

</script>
}

</body>
</html>