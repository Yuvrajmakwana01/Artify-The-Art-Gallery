
@{
    Layout = "../Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Artwork Moderation";
}

<style>
    :root {
        --brand:       #f97316;
        --brand-light: #fff7ed;
        --brand-dark:  #ea580c;
        --approved:    #22c55e;
        --rejected:    #ef4444;
        --pending:     #f97316;
        --surface:     #ffffff;
        --bg:          #f8f7f4;
        --border:      #e5e7eb;
        --text-main:   #111827;
        --text-muted:  #6b7280;
        --shadow-sm:   0 1px 3px rgba(0,0,0,.08);
        --shadow-md:   0 4px 16px rgba(0,0,0,.10);
        --radius:      12px;
        --radius-sm:   8px;
    }

    /* Layout */
    .mod-page         { display:flex; flex-direction:column; gap:20px; }
    .mod-header {
        display:flex;
        align-items:flex-start;
        justify-content:space-between;
        flex-wrap:wrap;
        gap:12px;

        position:relative; /* or just remove position entirely */

        background:var(--bg);
        padding:14px 0 10px;
        margin:-14px 0 0;
    }
    .mod-title        { font-size:1.65rem; font-weight:700; color:var(--text-main); margin:0; }
    .mod-subtitle     { font-size:.85rem; color:var(--text-muted); margin:2px 0 0; }
    .mod-body         { display:grid; grid-template-columns:1fr 320px; gap:20px; align-items:start; }


    /* Search / Filter Bar */
    .search-bar        { display:flex; gap:10px; flex-wrap:wrap; align-items:center;
                          background:var(--surface); border:1px solid var(--border);
                          border-radius:var(--radius); padding:10px 14px;
                          box-shadow:var(--shadow-sm); }
    .search-field      { position:relative; flex:1; min-width:180px; }
    .search-field i    { position:absolute; left:10px; top:50%; transform:translateY(-50%);
                          color:var(--text-muted); font-size:.85rem; pointer-events:none; }
    .search-input      { width:100%; border:1.5px solid var(--border); border-radius:8px;
                          padding:7px 10px 7px 32px; font-size:.82rem; color:var(--text-main);
                          background:#fafafa; outline:none; transition:border .2s, background .2s; font-family:inherit; }
    .search-input:focus { border-color:var(--brand); background:#fff; }
    .search-input::placeholder { color:#b0b7c3; }
    .search-divider    { width:1px; height:28px; background:var(--border); flex-shrink:0; }
    .search-clear-btn  { border:none; background:none; color:var(--text-muted); font-size:.78rem;
                          cursor:pointer; padding:4px 10px; border-radius:6px; white-space:nowrap;
                          transition:color .2s, background .2s; display:flex; align-items:center; gap:4px; }
    .search-clear-btn:hover { color:var(--rejected); background:#fef2f2; }
    .search-match-pill { font-size:.72rem; font-weight:600; color:var(--brand); background:var(--brand-light);
                          border:1px solid #fed7aa; border-radius:99px; padding:2px 9px; white-space:nowrap;
                          display:none; align-items:center; gap:4px; }
    .search-match-pill.visible { display:inline-flex; }

    /* Filter Tabs */
    .filter-tabs      { display:flex; gap:4px; background:#f3f4f6; border-radius:8px; padding:4px; }
    .filter-tab       { border:none; background:transparent; padding:7px 16px; border-radius:6px;
                         font-size:.82rem; font-weight:500; color:var(--text-muted); cursor:pointer;
                         transition:all .2s; display:flex; align-items:center; gap:6px; white-space:nowrap; }
    .filter-tab.active,
    .filter-tab:hover { background:var(--brand); color:#fff; }
    .filter-tab.active .tab-count,
    .filter-tab:hover .tab-count { background:rgba(255,255,255,.3); color:#fff; }

    /* Tab Count Badges */
    .tab-count        { display:inline-flex; align-items:center; justify-content:center;
                         min-width:20px; height:18px; padding:0 5px; border-radius:99px;
                         font-size:.68rem; font-weight:700; background:rgba(0,0,0,.1);
                         color:var(--text-muted); transition:all .2s; line-height:1; }
    .tab-count.is-pending { background:#fee2e2; color:#dc2626; }

    /* Alert */
    .alert-artify { border-radius:var(--radius-sm); border:none; font-size:.875rem; }

    /* Section Headers — span full grid width */
    .section-header   { grid-column:1/-1; display:flex; align-items:center; gap:10px; margin:18px 0 10px; }
    .section-header:first-child { margin-top:0; }
    .section-label    { font-size:.78rem; font-weight:700; text-transform:uppercase;
                         letter-spacing:.07em; color:var(--text-muted); white-space:nowrap; }
    .section-line     { flex:1; height:1px; background:var(--border); }
    .section-pill     { font-size:.68rem; font-weight:700; padding:2px 8px; border-radius:99px; white-space:nowrap; }
    .pill-pending     { background:#fff7ed; color:var(--brand); border:1px solid #fed7aa; }
    .pill-approved    { background:#f0fdf4; color:var(--approved); border:1px solid #bbf7d0; }
    .pill-rejected    { background:#fef2f2; color:var(--rejected); border:1px solid #fecaca; }

    /* Artwork Grid */
    .artwork-grid     { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
    .artwork-card     { background:var(--surface); border-radius:var(--radius); border:2px solid transparent;
                         box-shadow:var(--shadow-sm); cursor:pointer; transition:all .2s; overflow:hidden; }
    .artwork-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
    .artwork-card.selected { border-color:var(--brand); box-shadow:0 0 0 3px rgba(249,115,22,.15); }
    .artwork-card.card-pending  { border-left:3px solid var(--pending); }
    .artwork-card.card-approved { border-left:3px solid var(--approved); }
    .artwork-card.card-rejected { border-left:3px solid var(--rejected); }
    .artwork-card.card-pending.selected { border-color:var(--brand); border-left-color:var(--brand); }

    .card-img-wrap        { position:relative; height:160px; overflow:hidden; background:#f3f4f6; }
    .card-img-wrap img    { width:100%; height:100%; object-fit:cover; }
    .card-img-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center;
                             background:linear-gradient(135deg,#f3f4f6,#e5e7eb); }
    .card-img-placeholder i { font-size:2.5rem; color:#d1d5db; }

    .status-badge  { position:absolute; top:8px; left:8px; display:flex; align-items:center; gap:4px;
                      padding:3px 8px; border-radius:20px; font-size:.7rem; font-weight:600;
                      text-transform:uppercase; letter-spacing:.04em; }
    .badge-pending  { background:var(--pending);  color:#fff; }
    .badge-approved { background:var(--approved); color:#fff; }
    .badge-rejected { background:var(--rejected); color:#fff; }

    /* NEW badge — top-right, pulsing blue dot */
    .badge-new { position:absolute; top:8px; right:8px; background:#3b82f6; color:#fff;
                  font-size:.62rem; font-weight:800; padding:2px 7px; border-radius:20px;
                  text-transform:uppercase; letter-spacing:.06em; animation:pulse-new 2s infinite; }
    @@keyframes pulse-new {
        0%,100% { box-shadow:0 0 0 0 rgba(59,130,246,.5); }
        50%      { box-shadow:0 0 0 5px rgba(59,130,246,0); }
    }

    /* Relative-time tag on card image */
    .card-date-tag { position:absolute; bottom:8px; right:8px; background:rgba(0,0,0,.52); color:#fff;
                      font-size:.65rem; padding:2px 7px; border-radius:20px; font-weight:500;
                      backdrop-filter:blur(4px); }

    .card-body-inner  { padding:10px 12px; }
    .card-title-row   { display:flex; justify-content:space-between; align-items:baseline; gap:6px; overflow:hidden; }
    .card-artwork-title { font-size:.88rem; font-weight:600; color:var(--text-main);
                           white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:70%; min-width:0; flex:1; }
    .card-price       { font-size:.88rem; font-weight:700; color:var(--brand); white-space:nowrap; }
    .card-artist      { font-size:.75rem; color:var(--text-muted); margin:2px 0; }
    .card-meta        { font-size:.72rem; color:#9ca3af; }
    .card-actions     { display:flex; gap:6px; padding:8px 12px 10px; border-top:1px solid #f3f4f6; }
    .btn-approve-sm   { flex:1; padding:5px 10px; font-size:.75rem; font-weight:600; border-radius:6px;
                         border:none; background:var(--brand); color:#fff; cursor:pointer; transition:background .2s; }
    .btn-approve-sm:hover { background:var(--brand-dark); }
    .btn-reject-sm    { flex:1; padding:5px 10px; font-size:.75rem; font-weight:600; border-radius:6px;
                         border:1.5px solid #e5e7eb; background:#fff; color:var(--text-muted);
                         cursor:pointer; transition:all .2s; }
    .btn-reject-sm:hover { border-color:var(--rejected); color:var(--rejected); }

    /* Quick Review Panel */
    .review-panel    { background:var(--surface); border-radius:var(--radius); box-shadow:var(--shadow-sm);
                        border:1px solid var(--border); position:sticky; top:80px; }
    .review-header   { display:flex; justify-content:space-between; align-items:center;
                        padding:16px 18px 14px; border-bottom:1px solid var(--border); }
    .review-header h5 { font-size:.95rem; font-weight:700; color:var(--text-main); margin:0; }
    .review-expand   { background:none; border:none; color:var(--text-muted); font-size:1rem; cursor:pointer;
                        padding:2px; border-radius:4px; transition:color .2s; }
    .review-expand:hover { color:var(--brand); }
    /* Expanded review panel — taller image, larger meta */
    .mod-body.panel-expanded .review-img,
    .mod-body.panel-expanded .review-img-placeholder { height:320px; }
    .mod-body.panel-expanded .review-title  { font-size:1.4rem; }
    .mod-body.panel-expanded .meta-grid     { grid-template-columns:repeat(4,1fr); }
    .mod-body.panel-expanded .note-textarea { min-height:110px; }
    .review-img      { width:100%; height:200px; object-fit:cover; background:#f3f4f6; }
    .review-img-placeholder { width:100%; height:200px; display:flex; align-items:center; justify-content:center;
                               background:linear-gradient(135deg,#f3f4f6,#e5e7eb); }
    .review-img-placeholder i { font-size:3rem; color:#d1d5db; }
    .review-body     { padding:14px 18px; }
    .review-title    { font-size:1.1rem; font-weight:700; color:var(--brand); margin:0 0 2px; }
    .review-artist   { font-size:.8rem; color:var(--text-muted); margin:0 0 14px; }
    .review-artist a { color:var(--brand); text-decoration:none; font-weight:500; }
    .meta-grid       { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
    .meta-item label { display:block; font-size:.68rem; font-weight:600; text-transform:uppercase;
                        letter-spacing:.06em; color:var(--text-muted); margin-bottom:2px; }
    .meta-item span  { font-size:.82rem; font-weight:500; color:var(--text-main); }
    .price-val       { color:var(--brand) !important; font-weight:700 !important; }
    .note-label      { font-size:.75rem; font-weight:600; color:var(--text-muted); margin-bottom:5px; }
    .note-textarea   { width:100%; border:1.5px solid var(--border); border-radius:var(--radius-sm);
                        padding:8px 10px; font-size:.8rem; resize:vertical; min-height:80px;
                        font-family:inherit; color:var(--text-main); outline:none; transition:border .2s; }
    .note-textarea:focus { border-color:var(--brand); }
    .review-actions  { display:flex; gap:8px; margin-top:14px; }
    .btn-approve-full { flex:1; padding:10px; font-size:.85rem; font-weight:600; border-radius:var(--radius-sm);
                         border:none; background:var(--brand); color:#fff; cursor:pointer;
                         display:flex; align-items:center; justify-content:center; gap:6px; transition:background .2s; }
    .btn-approve-full:hover { background:var(--brand-dark); }
    .btn-reject-full  { flex:1; padding:10px 14px; font-size:.85rem; font-weight:600; border-radius:var(--radius-sm);
                         border:1.5px solid #fca5a5; background:#fff; color:var(--rejected); cursor:pointer;
                         display:flex; align-items:center; justify-content:center; gap:6px; transition:all .2s; }
    .btn-reject-full:hover { background:#fef2f2; border-color:var(--rejected); }
    .review-footer   { padding:10px 18px; border-top:1px solid var(--border);
                        display:flex; justify-content:space-between; align-items:center; }
    .review-footer small { font-size:.72rem; color:#9ca3af; }
    .safe-score      { font-size:.72rem; font-weight:600; color:var(--approved);
                        display:flex; align-items:center; gap:4px; }

    /* Pending spotlight banner */
    .pending-spotlight { background:linear-gradient(135deg,#fff7ed 0%,#fff 100%);
                          border:1.5px solid #fed7aa; border-radius:var(--radius);
                          padding:10px 16px; display:flex; align-items:center; gap:10px; margin-bottom:12px; }
    .pending-spotlight i { color:var(--brand); font-size:1.1rem; flex-shrink:0; }
    .pending-spotlight strong { font-size:.82rem; color:var(--brand-dark); font-weight:700; }
    .pending-spotlight span   { font-size:.78rem; color:var(--text-muted); }

    /* Section empty state */
    .section-empty { grid-column:1/-1; text-align:center; padding:18px; color:#9ca3af;
                      font-size:.8rem; font-style:italic; background:#fafafa;
                      border-radius:var(--radius-sm); border:1px dashed var(--border); }

    /* Pagination */
    .pagination-wrap { display:flex; align-items:center; justify-content:space-between;
                        padding:14px 2px 4px; flex-wrap:wrap; gap:10px; }
    .page-info       { font-size:.8rem; color:var(--text-muted); }
    .page-btns       { display:flex; gap:4px; }
    .page-btn        { border:1.5px solid var(--border); background:#fff; border-radius:6px;
                        padding:5px 12px; font-size:.8rem; font-weight:500; color:var(--text-muted);
                        cursor:pointer; transition:all .2s; }
    .page-btn.active,
    .page-btn:hover  { background:var(--brand); border-color:var(--brand); color:#fff; }
    .page-btn:disabled { pointer-events:none; opacity:.45; }

    /* Goal Bar */
    .goal-bar-wrap { background:var(--surface); border-radius:var(--radius); padding:14px 18px;
                      border:1px solid var(--border); box-shadow:var(--shadow-sm); margin-top:10px; }
    .goal-label    { font-size:.78rem; font-weight:700; color:var(--brand); margin-bottom:5px; }
    .goal-sub      { font-size:.72rem; color:var(--text-muted); margin-bottom:8px; }
    .goal-bar      { height:6px; background:#fee2e2; border-radius:99px; overflow:hidden; }
    .goal-fill     { height:100%; background:var(--brand); border-radius:99px; transition:width .6s ease; }

    /* Empty state */
    .empty-state   { text-align:center; padding:60px 20px; color:var(--text-muted); }
    .empty-state i { font-size:3rem; color:#d1d5db; display:block; margin-bottom:12px; }
    .empty-state p { font-size:.9rem; }

    /* Loading overlay */
    .loading-overlay { display:none; position:fixed; inset:0; z-index:9999;
                        background:rgba(255,255,255,.6); align-items:center; justify-content:center; }
    .loading-overlay.show { display:flex; }
    .spinner-brand   { width:44px; height:44px; border:4px solid #fed7aa;
                        border-top-color:var(--brand); border-radius:50%; animation:spin .7s linear infinite; }
    @@keyframes spin  { to { transform:rotate(360deg); } }

    /* Kendo toggle */
    #toggleGridBtn     { font-size:.78rem; padding:6px 14px; border-radius:6px;
                          border:1.5px solid var(--border); background:#fff;
                          color:var(--text-muted); cursor:pointer; transition:all .2s; }
    #toggleGridBtn:hover { border-color:var(--brand); color:var(--brand); }

    /* Kendo grid full-width wrapper */
    #kendoGridWrap     { width:100%; }

    /* Override status-badge inside kendo grid cells — must be inline not absolute */
    #kendoGridContainer .status-badge { position:static; display:inline-flex; }

    /* Ensure kendo grid title column text doesn't overflow */
    #kendoGridContainer .k-grid-content td { vertical-align:middle; height:60px; }
    #kendoGridContainer .k-grid-header th { vertical-align:middle; }
    #kendoGridContainer .k-grid-content td span { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:100%; display:inline-block; }

    @@keyframes slideIn { from { transform:translateX(80px); opacity:0; } to { transform:none; opacity:1; } }

    /* Panel expanded */
    .mod-body { transition: grid-template-columns .3s ease; }
    .mod-body.panel-expanded { grid-template-columns:0fr 1fr; }
    .mod-body.panel-expanded > div:first-child { overflow:hidden; min-width:0; opacity:0; pointer-events:none; transition: opacity .2s ease; }
    .mod-body > div:first-child { transition: opacity .2s ease; }
    .mod-body.panel-expanded .review-panel { box-shadow: var(--shadow-md); }

    /* Sort toolbar */
    .sort-toolbar    { display:flex; align-items:center; justify-content:flex-end; margin-bottom:8px; gap:8px; }
    #sortToggleBtn   { font-size:.78rem; padding:5px 13px; border-radius:6px;
                        border:1.5px solid var(--border); background:#fff;
                        color:var(--text-muted); cursor:pointer; transition:all .2s;
                        display:flex; align-items:center; gap:4px; }
    #sortToggleBtn:hover { border-color:var(--brand); color:var(--brand); }

    /* Responsive */
    @@media (max-width:900px) {
        .mod-body     { grid-template-columns:1fr; }
        .artwork-grid { grid-template-columns:repeat(2,1fr); }
        .review-panel { position:static; }
    }
    @@media (max-width:560px) {
        .artwork-grid { grid-template-columns:1fr; }
        .filter-tabs  { flex-wrap:wrap; }
    }
</style>

<div class="loading-overlay" id="loadingOverlay"><div class="spinner-brand"></div></div>

<div class="mod-page">

    <div class="mod-header">
        <div>
            <h1 class="mod-title">Artwork Moderation</h1>
            <p class="mod-subtitle">Manage and review incoming digital assets for the global marketplace.</p>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
            <div class="filter-tabs" id="filterTabs">
                <button class="filter-tab active" onclick="changeFilter('All')">
                    All <span class="tab-count" id="count-All">…</span>
                </button>
                <button class="filter-tab" onclick="changeFilter('Pending')">
                    Pending <span class="tab-count" id="count-Pending">…</span>
                </button>
                <button class="filter-tab" onclick="changeFilter('Approved')">
                    Approved <span class="tab-count" id="count-Approved">…</span>
                </button>
                <button class="filter-tab" onclick="changeFilter('Rejected')">
                    Rejected <span class="tab-count" id="count-Rejected">…</span>
                </button>
            </div>
            <button id="toggleGridBtn" onclick="toggleGridView()">
                <i class="bi bi-table me-1"></i>Grid View
            </button>
        </div>
    </div>

    <div id="alertArea"></div>

    <div id="kendoGridWrap" style="display:none;margin-top:4px;">
        <div id="kendoGridContainer"></div>
    </div>

    <div class="mod-body">
        <div>
            <!-- Search / Filter Bar -->
            <div class="search-bar" id="searchBar">
                <div class="search-field">
                    <i class="bi bi-person"></i>
                    <input type="text" id="searchArtist" class="search-input" placeholder="Search by artist name…" oninput="applySearchFilter()" autocomplete="off" />
                </div>
                <div class="search-divider"></div>
                <div class="search-field">
                    <i class="bi bi-tag"></i>
                    <input type="text" id="searchCategory" class="search-input" placeholder="Filter by category…" oninput="applySearchFilter()" autocomplete="off" />
                </div>
                <span class="search-match-pill" id="searchMatchPill">
                    <i class="bi bi-funnel-fill"></i> <span id="searchMatchCount">0</span> results
                </span>
                <button class="search-clear-btn" id="searchClearBtn" onclick="clearSearchFilter()" style="display:none;">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>

            <div id="pendingSpotlight" class="pending-spotlight" style="display:none;">
                <i class="bi bi-clock-history"></i>
                <div>
                    <strong id="spotlightCount">0 artworks</strong>
                    <span id="spotlightMsg"> awaiting your review — newest first.</span>
                </div>
            </div>
            <div class="sort-toolbar">
                <button id="sortToggleBtn" onclick="toggleSort()">
                    <i class="bi bi-sort-down me-1"></i>Newest First
                </button>
            </div>
            <div class="artwork-grid" id="artworkGrid"></div>
            <div class="pagination-wrap" id="paginationWrap" style="display:none;"></div>
        </div>

        <div>
            <div class="review-panel">
                <div class="review-header">
                    <h5><i class="bi bi-eye me-2"></i>Quick Review</h5>
                    <button class="review-expand" title="Expand" onclick="togglePanelExpand()">
                        <i class="bi bi-arrows-angle-expand"></i>
                    </button>
                </div>
                <div id="rv-img-wrap">
                    <img id="rv-img" class="review-img" src="" alt="" style="display:none;" />
                    <div id="rv-img-placeholder" class="review-img-placeholder">
                        <i class="bi bi-image-fill"></i>
                    </div>
                </div>
                <div class="review-body">
                    <h4 class="review-title" id="rv-title">Select an artwork</h4>
                    <p class="review-artist">
                        By <a href="#" id="rv-artist-link"><span id="rv-artist">—</span></a>
                        &bull; Uploaded <span id="rv-joined">—</span>
                    </p>
                    <div class="meta-grid">
                        <div class="meta-item"><label>Category</label><span id="rv-category">—</span></div>
                        <div class="meta-item"><label>Resolution</label><span id="rv-resolution">4000 x 4000 px</span></div>
                        <div class="meta-item"><label>File Size</label><span id="rv-filesize">—</span></div>
                        <div class="meta-item"><label>Asking Price</label><span class="price-val" id="rv-price">—</span></div>
                    </div>
                    <p class="note-label">Moderator Note <em style="font-weight:400;">(Internal)</em></p>
                    <textarea id="rv-note" class="note-textarea" placeholder="Add a reason for approval/rejection..."></textarea>
                    <div class="review-actions">
                        <button class="btn-approve-full" id="rv-approve-btn" onclick="reviewAction('approve')"
                                disabled style="opacity:.5;cursor:not-allowed;">
                            <i class="bi bi-check-lg"></i> Approve Artwork
                        </button>
                        <button class="btn-reject-full" id="rv-reject-btn" onclick="reviewAction('reject')"
                                disabled style="opacity:.5;cursor:not-allowed;">
                            <i class="bi bi-x-lg"></i> Reject Artwork
                        </button>
                    </div>
                </div>
                <div class="review-footer">
                    <small>Last reviewed by AI 2 mins ago</small>
                    <span class="safe-score"><i class="bi bi-shield-fill-check"></i> 98% Safe Score</span>
                </div>
            </div>
            <div class="goal-bar-wrap">
                <div class="goal-label">Moderation Goal</div>
                <div class="goal-sub" id="goalSub">Loading...</div>
                <div class="goal-bar"><div class="goal-fill" id="goalFill" style="width:0%"></div></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="approveModal" tabindex="-1" aria-labelledby="approveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-md);">
            <div class="modal-header" style="border-bottom:1px solid var(--border);">
                <h5 class="modal-title fw-bold" id="approveModalLabel">
                    <i class="bi bi-check-circle text-success me-2"></i>Approve Artwork
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" style="font-size:.875rem;">
                    You are approving: <strong id="modalApproveTitle"></strong>
                </p>
                <label class="note-label">Moderator Note <em style="font-weight:400;">(Optional)</em></label>
                <textarea id="modalApproveNote" class="note-textarea" rows="3"
                          placeholder="Add an optional note for the artist..."></textarea>
                <div id="modalApproveError" class="text-danger mt-2" style="font-size:.8rem;display:none;"></div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);gap:8px;">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success fw-semibold" onclick="submitApprove()">
                    <i class="bi bi-check-circle me-1"></i>Confirm Approve
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--radius);border:none;box-shadow:var(--shadow-md);">
            <div class="modal-header" style="border-bottom:1px solid var(--border);">
                <h5 class="modal-title fw-bold" id="rejectModalLabel">
                    <i class="bi bi-x-circle text-danger me-2"></i>Reject Artwork
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" style="font-size:.875rem;">
                    You are rejecting: <strong id="modalArtworkTitle"></strong>
                </p>
                <label class="note-label">Reason for Rejection <span class="text-danger">*</span></label>
                <textarea id="modalRejectNote" class="note-textarea" rows="4"
                          placeholder="Provide a clear reason so the artist can improve..."></textarea>
                <div id="modalError" class="text-danger mt-2" style="font-size:.8rem;display:none;">
                    A reason is required before rejecting.
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);gap:8px;">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger fw-semibold" onclick="submitReject()">
                    <i class="bi bi-x-circle me-1"></i>Confirm Reject
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ================================================================
   Artify – Artwork Moderation JS
   ================================================================ */

var API_BASE       = "http://localhost:5183";
var activeId       = null;
var rejectTargetId = null;
var approveTargetId = null;
var currentStatus  = "All";
var currentPage    = 1;
var pageSize       = 12;
var totalArtworks  = 0;
var sortDir        = "desc";   // "desc" = newest first, "asc" = oldest first
var lastArtworks   = [];       // cache last API result for client-side re-sort

/* ─── Auth ──────────────────────────────────────────────────────── */
function checkAuth() {
    var token  = localStorage.getItem("adminToken");
    var expiry = localStorage.getItem("adminExpiry");
    if (!token || !expiry) { window.location.href = "/Admin/Login"; return false; }
    if (Date.now() > expiry * 1000) {
        localStorage.removeItem("adminToken");
        localStorage.removeItem("adminExpiry");
        window.location.href = "/Admin/Login";
        return false;
    }
    return true;
}
function authHeader() {
    if (!checkAuth()) return {};
    return { "Authorization": "Bearer " + localStorage.getItem("adminToken") };
}

/* ─── UTC date parsing ───────────────────────────────────────────── */
/*
 * ROOT CAUSE of the "6h ago" bug:
 * PostgreSQL stores UTC timestamps. The API serialises them as
 * "2026-04-16T10:30:00" — NO trailing 'Z'.
 * JS's Date() treats a string without a timezone marker as LOCAL time,
 * so in IST (UTC+5:30) the parsed value is 5h30m behind the real UTC
 * moment, making every artwork appear 5h30m older than it really is.
 * Fix: always append 'Z' when no timezone suffix is present.
 */
function parseUTC(dateStr) {
    if (!dateStr) return null;
    var s = String(dateStr);
    // Append Z only if no timezone offset is already present
    if (!/[Zz]|[+-]\d{2}:?\d{2}$/.test(s)) s += "Z";
    var d = new Date(s);
    return isNaN(d.getTime()) ? null : d;
}

var NEW_THRESHOLD_MS = 48 * 60 * 60 * 1000; // 48 hours

function isRecent(dateStr) {
    var d = parseUTC(dateStr);
    return d !== null && (Date.now() - d.getTime()) < NEW_THRESHOLD_MS;
}

function relativeTime(dateStr) {
    var d = parseUTC(dateStr);
    if (!d) return "—";
    var diff = Date.now() - d.getTime();
    var mins = Math.floor(diff / 60000);
    if (mins < 1)  return "Just now";
    if (mins < 60) return mins + "m ago";
    var hrs = Math.floor(mins / 60);
    if (hrs  < 24) return hrs  + "h ago";
    var days = Math.floor(hrs / 24);
    if (days <  7) return days + "d ago";
    return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

/* ─── Sort by date — direction aware ─────────────────────────────── */
function sortByDate(arr, dir) {
    var d = dir !== undefined ? dir : sortDir;
    return arr.slice().sort(function(a, b) {
        var da = parseUTC(a.c_CreatedAt) || new Date(0);
        var db = parseUTC(b.c_CreatedAt) || new Date(0);
        return d === "asc" ? da - db : db - da;
    });
}

/* ─── Toggle sort direction (client-side re-render, no re-fetch) ─── */
function toggleSort() {
    sortDir = sortDir === "desc" ? "asc" : "desc";
    updateSortBtn();
    if (lastArtworks.length) renderGrid(lastArtworks);
}

function updateSortBtn() {
    var btn = document.getElementById("sortToggleBtn");
    if (!btn) return;
    btn.innerHTML = sortDir === "desc"
        ? '<i class="bi bi-sort-down me-1"></i>Newest First'
        : '<i class="bi bi-sort-up-alt me-1"></i>Oldest First';
}

/* ─── TAB COUNTS — each fetched independently from the API ──────── */
/*
 * ROOT CAUSE OF THE BUG:
 * Counting statuses from the current page's artworks only gives
 * per-page numbers (e.g. 3 Pending out of 10 shown) not true totals.
 * Fix: call the API once per status with pageSize=1.
 * The response's c_Total field is the real total for that status.
 */
function loadTabCounts() {
    var statuses = ["All", "Pending", "Approved", "Rejected"];

    statuses.forEach(function(s) {
        $.ajax({
            url    : API_BASE + "/api/admin/artworks",
            method : "GET",
            headers: authHeader(),
            data   : { status: s, page: 1, pageSize: 1 },
            success: function(data) {
                var n = data.c_Total || 0;
                $("#count-" + s).text(n);

                // Highlight pending badge in red when there are items waiting
                if (s === "Pending") {
                    $("#count-Pending").toggleClass("is-pending", n > 0);
                    // Update goal bar denominator now we have real pending count
                    updateGoalBarFromCounts(n, $("#count-All").text());
                }
            },
            error: function() {
                $("#count-" + s).text("?");
            }
        });
    });
}

function updateGoalBarFromCounts(pendingCount, totalCount) {
    var pending  = parseInt(pendingCount, 10) || 0;
    var total    = parseInt(totalCount,   10) || 0;
    var reviewed = total - pending;
    var pct      = total > 0 ? Math.round(reviewed / total * 100) : 0;
    $("#goalSub").text(pending + " submission" + (pending === 1 ? "" : "s") + " pending review today.");
    $("#goalFill").css("width", pct + "%");
}

/* ─── Load artworks from API ─────────────────────────────────────── */
function loadArtworks(status, page, size) {
    status = status || currentStatus;
    page   = page   || currentPage;
    size   = size   || pageSize;
    currentStatus = status;
    currentPage   = page;
    pageSize      = size;

    showLoader(true);

    $.ajax({
        url    : API_BASE + "/api/admin/artworks",
        method : "GET",
        headers: authHeader(),
        data   : { status: status, page: page, pageSize: size },
        success: function(data) {
            showLoader(false);
            totalArtworks = data.c_Total || 0;
            var artworks  = data.c_Data  || [];
            lastArtworks  = artworks;   // cache for client-side re-sort

            renderGrid(artworks);
            renderPagination(totalArtworks, page, size);
            updateActiveTab(status);
            clearPanel();

            // Auto-select newest pending for Quick Review
            var first = artworks.find(function(a) { return a.c_ApprovalStatus === "Pending"; })
                     || artworks[0];
            if (first) {
                var el = document.getElementById("card-" + first.c_ArtworkId);
                if (el) selectCard(el);
            }

            refreshKendoGrid(artworks);

            // Always refresh all tab counts after any data load
            // so numbers stay accurate across filter switches
            loadTabCounts();
        },
        error: function(xhr) {
            showLoader(false);
            if (xhr.status === 401) {
                showAlert("Session expired. Please log in again.", "danger");
                setTimeout(function() { window.location.href = "/Admin/Login"; }, 2000);
            } else {
                showAlert("Failed to load artworks. Please try again.", "danger");
            }
        }
    });
}

/* ─── Update which tab looks active (CSS only, counts untouched) ─── */
function updateActiveTab(status) {
    $("#filterTabs .filter-tab").each(function() {
        // Read button text without the child <span> text
        var label = $.trim($(this).contents().filter(function() {
            return this.nodeType === 3; // text nodes only
        }).text());
        $(this).toggleClass("active", label === status);
    });
}

/* ─── Grid render dispatcher ─────────────────────────────────────── */
function renderGrid(artworks) {
    var grid = $("#artworkGrid");
    grid.empty();
    document.getElementById("pendingSpotlight").style.display = "none";

    if (!artworks.length) {
        grid.html(
            '<div class="empty-state" style="grid-column:1/-1;">' +
            '<i class="bi bi-images"></i>' +
            '<p>No artworks found for <strong>' + currentStatus + '</strong>.</p>' +
            '</div>'
        );
        return;
    }

    if (currentStatus === "All") {
        renderGroupedGrid(artworks);
    } else {
        renderFlatGrid(sortByDate(artworks));
    }
}

/* ─── Grouped view: Pending → Approved → Rejected ────────────────── */
function renderGroupedGrid(artworks) {
    var sorted   = sortByDate(artworks);
    var pending  = sorted.filter(function(a) { return a.c_ApprovalStatus === "Pending";  });
    var approved = sorted.filter(function(a) { return a.c_ApprovalStatus === "Approved"; });
    var rejected = sorted.filter(function(a) { return a.c_ApprovalStatus === "Rejected"; });
    var grid     = $("#artworkGrid");

    // Pending always sorted newest-first regardless of global toggle
    // so the most urgent review is always top
    var pendingSorted = sortByDate(pending, "desc");

    // Spotlight banner
    if (pendingSorted.length > 0) {
        var dirLabel = sortDir === "asc" ? "oldest first" : "newest first";
        showSpotlight(pendingSorted.length, "awaiting your review — " + dirLabel + ".");
    }

    // Pending section — always rendered first, always newest-first
    grid.append(makeSectionHeader("bi-clock-history text-warning", "Pending Review", "pill-pending", pendingSorted.length + " pending"));
    if (pendingSorted.length > 0) {
        pendingSorted.forEach(function(a) { grid.append(buildCard(a)); });
    } else {
        grid.append('<div class="section-empty">No pending submissions — you\'re all caught up!</div>');
    }

    // Approved section
    if (approved.length > 0) {
        grid.append(makeSectionHeader("bi-check-circle-fill text-success", "Approved", "pill-approved", approved.length + " approved"));
        approved.forEach(function(a) { grid.append(buildCard(a)); });
    }

    // Rejected section
    if (rejected.length > 0) {
        grid.append(makeSectionHeader("bi-x-circle-fill text-danger", "Rejected", "pill-rejected", rejected.length + " rejected"));
        rejected.forEach(function(a) { grid.append(buildCard(a)); });
    }
}

/* ─── Flat list (Pending / Approved / Rejected filter views) ─────── */
function renderFlatGrid(artworks) {
    if (currentStatus === "Pending" && artworks.length > 0) {
        var dirLabel = sortDir === "asc" ? "oldest uploads shown first" : "newest uploads shown first";
        showSpotlight(artworks.length, "pending review — " + dirLabel + ".");
    }
    var grid = $("#artworkGrid");
    artworks.forEach(function(a) { grid.append(buildCard(a)); });
}

/* ─── Show the orange pending spotlight banner ───────────────────── */
function showSpotlight(count, msg) {
    var sp = document.getElementById("pendingSpotlight");
    sp.style.display = "flex";
    document.getElementById("spotlightCount").textContent =
        count + " artwork" + (count !== 1 ? "s" : "");
    document.getElementById("spotlightMsg").textContent = " " + msg;
}

/* ─── Build a section header <div> that spans the full grid ─────── */
function makeSectionHeader(iconClass, label, pillClass, pillText) {
    return $(
        '<div class="section-header">' +
        '<i class="bi ' + iconClass + '" style="font-size:.8rem;"></i>' +
        '<span class="section-label">' + label + '</span>' +
        '<span class="section-pill ' + pillClass + '">' + pillText + '</span>' +
        '<span class="section-line"></span>' +
        '</div>'
    );
}

/* ─── Build a single artwork card ────────────────────────────────── */
function buildCard(art) {
    var status    = art.c_ApprovalStatus;
    var isPending = status === "Pending";
    var badgeCls  = status === "Approved" ? "badge-approved" : status === "Rejected" ? "badge-rejected" : "badge-pending";
    var badgeIcon = status === "Approved" ? "bi-check-circle-fill" : status === "Rejected" ? "bi-x-circle-fill" : "bi-clock-fill";
    var cardCls   = status === "Approved" ? "card-approved" : status === "Rejected" ? "card-rejected" : "card-pending";
    var price     = parseFloat(art.c_Price || 0).toFixed(2);
    var relTime   = relativeTime(art.c_CreatedAt);
    var preview   = art.c_PreviewPath || "";
    var note      = escHtml(art.c_AdminNote || "");

    var imgHtml = preview
        ? '<img src="' + escHtml(preview) + '" alt="' + escHtml(art.c_Title) + '" ' +
          'onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';" />' +
          '<div class="card-img-placeholder" style="display:none;"><i class="bi bi-image"></i></div>'
        : '<div class="card-img-placeholder"><i class="bi bi-image"></i></div>';

    var newBadge    = (isPending && isRecent(art.c_CreatedAt)) ? '<span class="badge-new">NEW</span>' : "";
    var actionsHtml = (function() {
        var approveBtn = '<button class="btn-approve-sm" onclick="quickApprove(' + art.c_ArtworkId + ')"><i class="bi bi-check"></i> Approve</button>';
        var rejectBtn  = '<button class="btn-reject-sm" onclick="openRejectModal(' + art.c_ArtworkId + ',\'' + escJs(art.c_Title) + '\')">Reject</button>';
        if (isPending)               return '<div class="card-actions" onclick="event.stopPropagation()">' + approveBtn + rejectBtn + '</div>';
        if (status === "Approved")   return '<div class="card-actions" onclick="event.stopPropagation()">' + rejectBtn + '</div>';
        if (status === "Rejected")   return '<div class="card-actions" onclick="event.stopPropagation()">' + approveBtn + '</div>';
        return "";
    }());

    return $(
        '<div class="artwork-card ' + cardCls + '" id="card-' + art.c_ArtworkId + '"' +
        ' data-id="'       + art.c_ArtworkId              + '"' +
        ' data-title="'    + escHtml(art.c_Title)          + '"' +
        ' data-artist="'   + escHtml(art.c_ArtistName)     + '"' +
        ' data-category="' + escHtml(art.c_CategoryName)   + '"' +
        ' data-price="'    + price                         + '"' +
        ' data-status="'   + status                        + '"' +
        ' data-preview="'  + escHtml(preview)              + '"' +
        ' data-created="'  + relTime                       + '"' +
        ' data-rawdate="'  + escHtml(art.c_CreatedAt || "") + '"' +
        ' data-note="'     + note                          + '"' +
        ' onclick="selectCard(this)">' +

        '<div class="card-img-wrap">' + imgHtml +
        '<span class="status-badge ' + badgeCls + '"><i class="bi ' + badgeIcon + '"></i> ' + status + '</span>' +
        newBadge +
        '<span class="card-date-tag">' + escHtml(relTime) + '</span>' +
        '</div>' +

        '<div class="card-body-inner">' +
        '<div class="card-title-row">' +
        '<span class="card-artwork-title" title="' + escHtml(art.c_Title) + '">' + escHtml(art.c_Title) + '</span>' +
        '<span class="card-price">$' + parseFloat(price).toFixed(0) + '</span>' +
        '</div>' +
        '<div class="card-artist">Artist: <strong>' + escHtml(art.c_ArtistName) + '</strong></div>' +
        '<div class="card-meta">' + escHtml(art.c_CategoryName) + '</div>' +
        '</div>' +

        actionsHtml + '</div>'
    );
}

/* ─── Pagination ─────────────────────────────────────────────────── */
function renderPagination(total, page, size) {
    var wrap = $("#paginationWrap");
    if (total <= 0) { wrap.hide(); return; }

    var totalPages = Math.ceil(total / size);
    if (totalPages <= 1) { wrap.hide(); return; }

    var from = (page - 1) * size + 1;
    var to   = Math.min(page * size, total);
    var qs   = "'" + currentStatus + "'";

    var html = '<span class="page-info">Showing ' + from + '–' + to + ' of ' + total + ' artworks</span>';
    html += '<div class="page-btns">';

    // Prev button
    html += '<button class="page-btn" ' + (page <= 1 ? "disabled" : "") +
            ' onclick="loadArtworks(' + qs + ',' + (page - 1) + ',' + size + ')"><i class="bi bi-chevron-left"></i></button>';

    // First page + ellipsis
    if (page > 3) {
        html += '<button class="page-btn" onclick="loadArtworks(' + qs + ',1,' + size + ')">1</button>';
        if (page > 4) {
            html += '<span class="page-btn" style="pointer-events:none;border:none;color:var(--text-muted);">…</span>';
        }
    }

    // Window pages
    var start = Math.max(1, page - 2), end = Math.min(totalPages, page + 2);
    for (var p = start; p <= end; p++) {
        html += '<button class="page-btn ' + (p === page ? "active" : "") +
                '" onclick="loadArtworks(' + qs + ',' + p + ',' + size + ')">' + p + '</button>';
    }

    // Ellipsis + last page
    if (page < totalPages - 2) {
        if (page < totalPages - 3) {
            html += '<span class="page-btn" style="pointer-events:none;border:none;color:var(--text-muted);">…</span>';
        }
        html += '<button class="page-btn" onclick="loadArtworks(' + qs + ',' + totalPages + ',' + size + ')">' + totalPages + '</button>';
    }

    // Next button
    html += '<button class="page-btn" ' + (page >= totalPages ? "disabled" : "") +
            ' onclick="loadArtworks(' + qs + ',' + (page + 1) + ',' + size + ')"><i class="bi bi-chevron-right"></i></button>';

    html += '</div>';
    wrap.html(html).show();
}

/* ─── Goal bar ───────────────────────────────────────────────────── */
function updateGoalBar(artworks, total) {
    var pending = artworks.filter(function(a) { return a.c_ApprovalStatus === "Pending"; }).length;
    // Use real pending count from tab if available, otherwise estimate
    var realPending = parseInt($("#count-Pending").text(), 10);
    if (!isNaN(realPending)) pending = realPending;
    var realTotal   = parseInt($("#count-All").text(), 10);
    if (!isNaN(realTotal) && realTotal > 0) total = realTotal;
    var pct = total > 0 ? Math.round((total - pending) / total * 100) : 0;
    $("#goalSub").text(pending + " submission" + (pending === 1 ? "" : "s") + " pending review today.");
    $("#goalFill").css("width", pct + "%");
}

/* ─── Filter tab click ───────────────────────────────────────────── */

/* ─── Search / filter ──────────────────────────────────────────────── */
function applySearchFilter() {
    var artist   = ($("#searchArtist").val()   || "").trim().toLowerCase();
    var category = ($("#searchCategory").val() || "").trim().toLowerCase();
    var active   = artist || category;
    $("#searchClearBtn").toggle(!!active);

    var filtered = lastArtworks.filter(function(a) {
        var matchArtist   = !artist   || (a.c_ArtistName   || "").toLowerCase().indexOf(artist)   !== -1;
        var matchCategory = !category || (a.c_CategoryName || "").toLowerCase().indexOf(category) !== -1;
        return matchArtist && matchCategory;
    });

    if (active) {
        $("#searchMatchCount").text(filtered.length);
        $("#searchMatchPill").addClass("visible");
    } else {
        $("#searchMatchPill").removeClass("visible");
    }

    renderGrid(filtered);
}

function clearSearchFilter() {
    $("#searchArtist").val("");
    $("#searchCategory").val("");
    $("#searchMatchPill").removeClass("visible");
    $("#searchClearBtn").hide();
    renderGrid(lastArtworks);
}

function changeFilter(status) {
    clearSearchFilter();
    loadArtworks(status, 1, pageSize);
}

/* ─── Card selection → Quick Review panel ───────────────────────── */
function selectCard(el) {
    document.querySelectorAll(".artwork-card").forEach(function(c) { c.classList.remove("selected"); });
    el.classList.add("selected");
    activeId = el.dataset.id;

    $("#rv-title").text(el.dataset.title    || "—");
    $("#rv-artist").text(el.dataset.artist  || "—");
    $("#rv-category").text(el.dataset.category || "—");
    $("#rv-price").text(el.dataset.price ? "$" + parseFloat(el.dataset.price).toFixed(2) : "—");
    $("#rv-note").val(el.dataset.note || "");

    // Show "Xh ago" with exact datetime tooltip
    var relT  = el.dataset.created || "—";
    var rawD  = parseUTC(el.dataset.rawdate);
    var exact = rawD ? rawD.toLocaleString("en-IN", { dateStyle:"medium", timeStyle:"short" }) : "";
    var uploadedEl = document.getElementById("rv-joined");
    uploadedEl.textContent = relT;
    uploadedEl.title       = exact;  // hover tooltip shows exact time

    var img     = document.getElementById("rv-img");
    var ph      = document.getElementById("rv-img-placeholder");
    var preview = el.dataset.preview;
    if (preview && preview.trim()) {
        img.src = preview; img.style.display = "block"; ph.style.display = "none";
        img.onerror = function() { img.style.display = "none"; ph.style.display = "flex"; };
    } else {
        img.style.display = "none"; ph.style.display = "flex";
    }
    setPanelButtons(el.dataset.status === "Pending");
}

function setPanelButtons(enabled) {
    ["rv-approve-btn", "rv-reject-btn"].forEach(function(id) {
        var b = document.getElementById(id);
        b.disabled          = !enabled;
        b.style.opacity     = enabled ? "1" : ".5";
        b.style.cursor      = enabled ? "pointer" : "not-allowed";
    });
}

/* ─── Quick actions ──────────────────────────────────────────────── */
function quickApprove(id) {
    var card = document.getElementById("card-" + id);
    if (card && card.dataset.status !== "Pending") {
        showToast("This artwork has already been " + card.dataset.status.toLowerCase() + " and cannot be moderated again.", "warning");
        return;
    }
    approveTargetId = id;
    $("#modalApproveTitle").text(card ? card.dataset.title : "");
    $("#modalApproveNote").val(""); $("#modalApproveError").hide();
    new bootstrap.Modal(document.getElementById("approveModal")).show();
}
function openRejectModal(id, title) {
    var card = document.getElementById("card-" + id);
    if (card && card.dataset.status !== "Pending") {
        showToast("This artwork has already been " + card.dataset.status.toLowerCase() + " and cannot be moderated again.", "warning");
        return;
    }
    rejectTargetId = id;
    $("#modalArtworkTitle").text(title); $("#modalRejectNote").val(""); $("#modalError").hide();
    new bootstrap.Modal(document.getElementById("rejectModal")).show();
}
function reviewAction(type) {
    if (!activeId) { alert("Please select an artwork first."); return; }
    var card = document.getElementById("card-" + activeId);
    if (!card || card.dataset.status !== "Pending") { alert("This artwork has already been moderated."); return; }
    var note = $("#rv-note").val() || "";
    if (type === "approve") {
        approveTargetId = activeId;
        $("#modalApproveTitle").text(card.dataset.title);
        $("#modalApproveNote").val(note); $("#modalApproveError").hide();
        new bootstrap.Modal(document.getElementById("approveModal")).show();
    } else {
        rejectTargetId = activeId;
        $("#modalArtworkTitle").text(card.dataset.title);
        $("#modalRejectNote").val(note); $("#modalError").hide();
        new bootstrap.Modal(document.getElementById("rejectModal")).show();
    }
}
function submitReject() {
    var note = $("#modalRejectNote").val().trim();
    if (!note) { $("#modalError").show(); return; }
    $("#modalError").hide();
    bootstrap.Modal.getInstance(document.getElementById("rejectModal"))?.hide();
    callRejectApi(rejectTargetId, note);
}

function submitApprove() {
    var note = $("#modalApproveNote").val().trim();
    bootstrap.Modal.getInstance(document.getElementById("approveModal"))?.hide();
    callApproveApi(approveTargetId, note);
}

/* ─── API: Approve ───────────────────────────────────────────────── */
function callApproveApi(id, note) {
    showLoader(true);
    $.ajax({
        url: API_BASE + "/api/admin/artworks/" + id + "/approve",
        method: "POST", contentType: "application/json",
        headers: authHeader(), data: JSON.stringify({ c_AdminNote: note }),
        success: function() {
            showLoader(false);
            showToast("Artwork approved!", "success");
            removeCard(id);
            loadTabCounts(); // refresh all counts after action
        },
        error: function(xhr) {
            showLoader(false);
            showToast((xhr.responseJSON && xhr.responseJSON.error) || "Approval failed.", "danger");
        }
    });
}

/* ─── API: Reject ────────────────────────────────────────────────── */
function callRejectApi(id, note) {
    showLoader(true);
    $.ajax({
        url: API_BASE + "/api/admin/artworks/" + id + "/reject",
        method: "POST", contentType: "application/json",
        headers: authHeader(), data: JSON.stringify({ c_AdminNote: note }),
        success: function() {
            showLoader(false);
            showToast("Artwork rejected.", "warning");
            removeCard(id);
            loadTabCounts(); // refresh all counts after action
        },
        error: function(xhr) {
            showLoader(false);
            showToast((xhr.responseJSON && xhr.responseJSON.error) || "Rejection failed.", "danger");
        }
    });
}

function removeCard(id) {
    var card = document.getElementById("card-" + id);
    if (card) card.remove();
    if (String(activeId) === String(id)) clearPanel();
}

function clearPanel() {
    activeId = null;
    $("#rv-title").text("Select an artwork"); $("#rv-artist").text("—");
    $("#rv-joined").text("—"); $("#rv-category").text("—"); $("#rv-price").text("—"); $("#rv-note").val("");
    document.getElementById("rv-img").style.display = "none";
    document.getElementById("rv-img-placeholder").style.display = "flex";
    setPanelButtons(false);
}

/* ─── Kendo Grid ─────────────────────────────────────────────────── */
var kendoGrid = null;
function refreshKendoGrid(artworks) {
    if (typeof kendo === "undefined") return;
    var data = artworks.map(function(a) {
        return { id: a.c_ArtworkId, title: a.c_Title, artist: a.c_ArtistName,
                 category: a.c_CategoryName, price: a.c_Price,
                 status: a.c_ApprovalStatus, created: relativeTime(a.c_CreatedAt),
                 image: a.c_PreviewPath || "" };
    });
    if (kendoGrid) { kendoGrid.dataSource.data(data); return; }
    kendoGrid = $("#kendoGridContainer").kendoGrid({
        dataSource: { data: data, pageSize: 12, schema: { model: { fields: {
            id: { type:"number" }, title: { type:"string" }, artist: { type:"string" },
            category: { type:"string" }, price: { type:"number" }, status: { type:"string" }, created: { type:"string" }, image: { type:"string" }
        }}}},
        height: 520, sortable: true, filterable: true, scrollable: true, resizable: true,
        pageable: { refresh: true, pageSizes: [6, 12, 24] },
        columns: [
            { field:"image", title:"Image", width:80, sortable:false, filterable:false,
              template:"# if (image) { #<img src='#: image #' alt='#: title #' style='width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid \\#e5e7eb;' onerror=\"this.style.display='none'\" /># } else { #<span style='display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:6px;background:\\#f3f4f6;color:\\#9ca3af;'><i class='bi bi-image'></i></span># } #" },
            { field:"title",    title:"Title",     minResizableWidth:120, template:"<span title='#: title #'>#: title #</span>" },
            { field:"artist",   title:"Artist",    width:160 },
            { field:"category", title:"Category",  width:140 },
            { field:"price",    title:"Price ($)",  width:110, template:"#= kendo.toString(price,'n2') #" },
            { field:"status",   title:"Status",    width:130,
              template:"<span class='status-badge #: status==='Approved'?'badge-approved':status==='Rejected'?'badge-rejected':'badge-pending' #'>#: status #</span>" },
            { field:"created",  title:"Uploaded",  width:130 },
            { title:"Actions", width:170, sortable:false, filterable:false,
              template:"<span style='white-space:nowrap;'>" +
                "# if (status === 'Pending') { #" +
                "<button class='btn btn-sm btn-success me-1' style='font-size:.72rem;padding:3px 8px;' onclick=\"quickApprove(#: id #)\"><i class='bi bi-check'></i> Approve</button>" +
                "<button class='btn btn-sm btn-outline-danger' style='font-size:.72rem;padding:3px 8px;' onclick=\"openRejectModal(#: id #, '#: title #')\"><i class='bi bi-x'></i> Reject</button>" +
                "# } else { #" +
                "<button class='btn btn-sm btn-success me-1' style='font-size:.72rem;padding:3px 8px;opacity:.4;cursor:not-allowed;' disabled title='Already #: status #'><i class='bi bi-check'></i> Approve</button>" +
                "<button class='btn btn-sm btn-outline-danger' style='font-size:.72rem;padding:3px 8px;opacity:.4;cursor:not-allowed;' disabled title='Already #: status #'><i class='bi bi-x'></i> Reject</button>" +
                "# } #" +
                "</span>" }
        ]
    }).data("kendoGrid");
}

function toggleGridView() {
    var gw = $("#kendoGridWrap"), cw = $("#artworkGrid, #paginationWrap"), mb = $(".mod-body"), isGrid = gw.is(":visible");
    // Collapse expanded panel before switching views
    if (!isGrid) {
        mb[0].classList.remove("panel-expanded");
        var icon = document.querySelector(".review-expand i");
        if (icon) icon.className = "bi bi-arrows-angle-expand";
        var btn = document.querySelector(".review-expand");
        if (btn) btn.title = "Expand";
    }
    gw.toggle(!isGrid); cw.toggle(isGrid); mb.toggle(isGrid);
    $("#toggleGridBtn").html(isGrid
        ? '<i class="bi bi-table me-1"></i>Grid View'
        : '<i class="bi bi-grid-3x3-gap me-1"></i>Card View');
    // Re-render kendo grid to fit new full-width container
    if (!isGrid && kendoGrid) {
        kendoGrid.resize();
    }
}
function togglePanelExpand() {
    var body      = document.querySelector(".mod-body");
    var expanded  = body.classList.toggle("panel-expanded");
    var btn       = document.querySelector(".review-expand");
    var icon      = btn.querySelector("i");
    if (expanded) {
        icon.className = "bi bi-arrows-angle-contract";
        btn.title      = "Collapse";
    } else {
        icon.className = "bi bi-arrows-angle-expand";
        btn.title      = "Expand";
    }
}

/* ─── UI Helpers ─────────────────────────────────────────────────── */
function showLoader(show) { document.getElementById("loadingOverlay").classList.toggle("show", show); }

function showAlert(msg, type) {
    $("#alertArea").html(
        '<div class="alert alert-' + type + ' alert-dismissible fade show alert-artify" role="alert">' +
        '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + escHtml(msg) +
        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>'
    );
}

function showToast(msg, type) {
    var colours = { success:"#22c55e", danger:"#ef4444", warning:"#f97316" };
    var icon    = type === "success" ? "check-circle" : "exclamation-circle";
    var t = document.createElement("div");
    t.style.cssText = "position:fixed;bottom:24px;right:24px;z-index:10000;" +
        "background:" + (colours[type] || "#374151") + ";color:#fff;" +
        "padding:12px 20px;border-radius:10px;font-size:.85rem;font-weight:500;" +
        "box-shadow:0 4px 20px rgba(0,0,0,.18);max-width:320px;animation:slideIn .3s ease;";
    t.innerHTML = '<i class="bi bi-' + icon + ' me-2"></i>' + escHtml(msg);
    document.body.appendChild(t);
    setTimeout(function() { t.style.opacity = "0"; t.style.transition = "opacity .4s"; }, 2800);
    setTimeout(function() { t.remove(); }, 3200);
}

function escHtml(s) {
    if (!s) return "";
    return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
                    .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}
function escJs(s) {
    if (!s) return "";
    return String(s).replace(/\\/g,"\\\\").replace(/'/g,"\\'");
}

/* ─── Boot ───────────────────────────────────────────────────────── */
$(document).ready(function() {
    if (!checkAuth()) return;
    loadArtworks("All", 1, 12);
    // loadTabCounts() is called inside loadArtworks success callback,
    // so all 4 badges are populated from their own API calls every time.
});
</script>
