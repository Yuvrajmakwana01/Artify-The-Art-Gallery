@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artify – Admin Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2021.3.1207/styles/kendo.default-v2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        :root {
            --accent: #ff7e5f;
            --accent-hover: #ff6a4a;
            --text-main: #1a1a1a;
            --text-muted: #666666;
            --glass-card: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.6);
        }

        /* RESET */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        /* BODY */
        body {
            height: 100vh;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }

                /* 🔥 PREMIUM BACKGROUND */
        .animated-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            
            background:
                radial-gradient(circle at 20% 30%, rgba(255,126,95,0.25), transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(255,180,120,0.25), transparent 40%),
                radial-gradient(circle at 50% 50%, rgba(255,220,180,0.2), transparent 60%),
                linear-gradient(120deg, #fff8f3, #ffe9d6, #ffd8c2);

            background-blend-mode: screen;
            animation: gradientMove 18s ease infinite;
        }

        /* ✨ Add subtle noise texture */
        .animated-bg::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url("https://www.transparenttextures.com/patterns/noise.png");
            opacity: 0.15;
            mix-blend-mode: overlay;
        }

        /* Smooth movement */
        @@keyframes gradientMove {
            0% { transform: scale(1) translate(0, 0); }
            50% { transform: scale(1.1) translate(-20px, 20px); }
            100% { transform: scale(1) translate(0, 0); }
        }

        @@keyframes gradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* GLOW SHAPES */
        .bg-shapes {
            position: fixed;
            inset: 0;
            z-index: 1;
        }

        .shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.35;
            animation: float 10s ease-in-out infinite;
        }

        .shape1 {
            width: 300px;
            height: 300px;
            background: #ffb347;
            top: 10%;
            left: 10%;
        }

        .shape2 {
            width: 400px;
            height: 400px;
            background: #ff7e5f;
            bottom: 10%;
            right: 10%;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-30px); }
        }

        /* VIEWPORT */
        .viewport {
            position: fixed;
            inset: 0;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* CARD */
        .card {
            width: 100%;
            max-width: 420px;
            background: var(--glass-card);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            text-align: center;
        }

        /* TITLE */
        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 2.3rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 5px;
        }

        .admin-badge {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .card-sub {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 25px;
        }

        /* FIELDS */
        .field-group {
            text-align: left;
            margin-bottom: 18px;
        }

        .field-group label {
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 6px;
            display: block;
        }

        /* INPUT */
        .k-textbox {
            width: 100% !important;
            padding: 12px 14px !important;
            border-radius: 12px !important;
            border: 1px solid #ddd !important;
            font-size: 0.9rem !important;
            transition: 0.2s;
        }

        .k-textbox:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px rgba(255,126,95,0.15) !important;
        }

        /* PASSWORD */
        .pass-wrapper {
            position: relative;
        }

        .pass-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            border: none;
            background: none;
            cursor: pointer;
        }

        /* BUTTON */
        .btn-enter {
            width: 100%;
            padding: 13px;
            margin-top: 10px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #ff7e5f, #ff9966);
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-enter:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(255,126,95,0.4);
        }

        .btn-enter:disabled {
            opacity: 0.6;
        }

        /* ERROR */
        .field-error {
            font-size: 0.75rem;
            color: #ff4d4f;
            margin-top: 4px;
            display: block;
        }
        
        /* 🔥 MOUSE LIGHT EFFECT */
        .mouse-light {
            position: fixed;
            width: 300px;
            height: 300px;
            pointer-events: none;
            z-index: 1;

            background: radial-gradient(circle, rgba(255,126,95,0.25) 0%, transparent 70%);
            filter: blur(40px);

            transform: translate(-50%, -50%);
        }
        
        .swal2-popup {
            border-radius: 20px !important;
            backdrop-filter: blur(20px);
            font-family: 'Inter', sans-serif;
        }

        .swal2-title {
            font-weight: 700;
        }

        .swal2-confirm {
            border-radius: 12px !important;
            padding: 10px 20px !important;
        }
    </style>

</head>
<body>
    <div id="kNotification"></div>

    <div class="mouse-light"></div>
     <!-- ✅ Animated Background -->
    <div class="animated-bg"></div>

    <!-- ✅ Glow Shapes -->
    <div class="bg-shapes">
        <div class="shape shape1"></div>
        <div class="shape shape2"></div>
    </div>

    <!-- ✅ MAIN CONTENT -->
    <div class="viewport">
        <div class="card animate__animated animate__fadeInUp">

            <h2 class="card-title">Artify</h2>

            <div class="admin-badge">
                ★ Admin Portal
            </div>

            <p class="card-sub">Sign in to your admin workspace</p>

            <form id="loginForm">

                <div class="field-group">
                    <label>Email</label>
                    <input id="c_Email" name="c_Email" class="k-textbox" required/>
                    <span class="field-error" data-for="c_Email"></span>
                </div>

                <div class="field-group">
                    <label>Password</label>
                    <div class="pass-wrapper">
                        <input id="c_Password" name="c_Password" type="password" class="k-textbox" required/>

                        <button type="button" class="pass-toggle"
                                onclick="togglePass('c_Password', 'eyeIcon')">
                            👁
                        </button>
                    </div>
                    <span class="field-error" data-for="c_Password"></span>
                </div>

                <button type="submit" id="loginBtn" class="btn-enter">SIGN IN</button>

            </form>

        </div>
    </div>


    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2021.3.1207/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(function () {

            var notification = $("#kNotification").kendoNotification({
                position: { pinned: true, top: 20, right: 20 },
                autoHideAfter: 4000,
                stacking: "down",
                templates: [
                    { type: "success", template: "<div style='padding:6px 4px;font-family:Inter,sans-serif'><strong>✔ Success</strong> &nbsp; #: message #</div>" },
                    { type: "error",   template: "<div style='padding:6px 4px;font-family:Inter,sans-serif'><strong>✖ Error</strong> &nbsp; #: message #</div>" }
                ]
            }).data("kendoNotification");
            
            function showFieldErrors(errors) {
                $(".field-error").text("");
                $(".k-textbox").css("border-color", "#ddd");

                Object.keys(errors).forEach(field => {
                    const messages = errors[field];

                    const el = $(`.field-error[data-for='${field}']`);
                    const input = $(`[name='${field}']`);

                    if (el.length) {
                        el.text(messages[0]);
                    }

                    if (input.length) {
                        input.css("border-color", "#ff4d4f"); // 🔴 highlight
                    }
                });
            }

            function showSuccess(msg) { notification.show({ message: msg }, "success"); }
            function showError(msg)   { notification.show({ message: msg }, "error");   }

            var validator = $("#loginForm").kendoValidator({
                messages: {
                    required: function(input) {
                        if (input.attr("name") === "c_Email") {
                            return "Email is required";
                        }
                        if (input.attr("name") === "c_Password") {
                            return "Password is required";
                        }
                        return "This field is required";
                    }
                }
            }).data("kendoValidator");

            window.togglePass = function (inputId, iconId) {
                var inp    = document.getElementById(inputId);
                var isText = inp.type === "text";
                inp.type   = isText ? "password" : "text";
                document.getElementById(iconId).innerHTML = isText
                    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
                    : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>' +
                      '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>' +
                      '<line x1="1" y1="1" x2="23" y2="23"/>';
            };

            $("#loginForm").on("submit", function (e) {
                e.preventDefault();

                if (!validator.validate()) {
                    showError("Please fix the errors before submitting.");
                    return;
                }

                var btn = $("#loginBtn");
                btn.prop("disabled", true).text("Checking...");

                // ── Step 1: Verify credentials with the API ────────────────────
                $.ajax({
                    url:         "http://localhost:5183/api/AdminApi/login",
                    type:        "POST",
                    data:        new FormData($("#loginForm")[0]),
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        if (!res.success) {

                            if (res.errors) {
                                showFieldErrors(res.errors);   // 🔥 show field-wise errors
                            } else {
                                Swal.fire({
                                    icon: "error",
                                    title: "Access Denied",
                                    text: res.message || "Invalid email or password",
                                    background: "rgba(255,255,255,0.85)",
                                    backdrop: `
                                        rgba(0,0,0,0.4)
                                        url("https://media.giphy.com/media/3oEjI6SIIHBdRxXI40/giphy.gif")
                                        left top
                                        no-repeat
                                    `,
                                    color: "#1a1a1a",
                                    confirmButtonText: "Try Again",
                                    confirmButtonColor: "#ff7e5f",
                                    showClass: {
                                        popup: "animate__animated animate__shakeX"
                                    }
                                });
                            }

                            btn.prop("disabled", false).text("SIGN IN");
                            return;
                        }

                        if (res.success) {

                            const token = res.token;

                            // decode JWT
                            const payload = JSON.parse(atob(token.split('.')[1]));

                            localStorage.setItem("adminToken", token);
                            localStorage.setItem("adminExpiry", payload.exp); 
                            localStorage.setItem("adminData", JSON.stringify(res.Admin));

                            window.location.href = "/Admin/Index";
                        }

                    },
                    error: function (xhr) {
                        btn.prop("disabled", false).text("SIGN IN");

                        if (xhr.status === 400) {
                            const res = xhr.responseJSON;

                            if (res?.errors) {
                                showFieldErrors(res.errors);
                            } else {
                                showError(res?.message || "Validation error.");
                            }
                        }
                        else if (xhr.status === 401) {
                            Swal.fire({
                                icon: "error",
                                title: "Invalid Credentials",
                                text: "Email or password is incorrect",
                                confirmButtonColor: "#ff7e5f",
                                background: "rgba(255,255,255,0.9)",
                                showClass: {
                                    popup: "animate__animated animate__shakeX"
                                }
                            });
                        }
                        else {
                            showError("Server error. Try again.");
                        }
                    }
                });
            });

        });
    </script>
</body>
</html>