@{
    Layout = "../Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/paymentdetail.css" asp-append-version="true" />
</head>
<body>
    

<div class="page-header">
    <div>
        <h1>Payment Management</h1>
        <p class="breadcrumb">Admin › Finance › Payments</p>
    </div>
    <div class="header-right">
        <span class="dot-live"><span class="pulse-dot"></span> Live</span>
        <button class="btn btn-primary"><i class="fa fa-download"></i> Export Report</button>
    </div>
</div>

<div class="metrics-grid">
    <div class="metric-card purple" data-badge="+14.2%">
        <div class="metric-icon purple-icon"><i class="fa fa-dollar-sign"></i></div>
        <span class="metric-label">Total Revenue</span>
        <span class="metric-value">$0.00</span>
        <span class="metric-sub">Live from database</span>
    </div>
    <div class="metric-card green" data-badge="18,432 txns">
        <div class="metric-icon green-icon"><i class="fa fa-chart-line"></i></div>
        <span class="metric-label">Successful Txns</span>
        <span class="metric-value">0</span>
        <span class="metric-sub">Live from database</span>
    </div>
    <div class="metric-card amber" data-badge="23 requests">
        <div class="metric-icon amber-icon"><i class="fa fa-clock"></i></div>
        <span class="metric-label">Pending Payouts</span>
        <span class="metric-value">$0.00</span>
        <span class="metric-sub">0 requests awaiting</span>
    </div>
    <div class="metric-card red" data-badge="2.1% rate">
        <div class="metric-icon red-icon"><i class="fa fa-exclamation-triangle"></i></div>
        <span class="metric-label">Failed / Refunded</span>
        <span class="metric-value">$0.00</span>
        <span class="metric-sub">Live from database</span>
    </div>
</div>

<div class="page-body">
    <div id="paymentTabStrip">
        <ul>
            <li class="k-state-active">Transaction Logs</li>
            <li>Pending Payouts</li>
            <li>Payout History</li>
            <li>Analytics Panel</li>
        </ul>
        <div><div id="transactionLogs"></div></div>
        <div>
            <div style="display:flex;justify-content:flex-end;margin:8px 0 12px 0;">
                <select id="pendingArtistFilter" style="min-width:220px;padding:8px;border:1px solid #ddd;border-radius:8px;">
                    <option value="">All Artists</option>
                </select>
            </div>
            <div id="pendingPayouts"></div>
        </div>
        <div><div id="payoutHistory"></div></div>
        <div><div id="analyticsPanel"></div></div>
    </div>
</div>
</body>
</html>
@section Scripts {
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.common.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.default.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://kendo.cdn.telerik.com/2021.2.616/js/kendo.all.min.js"></script>

<script>
    var ADMIN_PAYOUT_API_BASE = "http://localhost:5183/api/AdminPayout";
    var pendingArtistId = "";

    function checkAuth() {
        const token = localStorage.getItem("adminToken");
        const expiry = localStorage.getItem("adminExpiry");
        if (!token || !expiry) {
            window.location.href = "/Admin/Login";
            return false;
        }

        if (Date.now() > expiry * 1000) {
            localStorage.removeItem("adminToken");
            localStorage.removeItem("adminExpiry");
            window.location.href = "/Admin/Login";
            return false;
        }
        return true;
    }

    function authHeader() {
        if (!checkAuth()) return {};
        return {
            "Authorization": "Bearer " + localStorage.getItem("adminToken")
        };
    }

    function fmtCurrency(v) {
        return "$" + Number(v || 0).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtDate(v) {
        if (!v) return "-";
        var d = new Date(v);
        if (isNaN(d.getTime())) return "-";
        return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" });
    }

    function statusTemplate(status) {
        var normalized = (status || "Pending").toLowerCase();
        var cls = 'status-' + normalized;
        return '<span class="status-badge ' + cls + '">' + (status || "Pending") + '</span>';
    }

    function approvePayout(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        $.ajax({
            url: ADMIN_PAYOUT_API_BASE + "/approve/" + dataItem.id,
            method: "POST",
            headers: authHeader()
        }).done(function () {
            if (window.Swal) {
                Swal.fire({
                    icon: "success",
                    title: "Payout Approved",
                    text: "Artist payout has been approved successfully.",
                    timer: 1600,
                    showConfirmButton: false
                });
            } else {
                alert("Payout Approved");
            }
            $("#pendingPayouts").data("kendoGrid").dataSource.read();
            $("#payoutHistory").data("kendoGrid").dataSource.read();
            loadAnalytics();
        });
    }

    function rejectPayout(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        $.ajax({
            url: ADMIN_PAYOUT_API_BASE + "/reject/" + dataItem.id,
            method: "POST",
            headers: authHeader()
        }).done(function () {
            if (window.Swal) {
                Swal.fire({
                    icon: "info",
                    title: "Payout Rejected",
                    text: "Payout request has been rejected.",
                    timer: 1600,
                    showConfirmButton: false
                });
            } else {
                alert("Payout Rejected");
            }
            $("#pendingPayouts").data("kendoGrid").dataSource.read();
            $("#payoutHistory").data("kendoGrid").dataSource.read();
            loadAnalytics();
        });
    }

    function loadAnalytics() {
        $.ajax({
            url: ADMIN_PAYOUT_API_BASE + "/analytics",
            method: "GET",
            headers: authHeader()
        }).done(function (res) {
            $(".metric-card.purple .metric-value").text(fmtCurrency(res.totalRevenue));
            $(".metric-card.green .metric-value").text(Number(res.successfulTransactions || 0).toLocaleString("en-US"));
            $(".metric-card.amber .metric-value").text(fmtCurrency(res.pendingPayoutAmount));
            $(".metric-card.amber .metric-sub").html('<span class="up">↑</span> ' + Number(res.pendingPayoutCount || 0) + ' requests awaiting');
            $(".metric-card.red .metric-value").text(fmtCurrency(res.failedOrRefundedAmount));

            var points = (res.monthlyNetPayoutSeries || []);
            var categories = points.map(function (x) { return x.label; });
            var values = points.map(function (x) { return x.value; });
            var chart = $("#analyticsPanel").data("kendoChart");
            if (chart) {
                chart.setOptions({
                    categoryAxis: { categories: categories },
                    series: [{ data: values, color: "#ff7a00", opacity: 0.3, line: { width: 2.5, color: "#ff7a00" } }]
                });
            }
        }).fail(function () {
            $(".metric-card.purple .metric-sub").text("Unable to load analytics");
            $(".metric-card.green .metric-sub").text("Unable to load analytics");
            $(".metric-card.amber .metric-sub").text("Unable to load analytics");
            $(".metric-card.red .metric-sub").text("Unable to load analytics");
        });
    }

    function loadPendingArtists() {
        $.ajax({
            url: ADMIN_PAYOUT_API_BASE + "/pending-artists",
            method: "GET",
            headers: authHeader()
        }).done(function (artists) {
            var ddl = $("#pendingArtistFilter");
            ddl.find("option:not([value=''])").remove();
            (artists || []).forEach(function (a) {
                ddl.append($("<option>", { value: String(a.artistId), text: a.artistName }));
            });
        });
    }

    function loadPendingPayouts(options) {
        var url = ADMIN_PAYOUT_API_BASE + "/pending-payouts";
        if (pendingArtistId) {
            url += "?artistId=" + encodeURIComponent(pendingArtistId);
        }

        $.ajax({
            url: url,
            method: "GET",
            headers: authHeader()
        }).done(function (data) {
            options.success(data);
        }).fail(function (err) {
            options.error(err);
        });
    }

    $(document).ready(function () {
        if (!checkAuth()) return;

        $("#paymentTabStrip").kendoTabStrip({
            animation: { open: { effects: "fadeIn", duration: 300 } }
        });

        $("#transactionLogs").kendoGrid({
            dataSource: {
                transport: {
                    read: function (options) {
                        $.ajax({
                            url: ADMIN_PAYOUT_API_BASE + "/transaction-logs",
                            method: "GET",
                            headers: authHeader()
                        }).done(function (data) { options.success(data); })
                          .fail(function (err) { options.error(err); });
                    }
                },
                pageSize: 10
            },
            pageable: true,
            columns: [
                { field: "transactionId", title: "Transaction ID",
                  template: '<span style="font-family:monospace;font-weight:600">#: transactionId #</span>' },
                { field: "user", title: "User" },
                { field: "amount", title: "Amount",
                  template: '<span style="font-weight:600">#: kendo.toString(amount, "c2") #</span>' },
                { field: "status", title: "Status",
                  template: '#= statusTemplate(status) #' },
                { field: "date", title: "Date",
                  template: '<span style="color:var(--text-muted)">#: fmtDate(date) #</span>' }
            ]
        });

        $("#pendingPayouts").kendoGrid({
            dataSource: {
                transport: {
                    read: function (options) {
                        loadPendingPayouts(options);
                    }
                },
                pageSize: 10
            },
            pageable: true,
            columns: [
                { field: "artistName", title: "Artist", template: '<span style="font-weight:500">#: artistName #</span>' },
                { field: "requestMonth", title: "Request Month", template: '<span style="color:var(--text-muted)">#: requestMonth #</span>' },
                { field: "ordersCount", title: "Orders", template: '<span style="font-weight:500">#: ordersCount #</span>' },
                { field: "artwork", title: "Artwork", template: '<span style="color:var(--text-muted)">#: artwork #</span>' },
                { field: "grossAmount", title: "Gross", template: '<span style="font-weight:600">#: kendo.toString(grossAmount, "c2") #</span>' },
                { field: "commission", title: "Commission", template: '<span>#: kendo.toString(commission, "c2") #</span>' },
                { field: "netAmount", title: "Net", template: '<span style="font-weight:600">#: kendo.toString(netAmount, "c2") #</span>' },
                {
                    command: [
                        { name: "approve", text: "✓ Approve", click: approvePayout },
                        { name: "reject", text: "✕ Reject", click: rejectPayout }
                    ],
                    title: "Action", width: 220
                }
            ]
        });

        $("#payoutHistory").kendoGrid({
            dataSource: {
                transport: {
                    read: function (options) {
                        $.ajax({
                            url: ADMIN_PAYOUT_API_BASE + "/payout-history",
                            method: "GET",
                            headers: authHeader()
                        }).done(function (data) { options.success(data); })
                          .fail(function (err) { options.error(err); });
                    }
                },
                pageSize: 10
            },
            pageable: true,
            columns: [
                { field: "artistName", title: "Artist", template: '<span style="font-weight:500">#: artistName #</span>' },
                { field: "amount", title: "Amount", template: '<span style="font-weight:600">#: kendo.toString(amount, "c2") #</span>' },
                { field: "status", title: "Status", template: '#= statusTemplate(status) #' },
                { field: "processedDate", title: "Processed Date",
                  template: '<span style="color:var(--text-muted)">#: fmtDate(processedDate) #</span>' }
            ]
        });

        $("#analyticsPanel").kendoChart({
            title: { text: "Revenue Overview", font: "18px 'Space Grotesk'", color: "#1a1a2e" },
            legend: { visible: false },
            seriesDefaults: { type: "area" },
            series: [{
                data: [],
                color: "#ff7a00", opacity: 0.3,
                line: { width: 2.5, color: "#ff7a00" }
            }],
            categoryAxis: {
                categories: [],
                labels: { font: "12px 'DM Sans'", color: "#9096a8" },
                majorGridLines: { color: "#f0ece8" },
                line: { visible: false }
            },
            valueAxis: {
                labels: { font: "12px 'DM Sans'", color: "#9096a8", template: "$#= value/1000 #k" },
                majorGridLines: { color: "#f0ece8", dashType: "dash" },
                line: { visible: false }
            },
            tooltip: {
                visible: true, template: "$#= kendo.toString(value, 'n0') #",
                background: "#fff", border: { color: "#f0ece8" }
            },
            chartArea: { background: "transparent", height: 320 }
        });

        $("#pendingArtistFilter").on("change", function () {
            pendingArtistId = $(this).val();
            $("#pendingPayouts").data("kendoGrid").dataSource.read();
        });

        loadPendingArtists();
        loadAnalytics();
    });
</script>
}
