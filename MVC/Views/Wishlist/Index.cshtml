    <div class="page">
        <div class="wishlist-shell">
            <div class="page-header">
                <div>
                    <span class="eyebrow">Saved Collection</span>
                    <h1>Review your wishlist</h1>
                    <p>Keep track of the artworks you love and move them to cart when you are ready.</p>
                </div>
                <div class="count-pill" id="countText">Loading...</div>
            </div>

            <div class="header-actions">
                <a href="/Buyer/ExploreArt" class="clear-btn secondary">
                    <svg style="margin-right:8px" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5">
                        <line x1="19" y1="12" x2="5" y2="12" />
                        <polyline points="12 19 5 12 12 5" />
                    </svg>
                    Explore Art
                </a>
                <button class="clear-btn" onclick="clearAll()">
                    <svg style="margin-right:8px" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                    </svg>
                    Clear All
                </button>
            </div>
            <div id="content">
                <div class="loading-state">
                    <div class="loading-spinner"></div>
                    <p>Loading your wishlist...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        var API_BASE = 'http://localhost:5183';
        var loadedItems = [];

        function getToken() { return localStorage.getItem('token'); }
        function authFetch(url, options) {
            options = options || {};
            var token = getToken();
            return fetch(url, Object.assign({}, options, {
                headers: Object.assign({ 'Content-Type': 'application/json' },
                    token ? { 'Authorization': 'Bearer ' + token } : {},
                    options.headers || {})
            }));
        }
        function imageUrl(path) {
            if (!path) return 'https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=600';
            if (path.startsWith('http')) return path;
            return window.location.origin + path;
        }

        // ── localStorage helpers (same keys as ExploreArt) ───────────────────
        function getWishlist() { try { return JSON.parse(localStorage.getItem('artify_wishlist') || '[]'); } catch (e) { return []; } }
        function saveWishlist(arr) { localStorage.setItem('artify_wishlist', JSON.stringify(arr)); }
        function getCart() { try { return JSON.parse(localStorage.getItem('artify_cart') || '[]'); } catch (e) { return []; } }
        function saveCart(arr) { localStorage.setItem('artify_cart', JSON.stringify(arr)); }
        function isInCart(id) { return getCart().some(function (x) { return x != null && x.toString() === id.toString(); }); }

        // updateBadges handled by globalBadges.js

        function removeFromWishlist(artworkId) {
            var wl = getWishlist();
            var idx = wl.findIndex(function (id) { return id != null && id.toString() === artworkId.toString(); });
            if (idx !== -1) { wl.splice(idx, 1); saveWishlist(wl); }
            loadedItems = loadedItems.filter(function (x) { return x.artworkId !== artworkId; });
            updateBadges();
            render(loadedItems);
        }

        function addToCart(artworkId) {
            if (isInCart(artworkId)) return;
            var ct = getCart();
            ct.push(artworkId);
            saveCart(ct);
            updateBadges();
            render(loadedItems); // re-render to show "In Cart" state
        }

        function clearAll() {
            saveWishlist([]);
            loadedItems = [];
            updateBadges();
            render([]);
        }

        function render(items) {
            document.getElementById('countText').textContent = items.length + ' item' + (items.length === 1 ? '' : 's') + ' saved';

            if (items.length === 0) {
                document.getElementById('content').innerHTML =
                    '<div class="empty-state">'
                    + '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>'
                    + '<h2>Your wishlist is empty</h2>'
                    + '<p>Save artworks you love and they\'ll appear here</p>'
                    + '<a href="/Buyer/ExploreArt">Explore Art</a>'
                    + '</div>';
                return;
            }

            var html = '<div class="art-grid">'
                + items.map(function (a, i) {
                    var inCart = isInCart(a.artworkId);
                    var img = imageUrl(a.previewPath);
                    var detailUrl = '/Buyer/ArtworkDetail/' + a.artworkId;
                    return '<div class="art-card" style="animation-delay:' + (i * 0.07) + 's">'
                        + '<a href="' + detailUrl + '" class="card-img">'
                        + '<img src="' + img + '" alt="' + a.title + '" loading="lazy"/>'
                        + '</a>'
                        + '<div class="card-info">'
                        + '<div class="card-top">'
                        + '<div class="card-meta">'
                        + '<span class="cat-badge">' + (a.categoryName || 'Original Artwork') + '</span>'
                        + (inCart ? '<span class="saved-state">Saved to cart</span>' : '<span class="saved-state muted">Ready to move</span>')
                        + '</div>'
                        + '<h3><a href="' + detailUrl + '" class="card-title-link">' + a.title + '</a></h3>'
                        + '<p class="artist">by ' + a.artistName + '</p>'
                        + '<p class="card-copy">Saved in your wishlist so you can revisit it anytime before checkout.</p>'
                        + '</div>'
                        + '<div class="meta">'
                        + '<div class="price-block"><small>Artwork Price</small><span class="price">$ ' + Number(a.price).toLocaleString('en-US') + '</span></div>'
                        + '<div class="item-actions">'
                        + '<a href="' + detailUrl + '" class="view-btn">'
                        + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>View</a>'
                        + (inCart ? '' : '<button class="clear-btn secondary" type="button" onclick="addToCart(' + a.artworkId + ')">Add to Cart</button>')
                        + '<button class="remove-btn" type="button" onclick="removeFromWishlist(' + a.artworkId + ')">'
                        + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>Remove</button>'
                        + '</div>'
                        + '</div>'
                        + '</div></div>';
                }).join('')
                + '</div>';

            document.getElementById('content').innerHTML = html;
        }

        async function loadWishlist() {
            var wishlistIds = getWishlist(); // array of artworkIds
            updateBadges();

            if (wishlistIds.length === 0) {
                loadedItems = [];
                render([]);
                return;
            }

            try {
                var res = await authFetch(API_BASE + '/api/artwork');
                if (!res.ok) throw new Error('Failed');
                var data = await res.json();

                var all = Array.isArray(data) ? data
                    : (data.$values || data.items || data.data || data.artworks || []);

                // Keep only artworks that are in the wishlist
                loadedItems = wishlistIds
                    .map(function (id) {
                        return all.find(function (a) {
                            return (a.artworkId || a.id).toString() === id.toString();
                        });
                    })
                    .filter(Boolean);

                render(loadedItems);
            } catch (err) {
                document.getElementById('content').innerHTML =
                    '<div class="loading-state"><p>Failed to load wishlist. <a href="/Buyer/ExploreArt" style="color:var(--accent)">Continue shopping</a></p></div>';
            }
        }

        document.addEventListener('DOMContentLoaded', loadWishlist);
    </script>
</body>

</html>
