@{
    ViewData["Title"] = "Wishlist | Artify";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet" />
    <style>
        :root {
            --bg: #DFE6E9;
            --text-main: #1a1a1a;
            --text-muted: #636e72;
            --heading-blue: #6B9BE6;
            --accent-gold: #EDA312;
            --btn-blue: #03289F;
            --card-white: #ffffff;
            --border: rgba(3, 40, 159, 0.08);
            --shadow-soft: 0 15px 45px rgba(3, 40, 159, 0.06);
            --shadow-hover: 0 20px 50px rgba(0, 0, 0, 0.08);
            --wishlist: #ff5e57;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            line-height: 1.6;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Playfair Display', serif;
        }

        nav {
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 4rem;
            background: rgba(223, 230, 233, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: .7rem;
            text-decoration: none;
        }

        .nav-logo-icon {
            height: 40px;
            width: 40px;
            border-radius: 12px;
            background: var(--btn-blue);
            display: grid;
            place-items: center;
            font-weight: 900;
            color: #fff;
            font-size: 1.2rem;
        }

        .nav-logo span {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -.02em;
            font-family: 'Playfair Display', serif;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            font-size: .88rem;
            color: var(--text-main);
            opacity: .7;
            transition: opacity .2s, color .2s;
        }

        .nav-links a:hover {
            opacity: 1;
            color: var(--heading-blue);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-icon-btn {
            position: relative;
            display: grid;
            place-items: center;
            height: 40px;
            width: 40px;
            border-radius: 50%;
            border: 1.5px solid var(--border);
            background: rgba(255,255,255,.5);
            cursor: pointer;
            color: var(--text-main);
            transition: background .2s, border-color .2s, transform .2s;
            text-decoration: none;
        }

        .nav-icon-btn:hover {
            background: var(--btn-blue);
            color: #fff;
            border-color: var(--btn-blue);
            transform: scale(1.08);
        }

        .nav-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            height: 16px;
            min-width: 16px;
            padding: 0 3px;
            background: var(--accent-gold);
            color: #fff;
            border-radius: 999px;
            font-size: .62rem;
            font-weight: 700;
            display: grid;
            place-items: center;
        }

        .nav-signin {
            font-size: .88rem;
            color: var(--text-main);
            text-decoration: none;
            opacity: .8;
            transition: opacity .2s, color .2s;
        }

        .nav-signin:hover {
            opacity: 1;
            color: var(--heading-blue);
        }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(223, 230, 233, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .navbar-inner {
            max-width: 1300px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 2rem;
        }

        .logo-wrap {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .back-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-main);
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .back-btn:hover {
            background: var(--btn-blue);
            color: #fff;
            border-color: var(--btn-blue);
            transform: translateX(-4px);
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: -0.01em;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
        }

        .nav-links a {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--btn-blue);
            transition: width 0.3s;
        }

        .nav-links a:hover {
            color: var(--text-main);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .icon-btn {
            position: relative;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            transition: all 0.3s;
            text-decoration: none;
        }

        .icon-btn:hover {
            background: var(--btn-blue);
            color: #fff;
            border-color: var(--btn-blue);
            transform: translateY(-3px);
        }

        .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            min-width: 20px;
            height: 20px;
            padding: 0 5px;
            border-radius: 999px;
            background: var(--accent-gold);
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }

        .badge.zero {
            display: none;
        }

        .avatar-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: white;
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.3s;
        }

        .avatar-btn:hover {
            background: var(--btn-blue);
            color: #fff;
            border-color: var(--btn-blue);
            transform: translateY(-3px);
        }

        .page {
            max-width: 1320px;
            margin: 0 auto;
            padding: 2.75rem 2rem 4rem;
            min-height: 80vh;
        }

        .wishlist-shell {
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.82);
            box-shadow: var(--shadow-soft);
            border-radius: 30px;
            padding: 2rem;
            backdrop-filter: blur(18px);
        }

        .page-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 28px;
            align-items: end;
            margin-bottom: 2.3rem;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(3, 40, 159, 0.07);
            color: var(--btn-blue);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            margin-bottom: 0.9rem;
        }

        .page-header h1 {
            font-size: clamp(1.9rem, 3vw, 2.7rem);
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.55rem;
            line-height: 1.08;
        }

        .page-header p {
            max-width: 620px;
            font-size: 0.92rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .count-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.8rem 1.05rem;
            border-radius: 999px;
            background: var(--card-white);
            border: 1px solid var(--border);
            font-size: 0.88rem;
            font-weight: 700;
            color: var(--text-main);
            box-shadow: 0 10px 30px rgba(31, 41, 51, 0.05);
        }

        .header-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .clear-btn {
            padding: 12px 20px;
            border-radius: 99px;
            border: 1.5px solid var(--border);
            background: white;
            font-size: 0.86rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            color: var(--text-main);
            transition: all 0.3s;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .clear-btn:hover {
            background: var(--wishlist);
            color: #fff;
            border-color: var(--wishlist);
            box-shadow: 0 8px 20px rgba(255, 94, 87, 0.2);
        }

        .clear-btn.secondary:hover {
            background: var(--btn-blue);
            border-color: var(--btn-blue);
        }

        /* Loading */
        .loading-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 14px;
            min-height: 320px;
            text-align: center;
            background: rgba(255,255,255,0.72);
            border: 1px solid var(--border);
            border-radius: 32px;
            color: var(--text-muted);
        }

        .loading-spinner {
            display: inline-block;
            width: 48px;
            height: 48px;
            border: 3px solid rgba(3, 40, 159, 0.12);
            border-top-color: var(--btn-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Empty */
        .empty-state {
            text-align: center;
            padding: 100px 40px;
            background: white;
            border-radius: 3rem;
            border: 1px solid var(--border);
        }

        .empty-state svg {
            color: var(--heading-blue);
            opacity: 0.5;
            margin-bottom: 30px;
        }

        .empty-state h2 {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .empty-state p {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-top: 12px;
        }

        .empty-state a {
            display: inline-block;
            margin-top: 32px;
            padding: 16px 40px;
            border-radius: 99px;
            background: var(--btn-blue);
            color: #fff;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 700;
            transition: all 0.3s;
        }

        .empty-state a:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(3, 40, 159, 0.2);
        }

        /* Grid */
        .art-grid {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .art-card {
            background: var(--card-white);
            border-radius: 24px;
            border: 1px solid var(--border);
            display: grid;
            grid-template-columns: 148px minmax(0, 1fr);
            gap: 22px;
            padding: 18px;
            transition: all 0.3s ease;
            animation: fade-up 0.6s ease-out forwards;
            opacity: 0;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
            min-width: 0;
        }

        .art-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(3, 40, 159, 0.12);
        }

        .card-img {
            position: relative;
            height: 188px;
            border-radius: 18px;
            overflow: hidden;
            background: #ebeef2;
            display: block;
            text-decoration: none;
        }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s;
            display: block;
        }

        .art-card:hover .card-img img {
            transform: scale(1.08);
        }

        .cat-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(23, 59, 122, 0.07);
            color: var(--heading-blue);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .card-info {
            min-width: 0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 18px;
        }

        .card-top {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .card-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .card-meta .cat-badge {
            position: static;
        }

        .saved-state {
            color: #1d9b6c;
            font-size: 0.84rem;
            font-weight: 700;
        }

        .saved-state.muted {
            color: var(--text-muted);
        }

        .card-info h3 {
            font-size: clamp(1.05rem, 1.8vw, 1.3rem);
            font-weight: 700;
            line-height: 1.15;
            color: var(--text-main);
            word-break: break-word;
        }

        .card-title-link {
            color: inherit;
            text-decoration: none;
            transition: color 0.3s;
        }

        .card-title-link:hover {
            color: var(--heading-blue);
        }

        .card-info .artist {
            font-size: 0.86rem;
            color: var(--text-muted);
            font-weight: 600;
        }

        .card-copy {
            color: var(--text-muted);
            font-size: 0.84rem;
            max-width: 560px;
        }

        .card-info .meta {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 18px;
            flex-wrap: wrap;
        }

        .price-block small {
            display: block;
            color: var(--text-muted);
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .card-info .price {
            font-size: 1.45rem;
            font-weight: 800;
            font-family: 'Playfair Display', serif;
            color: var(--text-main);
            line-height: 1;
        }

        .item-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .view-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 18px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text-main);
            font-size: 0.82rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s;
        }

        .view-btn:hover {
            border-color: var(--btn-blue);
            color: var(--btn-blue);
            transform: translateY(-2px);
        }

        .remove-btn {
            margin-top: 0;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 18px;
            border-radius: 999px;
            border: 1px solid rgba(214, 76, 65, 0.16);
            background: rgba(214, 76, 65, 0.06);
            color: #c44538;
            font-size: 0.82rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
        }

        .remove-btn:hover {
            background: #d64c41;
            color: #fff;
            border-color: #d64c41;
            box-shadow: 0 8px 20px rgba(214, 76, 65, 0.2);
        }

        .item-actions .clear-btn.secondary {
            min-width: 140px;
            justify-content: center;
        }

        .empty-state {
            text-align: center;
            padding: 100px 40px;
            background: white;
            border-radius: 3rem;
            border: 1px solid var(--border);
        }

        .empty-state svg {
            color: var(--heading-blue);
            opacity: 0.5;
            margin-bottom: 30px;
        }

        .empty-state h2 {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .empty-state p {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-top: 12px;
        }

        .empty-state a {
            display: inline-block;
            margin-top: 32px;
            padding: 16px 40px;
            border-radius: 99px;
            background: var(--btn-blue);
            color: #fff;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 700;
            transition: all 0.3s;
        }

        .empty-state a:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(3, 40, 159, 0.2);
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media(max-width:768px) {
            nav {
                padding: 1rem 1.25rem;
            }

            .nav-links {
                display: none;
            }

            .page {
                padding: 2rem 1rem 3rem;
            }

            .wishlist-shell {
                padding: 1.2rem;
                border-radius: 28px;
            }

            .page-header {
                grid-template-columns: 1fr;
                align-items: start;
            }

            .page-header h1 {
                font-size: 2.25rem;
            }

            .header-actions {
                width: 100%;
            }

            .art-card {
                grid-template-columns: 1fr;
                border-radius: 24px;
                padding: 16px;
            }

            .card-img {
                width: 100%;
                height: 240px;
            }

            .card-info .meta {
                align-items: stretch;
            }

            .item-actions .clear-btn.secondary,
            .view-btn,
            .remove-btn {
                width: 100%;
                min-width: 0;
                justify-content: center;
            }
        }
    </style>
</head>

<body>
    @Html.Partial("_Navbar")

