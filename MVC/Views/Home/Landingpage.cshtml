<script>
/* ══════════════════════════════════════════════════════════
   CONSTANTS & UTILS
   NOTE: API returns PascalCase directly from C# model —
         t_BuyerUiArtwork properties: ArtworkId, Title,
         Price, PreviewPath, ArtistName, LikesCount, etc.
══════════════════════════════════════════════════════════ */
const AB_CLASSES = ['ab0','ab1','ab2','ab3','ab4','ab5','ab6','ab7'];
const AB_EMOJIS  = ['🌌','🌊','🌿','✨','🔥','💎','🏔','🌸'];

const abClass = i => AB_CLASSES[i % AB_CLASSES.length];
const abEmoji = i => AB_EMOJIS[i % AB_EMOJIS.length];

function fmtPrice(p){
  const value = Number(p);
  if(!Number.isFinite(value)) return 'Rs. 0';
  return "Artify";
}

function esc(s){
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function pick(obj, camelKey, pascalKey){
  return obj?.[camelKey] ?? obj?.[pascalKey];
}

function normalizeMediaUrl(url){
  if(!url) return null;
  if(url.startsWith('http://')) return 'https://' + url.slice(7);
  return url;
}

function normalizeArtwork(raw){
  return {
    ArtworkId: pick(raw, 'artworkId', 'ArtworkId'),
    ArtistId: pick(raw, 'artistId', 'ArtistId'),
    CategoryId: pick(raw, 'categoryId', 'CategoryId'),
    Title: pick(raw, 'title', 'Title') || 'Untitled',
    Description: pick(raw, 'description', 'Description') || '',
    Price: pick(raw, 'price', 'Price') ?? 0,
    PreviewPath: normalizeMediaUrl(pick(raw, 'previewPath', 'PreviewPath')),
    OriginalPath: normalizeMediaUrl(pick(raw, 'originalPath', 'OriginalPath')),
    ApprovalStatus: pick(raw, 'approvalStatus', 'ApprovalStatus') || '',
    CreatedAt: pick(raw, 'createdAt', 'CreatedAt'),
    LikesCount: pick(raw, 'likesCount', 'LikesCount') ?? 0,
    SellCount: pick(raw, 'sellCount', 'SellCount') ?? 0,
    ArtistName: pick(raw, 'artistName', 'ArtistName') || 'Unknown Artist',
    CategoryName: pick(raw, 'categoryName', 'CategoryName') || ''
  };
}

/*
  Render the image portion of an artwork card.
  API field: aw.PreviewPath (PascalCase, may be null).
*/
function artImg(aw, idx){
  if(aw.PreviewPath){
    return `<img src="${esc(aw.PreviewPath)}" alt="${esc(aw.Title)}" loading="lazy"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <span style="display:none;width:100%;height:100%;align-items:center;justify-content:center;font-size:3.5rem">${abEmoji(idx)}</span>`;
  }
  return `<span style="font-size:3.5rem">${abEmoji(idx)}</span>`;
}

/* ══════════════════════════════════════════════════════════
   SINGLE API CALL — shared across all three renderers
   GET /api/artwork  →  List<t_BuyerUiArtwork>  (PascalCase JSON)
══════════════════════════════════════════════════════════ */
let _artworksPromise = null;
const ARTWORK_API_BASE = window.location.protocol === 'https:'
  ? 'https://localhost:7077'
  : 'http://localhost:5183';
const isUserLoggedIn = @isUserLoggedIn.ToString().ToLowerInvariant();
const loginUrl = '@loginUrl';
const artworkDetailUrlTemplate = '@artworkDetailUrlTemplate';
const getArtworkUrl = (artworkId) => isUserLoggedIn
  ? artworkDetailUrlTemplate.replace('__ARTWORK_ID__', artworkId)
  : loginUrl;

function getArtworks(){
  if(!_artworksPromise){
    _artworksPromise = fetch(`${ARTWORK_API_BASE}/api/artwork`)
      .then(r => {
        if(!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(payload => {
        const items = Array.isArray(payload)
          ? payload
          : (Array.isArray(payload?.data) ? payload.data : []);
        return items.map(normalizeArtwork);
      })
      .catch(err => {
        console.error('[getArtworks] fetch failed:', err);
        return [];
      });
  }
  return _artworksPromise;
}

/* ══════════════════════════════════════════════════════════
   1.  HERO FLOATING CARDS  (first 6 artworks)
   Fields used: PreviewPath, Title, Price
══════════════════════════════════════════════════════════ */
async function renderFloatCards(){
  try{
    const artworks = await getArtworks();
    const slice = artworks.slice(0, 6);
    if(!slice.length) return;   // keep skeleton placeholders

    const heights = [200, 185, 210, 190, 175, 195];
    const container = document.getElementById('floatCards');

    container.innerHTML = slice.map((aw, i) => {
      const bg = aw.PreviewPath ? '' : abClass(i);
      return `
        <div class="fcard" style="height:${heights[i]}px">
          <div class="fcard-img ${bg}" style="position:relative">
            ${artImg(aw, i)}
          </div>
          <div class="fcard-label">
            <div class="fcard-label-title">${esc(aw.Title)}</div>
            <div class="fcard-label-price">${fmtPrice(aw.Price)}</div>
          </div>
        </div>`;
    }).join('');

  } catch(err){ console.warn('[floatCards]', err); }
}

/* ══════════════════════════════════════════════════════════
   2.  GALLERY GRID  (first 5 artworks)
   Fields used: ArtworkId, PreviewPath, Title, ArtistName,
                Price, LikesCount
══════════════════════════════════════════════════════════ */
async function renderGallery(){
  const grid = document.getElementById('galleryGrid');
  try{
    const artworks = await getArtworks();
    const slice = artworks.slice(0, 5);

    if(!slice.length){
      grid.innerHTML = '<div class="gallery-error">No artworks available yet.</div>';
      return;
    }

    grid.innerHTML = slice.map((aw, i) => {
      const bg      = aw.PreviewPath ? '' : abClass(i);
      const badge   = i === 0 ? '<div class="gcard-badge">Featured</div>'
                    : i === 2 ? '<div class="gcard-badge">New</div>'
                    : '';
      const imgInner = aw.PreviewPath
        ? `<img src="${esc(aw.PreviewPath)}" alt="${esc(aw.Title)}" loading="lazy"
               onerror="this.style.display='none'">`
        : `<div class="art-placeholder ${bg}">${abEmoji(i)}</div>`;

      return `
        <div class="gcard" onclick="location.href=getArtworkUrl(${aw.ArtworkId})">
          <div class="gcard-art">
            <div class="gcard-art-inner ${bg}">${imgInner}</div>
          </div>
          ${badge}
          <div class="gcard-like" title="${aw.LikesCount} likes">♡</div>
          <div class="gcard-info">
            <div>
              <div class="gcard-title">${esc(aw.Title)}</div>
              <div class="gcard-sub">by @@${esc(aw.ArtistName)}</div>
            </div>
            <div class="gcard-price">${fmtPrice(aw.Price)}</div>
          </div>
        </div>`;
    }).join('');

    requestAnimationFrame(attachGalleryAnim);

  } catch(err){
    grid.innerHTML = '<div class="gallery-error">Could not load artworks — please refresh.</div>';
    console.error('[gallery]', err);
  }
}

function attachGalleryAnim(){
  const gcards = document.querySelectorAll('#galleryGrid .gcard');
  const obs = new IntersectionObserver(([e]) => {
    if(!e.isIntersecting) return;
    gcards.forEach((c, i) => {
      c.style.opacity    = '0';
      c.style.transform  = 'perspective(600px) rotateX(20deg) translateY(40px)';
      c.style.transition = `opacity 0.7s ease ${i*0.09}s, transform 0.7s cubic-bezier(0.22,1,0.36,1) ${i*0.09}s`;
      setTimeout(() => { c.style.opacity='1'; c.style.transform='perspective(600px) rotateX(0) translateY(0)'; }, 50+i*90);
    });
    obs.unobserve(e.target);
  }, {threshold:0.1});
  const g = document.getElementById('galleryGrid');
  if(g) obs.observe(g);
}

function buildDiverseStripPool(artworks, limit = 18){
  const source = artworks.length > 5 ? artworks.slice(5) : artworks.slice();
  if(source.length <= limit) return source;

  const groups = new Map();
  source.forEach(aw => {
    const artist = (aw.ArtistName || '').trim().toLowerCase() || 'unknown-artist';
    const category = (aw.CategoryName || '').trim().toLowerCase() || 'unknown-category';
    const key = `${category}::${artist}`;

    if(!groups.has(key)) groups.set(key, []);
    groups.get(key).push(aw);
  });

  const buckets = Array.from(groups.values()).sort((a, b) => b.length - a.length);
  const selected = [];

  while(selected.length < limit && buckets.some(bucket => bucket.length)){
    buckets.forEach(bucket => {
      if(bucket.length && selected.length < limit){
        selected.push(bucket.shift());
      }
    });
  }

  return selected;
}

/* ══════════════════════════════════════════════════════════
   3.  SHOWCASE STRIP  (artworks after the first 5, looped)
   Fields used: ArtworkId, PreviewPath, Title, Price
══════════════════════════════════════════════════════════ */
async function renderStrip(){
  const wrap = document.getElementById('stripTrackWrap');
  try{
    const artworks = await getArtworks();
    const pool = artworks.length > 5 ? artworks.slice(5) : artworks;
    if(!pool.length){ wrap.innerHTML = ''; return; }

    const doubled = [...pool, ...pool];

    wrap.innerHTML = `<div class="strip-track">${
      doubled.map((aw, i) => {
        const bg = aw.PreviewPath ? '' : abClass(i);
        const imgHTML = aw.PreviewPath
          ? `<img src="${esc(aw.PreviewPath)}" alt="${esc(aw.Title)}" loading="lazy"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
             <span class="scard-emoji" style="display:none">${abEmoji(i)}</span>`
          : `<span class="scard-emoji">${abEmoji(i)}</span>`;

        return `
          <div class="scard" onclick="location.href=getArtworkUrl(${aw.ArtworkId})">
            <div class="scard-art ${bg}">${imgHTML}</div>
            <div class="scard-info">
              <div class="scard-name">${esc(aw.Title)}</div>
              <div class="scard-price">${fmtPrice(aw.Price)}</div>
            </div>
          </div>`;
      }).join('')
    }</div>`;

    const track = wrap.querySelector('.strip-track');
    if(track){
      track.addEventListener('mouseenter', () => track.style.animationDuration='8s');
      track.addEventListener('mouseleave', () => track.style.animationDuration='25s');
    }

  } catch(err){ wrap.innerHTML = ''; console.error('[strip]', err); }
}

/* ── Kick off all three renderers ── */
renderFloatCards();
renderGallery();
renderStrip();

/* ══════════════════════════════════════════════════════════
   CUSTOM CURSOR
══════════════════════════════════════════════════════════ */
const cur  = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx=0, my=0, rx=0, ry=0;
document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; cur.style.left=mx+'px'; cur.style.top=my+'px'; });
(function loop(){ rx+=(mx-rx)*0.1; ry+=(my-ry)*0.1; ring.style.left=rx+'px'; ring.style.top=ry+'px'; requestAnimationFrame(loop); })();
document.querySelectorAll('a,button,.gcard,.rcard,.scard,.hcard').forEach(el=>{
  el.addEventListener('mouseenter', () => { cur.style.transform='translate(-50%,-50%) scale(2.5)'; ring.style.width='56px'; ring.style.height='56px'; });
  el.addEventListener('mouseleave', () => { cur.style.transform='translate(-50%,-50%) scale(1)';   ring.style.width='38px'; ring.style.height='38px'; });
});
['galleryGrid','stripTrackWrap','floatCards'].forEach(id => {
  const el = document.getElementById(id);
  if(!el) return;
  el.addEventListener('mouseenter', e => { if(e.target.closest('.gcard,.scard,.fcard')){ cur.style.transform='translate(-50%,-50%) scale(2.5)'; ring.style.width='56px'; ring.style.height='56px'; }}, true);
  el.addEventListener('mouseleave', e => { if(e.target.closest('.gcard,.scard,.fcard')){ cur.style.transform='translate(-50%,-50%) scale(1)';   ring.style.width='38px'; ring.style.height='38px'; }}, true);
});

/* ── Navbar scroll ── */
window.addEventListener('scroll', () => document.getElementById('navbar').classList.toggle('scrolled', scrollY > 50));

/* ── Scroll animation observer ── */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(!e.isIntersecting) return;
    const el = e.target;
    el.classList.add('visible');
    el.querySelectorAll('[data-target]').forEach(num => {
      const target = +num.dataset.target;
      const sfx = target >= 1000 ? '+' : '';
      let v=0, step=target/70;
      const t = setInterval(() => { v=Math.min(v+step,target); num.textContent=Math.floor(v).toLocaleString()+sfx; if(v>=target) clearInterval(t); }, 18);
    });
    el.querySelectorAll('.stat-bar[data-pct]').forEach((bar,i) => {
      setTimeout(() => { bar.style.width = bar.dataset.pct+'%'; }, 300+i*80);
    });
    if(el.classList.contains('gold-divider'))
      el.style.animation = 'lineDraw 1.2s cubic-bezier(0.22,1,0.36,1) forwards';
    io.unobserve(el);
  });
}, {threshold:0.12});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.reveal-clip,.reveal-flip,.reveal-line,.stagger-children,.gold-divider').forEach(el => io.observe(el));

/* ── Card shine ── */
function shineCard(e, card){
  const r = card.getBoundingClientRect();
  card.style.setProperty('--rx', ((e.clientX-r.left)/r.width*100)+'%');
  card.style.setProperty('--ry', ((e.clientY-r.top)/r.height*100)+'%');
}

/* ── Hero floating cards parallax ── */
document.addEventListener('mousemove', e => {
  const cx=window.innerWidth/2, cy=window.innerHeight/2;
  const dx=(e.clientX-cx)/cx, dy=(e.clientY-cy)/cy;
  document.querySelectorAll('.fcard').forEach((c,i) => {
    const d = (i%2===0?1:-1)*(i*3+8);
    c.style.transform = `translateY(${dy*d}px) translateX(${dx*d*0.5}px)`;
  });
});

/* ── Horizontal scroll track ── */
(function(){
  const section = document.querySelector('.hscroll-section');
  const track   = document.getElementById('htrack');
  if(!section || !track) return;
  function updateHorizontalTrack(){
    const rect = section.getBoundingClientRect();
    const vh   = window.innerHeight;
    const pct  = Math.max(0, Math.min(1, (vh - rect.top) / (vh + rect.height)));
    const max  = Math.max(0, track.scrollWidth - track.parentElement.clientWidth - 120);
    track.style.transform = `translateX(-${pct * max}px)`;
  }
  window.addEventListener('scroll', updateHorizontalTrack, { passive: true });
  window.addEventListener('resize', updateHorizontalTrack);
  updateHorizontalTrack();
})();

/* ── Section eyebrow slide-in ── */
document.querySelectorAll('.section-eyebrow').forEach(el => {
  const obs = new IntersectionObserver(([e]) => {
    if(!e.isIntersecting) return;
    el.style.cssText += 'opacity:0;transform:translateX(-20px);transition:opacity .6s ease,transform .6s ease';
    requestAnimationFrame(() => { el.style.opacity='1'; el.style.transform='translateX(0)'; });
    obs.unobserve(el);
  }, {threshold:0.5});
  obs.observe(el);
});

/* ── Scroll progress bar ── */
const progressBar = Object.assign(document.createElement('div'), {style:'position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#b8761a,#f0c060);z-index:9997;width:0%;transition:width .1s linear'});
document.body.appendChild(progressBar);
window.addEventListener('scroll', () => {
  progressBar.style.width = (scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100)+'%';
});

/* ── Process cards entrance ── */
(function(){
  const cards = document.querySelectorAll('.pcard');
  const obs = new IntersectionObserver(([e]) => {
    if(!e.isIntersecting) return;
    cards.forEach((c,i) => {
      c.style.cssText += `opacity:0;transform:translateY(30px);transition:opacity .6s ease ${i*.12}s,transform .6s cubic-bezier(.22,1,.36,1) ${i*.12}s`;
      setTimeout(() => { c.style.opacity='1'; c.style.transform='none'; }, 50+i*120);
    });
    obs.unobserve(e.target);
  }, {threshold:0.2});
  const pw = document.querySelector('.process-cards');
  if(pw) obs.observe(pw);
})();

/* ── Hcard stagger ── */
(function(){
  const cards = document.querySelectorAll('.hcard');
  const obs = new IntersectionObserver(([e]) => {
    if(!e.isIntersecting) return;
    cards.forEach((c,i) => {
      c.style.cssText += `opacity:0;transform:translateY(28px);transition:opacity .55s ease ${i*.08}s,transform .55s ease ${i*.08}s`;
      setTimeout(() => { c.style.opacity='1'; c.style.transform='none'; }, 30+i*80);
    });
    obs.unobserve(e.target);
  }, {threshold:0.15});
  const hw = document.querySelector('.hscroll-track-outer');
  if(hw) obs.observe(hw);
})();

/* ── Role cards stagger ── */
(function(){
  const cards = document.querySelectorAll('.rcard');
  const obs = new IntersectionObserver(([e]) => {
    if(!e.isIntersecting) return;
    cards.forEach((c,i) => {
      c.style.cssText += `opacity:0;transform:translateY(40px) scale(.96);transition:opacity .65s ease ${i*.14}s,transform .65s cubic-bezier(.22,1,.36,1) ${i*.14}s`;
      setTimeout(() => { c.style.opacity='1'; c.style.transform='none'; }, 50+i*140);
    });
    obs.unobserve(e.target);
  }, {threshold:0.15});
  const rg = document.querySelector('.roles-grid');
  if(rg) obs.observe(rg);
})();

/* ── Testimonial card tilt ── */
document.querySelectorAll('.tcard').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r=card.getBoundingClientRect();
    card.style.transform=`perspective(600px) rotateX(${((e.clientY-r.top)/r.height-.5)*-10}deg) rotateY(${((e.clientX-r.left)/r.width-.5)*10}deg) translateY(-4px)`;
    card.style.boxShadow='0 20px 50px rgba(28,23,17,.18)'; card.style.transition='transform .1s,box-shadow .1s';
  });
  card.addEventListener('mouseleave', () => { card.style.transform=''; card.style.boxShadow=''; card.style.transition='transform .4s,box-shadow .4s'; });
});

/* ── Strip card tilt (delegated for dynamic cards) ── */
const stripWrap = document.getElementById('stripTrackWrap');
stripWrap.addEventListener('mousemove', e => {
  const c = e.target.closest('.scard'); if(!c) return;
  const r=c.getBoundingClientRect();
  c.style.transform=`perspective(500px) rotateX(${((e.clientY-r.top)/r.height-.5)*-14}deg) rotateY(${((e.clientX-r.left)/r.width-.5)*14}deg) translateY(-12px)`;
  c.style.transition='transform .1s';
});
stripWrap.addEventListener('mouseleave', e => {
  const c = e.target.closest('.scard'); if(!c) return;
  c.style.transform=''; c.style.transition='transform .4s';
}, {passive:true});

/* ── Marquee hover speed ── */
const mtrack = document.querySelector('.marquee-track');
if(mtrack){
  mtrack.parentElement.addEventListener('mouseenter', () => mtrack.style.animationDuration='8s');
  mtrack.parentElement.addEventListener('mouseleave', () => mtrack.style.animationDuration='22s');
}
</script>
</body>
</html>


