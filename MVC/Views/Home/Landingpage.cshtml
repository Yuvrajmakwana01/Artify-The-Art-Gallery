        .drops-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .drop-card {
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(3, 40, 159, .10);
            background: rgba(255, 255, 255, .5);
