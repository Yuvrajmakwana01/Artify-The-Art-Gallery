            transition: all .3s;
        }
        .drop-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(3, 40, 159, .22); }
        .drop-img { aspect-ratio: 3 / 4; overflow: hidden; position: relative; }
        .drop-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
        .drop-card:hover .drop-img img { transform: scale(1.1); }
        .drop-img::after {
            content: "View Drop";
            position: absolute;
            bottom: -40px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--brand);
            color: #fff;
            padding: 8px 16px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            opacity: 0;
            transition: all .3s;
            z-index: 2;
            pointer-events: none;
        }
        .drop-card:hover .drop-img::after { bottom: 20px; opacity: 1; }
        .drop-img::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(3, 40, 159, 0);
            transition: all .3s;
            z-index: 1;
            pointer-events: none;
        }
        .drop-card:hover .drop-img::before { background: rgba(3, 40, 159, .28); }
        .drop-body { padding: 16px; }
