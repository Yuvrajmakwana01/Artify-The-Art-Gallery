<script>
    (function () {
        var body = document.body;
        var loader = document.getElementById('pageLoader');
        var loaderMinTime = 4800;
        var loaderExitTime = 900;
        var loaderCanClose = false;
        var pageLoaded = document.readyState === 'complete';
        var loaderDone = false;
        var nav = document.getElementById('floatingNav');
        var trigger = document.getElementById('floatingNavTrigger');
        var panel = document.getElementById('floatingNavPanel');
        var links = Array.prototype.slice.call(document.querySelectorAll('[data-nav-link]'));
        var defaultLink = links[0];
        var closeTimer = null;
        var isOpen = false;

        function finishLoader() {
            if (loaderDone || !loaderCanClose || !pageLoaded) {
                return;
            }

            loaderDone = true;
            body.classList.add('loader-leaving');

            window.setTimeout(function () {
                body.classList.remove('is-loading', 'loader-leaving');
                body.classList.add('loader-complete');

                if (loader) {
                    loader.setAttribute('aria-hidden', 'true');
                }
            }, loaderExitTime);
        }

        window.setTimeout(function () {
            loaderCanClose = true;
            finishLoader();
        }, loaderMinTime);

        window.addEventListener('load', function () {
            pageLoaded = true;
            finishLoader();
        });

        function clearCloseTimer() {
            if (closeTimer) {
                window.clearTimeout(closeTimer);
                closeTimer = null;
            }
        }

        function setActive(link) {
            links.forEach(function (item) {
                item.classList.toggle('is-active', item === link);
            });
        }

        function openNav() {
            clearCloseTimer();
            if (isOpen) {
                return;
            }

            isOpen = true;
            nav.classList.add('is-open');
            trigger.setAttribute('aria-expanded', 'true');
        }

        function closeNav() {
            clearCloseTimer();
            if (!isOpen) {
                return;
            }

            isOpen = false;
            nav.classList.remove('is-open');
            trigger.setAttribute('aria-expanded', 'false');
            setActive(defaultLink);
        }

        function scheduleClose() {
            clearCloseTimer();
            closeTimer = window.setTimeout(closeNav, 120);
        }

        trigger.addEventListener('mouseenter', openNav);
        trigger.addEventListener('focus', openNav);
        trigger.addEventListener('click', function () {
            if (isOpen) {
                closeNav();
            } else {
                openNav();
            }
        });

        nav.addEventListener('mouseenter', clearCloseTimer);
        nav.addEventListener('mouseleave', scheduleClose);
        panel.addEventListener('focusin', openNav);

        nav.addEventListener('focusout', function (event) {
            if (!nav.contains(event.relatedTarget)) {
                scheduleClose();
            }
        });

        links.forEach(function (link) {
            link.addEventListener('mouseenter', function () {
                setActive(link);
            });

            link.addEventListener('focus', function () {
                setActive(link);
                openNav();
            });

            link.addEventListener('click', closeNav);
        });

        document.addEventListener('click', function (event) {
            if (!nav.contains(event.target)) {
                closeNav();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeNav();
            }
        });
    })();

    document.addEventListener("DOMContentLoaded", function() {
        const mount = document.getElementById('hero-canvas-container');
        if (!mount || typeof THREE === 'undefined') return;

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(mount.clientWidth, mount.clientHeight);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        renderer.toneMapping = 4; // THREE.ACESFilmicToneMapping
        renderer.toneMappingExposure = 1.1;
        mount.appendChild(renderer.domElement);

        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0xDEE6E9);
        scene.fog = new THREE.Fog(0xDEE6E9, 22, 42);

        const camera = new THREE.PerspectiveCamera(58, mount.clientWidth / mount.clientHeight, 0.1, 60);
        camera.position.set(0, 1.65, 2);

        const loader = new THREE.TextureLoader();
        const loadTex = function(url) {
            const t = loader.load(url);
            t.encoding = 3001; // THREE.sRGBEncoding
            return t;
        };

        const ART = [
            'https://images.unsplash.com/photo-1615184697985-c9bde1b07da7?w=600&q=80',
            'https://images.unsplash.com/photo-1547891654-e66ed7ebb968?w=600&q=80',
            'https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=600&q=80',
            'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=600&q=80',
            'https://images.unsplash.com/photo-1501862700950-18382cd41497?w=600&q=80',
            'https://images.unsplash.com/photo-1577083552431-6e5fd01988ec?w=600&q=80'
        ];
        const STOP_Z = [-3, -8, -14, -20, -5, -11, -17, -23];

        const wallMat  = new THREE.MeshStandardMaterial({ color: 0xDEE6E9, roughness: 0.95, metalness: 0.0 });
        const floorMat = new THREE.MeshStandardMaterial({ color: 0xcddce1, roughness: 0.6,  metalness: 0.05 });
        const ceilMat  = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 1.0 });
        const goldMat  = new THREE.MeshStandardMaterial({ color: 0xEDA312, roughness: 0.25, metalness: 0.85 });

        const RW = 10, RH = 5, RD = 44;

        const floor = new THREE.Mesh(new THREE.PlaneGeometry(RW, RD), floorMat);
        floor.rotation.x = -Math.PI / 2;
        floor.position.set(0, 0, -RD / 2 + 4);
        floor.receiveShadow = true;
        scene.add(floor);

        const ceil = new THREE.Mesh(new THREE.PlaneGeometry(RW, RD), ceilMat);
        ceil.rotation.x = Math.PI / 2;
        ceil.position.set(0, RH, -RD / 2 + 4);
        scene.add(ceil);

        const lWall = new THREE.Mesh(new THREE.PlaneGeometry(RD, RH), wallMat);
        lWall.rotation.y = Math.PI / 2;
        lWall.position.set(-RW / 2, RH / 2, -RD / 2 + 4);
        lWall.receiveShadow = true;
        scene.add(lWall);

        const rWall = new THREE.Mesh(new THREE.PlaneGeometry(RD, RH), wallMat);
        rWall.rotation.y = -Math.PI / 2;
        rWall.position.set(RW / 2, RH / 2, -RD / 2 + 4);
        rWall.receiveShadow = true;
        scene.add(rWall);

        const bWall = new THREE.Mesh(new THREE.PlaneGeometry(RW, RH), wallMat);
        bWall.position.set(0, RH / 2, -RD + 4);
        scene.add(bWall);

        const baseMat = new THREE.MeshStandardMaterial({ color: 0xc5d6dc, roughness: 0.9 });
        const moldMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.8 });
        [-RW / 2 + 0.06, RW / 2 - 0.06].forEach(function(x) {
            const b = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.18, RD), baseMat);
            b.position.set(x, 0.09, -RD / 2 + 4);
            scene.add(b);
            const m = new THREE.Mesh(new THREE.BoxGeometry(0.14, 0.14, RD), moldMat);
            m.position.set(x, RH - 0.07, -RD / 2 + 4);
            scene.add(m);
        });

        const paintings = [
            { x: -RW / 2 + 0.06, y: 2.3, z: STOP_Z[0], ry:  Math.PI / 2, w: 1.8, h: 2.4, art: 0 },
            { x: -RW / 2 + 0.06, y: 2.1, z: STOP_Z[1], ry:  Math.PI / 2, w: 2.4, h: 1.8, art: 1 },
            { x: -RW / 2 + 0.06, y: 2.3, z: STOP_Z[2], ry:  Math.PI / 2, w: 1.6, h: 2.2, art: 2 },
            { x: -RW / 2 + 0.06, y: 2.1, z: STOP_Z[3], ry:  Math.PI / 2, w: 2.2, h: 1.8, art: 3 },
            { x:  RW / 2 - 0.06, y: 2.3, z: STOP_Z[4], ry: -Math.PI / 2, w: 2.0, h: 2.6, art: 4 },
            { x:  RW / 2 - 0.06, y: 2.1, z: STOP_Z[5], ry: -Math.PI / 2, w: 2.6, h: 1.9, art: 5 },
            { x:  RW / 2 - 0.06, y: 2.3, z: STOP_Z[6], ry: -Math.PI / 2, w: 1.8, h: 2.3, art: 0 },
            { x:  RW / 2 - 0.06, y: 2.1, z: STOP_Z[7], ry: -Math.PI / 2, w: 2.4, h: 2.0, art: 3 },
        ];

        paintings.forEach(function(p) {
            const grp = new THREE.Group();
            const FT = 0.12, FD = 0.08;

            const canvas = new THREE.Mesh(
                new THREE.PlaneGeometry(p.w, p.h),
                new THREE.MeshStandardMaterial({ map: loadTex(ART[p.art]), roughness: 0.9 })
            );
            canvas.position.z = FD / 2 + 0.002;
            grp.add(canvas);

            [
                { w: p.w + FT * 2, h: FT,  x: 0,                    y:  p.h / 2 + FT / 2 },
                { w: p.w + FT * 2, h: FT,  x: 0,                    y: -(p.h / 2 + FT / 2) },
                { w: FT,           h: p.h, x: -(p.w / 2 + FT / 2),  y: 0 },
                { w: FT,           h: p.h, x:  p.w / 2 + FT / 2,    y: 0 },
            ].forEach(function(barDef) {
                const bar = new THREE.Mesh(new THREE.BoxGeometry(barDef.w, barDef.h, FD), goldMat);
                bar.position.set(barDef.x, barDef.y, 0);
                bar.castShadow = true;
                grp.add(bar);
            });

            grp.position.set(p.x, p.y, p.z);
            grp.rotation.y = p.ry;
            scene.add(grp);

            const spot = new THREE.SpotLight(0xfff5e6, 4, 9, Math.PI / 6, 0.5, 1.5);
            const isLeft = p.ry > 0;
            spot.position.set(p.x + (isLeft ? 1.2 : -1.2), RH - 0.4, p.z);
            spot.target.position.set(p.x, p.y, p.z);
            spot.castShadow = false;
            scene.add(spot);
            scene.add(spot.target);
        });

        const archMat = new THREE.MeshStandardMaterial({ color: 0xc5d6dc, roughness: 0.8 });
        const doorFrame = new THREE.Mesh(new THREE.BoxGeometry(2.2, 3.2, 0.2), archMat);
        doorFrame.position.set(0, 1.6, -RD + 4.3);
        scene.add(doorFrame);
        
        const doorOpen = new THREE.Mesh(
            new THREE.PlaneGeometry(1.6, 2.8),
            new THREE.MeshStandardMaterial({ color: 0x6B9BE6, roughness: 1.0 })
        );
        doorOpen.position.set(0, 1.5, -RD + 4.18);
        scene.add(doorOpen);

        const benchWood  = new THREE.MeshStandardMaterial({ color: 0x03289F, roughness: 0.7 });
        const benchMetal = new THREE.MeshStandardMaterial({ color: 0xEDA312, roughness: 0.3, metalness: 0.8 });
        [{ z: -9 }, { z: -19 }].forEach(function(bDef) {
            const seat = new THREE.Mesh(new THREE.BoxGeometry(2.0, 0.07, 0.4), benchWood);
            seat.position.set(0, 0.42, bDef.z);
            seat.castShadow = true;
            scene.add(seat);
            [[-0.85, bDef.z - 0.13], [0.85, bDef.z - 0.13], [-0.85, bDef.z + 0.13], [0.85, bDef.z + 0.13]].forEach(function(lDef) {
                const leg = new THREE.Mesh(new THREE.BoxGeometry(0.05, 0.42, 0.05), benchMetal);
                leg.position.set(lDef[0], 0.21, lDef[1]);
                scene.add(leg);
            });
        });

        const trackMat = new THREE.MeshStandardMaterial({ color: 0xd0d0d0, roughness: 0.4, metalness: 0.6 });
        for (let z = -2; z > -RD + 4; z -= 5) {
            const track = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.06, 1.2), trackMat);
            track.position.set(0, RH - 0.05, z);
            scene.add(track);
            const bulb = new THREE.Mesh(
                new THREE.SphereGeometry(0.08, 8, 8),
                new THREE.MeshStandardMaterial({ color: 0xfff5e6, emissive: 0xfff5e6, emissiveIntensity: 1.5 })
            );
            bulb.position.set(0, RH - 0.18, z);
            scene.add(bulb);
            const pt = new THREE.PointLight(0xfff5e6, 2.2, 10, 2);
            pt.position.set(0, RH - 0.2, z);
            scene.add(pt);
        }

        scene.add(new THREE.AmbientLight(0xffffff, 1.2));

        const onResize = function() {
            camera.aspect = mount.clientWidth / mount.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(mount.clientWidth, mount.clientHeight);
        };
        window.addEventListener("resize", onResize);

        const clock = new THREE.Clock();
        const heroState = {
            currentStop: 0,
            targetZ: STOP_Z[0],
            camZ: 2,
            isAuto: true,
            autoT: 0
        };
        const heroDots = Array.prototype.slice.call(document.querySelectorAll('[data-hero-dot]'));

        const setActiveHeroDot = function(index) {
            heroDots.forEach(function(dot, dotIndex) {
                dot.classList.toggle('is-active', dotIndex === index);
            });
        };

        const goToHeroSlide = function(index) {
            const clamped = (index + STOP_Z.length) % STOP_Z.length;
            heroState.currentStop = clamped;
            heroState.targetZ = STOP_Z[clamped];
            heroState.isAuto = false;
            setActiveHeroDot(clamped);
        };

        const animate = function() {
            requestAnimationFrame(animate);
            const delta = clock.getDelta();
            const t = clock.elapsedTime;

            if (heroState.isAuto) {
                heroState.autoT += delta;
                const loop = (heroState.autoT % 28) / 28;
                const autoStop = Math.floor(loop * STOP_Z.length) % STOP_Z.length;
                if (autoStop !== heroState.currentStop) {
                    heroState.currentStop = autoStop;
                    setActiveHeroDot(autoStop);
                }
                heroState.camZ = 2 - loop * 18;
            } else {
                heroState.camZ += (heroState.targetZ - heroState.camZ) * Math.min(delta * 3.5, 1);
            }

            camera.position.set(
                Math.sin(t * 0.08) * 0.25,
                1.65 + Math.sin(t * 0.18) * 0.04,
                heroState.camZ
            );
            camera.lookAt(
                Math.sin(t * 0.06) * 0.15,
                1.55,
                heroState.camZ - 10
            );

            renderer.render(scene, camera);
        };
        animate();
        setActiveHeroDot(heroState.currentStop);

        const btnPrev = document.getElementById('hero-prev');
        const btnNext = document.getElementById('hero-next');
        if (btnPrev) {
            btnPrev.addEventListener('click', function() {
                goToHeroSlide(heroState.currentStop - 1);
            });
        }
        if (btnNext) {
            btnNext.addEventListener('click', function() {
                goToHeroSlide(heroState.currentStop + 1);
            });
        }
        heroDots.forEach(function(dot) {
            dot.addEventListener('click', function() {
                const index = parseInt(dot.getAttribute('data-hero-dot'), 10);
                if (!Number.isNaN(index)) {
                    goToHeroSlide(index);
                }
            });
        });
    });
</script>

</body>
</html>
