<section class="page-sec" id="explore">
    <div class="sec-header">
        <div>
            <div class="sec-eyebrow">Trending</div>
            <h2 class="sec-title">Drops moving fast</h2>
        </div>
        <a href="#" class="sec-link">View market -></a>
    </div>
    <div class="drops-grid">
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        const API_BASE = 'http://localhost:5183';

        function imageUrl(path) {
          if (!path) return 'https://images.unsplash.com/photo-1547891654-e66ed7ebb968?w=600&q=80';
          if (/^https?:\/\//i.test(path)) return path;
          return API_BASE.replace(/\/+$/, '') + '/' + path.replace(/^\/+/, '');
        }

        function escapeHtml(str) {
          return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function artistInitials(name) {
          return String(name || 'A')
            .split(/\s+/)
            .filter(Boolean)
            .slice(0, 2)
            .map(function(part) { return part.charAt(0).toUpperCase(); })
            .join('') || 'A';
        }

        function artistHandle(name) {
          return '@@' + String(name || 'artist')
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '');
        }

        function renderArtists(artworks) {
          const grid = document.querySelector(".artists-grid");
          if (!grid) return;

          const grouped = new Map();

          artworks.forEach(function(a) {
            const artistId = parseInt(a.artistId || a.c_artist_id || 0, 10) || 0;
            const artistName = a.artistName || a.c_artist_name || 'Unknown Artist';
            const key = artistId > 0 ? 'artist:' + artistId : 'artist:' + artistName.toLowerCase();

            if (!grouped.has(key)) {
              grouped.set(key, {
                artistId: artistId,
                artistName: artistName,
                artworks: [],
                totalLikes: 0,
                totalSales: 0
              });
            }

            const group = grouped.get(key);
            group.artworks.push(a);
            group.totalLikes += parseInt(a.likesCount || a.c_likes_count || 0, 10) || 0;
            group.totalSales += parseInt(a.sellCount || a.c_sell_count || 0, 10) || 0;
          });

          const artists = Array.from(grouped.values())
            .map(function(group) {
              group.artworks.sort(function(a, b) {
                const sellA = parseInt(a.sellCount || a.c_sell_count || 0, 10) || 0;
                const sellB = parseInt(b.sellCount || b.c_sell_count || 0, 10) || 0;
                if (sellB !== sellA) return sellB - sellA;

                const likeA = parseInt(a.likesCount || a.c_likes_count || 0, 10) || 0;
                const likeB = parseInt(b.likesCount || b.c_likes_count || 0, 10) || 0;
                if (likeB !== likeA) return likeB - likeA;

                const dateA = new Date(a.createdAt || a.c_created_at || 0).getTime() || 0;
                const dateB = new Date(b.createdAt || b.c_created_at || 0).getTime() || 0;
                return dateB - dateA;
              });

              return group;
            })
            .sort(function(a, b) {
              if (b.artworks.length !== a.artworks.length) return b.artworks.length - a.artworks.length;
              if (b.totalSales !== a.totalSales) return b.totalSales - a.totalSales;
              return b.totalLikes - a.totalLikes;
            })
            .slice(0, 4);

          grid.innerHTML = '';

          artists.forEach(function(group) {
            grid.innerHTML += `
                <div class="artist-card">
                    <div class="artist-avatar">${escapeHtml(artistInitials(group.artistName))}</div>
                    <h3 class="artist-name">${escapeHtml(group.artistName)}</h3>
                    <p class="artist-handle">${escapeHtml(artistHandle(group.artistName))}</p>
                    <div class="artist-stats">
                        <div><div class="artist-stat-val">${group.artworks.length}</div><div class="artist-stat-label">Works</div></div>
                    </div>
                </div>`;
          });
        }

        function renderTrending(artworks) {
          const grid = document.querySelector(".drops-grid");
          if (!grid) return;

          const sorted = artworks.slice().sort(function(a, b) {
            const sellA = a.sellCount || a.c_sell_count || 0;
            const sellB = b.sellCount || b.c_sell_count || 0;
            if (sellB !== sellA) return sellB - sellA;

            const likeA = a.likesCount || a.c_likes_count || 0;
            const likeB = b.likesCount || b.c_likes_count || 0;
            return likeB - likeA;
          });

          const topItems = sorted.slice(0, 8);
          grid.innerHTML = '';

          topItems.forEach(function(a) {
            const artist = a.artistName || a.c_artist_name || 'Unknown Artist';
            const price = parseFloat(a.price || a.c_price || 0);
            const img = imageUrl(a.previewPath || a.originalPath || a.c_preview_path || a.c_original_path);
            const priceStr = price > 0 ? '₹' + price.toLocaleString('en-IN') : 'Price on request';

            grid.innerHTML += `
                <div class="drop-card">
                    <div class="drop-img"><img src="${img}" alt="${escapeHtml(artist)}" loading="lazy" /></div>
                    <div class="drop-body">
                        <div class="drop-title">${escapeHtml(artist)}</div>
                        <div class="drop-price-row">
                            <span class="drop-price-label">Price</span>
                            <span class="drop-price">${escapeHtml(priceStr)}</span>
                        </div>
                    </div>
                </div>`;
          });
        }

        async function loadTrending() {
          try {
            const token = document.cookie.split('; ').find(function(r) { return r.startsWith('token='); });
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = 'Bearer ' + token.split('=')[1];

            const res = await fetch(API_BASE.replace(/\/+$/, '') + '/api/artwork', { headers: headers });
            if (!res.ok) throw new Error('API responded with ' + res.status);

            const json = await res.json();
            const artworks = Array.isArray(json)
              ? json
              : (json.data && Array.isArray(json.data)) ? json.data : [];

            renderArtists(artworks);
            renderTrending(artworks);
          } catch (err) {
            console.error('Failed to load trending artworks:', err);
          }
        }

        loadTrending();
      });
    </script>
</section>

