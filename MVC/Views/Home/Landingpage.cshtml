@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Artify – Digital Art Marketplace";
    Layout = null;
    var isUserLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("JWToken"));
    var loginUrl = Url.Action("UserLogin", "Auth") ?? "/Auth/UserLogin";
    var exploreArtUrl = Url.Action("ExploreArt", "Buyer") ?? "/Buyer/ExploreArt";
    var artworkDetailUrlTemplate = Url.Action("ArtworkDetail", "Buyer", new { id = "__ARTWORK_ID__" }) ?? "/Buyer/ArtworkDetail/__ARTWORK_ID__";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;0,700;1,300;1,600&family=Plus+Jakarta+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}

:root{
  --cream:#faf7f2;
  --warm:#f2ebe0;
  --warm2:#e8ddd0;
  --ink:#1c1711;
  --ink2:#3d3328;
  --muted:#8a7d6e;
  --border:#e0d6c8;
  --border2:#cfc3b2;
  --gold:#b8761a;
  --gold2:#d4943a;
  --gold3:#f0c060;
  --gold-light:#fef3dc;
  --coral:#c2442a;
  --teal:#1a6b6b;
  --shadow:rgba(28,23,17,0.08);
  --shadow2:rgba(28,23,17,0.15);
  --shadow3:rgba(28,23,17,0.25);
}

body{
  background:var(--cream);
  color:var(--ink);
  font-family:'Plus Jakarta Sans',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  cursor:none;
}

/* ── Custom cursor ── */
#cursor{
  position:fixed;width:10px;height:10px;
  background:var(--gold);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.12s,background 0.2s;
}
#cursor-ring{
  position:fixed;width:38px;height:38px;
  border:1.5px solid rgba(184,118,26,0.5);
  border-radius:50%;pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:width 0.3s,height 0.3s,border-color 0.3s;
}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.2rem 4vw;
  transition:all 0.4s;
}
nav.scrolled{
  background:rgba(250,247,242,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  box-shadow:0 4px 30px var(--shadow);
}
.nav-logo{
  font-family:'Cormorant Garamond',serif;
  font-size:1.9rem;font-weight:700;
  color:var(--ink);text-decoration:none;
  letter-spacing:-0.5px;
}
.nav-logo em{color:var(--gold);font-style:normal}
.nav-links{display:flex;align-items:center;gap:2.5rem}
.nav-links a{
  font-size:0.8rem;font-weight:400;
  color:var(--muted);text-decoration:none;
  letter-spacing:0.05em;text-transform:uppercase;
  transition:color 0.2s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;
  height:1px;background:var(--gold);transform:scaleX(0);
  transition:transform 0.25s;transform-origin:left;
}
.nav-links a:hover{color:var(--ink)}
.nav-links a:hover::after{transform:scaleX(1)}
.btn-nav{
  padding:0.55rem 1.4rem;border-radius:5px;
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:0.8rem;font-weight:400;
  text-decoration:none;transition:all 0.2s;
  letter-spacing:0.03em;
}
.btn-nav-ghost{
  border:1px solid var(--border2);color:var(--ink);background:transparent;
}
.btn-nav-ghost:hover{border-color:var(--gold);color:var(--gold)}
.btn-nav-solid{
  background:var(--ink);color:var(--cream);border:1px solid var(--ink);
}
.btn-nav-solid:hover{background:var(--gold);border-color:var(--gold)}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  padding:7rem 4vw 4rem;
}
.hero-mesh{
  position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden;
}
.float-cards{
  position:absolute;inset:0;z-index:1;
  perspective:1000px;pointer-events:none;
}
.fcard{
  position:absolute;
  border-radius:14px;
  border:1px solid var(--border);
  box-shadow:0 20px 60px var(--shadow2),0 4px 16px var(--shadow);
  overflow:hidden;
  transform-style:preserve-3d;
  animation:floatCard 8s ease-in-out infinite;
  background:white;
}
.fcard-img{
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:center;
  font-size:3.5rem;position:relative;
  overflow:hidden;
}
.fcard-img img{
  width:100%;height:100%;object-fit:cover;position:absolute;inset:0;
}
.fcard-img .fcard-emoji{
  position:relative;z-index:1;font-size:3.5rem;
}
.fcard-label{
  position:absolute;bottom:0;left:0;right:0;
  padding:0.6rem 0.8rem;
  background:rgba(250,247,242,0.95);
  backdrop-filter:blur(6px);
  border-top:1px solid var(--border);
}
.fcard-label-title{font-size:0.72rem;font-weight:500;color:var(--ink);margin-bottom:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fcard-label-price{font-size:0.68rem;color:var(--gold);font-weight:500}

.fcard:nth-child(1){width:160px;top:15%;left:5%;animation-delay:-1s;animation-duration:7s;}
.fcard:nth-child(2){width:140px;top:55%;left:2%;animation-delay:-3s;animation-duration:9s;}
.fcard:nth-child(3){width:170px;top:10%;right:6%;animation-delay:-2s;animation-duration:8s;}
.fcard:nth-child(4){width:150px;top:60%;right:3%;animation-delay:-4s;animation-duration:7.5s;}
.fcard:nth-child(5){width:130px;top:78%;left:20%;animation-delay:-5s;animation-duration:10s;}
.fcard:nth-child(6){width:145px;top:75%;right:20%;animation-delay:-2.5s;animation-duration:8.5s;}

@@keyframes floatCard{
  0%,100%{transform:translateY(0) rotateX(2deg) rotateY(-2deg)}
  25%{transform:translateY(-16px) rotateX(-1deg) rotateY(3deg)}
  50%{transform:translateY(-8px) rotateX(3deg) rotateY(-1deg)}
  75%{transform:translateY(-20px) rotateX(-2deg) rotateY(2deg)}
}

.hero-content{
  position:relative;z-index:10;
  text-align:center;max-width:800px;
}
.hero-pill{
  display:inline-flex;align-items:center;gap:8px;
  padding:0.4rem 1.1rem;
  background:var(--gold-light);
  border:1px solid rgba(184,118,26,0.25);
  border-radius:20px;
  font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--gold);font-weight:500;
  margin-bottom:2rem;
  animation:fadeUp 0.8s ease 0.2s both;
}
.hero-pill-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--gold);
  animation:pulse2 2s ease-in-out infinite;
}
@@keyframes pulse2{0%,100%{transform:scale(1)}50%{transform:scale(1.5)}}

.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,9vw,8.5rem);
  font-weight:700;line-height:0.9;
  letter-spacing:-2px;
  animation:fadeUp 0.9s ease 0.35s both;
  color:var(--ink);
}
.hero h1 .h1-italic{display:block;font-style:italic;font-weight:300;color:var(--gold);}
.hero h1 .h1-outline{display:block;color:transparent;-webkit-text-stroke:1.5px var(--ink2);}

.hero-desc{
  font-size:1rem;font-weight:300;
  color:var(--muted);line-height:1.85;
  max-width:480px;margin:2rem auto 3rem;
  animation:fadeUp 0.9s ease 0.5s both;
}
.hero-btns{
  display:flex;align-items:center;justify-content:center;
  gap:14px;flex-wrap:wrap;
  animation:fadeUp 0.9s ease 0.65s both;
}
.btn-primary{
  padding:0.9rem 2.6rem;
  background:var(--ink);color:var(--cream);
  border:none;border-radius:6px;
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:0.9rem;font-weight:500;
  cursor:pointer;text-decoration:none;
  letter-spacing:0.03em;
  transition:all 0.25s;
  box-shadow:0 8px 24px var(--shadow2);
  position:relative;overflow:hidden;
}
.btn-primary::before{
  content:'';position:absolute;inset:0;background:var(--gold);
  transform:translateY(100%);transition:transform 0.35s cubic-bezier(0.22,1,0.36,1);
}
.btn-primary:hover::before{transform:translateY(0)}
.btn-primary span{position:relative;z-index:1}
.btn-primary:hover{box-shadow:0 12px 32px rgba(184,118,26,0.35)}

.btn-ghost{
  padding:0.9rem 2.2rem;
  background:transparent;
  border:1.5px solid var(--border2);
  border-radius:6px;
  color:var(--ink);font-size:0.9rem;font-weight:400;
  cursor:pointer;text-decoration:none;
  letter-spacing:0.03em;
  transition:all 0.25s;
}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-light)}

.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;
  transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--muted);
  animation:fadeUp 1s ease 1s both;
}
.scroll-mouse{
  width:22px;height:34px;
  border:1.5px solid var(--border2);
  border-radius:11px;
  position:relative;display:flex;
  justify-content:center;padding-top:5px;
}
.scroll-mouse::after{
  content:'';width:3px;height:6px;
  background:var(--gold);border-radius:2px;
  animation:scrollBob 2s ease-in-out infinite;
}
@@keyframes scrollBob{0%,100%{transform:translateY(0);opacity:1}50%{transform:translateY(8px);opacity:0.3}}

/* ── MARQUEE ── */
.marquee-section{
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  background:white;padding:0.9rem 0;
  overflow:hidden;
}
.marquee-track{
  display:flex;gap:0;width:max-content;
  animation:marquee 22s linear infinite;
}
@@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.m-item{
  display:flex;align-items:center;gap:10px;
  padding:0 2rem;
  font-size:0.78rem;letter-spacing:0.07em;text-transform:uppercase;
  color:var(--muted);white-space:nowrap;
  border-right:1px solid var(--border);
}
.m-gem{color:var(--gold);font-size:0.6rem}

/* ── SECTION BASE ── */
section{position:relative;padding:7rem 6vw}
.section-eyebrow{
  font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;
  color:var(--gold);font-weight:500;
  display:flex;align-items:center;gap:10px;margin-bottom:1.2rem;
}
.section-eyebrow::before{content:'';width:28px;height:1.5px;background:var(--gold)}
.section-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(2.2rem,4.5vw,4rem);
  font-weight:700;line-height:1.05;
  letter-spacing:-1px;color:var(--ink);
  margin-bottom:1rem;
}
.section-title em{font-style:italic;font-weight:300;color:var(--gold)}

/* ── STATS ── */
.stats-row{
  display:grid;grid-template-columns:repeat(4,1fr);
  background:var(--ink);
}
.sstat{
  padding:3.5rem 2.5rem;text-align:center;
  border-right:1px solid rgba(255,255,255,0.07);
  position:relative;overflow:hidden;
}
.sstat::before{
  content:'';position:absolute;
  top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold),var(--gold3));
  transform:scaleX(0);transition:transform 0.4s;
}
.sstat:hover::before{transform:scaleX(1)}
.sstat-num{
  font-family:'Cormorant Garamond',serif;
  font-size:3.5rem;font-weight:700;
  color:var(--gold3);line-height:1;
  margin-bottom:0.5rem;
}
.sstat-lbl{font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.4)}

/* ── HOW IT WORKS ── */
.how-section{background:var(--warm)}
.how-steps{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:0;margin-top:4rem;
  border:1px solid var(--border);border-radius:16px;
  overflow:hidden;
  box-shadow:0 20px 60px var(--shadow);
}
.how-step{
  padding:3rem 2.5rem;background:white;
  border-right:1px solid var(--border);
  position:relative;overflow:hidden;
  transition:transform 0.35s,box-shadow 0.35s;
}
.how-step:last-child{border-right:none}
.how-step::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,var(--gold-light),transparent);
  opacity:0;transition:opacity 0.35s;
}
.how-step:hover{transform:translateY(-4px);box-shadow:0 24px 60px var(--shadow2)}
.how-step:hover::after{opacity:1}
.step-num{
  font-family:'Cormorant Garamond',serif;
  font-size:5rem;font-weight:700;
  color:rgba(184,118,26,0.1);
  line-height:1;margin-bottom:1.5rem;
  transition:color 0.3s;
  
}
.how-step:hover .step-num{color:rgba(184,118,26,0.2)}
.step-icon{
  width:52px;height:52px;border-radius:12px;
  background:var(--gold-light);
  border:1px solid rgba(184,118,26,0.2);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1.5rem;
  transition:background 0.3s,transform 0.3s;
  position:relative;z-index:1;
}
.how-step:hover .step-icon{background:var(--gold);transform:rotate(6deg) scale(1.05)}
.step-icon svg{width:22px;height:22px;transition:stroke 0.3s}
.how-step:hover .step-icon svg{stroke:white}
.step-title{font-size:1.1rem;font-weight:600;color:var(--ink);margin-bottom:0.75rem;position:relative;z-index:1}
.step-desc{font-size:0.85rem;line-height:1.8;color:var(--muted);position:relative;z-index:1}

/* ── GALLERY ── */
.gallery-section{background:var(--cream)}
.gallery-grid{
  display:grid;
  grid-template-columns:repeat(12,1fr);
  grid-template-rows:auto auto;
  gap:16px;margin-top:4rem;
  min-height:300px;
}
.gallery-loading{
  grid-column: span 12;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:1rem;padding:4rem 0;color:var(--muted);
}
.gallery-spinner{
  width:40px;height:40px;border-radius:50%;
  border:2px solid var(--border2);
  border-top-color:var(--gold);
  animation:spin 0.8s linear infinite;
}
@@keyframes spin{to{transform:rotate(360deg)}}
.gallery-error{
  grid-column: span 12;
  text-align:center;padding:4rem 0;
  font-size:0.9rem;color:var(--coral);
}
.gcard{
  border-radius:12px;overflow:hidden;
  position:relative;
  box-shadow:0 8px 30px var(--shadow);
  cursor:pointer;
  transform-style:preserve-3d;
  transition:transform 0.5s cubic-bezier(0.23,1,0.32,1),box-shadow 0.5s;
  background:white;
}
.gcard:hover{
  transform:translateY(-10px) rotateX(3deg) scale(1.02);
  box-shadow:0 30px 70px var(--shadow3);
}
.gcard:nth-child(1){grid-column:span 5;grid-row:span 2}
.gcard:nth-child(2){grid-column:span 4}
.gcard:nth-child(3){grid-column:span 3}
.gcard:nth-child(4){grid-column:span 3}
.gcard:nth-child(5){grid-column:span 4}
.gcard:nth-child(n+6){grid-column:span 4}
.gcard-art{
  width:100%;padding-bottom:100%;position:relative;overflow:hidden;
}
.gcard:nth-child(1) .gcard-art{padding-bottom:130%}
.gcard-art-inner{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  transition:transform 0.6s cubic-bezier(0.23,1,0.32,1);
  overflow:hidden;
}
.gcard-art-inner img{
  width:100%;height:100%;object-fit:cover;
  transition:transform 0.6s cubic-bezier(0.23,1,0.32,1);
}
.gcard:hover .gcard-art-inner img{transform:scale(1.08)}
.gcard-art-inner .art-placeholder{
  width:100%;height:100%;display:flex;align-items:center;justify-content:center;
  font-size:4rem;
}
.gcard:hover .gcard-art-inner .art-placeholder{transform:scale(1.08)}
.gcard-info{
  padding:1rem 1.1rem;
  background:white;
  border-top:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:center;
}
.gcard-title{font-size:0.82rem;font-weight:500;color:var(--ink)}
.gcard-sub{font-size:0.7rem;color:var(--muted);margin-top:2px}
.gcard-price{font-size:0.82rem;font-weight:600;color:var(--gold);white-space:nowrap;}
.gcard-badge{
  position:absolute;top:12px;left:12px;z-index:2;
  background:rgba(250,247,242,0.92);
  backdrop-filter:blur(6px);
  border:1px solid var(--border);
  border-radius:4px;
  padding:3px 10px;
  font-size:0.65rem;font-weight:500;
  letter-spacing:0.06em;text-transform:uppercase;
  color:var(--gold);
}
.gcard-like{
  position:absolute;top:12px;right:12px;z-index:2;
  width:32px;height:32px;border-radius:50%;
  background:rgba(250,247,242,0.9);
  backdrop-filter:blur(6px);
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:0.9rem;
  transition:transform 0.2s,background 0.2s;
}
.gcard:hover .gcard-like{transform:scale(1.15);background:white}

/* artwork placeholder gradients */
.ab0{background:linear-gradient(145deg,#1a0533,#6b0f8a,#c840e8)}
.ab1{background:linear-gradient(145deg,#051a33,#0f4b8a,#2196F3)}
.ab2{background:linear-gradient(145deg,#1a3305,#3d8a0f,#76c840)}
.ab3{background:linear-gradient(145deg,#331a05,#8a4a0f,#F59340)}
.ab4{background:linear-gradient(145deg,#1a0505,#8a0f0f,#E53935)}
.ab5{background:linear-gradient(145deg,#1a1a33,#4a3d8a,#9b59b6)}
.ab6{background:linear-gradient(145deg,#0d1a33,#1a3d5a,#16a085)}
.ab7{background:linear-gradient(145deg,#1a0d0d,#5a1a3d,#c0392b)}

/* ── ROLES ── */
.roles-section{background:white}
.roles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:4rem;}
.rcard{
  padding:2.5rem 2.2rem;
  border:1px solid var(--border);
  border-radius:14px;background:var(--cream);
  position:relative;overflow:hidden;
  transition:all 0.4s cubic-bezier(0.23,1,0.32,1);
  transform-style:preserve-3d;
}
.rcard:hover{
  transform:translateY(-8px) rotateX(3deg);
  border-color:var(--gold2);
  box-shadow:0 24px 60px var(--shadow2);
  background:white;
}
.rcard-shine{
  position:absolute;inset:0;
  background:radial-gradient(circle at var(--rx,50%) var(--ry,50%),rgba(184,118,26,0.07),transparent 65%);
  pointer-events:none;opacity:0;transition:opacity 0.3s;
}
.rcard:hover .rcard-shine{opacity:1}
.rcard-icon{
  width:56px;height:56px;border-radius:14px;
  background:var(--gold-light);
  border:1px solid rgba(184,118,26,0.2);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1.4rem;
  transition:transform 0.3s,background 0.3s;
}
.rcard:hover .rcard-icon{background:var(--gold);transform:rotate(-6deg) scale(1.1)}
.rcard-icon svg{width:26px;height:26px;transition:stroke 0.3s}
.rcard:hover .rcard-icon svg{stroke:white}
.rcard-title{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:700;color:var(--ink);margin-bottom:0.7rem;}
.rcard-desc{font-size:0.83rem;color:var(--muted);line-height:1.8;margin-bottom:1.5rem}
.rcard-list{list-style:none;display:flex;flex-direction:column;gap:8px}
.rcard-list li{display:flex;align-items:center;gap:10px;font-size:0.8rem;color:var(--muted);}
.rcard-list li::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;}
.rcard-cta{
  display:inline-block;margin-top:1.5rem;
  font-size:0.8rem;font-weight:500;
  color:var(--gold);text-decoration:none;
  letter-spacing:0.03em;
  border-bottom:1px solid rgba(184,118,26,0.3);
  padding-bottom:2px;transition:border-color 0.2s;
}
.rcard-cta:hover{border-color:var(--gold)}

/* ── TESTIMONIALS ── */
.testi-section{background:var(--warm);overflow:hidden}
.testi-track-wrap{position:relative;margin-top:4rem;overflow:hidden}
.testi-track{
  display:flex;gap:20px;width:max-content;
  animation:testiScroll 30s linear infinite;
}
.testi-track:hover{animation-play-state:paused}
@@keyframes testiScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tcard{
  width:340px;flex-shrink:0;
  padding:2rem 2.2rem;
  background:white;border:1px solid var(--border);
  border-radius:14px;box-shadow:0 6px 24px var(--shadow);
}
.tcard-stars{display:flex;gap:3px;margin-bottom:1rem;color:var(--gold3);font-size:0.9rem;}
.tcard-text{font-size:0.88rem;line-height:1.8;color:var(--ink2);margin-bottom:1.4rem;font-style:italic;}
.tcard-author{display:flex;align-items:center;gap:12px}
.tcard-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:600;color:white;flex-shrink:0;}
.tcard-name{font-size:0.82rem;font-weight:500;color:var(--ink)}
.tcard-role{font-size:0.72rem;color:var(--muted)}

/* ── TECH / PROCESS ── */
.process-section{background:var(--ink);color:white}
.process-section .section-title{color:white}
.process-section .section-eyebrow{color:var(--gold3)}
.process-section .section-eyebrow::before{background:var(--gold3)}
.process-cards{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1px;background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.07);
  border-radius:14px;overflow:hidden;margin-top:4rem;
}
.pcard{
  padding:2.5rem 2rem;background:var(--ink);
  position:relative;overflow:hidden;transition:background 0.3s;
}
.pcard::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--gold),var(--gold3));
  transform:scaleX(0);transform-origin:left;transition:transform 0.4s;
}
.pcard:hover::before{transform:scaleX(1)}
.pcard:hover{background:#231e19}
.pcard-icon{
  width:48px;height:48px;border-radius:10px;
  background:rgba(184,118,26,0.12);border:1px solid rgba(184,118,26,0.2);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1.4rem;transition:background 0.3s;
}
.pcard:hover .pcard-icon{background:rgba(184,118,26,0.25)}
.pcard-icon svg{width:22px;height:22px}
.pcard-title{font-size:0.95rem;font-weight:500;color:white;margin-bottom:0.6rem}
.pcard-desc{font-size:0.8rem;line-height:1.8;color:rgba(255,255,255,0.4)}

/* ── SHOWCASE STRIP ── */
.showcase-strip{background:var(--cream);padding:5rem 0;overflow:hidden;}
.strip-label{
  text-align:center;padding:0 4vw;
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(1.5rem,3vw,2.5rem);
  font-weight:700;color:var(--ink);
  margin-bottom:3rem;letter-spacing:-0.5px;
}
.strip-label em{font-style:italic;color:var(--gold)}
.strip-track{
  display:flex;gap:20px;width:max-content;
  animation:stripScroll 25s linear infinite;padding:1rem 0 2rem;
}
.strip-track:hover{animation-play-state:paused}
@@keyframes stripScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.scard{
  width:220px;flex-shrink:0;border-radius:12px;
  overflow:hidden;border:1px solid var(--border);
  background:white;box-shadow:0 8px 28px var(--shadow);
  transform-style:preserve-3d;
  transition:transform 0.4s,box-shadow 0.4s;cursor:pointer;
}
.scard:hover{
  transform:translateY(-12px) rotateY(5deg) rotateX(3deg);
  box-shadow:0 28px 60px var(--shadow3);
}
.scard-art{
  height:200px;display:flex;align-items:center;
  justify-content:center;
  position:relative;overflow:hidden;
}
.scard-art img{
  width:100%;height:100%;object-fit:cover;position:absolute;inset:0;
  transition:transform 0.4s;
}
.scard:hover .scard-art img{transform:scale(1.08)}
.scard-art .scard-emoji{position:relative;z-index:1;font-size:3.5rem;}
.scard-info{padding:1rem;border-top:1px solid var(--border)}
.scard-name{font-size:0.8rem;font-weight:500;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.scard-price{font-size:0.75rem;color:var(--gold);font-weight:500;margin-top:2px}

.strip-loading{
  display:flex;align-items:center;justify-content:center;
  width:100%;padding:3rem 0;color:var(--muted);font-size:0.85rem;
  gap:1rem;
}
.strip-spinner{
  width:28px;height:28px;border-radius:50%;
  border:2px solid var(--border2);
  border-top-color:var(--gold);
  animation:spin 0.8s linear infinite;
}

/* ── CTA ── */
.cta-section{
  background:var(--ink);padding:9rem 6vw;text-align:center;
  position:relative;overflow:hidden;
}
.cta-bg-art{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:0.04;}
.cta-section h2{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3rem,7vw,6.5rem);
  font-weight:700;line-height:0.92;
  letter-spacing:-2px;color:white;
  margin-bottom:1.5rem;position:relative;z-index:1;
}
.cta-section h2 em{font-style:italic;font-weight:300;color:var(--gold3);}
.cta-section p{font-size:1rem;color:rgba(255,255,255,0.45);max-width:450px;margin:0 auto 3rem;line-height:1.8;position:relative;z-index:1;}
.cta-btns{display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;position:relative;z-index:1;}
.cta-btn-primary{
  padding:1rem 2.8rem;background:var(--gold);color:white;
  border:none;border-radius:6px;
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:0.95rem;font-weight:500;cursor:pointer;text-decoration:none;
  transition:all 0.25s;box-shadow:0 8px 24px rgba(184,118,26,0.4);
}
.cta-btn-primary:hover{background:var(--gold2);transform:translateY(-2px);box-shadow:0 14px 36px rgba(184,118,26,0.5)}
.cta-btn-ghost{
  padding:1rem 2.4rem;background:transparent;color:rgba(255,255,255,0.7);
  border:1.5px solid rgba(255,255,255,0.2);border-radius:6px;
  font-size:0.95rem;font-weight:400;cursor:pointer;text-decoration:none;transition:all 0.25s;
}
.cta-btn-ghost:hover{border-color:var(--gold3);color:var(--gold3)}

/* ── FOOTER ── */
footer{
  background:var(--ink);
  border-top:1px solid rgba(255,255,255,0.07);
  padding:2.5rem 6vw;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;
}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:white;text-decoration:none;}
.footer-logo em{color:var(--gold);font-style:normal}
.footer-links{display:flex;gap:2rem}
.footer-links a{font-size:0.78rem;color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.2s;}
.footer-links a:hover{color:white}
.footer-copy{font-size:0.72rem;color:rgba(255,255,255,0.25)}

/* ════ SCROLL ANIMATION SYSTEM ════ */
.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.85s cubic-bezier(0.22,1,0.36,1),transform 0.85s cubic-bezier(0.22,1,0.36,1);}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:0.12s}
.reveal-delay-2{transition-delay:0.24s}
.reveal-delay-3{transition-delay:0.36s}
.stagger-children > *{opacity:0;transform:translateY(36px);transition:opacity 0.75s cubic-bezier(0.22,1,0.36,1),transform 0.75s cubic-bezier(0.22,1,0.36,1);}
.stagger-children.visible > *:nth-child(1){opacity:1;transform:none;transition-delay:0s}
.stagger-children.visible > *:nth-child(2){opacity:1;transform:none;transition-delay:0.12s}
.stagger-children.visible > *:nth-child(3){opacity:1;transform:none;transition-delay:0.24s}
.stagger-children.visible > *:nth-child(4){opacity:1;transform:none;transition-delay:0.36s}
.stagger-children.visible > *:nth-child(5){opacity:1;transform:none;transition-delay:0.48s}
.reveal-left{opacity:0;transform:translateX(-48px);transition:opacity 0.85s cubic-bezier(0.22,1,0.36,1),transform 0.85s cubic-bezier(0.22,1,0.36,1);}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(48px);transition:opacity 0.85s cubic-bezier(0.22,1,0.36,1),transform 0.85s cubic-bezier(0.22,1,0.36,1);}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(0.88);transition:opacity 0.85s cubic-bezier(0.22,1,0.36,1),transform 0.85s cubic-bezier(0.22,1,0.36,1);}
.reveal-scale.visible{opacity:1;transform:scale(1)}
.reveal-flip{opacity:0;transform:perspective(600px) rotateX(18deg) translateY(30px);transition:opacity 0.75s cubic-bezier(0.22,1,0.36,1),transform 0.75s cubic-bezier(0.22,1,0.36,1);}
.reveal-flip.visible{opacity:1;transform:perspective(600px) rotateX(0deg) translateY(0)}
.gold-divider{height:1px;margin:0;background:linear-gradient(90deg,transparent,var(--gold),var(--gold3),transparent);transform:scaleX(0);transform-origin:left;}
.gold-divider.visible{animation:lineDraw 1.2s cubic-bezier(0.22,1,0.36,1) forwards;}
@@keyframes lineDraw{to{transform:scaleX(1)}}
@@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

.stat-bar-wrap{height:2px;background:rgba(255,255,255,0.1);border-radius:2px;margin-top:1rem;overflow:hidden;}
.stat-bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold3));width:0%;transition:width 1.4s cubic-bezier(0.22,1,0.36,1);}

.hscroll-section{background:var(--warm2);padding:6rem 0;overflow:hidden;}
.hscroll-label{padding:0 6vw;font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:700;letter-spacing:-1px;color:var(--ink);margin-bottom:3rem;}
.hscroll-label em{font-style:italic;color:var(--gold)}
.hscroll-track-outer{overflow:hidden;position:relative}
.hscroll-track{display:flex;gap:24px;padding:1rem 6vw 3rem;transition:transform 0.1s linear;will-change:transform;}
.hcard{min-width:320px;background:white;border-radius:16px;border:1px solid var(--border);padding:2rem;box-shadow:0 8px 32px var(--shadow);flex-shrink:0;transition:transform 0.35s,box-shadow 0.35s;}
.hcard:hover{transform:translateY(-6px);box-shadow:0 20px 50px var(--shadow2)}
.hcard-num{font-family:'Cormorant Garamond',serif;font-size:4rem;font-weight:700;color:rgba(184,118,26,0.15);line-height:1;margin-bottom:1rem;}
.hcard-title{font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:0.6rem}
.hcard-desc{font-size:0.82rem;line-height:1.8;color:var(--muted)}
.hcard-tag{display:inline-block;margin-top:1rem;padding:0.3rem 0.85rem;background:var(--gold-light);border:1px solid rgba(184,118,26,0.2);border-radius:20px;font-size:0.68rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--gold);font-weight:500;}

@@media(max-width:1100px){
  .stats-row,.how-steps,.roles-grid,.process-cards{grid-template-columns:1fr 1fr}
  .gallery-grid{grid-template-columns:repeat(6,1fr)}
  .gcard:nth-child(1){grid-column:span 6}
  .gcard:nth-child(2),.gcard:nth-child(3){grid-column:span 3}
  .gcard:nth-child(4),.gcard:nth-child(5){grid-column:span 3}
  .gcard:nth-child(n+6){grid-column:span 3}
}
@@media(max-width:768px){
  nav{padding:1rem 1.5rem}
  .nav-links{display:none}
  section{padding:4.5rem 5vw}
  .stats-row,.how-steps,.roles-grid,.process-cards{grid-template-columns:1fr}
  .gallery-grid{grid-template-columns:1fr 1fr}
  .gcard:nth-child(n){grid-column:span 1}
  .fcard:nth-child(n+3){display:none}
}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<!-- NAV -->
<nav id="navbar">
  <a href="#" class="nav-logo">Artify<em>.</em></a>
  <div class="nav-links">
    <a href="#how">Process</a>
    @* <a asp-action="ExploreArt" asp-controller="Buyer">Gallery</a> *@
    <a asp-action="Index" asp-controller="Artist">Artist</a>
    <a asp-action="AboutUs" asp-controller="Home">About</a>
    
  </div>
  <div style="display:flex;gap:10px;align-items:center">
    <a asp-action="UserLogin" asp-controller="Auth" class="btn-nav btn-nav-ghost">
      <span class="k-icon k-i-logout"></span> Login/Sign Up
    </a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-mesh">
    <svg width="100%" height="100%" viewBox="0 0 1400 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="rg1" cx="30%" cy="40%" r="50%">
          <stop offset="0%" stop-color="#fef3dc" stop-opacity="0.8"/>
          <stop offset="100%" stop-color="#faf7f2" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="rg2" cx="75%" cy="65%" r="45%">
          <stop offset="0%" stop-color="#f2ebe0" stop-opacity="0.9"/>
          <stop offset="100%" stop-color="#faf7f2" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <rect width="1400" height="900" fill="#faf7f2"/>
      <rect width="1400" height="900" fill="url(#rg1)"/>
      <rect width="1400" height="900" fill="url(#rg2)"/>
      <g stroke="#e0d6c8" stroke-width="0.5" opacity="0.6">
        <line x1="0" y1="150" x2="1400" y2="150"/><line x1="0" y1="300" x2="1400" y2="300"/>
        <line x1="0" y1="450" x2="1400" y2="450"/><line x1="0" y1="600" x2="1400" y2="600"/>
        <line x1="0" y1="750" x2="1400" y2="750"/>
        <line x1="200" y1="0" x2="200" y2="900"/><line x1="400" y1="0" x2="400" y2="900"/>
        <line x1="600" y1="0" x2="600" y2="900"/><line x1="800" y1="0" x2="800" y2="900"/>
        <line x1="1000" y1="0" x2="1000" y2="900"/><line x1="1200" y1="0" x2="1200" y2="900"/>
      </g>
      <circle cx="120" cy="120" r="80" fill="none" stroke="#cfc3b2" stroke-width="0.5" opacity="0.5"/>
      <circle cx="120" cy="120" r="50" fill="none" stroke="#b8761a" stroke-width="0.5" opacity="0.3"/>
      <circle cx="1280" cy="780" r="100" fill="none" stroke="#cfc3b2" stroke-width="0.5" opacity="0.5"/>
      <circle cx="1280" cy="780" r="65" fill="none" stroke="#b8761a" stroke-width="0.5" opacity="0.25"/>
      <line x1="0" y1="0" x2="300" y2="300" stroke="#b8761a" stroke-width="0.5" opacity="0.12"/>
      <line x1="1400" y1="900" x2="1100" y2="600" stroke="#b8761a" stroke-width="0.5" opacity="0.12"/>
    </svg>
  </div>

  <div class="float-cards" id="floatCards">
    <div class="fcard" style="height:200px"><div class="fcard-img ab0"><span class="fcard-emoji">🌌</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
    <div class="fcard" style="height:185px"><div class="fcard-img ab1"><span class="fcard-emoji">🌊</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
    <div class="fcard" style="height:210px"><div class="fcard-img ab2"><span class="fcard-emoji">🌿</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
    <div class="fcard" style="height:190px"><div class="fcard-img ab3"><span class="fcard-emoji">✨</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
    <div class="fcard" style="height:175px"><div class="fcard-img ab4"><span class="fcard-emoji">🔥</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
    <div class="fcard" style="height:195px"><div class="fcard-img ab5"><span class="fcard-emoji">💎</span></div><div class="fcard-label"><div class="fcard-label-title">Loading…</div><div class="fcard-label-price">—</div></div></div>
  </div>

  <div class="hero-content">
    <div class="hero-pill"><span class="hero-pill-dot"></span>Digital art marketplace — Open to all</div>
    <h1>
      The home of<br>
      <span class="h1-italic">digital art</span>
      <span class="h1-outline">&amp; creativity</span>
    </h1>
    <p class="hero-desc">Discover extraordinary digital art from creators worldwide. Buy, sell, and build your collection — on a platform designed for the future of creative commerce.</p>
    <div class="hero-btns">
      <a asp-action="UserLogin" asp-controller="Auth" class="btn-primary"><span>Explore gallery</span></a>
      <a asp-action="Login" asp-controller="Artist" class="btn-ghost">Sell your art →</a>
    </div>
  </div>

  <div class="hero-scroll"><div class="scroll-mouse"></div>Scroll</div>
</section>

<!-- MARQUEE -->
<div class="marquee-section">
  <div class="marquee-track" id="mtrack">
    <span class="m-item"><span class="m-gem">◆</span>Digital Painting</span>
    <span class="m-item"><span class="m-gem">◆</span>Illustration</span>
    <span class="m-item"><span class="m-gem">◆</span>3D Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Photography</span>
    <span class="m-item"><span class="m-gem">◆</span>Abstract Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Pixel Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Concept Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Generative Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Digital Painting</span>
    <span class="m-item"><span class="m-gem">◆</span>Illustration</span>
    <span class="m-item"><span class="m-gem">◆</span>3D Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Photography</span>
    <span class="m-item"><span class="m-gem">◆</span>Abstract Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Pixel Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Concept Art</span>
    <span class="m-item"><span class="m-gem">◆</span>Generative Art</span>
  </div>
</div>

<!-- STATS -->
<div class="stats-row stagger-children">
  <div class="sstat">
    <div class="sstat-num" data-target="12400">0</div>
    <div class="sstat-lbl">Artworks listed</div>
    <div class="stat-bar-wrap"><div class="stat-bar" data-pct="88"></div></div>
  </div>
  <div class="sstat">
    <div class="sstat-num" data-target="3800">0</div>
    <div class="sstat-lbl">Artists worldwide</div>
    <div class="stat-bar-wrap"><div class="stat-bar" data-pct="72"></div></div>
  </div>
  <div class="sstat">
    <div class="sstat-num" data-target="28000">0</div>
    <div class="sstat-lbl">Happy collectors</div>
    <div class="stat-bar-wrap"><div class="stat-bar" data-pct="95"></div></div>
  </div>
  <div class="sstat">
    <div class="sstat-num" data-target="95">0</div>
    <div class="sstat-lbl">% artist payout</div>
    <div class="stat-bar-wrap"><div class="stat-bar" data-pct="95"></div></div>
  </div>
</div>

<div class="gold-divider"></div>

<!-- HOW IT WORKS -->
<section id="how" class="how-section">
  <div class="section-eyebrow reveal-left">Process</div>
  <div class="section-title reveal">How <em>Artify</em> works<br/>for you</div>
  <div class="how-steps stagger-children">
    <div class="how-step">
      <div class="step-num" style="color:rgb(146, 113, 5);">01</div>
      <div class="step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#b8761a" stroke-width="1.8" stroke-linecap="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div class="step-title">Create your profile</div>
      <div class="step-desc">Sign up in seconds as a buyer or artist. Personalize your space, set preferences, and join a thriving creative community.</div>
    </div>
    <div class="how-step">
      <div class="step-num" style="color:rgb(146, 113, 5);">02</div>
      <div class="step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#b8761a" stroke-width="1.8" stroke-linecap="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
      </div>
      <div class="step-title">Upload or discover</div>
      <div class="step-desc">Artists upload high-res work with custom pricing. Buyers browse curated collections filtered by style, category, and price range.</div>
    </div>
    <div class="how-step">
      <div class="step-num" style="color:rgb(146, 113, 5);">03</div>
      <div class="step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#b8761a" stroke-width="1.8" stroke-linecap="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
      </div>
      <div class="step-title">Buy, sell, and earn</div>
      <div class="step-desc">Secure PayPal checkout for buyers. Artists earn directly — instant download delivered, payout requested anytime.</div>
    </div>
  </div>
</section>

<!-- GALLERY -->
