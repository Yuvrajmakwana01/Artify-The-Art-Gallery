@{
    ViewData["Title"] = "Artify - Step into the World of Art";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #DEE6E9;
            --brand: #03289F;
            --heading: #EDA312;
            --subhead: #6B9BE6;
            --text: #03289F;
            --white: #ffffff;
            --shadow: 0 8px 40px rgba(3, 40, 159, .15);
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }
        h1, h2, h3 { font-family: 'Playfair Display', serif; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--subhead); border-radius: 3px; }
        body.is-loading { overflow: hidden; }

        .page-loader {
            position: fixed;
            inset: 0;
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #050505;
            overflow: hidden;
            transition: opacity .85s ease, visibility .85s ease;
        }
        body.loader-complete .page-loader {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .page-loader::before,
        .page-loader::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: .3;
        }
        .page-loader::before {
            width: 280px;
            height: 280px;
            background: rgba(237, 163, 18, .16);
            top: calc(50% - 140px);
            left: calc(50% - 250px);
        }
        .page-loader::after {
            width: 220px;
            height: 220px;
            background: rgba(107, 155, 230, .14);
            top: calc(50% - 110px);
            left: calc(50% + 40px);
        }
        .page-loader-stage {
            position: relative;
            width: min(90vw, 940px);
            height: min(42vw, 320px);
            min-height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform .95s cubic-bezier(.16, 1, .3, 1), opacity .75s ease;
        }
        body.loader-leaving .page-loader-stage {
            transform: scale(18);
            opacity: 0;
        }
        .page-loader-brand {
            position: relative;
            display: flex;
            align-items: center;
            gap: 26px;
            z-index: 50;
            flex-wrap: wrap;
            justify-content: center;
        }
        .page-loader-logo {
            width: clamp(88px, 10vw, 168px);
            height: clamp(88px, 10vw, 168px);
            flex: 0 0 auto;
            filter: drop-shadow(0 14px 28px rgba(0, 0, 0, .3));
            animation: loaderLogoSettle .9s .08s both;
        }
        .page-loader-logo img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
        }
        .page-loader-copy {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 6px;
            flex-shrink: 0;
            z-index: 50;
        }
        .page-loader-title-wrap {
            display: block;
            overflow: visible;
            opacity: 0;
            transform: translateX(-18px);
            animation: loaderTitleReveal 1s 1.3s cubic-bezier(.16, 1, .3, 1) forwards;
        }
        .page-loader-title {
            display: inline-block;
            white-space: nowrap;
            font-family: 'Playfair Display', serif;
            font-size: clamp(56px, 9vw, 140px);
            font-weight: 800;
            line-height: .88;
            letter-spacing: .08em;
            color: #ffffff;
            text-transform: uppercase;
        }
        .page-loader-tagline {
            font-family: 'Playfair Display', serif;
            font-size: clamp(18px, 2.5vw, 40px);
            font-weight: 700;
            line-height: 1.2;
            letter-spacing: .04em;
            color: #EDA312;
            opacity: 0;
            transform: translateY(10px);
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.9), 0 0 10px rgba(237, 163, 18, 0.4);
            animation: loaderTaglineIn .8s 1.78s ease forwards;
        }
        .page-loader-tiles {
            position: absolute;
            left: 50%;
            top: 50%;
            width: min(54vw, 440px);
            height: min(26vw, 190px);
            transform: translate(25%, -8%);
            z-index: 1;
        }
        .page-loader-tile {
            position: absolute;
            overflow: hidden;
            border-radius: 12px;
            opacity: 0;
            transform: translate(-26px, 12px) scale(.35) rotate(-12deg);
            box-shadow: 0 12px 32px rgba(0, 0, 0, .28);
            border: 1px solid rgba(255, 255, 255, .14);
            animation: loaderTileIn .9s var(--delay) cubic-bezier(.16, 1, .3, 1) forwards;
        }
        .page-loader-tile::before,
        .page-loader-tile::after {
            content: "";
            position: absolute;
            inset: 0;
        }
        .page-loader-tile::before {
            background-image: var(--tile-bg);
            background-size: cover;
            background-position: center;
        }
        .page-loader-tile::after {
            background: linear-gradient(135deg, rgba(255, 255, 255, .24), transparent 34%, transparent 68%, rgba(0, 0, 0, .2));
        }
        .page-loader-tile.tile-1 {
            --delay: 2.8s;
            --tile-bg: url('https://images.unsplash.com/photo-1615184697985-c9bde1b07da7?w=300&q=80');
            left: 92px;
            top: 104px;
            width: 54px;
            height: 54px;
        }
        .page-loader-tile.tile-2 {
            --delay: 3.0s;
            --tile-bg: url('https://images.unsplash.com/photo-1541701494587-cb58502866ab?w=300&q=80');
            left: 138px;
            top: 74px;
            width: 66px;
            height: 66px;
        }
        .page-loader-tile.tile-3 {
            --delay: 3.15s;
            --tile-bg: url('https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=300&q=80');
            left: 196px;
            top: 108px;
            width: 40px;
            height: 40px;
        }
        .page-loader-tile.tile-4 {
            --delay: 3.3s;
            --tile-bg: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=300&q=80');
            left: 228px;
            top: 52px;
            width: 76px;
            height: 76px;
        }
        .page-loader-tile.tile-5 {
            --delay: 3.45s;
            --tile-bg: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=300&q=80');
            left: 178px;
            top: 30px;
            width: 52px;
            height: 52px;
        }
        @@keyframes loaderLogoSettle {
            from { opacity: 0; transform: scale(.8) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        @@keyframes loaderTitleReveal {
            from { opacity: 0; transform: translateX(-18px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @@keyframes loaderTileIn {
            0% { opacity: 0; transform: translate(-26px, 12px) scale(.35) rotate(-12deg); }
            100% { opacity: 1; transform: translate(0, 0) scale(1) rotate(0deg); }
        }
        @@keyframes loaderTaglineIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .floating-nav {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 220;
            width: min(92vw, 860px);
            display: grid;
            place-items: center;
            pointer-events: none;
        }
        .floating-nav-trigger,
        .floating-nav-panel {
            grid-area: 1 / 1;
        }
        .floating-nav-trigger,
        .floating-nav-panel,
        .floating-nav-logo,
        .floating-nav-link,
        .floating-nav-toggle {
            pointer-events: auto;
        }
        .floating-nav-trigger {
            border: none;
            border-radius: 18px;
            min-width: 150px;
            min-height: 58px;
            padding: 0 30px;
            background: #111111;
            color: #ffffff;
            font-family: 'DM Sans', sans-serif;
            font-size: 24px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .22);
            transition: opacity .28s ease, transform .34s cubic-bezier(.16, 1, .3, 1), box-shadow .25s ease;
        }
        .floating-nav-trigger:hover { box-shadow: 0 22px 48px rgba(0, 0, 0, .28); }
        .floating-nav.is-open .floating-nav-trigger {
            opacity: 0;
            transform: translateY(10px) scale(.88);
            pointer-events: none;
        }
        .floating-nav-panel {
            width: 100%;
            display: grid;
            grid-template-columns: 68px minmax(0, 1fr) 68px;
            align-items: center;
            gap: 18px;
            opacity: 0;
            transform: translateY(10px) scale(.96);
            transform-origin: bottom center;
            transition: opacity .32s ease, transform .42s cubic-bezier(.16, 1, .3, 1);
            pointer-events: none;
        }
        .floating-nav.is-open .floating-nav-panel {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: auto;
        }
        .floating-nav-logo {
            width: 68px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            filter: drop-shadow(0 18px 34px rgba(0, 0, 0, .18));
        }
        .floating-nav-logo img {
            width: 68px;
            height: 68px;
            display: block;
            object-fit: contain;
        }
        .floating-nav-links {
            min-width: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 16px;
            border-radius: 20px;
            background: rgba(246, 247, 249, .96);
            border: 1px solid rgba(17, 17, 17, .05);
            box-shadow: 0 18px 40px rgba(15, 23, 42, .14);
            backdrop-filter: blur(16px);
        }
        .floating-nav-link {
            flex: 0 0 auto;
            padding: 13px 22px;
            border-radius: 999px;
            color: #151515;
            font-size: 15px;
            font-weight: 700;
            line-height: 1;
            text-decoration: none;
            transition: background .22s ease, color .22s ease, transform .22s ease;
        }
        .floating-nav-link.is-active,
        .floating-nav-link:hover,
        .floating-nav-link:focus-visible {
            background: #111111;
            color: #ffffff;
        }
        .floating-nav-logo:focus-visible,
        .floating-nav-trigger:focus-visible,
        .floating-nav-link:focus-visible {
            outline: 2px solid var(--subhead);
            outline-offset: 4px;
        }
        .floating-nav-toggle {
            position: relative;
            width: 68px;
            height: 68px;
            border: none;
            border-radius: 18px;
            background: #111111;
            box-shadow: 0 18px 34px rgba(0, 0, 0, .18);
            cursor: default;
        }
        .floating-nav-toggle::before,
        .floating-nav-toggle::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            transform: translateY(-50%);
        }
        .floating-nav-toggle::before {
            left: 21px;
            background: rgba(221, 214, 204, .42);
        }
        .floating-nav-toggle::after {
            left: 31px;
            background: #ffffff;
        }

        .hero {
            position: relative;
            height: 100vh;
            min-height: 600px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .hero-video-wrap { position: absolute; inset: 0; }
        .hero-video-wrap video { width: 100%; height: 100%; object-fit: cover; display: block; }
        .hero-video-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, .28); }

        .hero-card-wrap {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 560px;
            padding: 0 20px;
            animation: fadeUp .9s ease both;
        }
        .hero-arrow-row {
            position: absolute;
            left: 50%;
            bottom: 38px;
            transform: translateX(-50%);
            z-index: 12;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }
        .hero-dot-row {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .hero-dot-btn {
            width: 6px;
            height: 6px;
            border: 0;
            border-radius: 999px;
            padding: 0;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.38);
            transition: width 0.3s ease, background 0.3s ease, transform 0.3s ease;
        }
        .hero-dot-btn.is-active {
            width: 20px;
            background: var(--heading);
        }
        .hero-dot-btn:hover {
            transform: scale(1.08);
            background: rgba(255, 255, 255, 0.62);
        }
        .hero-arrow-btn {
            width: 52px;
            height: 52px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.32);
            background: rgba(255, 255, 255, 0.18);
            color: var(--white);
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            box-shadow: 0 16px 40px rgba(2, 28, 115, 0.18);
            transition: transform 0.25s ease, background 0.25s ease, opacity 0.25s ease;
        }
        .hero-arrow-btn:hover {
            opacity: 1;
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.26);
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(32px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hero-card {
            border-radius: 26px;
            padding: 52px 48px;
            text-align: center;
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(24px) saturate(1.8);
            -webkit-backdrop-filter: blur(24px) saturate(1.8);
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: 0 24px 64px rgba(3, 40, 159, 0.15), inset 0 1px 0 rgba(255, 255, 255, 1);
        }
        .hero-eyebrow {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .38em;
            color: var(--brand);
            opacity: 0.7;
            margin-bottom: 20px;
            font-weight: 700;
        }
        .hero-title {
            font-size: clamp(32px, 4.5vw, 56px);
            line-height: 1.06;
            color: var(--brand);
            margin-bottom: 18px;
        }
        .hero-title em { color: var(--heading); font-style: italic; }
        .hero-sub {
            font-size: 15px;
            line-height: 1.8;
            color: rgba(3, 40, 159, .8);
            font-weight: 500;
            max-width: 420px;
            margin: 0 auto 34px;
        }
        .hero-btns {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .hero-btn-primary {
            border-radius: 999px;
            background: var(--brand);
            color: var(--white);
            border: none;
            padding: 14px 32px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-family: 'DM Sans', sans-serif;
            letter-spacing: .08em;
            text-transform: uppercase;
            transition: transform .2s, box-shadow .2s;
            box-shadow: 0 8px 24px rgba(3, 40, 159, 0.25);
        }
        .hero-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(3, 40, 159, 0.35); background: #021c73; }
        .hero-btn-ghost {
            border-radius: 999px;
            background: transparent;
            color: var(--brand);
            border: 2px solid var(--brand);
            padding: 12px 30px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-family: 'DM Sans', sans-serif;
            letter-spacing: .08em;
            text-transform: uppercase;
            transition: all .2s;
        }
        .hero-btn-ghost:hover { background: rgba(3, 40, 159, .06); transform: translateY(-2px); }
        .hero-stats {
            margin-top: 36px;
            padding-top: 26px;
            border-top: 1px solid rgba(3, 40, 159, .12);
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }
        .hero-stat-val {
            font-size: 26px;
            font-weight: 700;
            color: var(--brand);
            font-family: 'Playfair Display', serif;
        }
        .hero-stat-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .18em;
            color: rgba(3, 40, 159, .6);
            margin-top: 4px;
            font-weight: 600;
        }

        .marquee-wrap {
            overflow: hidden;
            padding: 20px 0;
            background: rgba(3, 40, 159, .06);
            border-top: 1px solid rgba(3, 40, 159, .10);
            border-bottom: 1px solid rgba(3, 40, 159, .10);
        }
        .marquee-track { display: flex; animation: marquee 28s linear infinite; white-space: nowrap; }
        .marquee-track span {
            display: inline-block;
            padding: 0 28px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .25em;
            color: var(--subhead);
        }
        @@keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        section.page-sec { padding: 88px 64px; }
        .sec-eyebrow {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .25em;
            color: var(--subhead);
        }
        .sec-title {
            margin-top: 10px;
            font-size: clamp(28px, 4vw, 44px);
            color: var(--heading);
        }
        .sec-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 48px;
        }
        .sec-link {
            font-size: 14px;
            color: var(--brand);
            text-decoration: none;
            font-weight: 600;
            opacity: .75;
            transition: opacity .2s;
        }
        .sec-link:hover { opacity: 1; }

        .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .cat-card {
            position: relative;
            height: 300px;
            overflow: hidden;
            border-radius: 24px;
            box-shadow: var(--shadow);
            border: 1px solid rgba(3, 40, 159, .08);
            transition: all .4s;
            display: block;
            text-decoration: none;
        }
        .cat-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(3, 40, 159, .25); }
        .cat-img-slider { position: absolute; inset: 0; width: 100%; height: 100%; }
        .cat-img-slider img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: transform .6s, opacity .4s;
        }
        .cat-img-slider img:first-child { opacity: 1; }
        .cat-card:hover .cat-img-slider img { transform: scale(1.08); animation: slideShow 4s infinite; opacity: 0; }
        .cat-card:hover .cat-img-slider img:nth-child(1) { animation-delay: 0s; }
        .cat-card:hover .cat-img-slider img:nth-child(2) { animation-delay: 2s; }
        .cat-card:hover .cat-img-slider img:nth-child(3) { animation-delay: 3s; }
        @@keyframes slideShow {
            0%, 25% { opacity: 1; }
            33%, 92% { opacity: 0; }
            100% { opacity: 1; }
        }
        .cat-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(3, 40, 159, .85) 0%, rgba(3, 40, 159, .30) 50%, transparent 100%);
            z-index: 2;
        }
        .cat-body { position: absolute; bottom: 0; left: 0; right: 0; padding: 24px; z-index: 3; }
        .cat-count { font-size: 11px; text-transform: uppercase; letter-spacing: .2em; color: var(--heading); }
        .cat-name {
            font-size: 22px;
            font-weight: 700;
            color: var(--white);
            font-family: 'Playfair Display', serif;
            margin-top: 4px;
        }
        .cat-blurb { font-size: 13px; color: rgba(255, 255, 255, .75); margin-top: 4px; }
        .cat-arrow {
            position: absolute;
            bottom: 24px;
            right: 20px;
            height: 36px;
            width: 36px;
            border-radius: 999px;
            background: var(--heading);
            display: grid;
            place-items: center;
            color: var(--white);
            font-weight: 700;
            opacity: 0;
            transform: translateX(8px);
            transition: all .3s;
            z-index: 3;
        }
        .cat-card:hover .cat-arrow { opacity: 1; transform: translateX(0); }

        .artists-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .artist-card {
            border-radius: 24px;
            background: rgba(255, 255, 255, .5);
            border: 1px solid rgba(3, 40, 159, .10);
            padding: 28px 20px;
            text-align: center;
            backdrop-filter: blur(8px);
            box-shadow: var(--shadow);
            transition: all .3s;
        }
        .artist-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(3, 40, 159, .18); }
        .artist-avatar {
            height: 88px;
            width: 88px;
            border-radius: 999px;
            background: var(--brand);
            margin: 0 auto;
            display: grid;
            place-items: center;
            font-size: 32px;
            font-weight: 700;
            color: var(--white);
            box-shadow: 0 0 0 3px rgba(237, 163, 18, .5);
            font-family: 'Playfair Display', serif;
        }
        .artist-name {
            margin-top: 18px;
            font-size: 17px;
            font-weight: 700;
            color: var(--heading);
            font-family: 'Playfair Display', serif;
        }
        .artist-handle { font-size: 12px; color: var(--subhead); margin-top: 4px; }
        .artist-stats {
            margin-top: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
        }
        .artist-stat-val { font-size: 16px; font-weight: 700; color: var(--brand); }
        .artist-stat-label { font-size: 11px; color: var(--subhead); text-transform: uppercase; letter-spacing: .1em; }
        .artist-divider { width: 1px; height: 32px; background: rgba(3, 40, 159, .12); }
        .btn-follow {
            margin-top: 20px;
