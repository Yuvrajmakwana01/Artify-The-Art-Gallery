@{
    Layout = null;
    ViewData["Title"] = "Artify";
    var landingUrl = Url.Action("Landingpage", "Home")!;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <style>
        :root { --surface:#fffdf8; --ink:#24180f; --muted:#776555; --line:rgba(93,65,40,.12); --accent:#b67a35; --accent-2:#d5aa5c; --soft:#f0e6d7; --success:#307d56; --danger:#a54a46; --shadow:0 24px 70px rgba(37,23,10,.12); }
        * { box-sizing:border-box; }
        html, body { margin:0; padding:0; min-height:100%; scroll-behavior:smooth; }
        body { font-family:"Segoe UI",Tahoma,sans-serif; color:var(--ink); background:radial-gradient(circle at top left, rgba(233,205,154,.28), transparent 24%), linear-gradient(180deg,#fdf9f3 0%,#f3e8da 100%); overflow-x:hidden; overflow-y:scroll; }
        body.modal-open { overflow:hidden; }
        a { color:inherit; text-decoration:none; }
        button { font:inherit; }
        .shell { width:min(1200px, calc(100vw - 32px)); margin:0 auto; }
        .site-header { position:sticky; top:0; z-index:20; background:rgba(253,249,243,.86); border-bottom:1px solid rgba(93,65,40,.08); backdrop-filter:blur(14px); }
        .site-header .shell { display:flex; align-items:center; justify-content:space-between; gap:16px; padding:18px 0; }
        .brand { font:700 clamp(2rem, 4vw, 2.6rem) Georgia,"Times New Roman",serif; letter-spacing:-.03em; }
        .nav { display:flex; gap:24px; color:var(--muted); font-weight:600; }
        .header-actions { display:flex; align-items:center; gap:12px; }
        .metric-pill { display:inline-flex; align-items:center; gap:8px; padding:10px 14px; border-radius:999px; background:rgba(255,255,255,.82); border:1px solid var(--line); color:var(--muted); font-weight:700; }
        .btn { display:inline-flex; align-items:center; justify-content:center; gap:10px; min-height:48px; padding:0 20px; border-radius:999px; border:1px solid transparent; cursor:pointer; transition:transform .18s ease, box-shadow .18s ease; font-weight:700; }
        .btn:hover { transform:translateY(-1px); }
        .btn-primary { color:#fff; background:linear-gradient(135deg,var(--accent),var(--accent-2)); box-shadow:0 18px 30px rgba(182,122,53,.24); }
        .btn-secondary { color:var(--ink); background:rgba(255,255,255,.78); border-color:var(--line); }
        .btn-ghost { color:var(--ink); background:#f5ecdf; border-color:rgba(93,65,40,.08); }
        .hero { padding:40px 0 30px; }
        .hero-grid { display:grid; grid-template-columns:minmax(0, 1.1fr) minmax(320px, .9fr); gap:28px; align-items:center; }
        .eyebrow { display:inline-flex; align-items:center; gap:10px; padding:10px 16px; border-radius:999px; background:#f2e7d4; color:#7a6148; font-size:.92rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase; }
        .hero h1 { margin:20px 0 16px; font:700 clamp(3.3rem, 8vw, 6.2rem) Georgia,"Times New Roman",serif; line-height:.92; letter-spacing:-.05em; }
        .hero h1 span { color:var(--accent); display:block; }
        .hero p { max-width:660px; margin:0; color:var(--muted); font-size:1.08rem; line-height:1.8; }
        .hero-actions { display:flex; flex-wrap:wrap; gap:14px; margin-top:28px; }
        .stats { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:14px; margin-top:26px; }
        .stat-card { padding:18px 20px; border-radius:24px; background:rgba(255,255,255,.68); border:1px solid rgba(93,65,40,.08); box-shadow:var(--shadow); }
        .stat-card strong { display:block; font-size:1.7rem; font-family:Georgia,"Times New Roman",serif; }
        .stat-card span { display:block; margin-top:8px; color:var(--muted); }
        .hero-panel { position:relative; min-height:620px; border-radius:36px; background:linear-gradient(180deg,#fff7ec 0%,#eadbc7 100%); border:1px solid rgba(93,65,40,.08); box-shadow:var(--shadow); overflow:hidden; }
        .hero-float { position:absolute; overflow:hidden; border-radius:28px; box-shadow:0 20px 40px rgba(40,25,12,.16); }
        .hero-float img { display:block; width:100%; height:100%; object-fit:cover; }
        .hero-float.one { top:40px; left:32px; width:190px; height:250px; transform:rotate(-8deg); }
        .hero-float.two { top:110px; right:32px; width:230px; height:320px; transform:rotate(7deg); }
        .hero-float.three { bottom:54px; left:120px; width:220px; height:300px; }
        .hero-blurb { position:absolute; right:28px; bottom:28px; max-width:280px; padding:18px 20px; border-radius:24px; background:rgba(31,21,13,.85); color:#fff6e8; }
        .hero-blurb strong { display:block; margin-bottom:8px; font-size:1.12rem; }
        .section { padding:34px 0 0; }
        .section-head { display:flex; align-items:end; justify-content:space-between; gap:16px; margin-bottom:20px; }
        .section-head h2 { margin:0 0 8px; font:700 clamp(2.3rem, 5vw, 4rem) Georgia,"Times New Roman",serif; line-height:.96; letter-spacing:-.04em; }
        .section-head p { margin:0; max-width:640px; color:var(--muted); line-height:1.7; }
        .featured-grid, .catalog-grid { display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:20px; }
        .feature-card { position:relative; min-height:340px; border-radius:28px; overflow:hidden; border:1px solid rgba(255,255,255,.8); box-shadow:var(--shadow); }
        .feature-card img { display:block; width:100%; height:100%; object-fit:cover; }
        .feature-copy { position:absolute; inset:auto 18px 18px; padding:18px; border-radius:22px; background:linear-gradient(180deg, rgba(15,10,6,.1), rgba(15,10,6,.72)); color:#fff9ef; }
        .feature-copy span { display:block; color:rgba(255,249,239,.76); margin-top:8px; }
        .catalog-tools { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:18px; }
        .chip { display:inline-flex; align-items:center; justify-content:center; min-height:42px; padding:0 16px; border-radius:999px; border:1px solid rgba(93,65,40,.1); background:#f7efe4; color:#5c4c3d; cursor:pointer; font-weight:700; }
        .chip.active { color:#fff; background:linear-gradient(135deg,var(--accent),var(--accent-2)); border-color:transparent; }
        .art-card { overflow:hidden; border-radius:24px; background:var(--surface); border:1px solid rgba(93,65,40,.08); box-shadow:0 16px 34px rgba(37,23,10,.09); }
        .art-media { position:relative; height:280px; background:#eadcc7; }
        .art-media img { display:block; width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
        .art-card:hover .art-media img { transform:scale(1.03); }
        .art-pill { position:absolute; top:14px; left:14px; display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px; background:rgba(255,255,255,.92); color:#6e5a48; font-size:.88rem; font-weight:700; }
        .details-btn { position:absolute; left:14px; right:14px; bottom:14px; min-height:44px; border-radius:999px; border:0; background:rgba(255,249,240,.86); color:#473628; font-weight:700; cursor:pointer; }
        .art-body { padding:16px; }
        .art-meta { display:flex; align-items:start; justify-content:space-between; gap:12px; }
        .art-title { margin:0; font-size:1.1rem; font-weight:800; }
        .art-artist { margin:8px 0 0; color:var(--muted); }
        .art-price { font:700 1.06rem Georgia,"Times New Roman",serif; color:var(--accent); white-space:nowrap; }
        .art-tag { display:inline-flex; margin-top:14px; padding:7px 12px; border-radius:999px; background:#f3eadf; color:#655342; font-size:.85rem; font-weight:700; }
        .site-footer { margin-top:34px; padding:30px 0 50px; color:var(--muted); }
        .footer-band { display:flex; align-items:center; justify-content:space-between; gap:16px; padding-top:22px; border-top:1px solid rgba(93,65,40,.1); }
        .empty-state { padding:40px 20px; border-radius:24px; background:rgba(255,255,255,.68); border:1px dashed rgba(93,65,40,.18); text-align:center; color:var(--muted); }
        .toast { position:fixed; right:18px; bottom:18px; z-index:60; min-width:280px; max-width:360px; padding:14px 16px; border-radius:16px; background:rgba(35,24,15,.92); color:#fff8ef; box-shadow:var(--shadow); opacity:0; transform:translateY(10px); pointer-events:none; transition:opacity .2s ease, transform .2s ease; }
        .toast.show { opacity:1; transform:translateY(0); }
        .modal { position:fixed; inset:0; display:none; align-items:center; justify-content:center; padding:20px; background:rgba(20,13,8,.56); z-index:50; }
        .modal.open { display:flex; }
        .modal-card { width:min(980px, 100%); max-height:calc(100vh - 40px); overflow:auto; background:var(--surface); border-radius:30px; border:1px solid rgba(93,65,40,.08); box-shadow:0 34px 70px rgba(15,10,6,.26); }
        .modal-close { position:absolute; top:18px; right:18px; width:42px; height:42px; border-radius:50%; border:1px solid rgba(93,65,40,.1); background:#fff; cursor:pointer; }
        .modal-inner { position:relative; display:grid; grid-template-columns:minmax(0, 1.2fr) minmax(300px, .8fr); gap:22px; padding:22px; }
        .modal-inner img { width:100%; height:520px; object-fit:cover; border-radius:24px; }
        .modal-copy h3 { margin:14px 0 10px; font:700 2.4rem Georgia,"Times New Roman",serif; line-height:1; }
        .modal-copy p { margin:0 0 14px; color:var(--muted); line-height:1.75; }
        @@media (max-width:1080px) { .hero-grid, .modal-inner { grid-template-columns:1fr; } .featured-grid, .catalog-grid { grid-template-columns:repeat(2, minmax(0, 1fr)); } .hero-panel { min-height:520px; } }
        @@media (max-width:780px) { .site-header .shell, .section-head, .footer-band { flex-direction:column; align-items:flex-start; } .nav { display:none; } .featured-grid, .catalog-grid, .stats { grid-template-columns:1fr; } .hero-actions { width:100%; } .hero-panel { min-height:420px; } .hero-float.three { left:28px; width:180px; height:220px; } .hero-float.two { width:180px; height:240px; } }
    </style>
</head>
<body>
    <header class="site-header">
        <div class="shell">
            <a class="brand" href="#top">Artify</a>
            <nav class="nav">
                <a href="#featured">Featured</a>
                <a href="#catalog">Collection</a>
            </nav>
            <div class="header-actions">
                <div class="metric-pill" id="artCount">Loading collection...</div>
            </div>
        </div>
    </header>

    <main id="top">
        <section class="hero">
            <div class="shell hero-grid">
                <div>
                    <span class="eyebrow">Public Digital Gallery</span>
                    <h1>Discover art that<span>inspires.</span></h1>
                    <p>Welcome to Artify. Browse our curated selection of digital masterpieces. Our gallery is open for public viewing, showcasing the very best in contemporary digital art.</p>
                    <div class="hero-actions">
                        <a class="btn btn-primary" href="#catalog">Browse Collection</a>
                    </div>
                    <div class="stats">
                        <div class="stat-card"><strong id="statTotal">0</strong><span>total works</span></div>
                        <div class="stat-card"><strong id="statCategories">0</strong><span>categories</span></div>
                    </div>
                </div>
                <div class="hero-panel" id="heroPanel">
                    <div class="hero-blurb">
                        <strong>Open Gallery</strong>
                        <span>Explore our high-resolution digital collection freely. Use the filters below to find specific styles.</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="section" id="featured">
            <div class="shell">
                <div class="section-head">
                    <div>
                        <h2>Gallery highlights</h2>
                        <p>A hand-picked selection of our most influential current pieces.</p>
                    </div>
                </div>
                <div class="featured-grid" id="featuredGrid"></div>
            </div>
        </section>

        <section class="section" id="catalog">
            <div class="shell">
                <div class="section-head">
                    <div>
                        <h2>Full Collection</h2>
                        <p>Filter through our entire library of digital assets.</p>
                    </div>
                </div>
                <div class="catalog-tools" id="categoryToolbar"></div>
                <div class="catalog-grid" id="catalogGrid"></div>
                <div class="empty-state" id="catalogEmpty" style="display:none;">No artworks match this category right now.</div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="shell footer-band">
            <strong>Artify</strong>
            <span>Curated digital art for the public domain.</span>
        </div>
    </footer>

    <div class="toast" id="toast"></div>
    <div class="modal" id="detailModal">
        <div class="modal-card">
            <div class="modal-inner" id="detailContent"></div>
        </div>
    </div>

    <script>
        const urls = { data: '@Url.Action("LandingPageData", "Home")' };
        const pageState = { data: null, selectedCategory: 'All' };

        $(function () {
            loadLandingData();
            bindEvents();
        });

        function bindEvents() {
            $(document).on('click', '.js-category', function () {
                pageState.selectedCategory = $(this).data('category');
                renderCategoryToolbar();
                renderCatalog();
            });
            $(document).on('click', '.js-details', function () { openDetail(Number($(this).data('id'))); });
            $(document).on('click', '#detailModal', function (e) { if (e.target.id === 'detailModal') { closeDetail(); } });
            $(document).on('click', '.modal-close', closeDetail);
            $(document).on('keydown', function (e) { if (e.key === 'Escape') { closeDetail(); } });
        }

        function loadLandingData() {
            $.getJSON(urls.data)
                .done(function (response) {
                    pageState.data = response;
                    renderPage();
                })
                .fail(function () {
                    showToast('We could not load the gallery.');
                });
        }

        function renderPage() {
            renderStats();
            renderHeroPanel();
            renderFeatured();
            renderCategoryToolbar();
            renderCatalog();
        }

        function renderStats() {
            const count = (pageState.data.artworks || []).length;
            const cats = (pageState.data.categories || []).length;
            $('#statTotal').text(count);
            $('#statCategories').text(cats);
            $('#artCount').text(count + ' Artworks');
        }

        function renderHeroPanel() {
            const items = (pageState.data.artworks || []).slice(0, 3);
            const host = $('#heroPanel');
            host.find('.hero-float').remove();
            host.prepend(items.map((item, i) => {
                const classes = ['one', 'two', 'three'];
                return `<div class="hero-float ${classes[i]}"><img src="${item.imageUrl}" alt="${escapeHtml(item.title)}"></div>`;
            }).join(''));
        }

        function renderFeatured() {
            const items = (pageState.data.artworks || []).slice(0, 4);
            $('#featuredGrid').html(items.map(item => `
                <article class="feature-card">
                    <img src="${item.imageUrl}" alt="${escapeHtml(item.title)}">
                    <div class="feature-copy">
                        <strong>${escapeHtml(item.title)}</strong>
                        <span>${escapeHtml(item.artistName)}</span>
                    </div>
                </article>
            `).join(''));
        }

        function renderCategoryToolbar() {
            const categories = pageState.data.categories || [];
            $('#categoryToolbar').html(categories.map(cat => {
                const active = cat === pageState.selectedCategory ? ' active' : '';
                return `<button class="chip js-category${active}" data-category="${escapeHtml(cat)}">${escapeHtml(cat)}</button>`;
            }).join(''));
        }

        function renderCatalog() {
            const items = pageState.selectedCategory === 'All' 
                ? (pageState.data.artworks || []) 
                : (pageState.data.artworks || []).filter(item => item.category === pageState.selectedCategory);
            
            $('#catalogGrid').html(items.map(renderCard).join(''));
            $('#catalogEmpty').toggle(items.length === 0);
        }

        function renderCard(item) {
            return `
                <article class="art-card">
                    <div class="art-media">
                        <img src="${item.imageUrl}" alt="${escapeHtml(item.title)}">
                        <span class="art-pill">★ ${item.likes}</span>
                        <button class="details-btn js-details" data-id="${item.id}">View details</button>
                    </div>
                    <div class="art-body">
                        <div class="art-meta">
                            <div><h3 class="art-title">${escapeHtml(item.title)}</h3><p class="art-artist">${escapeHtml(item.artistName)}</p></div>
                            <div class="art-price">$${Number(item.price).toLocaleString()}</div>
                        </div>
                        <span class="art-tag">${escapeHtml(item.category)}</span>
                    </div>
                </article>`;
        }

        function openDetail(id) {
            const item = (pageState.data.artworks || []).find(art => art.id === id);
            if (!item) return;
            $('#detailContent').html(`
                <div><img src="${item.imageUrl}"></div>
                <div class="modal-copy">
                    <button class="modal-close">×</button>
                    <span class="art-tag">${escapeHtml(item.category)}</span>
                    <h3>${escapeHtml(item.title)}</h3>
                    <p>By ${escapeHtml(item.artistName)}</p>
                    <p><strong>$${Number(item.price).toLocaleString()}</strong></p>
                    <p>This digital piece is currently on display in our public collection.</p>
                </div>
            `);
            $('#detailModal').addClass('open');
            $('body').addClass('modal-open');
        }

        function closeDetail() {
            $('#detailModal').removeClass('open');
            $('body').removeClass('modal-open');
        }

        function showToast(msg) {
            const toast = $('#toast');
            toast.text(msg).addClass('show');
            setTimeout(() => toast.removeClass('show'), 2200);
        }

        function escapeHtml(val) {
            return String(val || '').replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' })[c]);
        }
    </script>
</body>
</html>