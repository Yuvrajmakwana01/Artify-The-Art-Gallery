@model Repository.Models.t_ResetPassword
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
    @* var email = Request.Query["email"].ToString();
    var otp   = Request.Query["otp"].ToString(); *@
}

<style>
    .auth-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .auth-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        animation: bgPan 25s ease-in-out infinite;
    }
    .auth-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg,
            hsl(25 20% 8% / 0.70) 0%,
            hsl(25 20% 8% / 0.50) 50%,
            hsl(25 20% 8% / 0.75) 100%);
    }
    .auth-wrapper {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 440px;
        margin: 24px 16px;
        animation: scaleIn 0.4s ease-out;
    }
    .glass-card {
        background: hsl(35 30% 92% / 0.88);
        backdrop-filter: blur(24px);
        border: 1px solid hsl(30 15% 82% / 0.35);
        border-radius: 1.25rem;
        padding: 2rem;
        box-shadow: 0 8px 32px -8px hsl(25 20% 10% / 0.40),
                    inset 0 1px 0 hsl(35 30% 97% / 0.18);
    }
    .auth-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: hsl(25, 30%, 10%);
        margin: 0 0 0.3rem;
    }
    .auth-subtitle {
        font-size: 0.8rem;
        color: hsl(25, 15%, 35%);
        margin: 0 0 0.5rem;
    }
    .form-group { margin-top: 1rem; }
    .form-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        color: hsl(25, 30%, 10%);
        margin-bottom: 0.3rem;
    }
    .k-textbox, .k-input {
        background-color: hsl(32, 18%, 88%) !important;
        border-color: hsl(30, 15%, 78%) !important;
        border-radius: 0.6rem !important;
        color: hsl(25, 30%, 10%) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 0.85rem !important;
        height: 38px !important;
        width: 100% !important;
    }
    .k-textbox:focus, .k-input:focus-within {
        border-color: hsl(28, 60%, 45%) !important;
        box-shadow: 0 0 0 3px hsl(28 60% 45% / 0.15) !important;
    }
    .pass-wrapper { position: relative; }
    .pass-wrapper .k-textbox { padding-right: 2.4rem !important; }
    .pass-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: hsl(25, 15%, 45%);
        display: flex;
        align-items: center;
        z-index: 5;
        padding: 0;
    }
    .pass-toggle:hover { color: hsl(25, 30%, 10%); }
    .pass-hint {
        font-size: 0.67rem;
        color: hsl(25, 15%, 40%);
        margin-top: 0.4rem;
    }
    .btn-gold {
        display: block;
        width: 100%;
        height: 42px;
        background: linear-gradient(135deg, hsl(28,60%,45%), hsl(18,70%,38%));
        color: hsl(35, 30%, 97%);
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        border-radius: 0.65rem;
        cursor: pointer;
        margin-top: 1.2rem;
        transition: filter 0.25s, box-shadow 0.25s;
        box-shadow: 0 4px 14px hsl(28 60% 45% / 0.32);
    }
    .btn-gold:hover:not(:disabled) {
        filter: brightness(1.08);
        box-shadow: 0 6px 20px hsl(28 60% 45% / 0.42);
    }
    .btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }
    @@keyframes bgPan {
        0%   { transform: scale(1.15) translate(0%, 0%); }
        25%  { transform: scale(1.20) translate(-2%, -1%); }
        50%  { transform: scale(1.15) translate(-1%, 1%); }
        75%  { transform: scale(1.20) translate(1%, -1%); }
        100% { transform: scale(1.15) translate(0%, 0%); }
    }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 1; transform: scale(1); }
    }
</style>

<div class="auth-page">
    <img class="auth-bg-img"
         src="https://images.unsplash.com/photo-1578926375605-eaf7559b1458?w=1920&q=80"
         alt="Art gallery" />
    <div class="auth-bg-overlay"></div>

    <div class="auth-wrapper">
        <div class="glass-card">

            <h1 class="auth-title">Set New Password</h1>
            <p class="auth-subtitle">Choose a strong password for your account.</p>

            <!-- Kendo Notification -->
            <span id="kNotify"></span>

            <!-- Hidden fields — email aur otp query string se -->
            <input type="hidden" id="hiddenEmail" value="@Model.c_Email" />
            <input type="hidden" id="hiddenOtp" value="@Model.c_Otp" />

            <form id="resetForm">

                <!-- New Password -->
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <div class="pass-wrapper">
                        <input id="c_NewPassword" name="c_NewPassword"
                               type="password" placeholder="••••••••"
                               data-required-msg="Password is required"
                               class="k-textbox" />
                        <button type="button" class="pass-toggle"
                                onclick="togglePass('c_NewPassword','eye-new')">
                            <svg id="eye-new" xmlns="http://www.w3.org/2000/svg"
                                 width="15" height="15" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span class="k-invalid-msg" data-for="c_NewPassword"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <div class="pass-wrapper">
                        <input id="c_ConfirmPassword" name="c_ConfirmPassword"
                               type="password" placeholder="••••••••"
                               data-required-msg="Please confirm password"
                               class="k-textbox" />
                        <button type="button" class="pass-toggle"
                                onclick="togglePass('c_ConfirmPassword','eye-conf')">
                            <svg id="eye-conf" xmlns="http://www.w3.org/2000/svg"
                                 width="15" height="15" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <p class="pass-hint">
                    Min 6 chars &middot; uppercase &middot; lowercase
                    &middot; number &middot; special char
                </p>

                <button type="submit" class="btn-gold" id="resetBtn">
                    Update Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
$(function () {
    // Kendo Notification
    var notify = $("#kNotify").kendoNotification({
        position: { pinned: true, top: 20, right: 20 },
        autoHideAfter: 3500,
        stacking: "down"
    }).data("kendoNotification");

    
    // Kendo TextBox
    $("#c_NewPassword").kendoTextBox();
    $("#c_ConfirmPassword").kendoTextBox();

    // Kendo Validator — custom rules
    var validator = $("#resetForm").kendoValidator({
        rules: {
            passwordStrength: function (input) {
                if (input.is("[name='c_NewPassword']") && input.val()) {
                    return /^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[@@$!%*?&]).{6,}$/.test(input.val());
                }
                return true;
            },
            passwordMatch: function (input) {
                if (input.is("[name='c_ConfirmPassword']")) {
                    return input.val() === $("#c_NewPassword").val();
                }
                return true;
            }
        },
        messages: {
            required:         "#= message #",
            passwordStrength: "Min 6 chars, uppercase, lowercase, number and special char",
            passwordMatch:    "Passwords do not match"
        }
    }).data("kendoValidator");

    // Toggle password visibility
    window.togglePass = function (inputId, iconId) {
        var inp = document.getElementById(inputId);
        var isText = inp.type === "text";
        inp.type = isText ? "password" : "text";
        document.getElementById(iconId).innerHTML = isText
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>' +
              '<circle cx="12" cy="12" r="3"/>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8' +
              'a18.45 18.45 0 015.06-5.94"/>' +
              '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8' +
              'a18.5 18.5 0 01-2.16 3.19"/>' +
              '<line x1="1" y1="1" x2="23" y2="23"/>';
    };

    // Submit — AJAX
    $("#resetForm").on("submit", function (e) {
        e.preventDefault();

        if (!validator.validate()) return;

        var payload = {
            c_Email:            $("#hiddenEmail").val().trim().toLowerCase(),
            c_Otp:             $("#hiddenOtp").val(),
            c_NewPassword:     $("#c_NewPassword").val(),
            c_ConfirmPassword: $("#c_ConfirmPassword").val()
        };

        var btn = $("#resetBtn");
        btn.prop("disabled", true).text("Updating...");

        $.ajax({
            url:  "http://localhost:5183/api/AuthApi/UserResetPassword",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (res) {
                btn.prop("disabled", false).text("Update Password");
                Swal.fire({
                    icon: "success",
                    title: "Password Updated!",
                    text: res.message || "Your password has been changed successfully.",
                    confirmButtonColor: "hsl(28,60%,45%)",
                    confirmButtonText: "Go to Login"
                }).then(function () {
                    window.location.href = "/Auth/UserLogin";
                });
            },
            error: function (err) {
                btn.prop("disabled", false).text("Update Password");
                var msg = "Something went wrong.";
                if (err.responseJSON && err.responseJSON.message)
                    msg = err.responseJSON.message;
                Swal.fire({
                    icon: "error",
                    title: "Failed",
                    text: msg,
                    confirmButtonColor: "hsl(28,60%,45%)"
                });
            }
        });
    });
});
</script>
}