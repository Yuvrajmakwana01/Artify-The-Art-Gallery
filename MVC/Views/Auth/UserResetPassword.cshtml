@model Repository.Models.t_ResetPassword
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password – Artify</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
    --bg: #DFE6E9; --cobalt: #03289F; --cobalt-dk: #021A6E; --cobalt-lt: #1A3DB5;
    --gold: #EDA312; --sky: #6B9BE6; --ink: #0A1628; --white: #FFFFFF; --err: #D63031;
}
html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); overflow: hidden; }

/* Mosaic BG */
.bg-stage { position: fixed; inset: 0; z-index: 0; overflow: hidden; background: var(--bg); }
.mosaic-grid {
    position: absolute; display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 3px; width: 210%; height: 210%; top: -55%; left: -55%; opacity: 0;
    transform: rotateX(14deg) rotateZ(8deg) skewX(3deg);
    animation: mosaicDrift 75s linear infinite; transition: opacity 1.8s ease;
}
.mosaic-grid.alive { opacity: 1; }
.mosaic-tile {
    width: 100%; height: 200px; background-size: cover; background-position: center;
    border-radius: 4px; animation: tilePulse 20s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.12s);
}
@@keyframes mosaicDrift {
    0%   { transform: rotateX(14deg) rotateZ(8deg) skewX(3deg) translateY(0%); }
    100% { transform: rotateX(14deg) rotateZ(8deg) skewX(3deg) translateY(14%); }
}
@@keyframes tilePulse { 0%,100%{ filter:brightness(0.92) saturate(0.85); } 50%{ filter:brightness(1.05) saturate(1.05); } }
.bg-veil { position: absolute; inset: 0; z-index: 1; background: linear-gradient(135deg, rgba(223,230,233,0.80) 0%, rgba(223,230,233,0.50) 50%, rgba(223,230,233,0.78) 100%); }
.orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 1; }
.orb-a { width: 450px; height: 450px; background: radial-gradient(circle, rgba(107,155,230,0.20) 0%, transparent 70%); top: -10%; right: -5%; animation: orbDrift 22s ease-in-out infinite; }
.orb-b { width: 320px; height: 320px; background: radial-gradient(circle, rgba(237,163,18,0.12) 0%, transparent 70%); bottom: -10%; left: -5%; animation: orbDrift 28s ease-in-out infinite; animation-delay: -10s; }
@@keyframes orbDrift { 0%,100%{ transform:translate(0,0); } 50%{ transform:translate(-18px,14px); } }
.bg-grid {
    position: absolute; inset: 0; z-index: 1;
    background-image: linear-gradient(rgba(107,155,230,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(107,155,230,0.04) 1px, transparent 1px);
    background-size: 44px 44px; animation: gridShift 70s linear infinite;
}
@@keyframes gridShift { from{ background-position:0 0; } to{ background-position:44px 44px; } }

/* Shell */
.auth-shell { position: fixed; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; padding: 1rem; }

/* Glass Card */
.glass-card {
    position: relative; width: 100%; max-width: 420px;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(107,155,230,0.25); border-radius: 24px;
    padding: 2.4rem 2.2rem 2rem;
    box-shadow: 0 2px 0 rgba(255,255,255,0.9) inset, 0 0 0 1px rgba(255,255,255,0.4),
                0 24px 64px rgba(3,40,159,0.12), 0 4px 16px rgba(107,155,230,0.10);
    animation: cardReveal 0.7s cubic-bezier(0.16,1,0.3,1) both; overflow: hidden;
}
.glass-card::before {
    content: ''; position: absolute; top:0; left:0; right:0; height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--sky) 30%, var(--gold) 65%, transparent 100%); z-index: 2;
}
@@keyframes cardReveal { from{ opacity:0; transform:translateY(28px) scale(0.97); } to{ opacity:1; transform:translateY(0) scale(1); } }

/* Brand */
.card-brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1.4rem; animation: fadeUp 0.5s 0.1s both; }
.brand-gem { width: 32px; height: 32px; background: linear-gradient(135deg, var(--cobalt), var(--cobalt-lt)); border-radius: 8px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(3,40,159,0.28); overflow: hidden; }
.brand-name { font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: var(--cobalt); letter-spacing: 0.03em; }

/* Icon circle */
.icon-circle { width: 58px; height: 58px; border-radius: 50%; background: rgba(3,40,159,0.08); border: 2px solid rgba(107,155,230,0.25); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; animation: fadeUp 0.5s 0.16s both; box-shadow: 0 0 0 6px rgba(107,155,230,0.07); }

/* Heading */
.card-heading { text-align: center; margin-bottom: 1.4rem; animation: fadeUp 0.5s 0.22s both; }
.card-heading h1 { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; color: var(--gold); line-height: 1.1; margin-bottom: 0.3rem; }
.card-heading p { font-size: 0.76rem; color: var(--sky); font-weight: 400; }

/* Form fields */
.form-group { margin-bottom: 1rem; animation: fadeUp 0.5s 0.28s both; }
.form-group + .form-group { animation-delay: 0.34s; }
.form-label { display: block; font-size: 0.64rem; font-weight: 600; color: var(--cobalt); letter-spacing: 0.10em; text-transform: uppercase; margin-bottom: 0.32rem; }

.pass-wrapper { position: relative; display: flex; align-items: center; }
.i-icon { position: absolute; left: 12px; color: var(--sky); pointer-events: none; display: flex; z-index: 2; transition: color 0.25s; }
.pass-wrapper:focus-within .i-icon { color: var(--cobalt); }

/* Plain input — no Kendo to avoid double rendering */
.plain-input {
    width: 100%; height: 48px;
    background: rgba(255,255,255,0.60);
    border: 1.5px solid rgba(107,155,230,0.22);
    border-radius: 12px;
    padding: 0 2.8rem 0 2.8rem;
    font-family: 'Jost', sans-serif; font-size: 0.875rem;
    color: var(--ink); outline: none;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    -webkit-appearance: none;
}
.plain-input::placeholder { color: rgba(107,155,230,0.45); }
.plain-input:focus {
    border-color: var(--cobalt);
    background: var(--white);
    box-shadow: 0 0 0 3.5px rgba(3,40,159,0.10);
}

.pass-toggle { position: absolute; right: 10px; background: none; border: none; cursor: pointer; color: var(--sky); display: flex; align-items: center; z-index: 5; padding: 0; transition: color 0.2s; }
.pass-toggle:hover { color: var(--cobalt); }

.field-error { font-size: 0.68rem; color: var(--err); display: block; margin-top: 0.28rem; min-height: 1rem; font-weight: 500; }

.pass-hint { font-size: 0.62rem; color: var(--sky); margin-top: 0.4rem; line-height: 1.5; animation: fadeUp 0.5s 0.42s both; }

/* Submit */
.btn-gold {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 50px;
    background: linear-gradient(130deg, var(--cobalt-lt) 0%, var(--cobalt) 55%, var(--cobalt-dk) 100%);
    color: var(--white); font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 600;
    border: 1px solid rgba(107,155,230,0.20); border-radius: 12px; cursor: pointer;
    letter-spacing: 0.06em; transition: transform 0.2s, box-shadow 0.3s, filter 0.2s;
    box-shadow: 0 6px 24px rgba(3,40,159,0.25); position: relative; overflow: hidden;
    margin-top: 1rem; animation: fadeUp 0.5s 0.48s both;
}
.btn-gold::before { content: ''; position: absolute; top:0; left:-100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent); transform: skewX(-18deg); transition: left 0.5s ease; }
.btn-gold:hover::before { left: 160%; }
.btn-gold:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(3,40,159,0.35); filter: brightness(1.08); }
.btn-gold:active:not(:disabled) { transform: translateY(0); }
.btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }
.btn-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; box-shadow: 0 0 8px rgba(237,163,18,0.7); }

.spinner { width: 15px; height: 15px; border: 2px solid rgba(255,255,255,0.25); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; }
@@keyframes spin { to { transform: rotate(360deg); } }
@@keyframes fadeUp { from{ opacity:0; transform:translateY(12px); } to{ opacity:1; transform:translateY(0); } }
</style>
</head>
<body>

<div class="bg-stage">
    <div class="mosaic-grid" id="artGrid"></div>
    <div class="bg-veil"></div>
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="bg-grid"></div>
</div>

<div class="auth-shell">
    <div class="glass-card">

        <div class="card-brand">
            <div class="brand-gem">
                <img src="/Images/Artify-Logos.png" alt="Artify" aria-hidden="true" style="width: 100%; height: 100%; object-fit: cover; transform: scale(2.65) translateX(3%);" />
            </div>
            <span class="brand-name">Artify</span>
        </div>

        <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" style="color:var(--cobalt)">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
        </div>

        <div class="card-heading">
            <h1>New Password</h1>
            <p>Choose a strong password for your Artify account.</p>
        </div>

        <!-- Hidden fields from query string -->
        <input type="hidden" id="hiddenEmail" value="@Model.c_Email" />
        <input type="hidden" id="hiddenOtp"   value="@Model.c_Otp" />

        <form id="resetForm" novalidate>

            <!-- New Password -->
            <div class="form-group">
                <label class="form-label">New Password</label>
                <div class="pass-wrapper">
                    <span class="i-icon">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                    </span>
                    <input id="c_NewPassword" name="c_NewPassword"
                           type="password" placeholder="••••••••"
                           class="plain-input" />
                    <button type="button" class="pass-toggle" onclick="togglePass('c_NewPassword','eye-new')">
                        <svg id="eye-new" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span class="field-error" id="newPassError"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label class="form-label">Confirm New Password</label>
                <div class="pass-wrapper">
                    <span class="i-icon">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                    </span>
                    <input id="c_ConfirmPassword" name="c_ConfirmPassword"
                           type="password" placeholder="••••••••"
                           class="plain-input" />
                    <button type="button" class="pass-toggle" onclick="togglePass('c_ConfirmPassword','eye-conf')">
                        <svg id="eye-conf" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span class="field-error" id="confPassError"></span>
            </div>

            <p class="pass-hint">Min 6 chars &middot; uppercase &middot; lowercase &middot; number &middot; special char</p>

            <button type="submit" class="btn-gold" id="resetBtn">
                <span class="btn-dot"></span>
                Update Password
            </button>
        </form>

    </div>
</div>

<script>
$(function () {

    var API_BASE       = 'http://localhost:5183';
    var CACHE_KEY      = 'unsplash_art_images';
    var CACHE_TIME_KEY = 'unsplash_last_fetch';
    var ONE_HOUR       = 3600000;

    @* /* Mosaic background */
    async function renderImages(images) {
        var grid = document.getElementById('artGrid');
        if (!grid) return;
        grid.innerHTML = '';
        var frag = document.createDocumentFragment();
        var promises = images.map(function(item, index) {
            return new Promise(function(resolve) {
                var tile = document.createElement('div');
                tile.className = 'mosaic-tile';
                tile.style.setProperty('--i', index);
                var url = item.urls ? item.urls.regular : (typeof item === 'string' ? item : '');
                if (!url) { resolve(); return; }
                var img = new Image();
                img.src = url;
                img.onload = function() { tile.style.backgroundImage = "url('" + url + "')"; frag.appendChild(tile); resolve(); };
                img.onerror = function() { resolve(); };
            });
        });
        await Promise.all(promises);
        grid.appendChild(frag);
        setTimeout(function() { grid.classList.add('alive'); }, 100);
    }

    async function loadMosaicBackground() {
        var cachedData = localStorage.getItem(CACHE_KEY);
        var lastFetch  = localStorage.getItem(CACHE_TIME_KEY);
        var now        = Date.now();
        if (cachedData && lastFetch && (now - lastFetch < ONE_HOUR)) { await renderImages(JSON.parse(cachedData)); return; }
        try {
            var res = await fetch(API_BASE + '/api/ImageApi/art-background?count=100');
            if (res.ok) {
                var data = await res.json();
                localStorage.setItem(CACHE_KEY, JSON.stringify(data));
                localStorage.setItem(CACHE_TIME_KEY, now.toString());
                await renderImages(data);
            } else { throw new Error('not ok'); }
        } catch(e) { if (cachedData) await renderImages(JSON.parse(cachedData)); }
    }
    loadMosaicBackground(); *@

    /* Toggle password visibility */
    window.togglePass = function (inputId, iconId) {
        var inp = document.getElementById(inputId);
        var isText = inp.type === "text";
        inp.type = isText ? "password" : "text";
        document.getElementById(iconId).innerHTML = isText
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>' +
              '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>' +
              '<line x1="1" y1="1" x2="23" y2="23"/>';
    };

    /* Form Submit */
    $("#resetForm").on("submit", function (e) {
        e.preventDefault();

        var newPass  = $("#c_NewPassword").val();
        var confPass = $("#c_ConfirmPassword").val();
        var valid    = true;

        $("#newPassError").text("");
        $("#confPassError").text("");

        if (!newPass) {
            $("#newPassError").text("Password is required"); valid = false;
        } else if (!/^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[@@$!%*?&]).{6,}$/.test(newPass)) {
            $("#newPassError").text("Min 6 chars, uppercase, lowercase, number and special char"); valid = false;
        }

        if (!confPass) {
            $("#confPassError").text("Please confirm your password"); valid = false;
        } else if (newPass && confPass !== newPass) {
            $("#confPassError").text("Passwords do not match"); valid = false;
        }

        if (!valid) return;

        var payload = {
            c_Email:            $("#hiddenEmail").val().trim().toLowerCase(),
            c_Otp:              $("#hiddenOtp").val(),
            c_NewPassword:      newPass,
            c_ConfirmPassword:  confPass
        };

        var btn = $("#resetBtn");
        btn.prop("disabled", true).html('<span class="spinner"></span> Updating...');

        $.ajax({
            url:  API_BASE + "/api/AuthApi/UserResetPassword",
            type: "POST", contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (res) {
                btn.prop("disabled", false).html('<span class="btn-dot"></span> Update Password');
                Swal.fire({
                    icon: "success", title: "Password Updated!",
                    text: res.message || "Your password has been changed successfully.",
                    confirmButtonColor: "#03289F", background: "#DFE6E9", color: "#0A1628",
                    confirmButtonText: "Go to Login"
                }).then(function () {
                    window.location.href = "/Auth/UserLogin";
                });
            },
            error: function (err) {
                btn.prop("disabled", false).html('<span class="btn-dot"></span> Update Password');
                var msg = "Something went wrong.";
                if (err.responseJSON && err.responseJSON.message) msg = err.responseJSON.message;
                Swal.fire({ icon: "error", title: "Failed", text: msg, confirmButtonColor: "#03289F", background: "#DFE6E9", color: "#0A1628" });
            }
        });
    });
});
</script>
</body>
</html>
