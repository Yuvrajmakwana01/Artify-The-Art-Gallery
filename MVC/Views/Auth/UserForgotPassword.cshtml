@* @model Repository.Models.t_ResetPassword
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
    // step: "email" | "otp" | "reset" | "done"
    var step = ViewBag.Step as string ?? "email";
}

<div class="auth-page">
    <img class="auth-bg-img"
         src="https://images.unsplash.com/photo-1578926375605-eaf7559b1458?w=1920&q=80"
         alt="Art gallery" />
    <div class="auth-bg-overlay"></div>

    <div class="auth-wrapper">
        <div class="glass-card">

            <!-- Back to login link (always visible) -->
            <a asp-action="UserLogin" asp-controller="Auth" class="btn-back">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Login
            </a>

            <!-- Server error -->
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }
            @if (ViewBag.Success != null)
            {
                <div class="alert-success">@ViewBag.Success</div>
            }

            <!-- ══ STEP 1: Enter Email ══ -->
            @if (step == "email")
            {
                <div class="animate-fade-up">
                    <h1 class="auth-title" style="font-size:1.5rem">Forgot Password?</h1>
                    <p class="auth-subtitle">Enter your email — we'll send a 6-digit OTP.</p>

                    <form asp-action="UserForgotPassword" asp-controller="Auth" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <!-- Kendo TextBox -->
                            <input id="fp-email" name="c_Email"
                                   type="email"
                                   placeholder="your@email.com"
                                   class="k-input k-rounded-md" />
                            <span class="field-error">@Html.ValidationMessage("c_Email")</span>
                        </div>

                        <button type="submit" class="btn-gold">Send OTP</button>
                    </form>
                </div>
            }

            <!-- ══ STEP 2: Enter OTP ══ -->
            @if (step == "otp")
            {
                <div class="animate-fade-up">
                    <!-- Envelope icon -->
                    <div style="text-align:center;margin-bottom:1rem">
                        <div style="width:56px;height:56px;border-radius:50%;
                                    background:hsl(28 60% 45%/0.15);
                                    display:flex;align-items:center;justify-content:center;margin:0 auto 0.75rem">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                 fill="none" viewBox="0 0 24 24" stroke="hsl(28,60%,45%)" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="auth-title" style="font-size:1.4rem">Enter OTP</h2>
                        <p class="auth-subtitle">
                            6-digit OTP sent to <strong style="color:var(--fg)">@ViewBag.Email</strong>
                        </p>
                    </div>

                    <form asp-action="UserVerifyOtp" asp-controller="Auth" method="post">
                        @Html.AntiForgeryToken()
                        <!-- Hidden email carried forward -->
                        <input type="hidden" name="c_Email" value="@ViewBag.Email" />

                        <!-- 6 OTP boxes — auto-advance on each digit -->
                        <div class="otp-row" id="otp-row">
                            @for (int i = 0; i < 6; i++)
                            {
                                <input class="otp-box"
                                       type="text"
                                       maxlength="1"
                                       inputmode="numeric"
                                       pattern="[0-9]"
                                       id="otp-@i"
                                       autocomplete="off" />
                            }
                        </div>
                        <!-- Hidden field that holds assembled OTP -->
                        <input type="hidden" name="c_Otp" id="otp-hidden" />

                        <span class="field-error" style="display:block;text-align:center;margin-top:0.5rem">
                            @Html.ValidationMessage("c_Otp")
                        </span>

                        <button type="submit" class="btn-gold" onclick="assembleOtp()">
                            Verify OTP
                        </button>
                    </form>

                    <!-- Resend OTP -->
                    <p style="text-align:center;font-size:0.78rem;color:var(--muted);margin-top:1rem">
                        Didn't receive it?
                        <a asp-action="UserForgotPassword" asp-controller="Auth"
                           asp-route-email="@ViewBag.Email"
                           class="link-accent">Resend OTP</a>
                    </p>
                </div>
            }

            <!-- ══ STEP 3: New Password ══ -->
            @if (step == "reset")
            {
                <div class="animate-fade-up">
                    <h1 class="auth-title" style="font-size:1.5rem">Set New Password</h1>
                    <p class="auth-subtitle">Choose a strong password for your account.</p>

                    <form asp-action="UserResetPassword" asp-controller="Auth" method="post">
                        @Html.AntiForgeryToken()
                        <!-- Hidden fields carried forward -->
                        <input type="hidden" name="c_Email" value="@Model?.c_Email" />
                        <input type="hidden" name="c_Otp"   value="@Model?.c_Otp" />

                        <!-- New Password -->
                        <div class="form-group">
                            <label class="form-label">New Password</label>
                            <div class="pass-wrapper">
                                <input id="c_NewPassword" name="c_NewPassword"
                                       type="password"
                                       placeholder="••••••••"
                                       class="k-input k-rounded-md"
                                       style="padding-right:2.2rem" />
                                <button type="button" class="pass-toggle"
                                        onclick="togglePass('c_NewPassword','eye-new')">
                                    <svg id="eye-new" xmlns="http://www.w3.org/2000/svg"
                                         width="15" height="15" fill="none"
                                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </button>
                            </div>
                            <span class="field-error">@Html.ValidationMessage("c_NewPassword")</span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="form-group">
                            <label class="form-label">Confirm New Password</label>
                            <div class="pass-wrapper">
                                <input id="c_ConfirmPassword" name="c_ConfirmPassword"
                                       type="password"
                                       placeholder="••••••••"
                                       class="k-input k-rounded-md"
                                       style="padding-right:2.2rem" />
                                <button type="button" class="pass-toggle"
                                        onclick="togglePass('c_ConfirmPassword','eye-conf')">
                                    <svg id="eye-conf" xmlns="http://www.w3.org/2000/svg"
                                         width="15" height="15" fill="none"
                                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </button>
                            </div>
                            <span class="field-error">@Html.ValidationMessage("c_ConfirmPassword")</span>
                        </div>

                        <p style="font-size:0.68rem;color:var(--muted);margin-top:0.4rem">
                            Min 6 chars · uppercase · lowercase · number · special char
                        </p>

                        <button type="submit" class="btn-gold">Update Password</button>
                    </form>
                </div>
            }

            <!-- ══ STEP 4: Done ══ -->
            @if (step == "done")
            {
                <div class="animate-fade-up" style="text-align:center;padding:1rem 0">
                    <!-- Checkmark icon -->
                    <div style="width:64px;height:64px;border-radius:50%;
                                background:hsl(120 40% 40%/0.12);
                                display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28"
                             fill="none" viewBox="0 0 24 24" stroke="hsl(120,40%,32%)" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <p style="font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--fg)">
                        Password Updated!
                    </p>
                    <p style="font-size:0.8rem;color:var(--muted);margin-top:0.4rem">
                        Your password has been changed successfully.
                    </p>
                    <a asp-action="UserLogin" asp-controller="Auth"
                       class="btn-gold"
                       style="display:inline-block;text-decoration:none;
                              line-height:42px;padding:0 2rem;margin-top:1.5rem;width:auto">
                        Back to Login
                    </a>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Kendo TextBox inits ──
    if (document.getElementById("fp-email"))
        $("#fp-email").kendoTextBox();
    if (document.getElementById("c_NewPassword"))
        $("#c_NewPassword").kendoTextBox();
    if (document.getElementById("c_ConfirmPassword"))
        $("#c_ConfirmPassword").kendoTextBox();

    // ── OTP boxes — auto advance to next box ──
    document.querySelectorAll(".otp-box").forEach(function(box, idx, boxes) {
        box.addEventListener("input", function() {
            // Only allow digits
            this.value = this.value.replace(/\D/g, "");
            if (this.value && idx < boxes.length - 1)
                boxes[idx + 1].focus();
        });
        box.addEventListener("keydown", function(e) {
            // Backspace goes to previous box
            if (e.key === "Backspace" && !this.value && idx > 0)
                boxes[idx - 1].focus();
        });
        // Allow paste of full 6-digit OTP
        box.addEventListener("paste", function(e) {
            e.preventDefault();
            var text = (e.clipboardData || window.clipboardData)
                         .getData("text").replace(/\D/g,"").slice(0,6);
            [...text].forEach(function(ch, i) {
                if (boxes[i]) boxes[i].value = ch;
            });
            if (boxes[Math.min(text.length, 5)]) boxes[Math.min(text.length, 5)].focus();
        });
    });

    // ── Assemble OTP from 6 boxes into hidden field ──
    function assembleOtp() {
        var val = "";
        document.querySelectorAll(".otp-box").forEach(function(b) { val += b.value; });
        document.getElementById("otp-hidden").value = val;
    }

    // ── Toggle password visibility ──
    function togglePass(inputId, iconId) {
        var inp = document.getElementById(inputId);
        var showing = inp.type === "text";
        inp.type = showing ? "password" : "text";
        document.getElementById(iconId).innerHTML = showing
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>' +
              '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>' +
              '<line x1="1" y1="1" x2="23" y2="23"/>';
    }
</script>
} *@

@model Repository.Models.t_ForgotPassword
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<style>
    .auth-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .auth-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        animation: bgPan 25s ease-in-out infinite;
    }
    .auth-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg,
            hsl(25 20% 8% / 0.70) 0%,
            hsl(25 20% 8% / 0.50) 50%,
            hsl(25 20% 8% / 0.75) 100%);
    }
    .auth-wrapper {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 440px;
        margin: 24px 16px;
        animation: scaleIn 0.4s ease-out;
    }
    .glass-card {
        background: hsl(35 30% 92% / 0.88);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid hsl(30 15% 82% / 0.35);
        border-radius: 1.25rem;
        padding: 2rem;
        box-shadow: 0 8px 32px -8px hsl(25 20% 10% / 0.40),
                    inset 0 1px 0 hsl(35 30% 97% / 0.18);
    }
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        color: hsl(22, 50%, 38%);
        font-size: 0.82rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        padding: 0;
        margin-bottom: 1rem;
        text-decoration: none;
        transition: color 0.2s;
    }
    .btn-back:hover { color: hsl(28, 60%, 45%); }
    .auth-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: hsl(25, 30%, 10%);
        margin: 0;
    }
    .auth-subtitle {
        font-size: 0.8rem;
        color: hsl(25, 15%, 35%);
        margin: 0.25rem 0 0;
        font-weight: 500;
    }
    .form-group { margin-top: 1rem; }
    .form-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        color: hsl(25, 30%, 10%);
        margin-bottom: 0.3rem;
    }
    .k-textbox, .k-input {
        background-color: hsl(32, 18%, 88%) !important;
        border-color: hsl(30, 15%, 78%) !important;
        border-radius: 0.6rem !important;
        color: hsl(25, 30%, 10%) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 0.85rem !important;
        height: 38px !important;
        width: 100% !important;
    }
    .k-textbox:focus, .k-input:focus-within {
        border-color: hsl(28, 60%, 45%) !important;
        box-shadow: 0 0 0 3px hsl(28 60% 45% / 0.15) !important;
    }
    .btn-gold {
        display: block;
        width: 100%;
        height: 42px;
        background: linear-gradient(135deg, hsl(28,60%,45%), hsl(18,70%,38%));
        color: hsl(35, 30%, 97%);
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        border-radius: 0.65rem;
        cursor: pointer;
        margin-top: 1.2rem;
        transition: filter 0.25s, box-shadow 0.25s;
        box-shadow: 0 4px 14px hsl(28 60% 45% / 0.32);
    }
    .btn-gold:hover:not(:disabled) {
        filter: brightness(1.08);
        box-shadow: 0 6px 20px hsl(28 60% 45% / 0.42);
    }
    .btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }
    @@keyframes bgPan {
        0%   { transform: scale(1.15) translate(0%, 0%); }
        25%  { transform: scale(1.20) translate(-2%, -1%); }
        50%  { transform: scale(1.15) translate(-1%, 1%); }
        75%  { transform: scale(1.20) translate(1%, -1%); }
        100% { transform: scale(1.15) translate(0%, 0%); }
    }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 1; transform: scale(1); }
    }
</style>

<div class="auth-page">
    <img class="auth-bg-img"
         src="https://images.unsplash.com/photo-1578926375605-eaf7559b1458?w=1920&q=80"
         alt="Art gallery" />
    <div class="auth-bg-overlay"></div>

    <div class="auth-wrapper">
        <div class="glass-card">

            <a href="/Auth/UserLogin" class="btn-back">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Login
            </a>

            <h1 class="auth-title">Forgot Password?</h1>
            <p class="auth-subtitle">Enter your email — we'll send a 6-digit OTP.</p>

            <!-- Kendo Notification -->
            <span id="kNotify"></span>

            <form id="forgotForm">
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input id="fp_email" name="c_Email"
                           type="email"
                           placeholder="your@email.com"
                           data-required-msg="Email is required"
                           data-email-msg="Invalid email format"
                           class="k-textbox" />
                </div>
                <button type="submit" class="btn-gold" id="sendOtpBtn">
                    Send OTP
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
$(function () {

    // Kendo Notification
    var notify = $("#kNotify").kendoNotification({
        position: { pinned: true, top: 20, right: 20 },
        autoHideAfter: 3500,
        stacking: "down"
    }).data("kendoNotification");

    // Kendo TextBox
    $("#fp_email").kendoTextBox();

    // Kendo Validator
    var validator = $("#forgotForm").kendoValidator({
        messages: {
            required: "#= message #",
            email:    "#= message #"
        }
    }).data("kendoValidator");

    // Submit — AJAX
    $("#forgotForm").on("submit", function (e) {
        e.preventDefault();

        if (!validator.validate()) return;

        var email = $("#fp_email").val().trim().toLowerCase();
        var btn   = $("#sendOtpBtn");
        btn.prop("disabled", true).text("Sending...");

        $.ajax({
            url:  "http://localhost:5183/api/AuthApi/UserForgotPassword",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({ c_Email: email }),
            success: function (res) {
                btn.prop("disabled", false).text("Send OTP");
                Swal.fire({
                    icon: "success",
                    title: "OTP Sent!",
                    text: res.message || "Check your email for the OTP.",
                    @* confirmButtonColor: "hsl(28,60%,45%)", *@
                    @* confirmButtonText: "Enter OTP" *@
                }).then(function () {
                    // OTP page pe redirect — email query string mein
                    window.location.href = "/Auth/UserVerifyOtp?email=" + encodeURIComponent(email);
                });
            },
            error: function (err) {
                btn.prop("disabled", false).text("Send OTP");
                var msg = "Something went wrong.";
                if (err.responseJSON && err.responseJSON.message)
                    msg = err.responseJSON.message;
                Swal.fire({
                    icon: "error",
                    title: "Failed",
                    text: msg,
                    confirmButtonColor: "hsl(28,60%,45%)"
                });
            }
        });
    });
});
</script>
}