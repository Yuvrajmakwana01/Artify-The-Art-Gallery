@model Repository.Models.t_ForgotPassword
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --bg:       #DFE6E9;
    --cobalt:   #03289F;
    --cobalt-dk:#021A6E;
    --cobalt-lt:#1A3DB5;
    --gold:     #EDA312;
    --gold-lt:  #F5C84A;
    --sky:      #6B9BE6;
    --sky-lt:   #A8C4F0;
    --ink:      #0A1628;
    --white:    #FFFFFF;
}

html, body {
    height: 100%; font-family: 'Jost', sans-serif;
    background: var(--bg); overflow: hidden;
}

/* ── Mosaic BG ── */
.bg-stage {
    position: fixed; inset: 0; z-index: 0; overflow: hidden; background: var(--bg);
}
.mosaic-grid {
    position: absolute;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 3px;
    width: 210%; height: 210%;
    top: -55%; left: -55%;
    opacity: 0;
    transform: rotateX(14deg) rotateZ(8deg) skewX(3deg);
    animation: mosaicDrift 75s linear infinite;
    transition: opacity 1.8s ease;
}
.mosaic-grid.alive { opacity: 1; }
.mosaic-tile {
    width: 100%; height: 200px;
    background-size: cover; background-position: center;
    border-radius: 4px;
    animation: tilePulse 20s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.12s);
}
@@keyframes mosaicDrift {
    0%   { transform: rotateX(14deg) rotateZ(8deg) skewX(3deg) translateY(0%); }
    100% { transform: rotateX(14deg) rotateZ(8deg) skewX(3deg) translateY(14%); }
}
@@keyframes tilePulse {
    0%,100% { filter: brightness(0.92) saturate(0.85); }
    50%      { filter: brightness(1.05) saturate(1.05); }
}
.bg-veil {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(135deg, rgba(223,230,233,0.80) 0%, rgba(223,230,233,0.50) 50%, rgba(223,230,233,0.78) 100%);
}
.orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none; z-index: 1;
}
.orb-a {
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(107,155,230,0.20) 0%, transparent 70%);
    top: -10%; right: -5%;
    animation: orbDrift 22s ease-in-out infinite;
}
.orb-b {
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(237,163,18,0.12) 0%, transparent 70%);
    bottom: -10%; left: -5%;
    animation: orbDrift 28s ease-in-out infinite; animation-delay: -10s;
}
@@keyframes orbDrift { 0%,100%{transform:translate(0,0);} 50%{transform:translate(-18px,14px);} }
.bg-grid {
    position: absolute; inset: 0; z-index: 1;
    background-image:
        linear-gradient(rgba(107,155,230,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(107,155,230,0.04) 1px, transparent 1px);
    background-size: 44px 44px;
    animation: gridShift 70s linear infinite;
}
@@keyframes gridShift { from{background-position:0 0;} to{background-position:44px 44px;} }

/* ── Shell ── */
.auth-shell {
    position: fixed; inset: 0; z-index: 10;
    display: flex; align-items: center; justify-content: center; padding: 1rem;
}

/* ── Glass Card ── */
.glass-card {
    position: relative;
    width: 100%; max-width: 420px;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(107,155,230,0.25);
    border-radius: 24px;
    padding: 2.4rem 2.2rem 2rem;
    box-shadow:
        0 2px 0 rgba(255,255,255,0.9) inset,
        0 0 0 1px rgba(255,255,255,0.4),
        0 24px 64px rgba(3,40,159,0.12),
        0 4px 16px rgba(107,155,230,0.10);
    animation: cardReveal 0.7s cubic-bezier(0.16,1,0.3,1) both;
    overflow: hidden;
}
.glass-card::before {
    content: '';
    position: absolute; top:0; left:0; right:0; height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--sky) 30%, var(--gold) 65%, transparent 100%);
    z-index: 2;
}
@@keyframes cardReveal {
    from { opacity:0; transform: translateY(28px) scale(0.97); }
    to   { opacity:1; transform: translateY(0) scale(1); }
}

/* ── Brand ── */
.card-brand {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 1.6rem;
    animation: fadeUp 0.5s 0.1s both;
}
.brand-gem {
    width: 32px; height: 32px;
    background: linear-gradient(135deg, var(--cobalt), var(--cobalt-lt));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(3,40,159,0.28);
}
.brand-gem svg { width: 15px; height: 15px; }
.brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem; font-weight: 700;
    color: var(--cobalt); letter-spacing: 0.03em;
}

/* ── Icon circle ── */
.icon-circle {
    width: 58px; height: 58px; border-radius: 50%;
    background: rgba(3,40,159,0.08);
    border: 2px solid rgba(107,155,230,0.25);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.2rem;
    animation: fadeUp 0.5s 0.18s both;
    box-shadow: 0 0 0 6px rgba(107,155,230,0.07);
}

/* ── Heading ── */
.card-heading {
    text-align: center; margin-bottom: 1.6rem;
    animation: fadeUp 0.5s 0.24s both;
}
.card-heading h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem; font-weight: 700;
    color: var(--gold); line-height: 1.1; margin-bottom: 0.3rem;
}
.card-heading p { font-size: 0.76rem; color: var(--sky); font-weight: 400; }

/* ── Back link ── */
.btn-back {
    display: inline-flex; align-items: center; gap: 5px;
    background: none; border: none; cursor: pointer;
    color: var(--cobalt); font-size: 0.75rem; font-weight: 600;
    font-family: 'Jost', sans-serif; padding: 0;
    margin-bottom: 1.4rem; text-decoration: none;
    transition: color 0.2s; animation: fadeUp 0.5s 0.05s both;
}
.btn-back:hover { color: var(--gold); }

/* ── Field ── */
.form-group {
    margin-bottom: 1rem;
    animation: fadeUp 0.5s 0.30s both;
}
.form-label {
    display: block; font-size: 0.64rem; font-weight: 600;
    color: var(--cobalt); letter-spacing: 0.10em; text-transform: uppercase;
    margin-bottom: 0.32rem;
}
.input-shell { position: relative; display: flex; align-items: center; }
.i-icon {
    position: absolute; left: 12px;
    color: var(--sky); pointer-events: none; display: flex; transition: color 0.25s;
}
.input-shell:focus-within .i-icon { color: var(--cobalt); }

.k-textbox {
    width: 100%; height: 48px;
    background: rgba(255,255,255,0.60) !important;
    border: 1.5px solid rgba(107,155,230,0.22) !important;
    border-radius: 12px !important;
    padding: 0 1rem 0 2.8rem !important;
    font-family: 'Jost', sans-serif !important; font-size: 0.875rem !important;
    color: var(--ink) !important; outline: none;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s !important;
    -webkit-appearance: none;
    box-shadow: none !important;
}
.k-textbox::placeholder { color: rgba(107,155,230,0.45) !important; }
.k-textbox:focus {
    border-color: var(--cobalt) !important;
    background: var(--white) !important;
    box-shadow: 0 0 0 3.5px rgba(3,40,159,0.10) !important;
}

/* ── Submit ── */
.btn-gold {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 50px;
    background: linear-gradient(130deg, var(--cobalt-lt) 0%, var(--cobalt) 55%, var(--cobalt-dk) 100%);
    color: var(--white);
    font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 600;
    border: 1px solid rgba(107,155,230,0.20);
    border-radius: 12px; cursor: pointer;
    letter-spacing: 0.06em;
    transition: transform 0.2s, box-shadow 0.3s, filter 0.2s;
    box-shadow: 0 6px 24px rgba(3,40,159,0.25);
    position: relative; overflow: hidden;
    animation: fadeUp 0.5s 0.36s both;
}
.btn-gold::before {
    content: '';
    position: absolute; top:0; left:-100%;
    width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    transform: skewX(-18deg); transition: left 0.5s ease;
}
.btn-gold:hover::before { left: 160%; }
.btn-gold:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(3,40,159,0.35);
    filter: brightness(1.08);
}
.btn-gold:active:not(:disabled) { transform: translateY(0); }
.btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }
.btn-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); flex-shrink: 0;
    box-shadow: 0 0 8px rgba(237,163,18,0.7);
}

/* Spinner */
.spinner {
    width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,0.25);
    border-top-color: white;
    border-radius: 50%; animation: spin 0.7s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }

@@keyframes fadeUp {
    from { opacity:0; transform: translateY(12px); }
    to   { opacity:1; transform: translateY(0); }
}
</style>

<div class="bg-stage">
    <div class="mosaic-grid" id="artGrid"></div>
    <div class="bg-veil"></div>
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="bg-grid"></div>
</div>

<div class="auth-shell">
    <div class="glass-card">

        <div class="card-brand">
            <div class="brand-gem">
                @* <svg viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                </svg> *@
                <img src="/Images/bob-logo.png" alt="Artify" style="width: 35px; height:35px; ">
            </div>
            <span class="brand-name">Artify</span>
        </div>

        <a href="/Auth/UserLogin" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Login
        </a>

        <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" style="color: var(--cobalt)">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
        </div>

        <div class="card-heading">
            <h1>Forgot Password?</h1>
            <p>Enter your email — we'll send you a 6-digit OTP to reset it.</p>
        </div>

        <!-- Kendo Notification -->
        <span id="kNotify"></span>

        <form id="forgotForm">
            <div class="form-group">
                <label class="form-label">Email Address</label>
                <div class="input-shell">
                    <span class="i-icon">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </span>
                    <input id="fp_email" name="c_Email" type="email"
                           placeholder="your@email.com"
                           data-required-msg="Email is required"
                           data-email-msg="Invalid email format"
                           class="k-textbox" />
                </div>
            </div>
            <button type="submit" class="btn-gold" id="sendOtpBtn">
                <span class="btn-dot"></span>
                Send OTP
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
$(function () {

    var API_BASE       = 'http://localhost:5183';
    var CACHE_KEY      = 'unsplash_art_images';
    var CACHE_TIME_KEY = 'unsplash_last_fetch';
    var ONE_HOUR       = 3600000;

    /* Mosaic background */
    async function renderImages(images) {
        var grid = document.getElementById('artGrid');
        if (!grid) return;
        grid.innerHTML = '';
        var frag = document.createDocumentFragment();
        var promises = images.map(function(item, index) {
            return new Promise(function(resolve) {
                var tile = document.createElement('div');
                tile.className = 'mosaic-tile';
                tile.style.setProperty('--i', index);
                var url = item.urls ? item.urls.regular : (typeof item === 'string' ? item : '');
                if (!url) { resolve(); return; }
                var img = new Image();
                img.src = url;
                img.onload = function() { tile.style.backgroundImage = "url('" + url + "')"; frag.appendChild(tile); resolve(); };
                img.onerror = function() { resolve(); };
            });
        });
        await Promise.all(promises);
        grid.appendChild(frag);
        setTimeout(function() { grid.classList.add('alive'); }, 100);
    }
    async function loadMosaicBackground() {
        var cachedData = localStorage.getItem(CACHE_KEY);
        var lastFetch  = localStorage.getItem(CACHE_TIME_KEY);
        var now        = Date.now();
        if (cachedData && lastFetch && (now - lastFetch < ONE_HOUR)) { await renderImages(JSON.parse(cachedData)); return; }
        try {
            var res = await fetch(API_BASE + '/api/ImageApi/art-background?count=100');
            if (res.ok) {
                var data = await res.json();
                localStorage.setItem(CACHE_KEY, JSON.stringify(data));
                localStorage.setItem(CACHE_TIME_KEY, now.toString());
                await renderImages(data);
            } else { throw new Error('not ok'); }
        } catch(e) { if (cachedData) await renderImages(JSON.parse(cachedData)); }
    }
    loadMosaicBackground();

    // Kendo Notification
    var notify = $("#kNotify").kendoNotification({
        position: { pinned: true, top: 20, right: 20 },
        autoHideAfter: 3500, stacking: "down"
    }).data("kendoNotification");

    // Kendo TextBox
    $("#fp_email").kendoTextBox();

    // Kendo Validator
    var validator = $("#forgotForm").kendoValidator({
        messages: { required: "#= message #", email: "#= message #" }
    }).data("kendoValidator");

    // Submit — AJAX
    $("#forgotForm").on("submit", function (e) {
        e.preventDefault();
        if (!validator.validate()) return;
        var email = $("#fp_email").val().trim().toLowerCase();
        var btn   = $("#sendOtpBtn");
        btn.prop("disabled", true).html('<span class="spinner"></span> Sending...');
        $.ajax({
            url:  "http://localhost:5183/api/AuthApi/UserForgotPassword",
            type: "POST", contentType: "application/json",
            data: JSON.stringify({ c_Email: email }),
            success: function (res) {
                btn.prop("disabled", false).html('<span class="btn-dot"></span> Send OTP');
                Swal.fire({
                    icon: "success", title: "OTP Sent!",
                    text: res.message || "Check your email for the OTP.",
                    confirmButtonColor: "#03289F", background: "#DFE6E9", color: "#0A1628"
                }).then(function () {
                    window.location.href = "/Auth/UserVerifyOtp?email=" + encodeURIComponent(email);
                });
            },
            error: function (err) {
                btn.prop("disabled", false).html('<span class="btn-dot"></span> Send OTP');
                var msg = "Something went wrong.";
                if (err.responseJSON && err.responseJSON.message) msg = err.responseJSON.message;
                Swal.fire({ icon: "error", title: "Failed", text: msg, confirmButtonColor: "#03289F", background: "#DFE6E9", color: "#0A1628" });
            }
        });
    });
});
</script>
}
