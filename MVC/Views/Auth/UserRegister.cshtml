@model Repository.Models.t_UserRegister
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<style>
    /* ── Auth page wrapper ── */
    .auth-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* Background image with slow pan */
    .auth-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        animation: bgPan 25s ease-in-out infinite;
    }

    /* Dark overlay */
    .auth-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            hsl(25 20% 8% / 0.70) 0%,
            hsl(25 20% 8% / 0.50) 50%,
            hsl(25 20% 8% / 0.75) 100%
        );
    }

    /* Card wrapper */
    .auth-wrapper {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 520px;
        margin: 24px 16px;
        animation: scaleIn 0.4s ease-out;
    }

    /* Glass card */
    .glass-card {
        background: hsl(35 30% 92% / 0.88);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid hsl(30 15% 82% / 0.35);
        border-radius: 1.25rem;
        padding: 2rem 2rem 1.5rem;
        box-shadow:
            0 8px 32px -8px hsl(25 20% 10% / 0.40),
            inset 0 1px 0 hsl(35 30% 97% / 0.18);
    }

    /* Logo float */
    .logo-float {
        width: 64px;
        height: 64px;
        object-fit: contain;
        display: block;
        margin: 0 auto 0.6rem;
        animation: float 3s ease-in-out infinite;
    }

    .auth-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: hsl(25, 30%, 10%);
        text-align: center;
        margin: 0;
    }

    .auth-subtitle {
        font-size: 0.8rem;
        color: hsl(25, 15%, 35%);
        text-align: center;
        margin: 0.25rem 0 0;
        font-weight: 500;
    }

    /* ── Form layout ── */
    .form-group {
        margin-top: 0.9rem;
    }

    .form-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        color: hsl(25, 30%, 10%);
        margin-bottom: 0.3rem;
    }

    .form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-top: 0.9rem;
    }

    /* ── Kendo input override — beige theme ── */
    .k-textbox,
    .k-input.k-textbox,
    .k-input {
        background-color: hsl(32, 18%, 88%) !important;
        border-color: hsl(30, 15%, 78%) !important;
        border-radius: 0.6rem !important;
        color: hsl(25, 30%, 10%) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 0.85rem !important;
        height: 38px !important;
        width: 100% !important;
        transition: border-color 0.25s, box-shadow 0.25s !important;
    }

    .k-textbox:focus,
    .k-input:focus-within {
        border-color: hsl(28, 60%, 45%) !important;
        box-shadow: 0 0 0 3px hsl(28 60% 45% / 0.15) !important;
        outline: none !important;
    }

    /* Kendo DropDownList */
    .k-dropdownlist {
        background-color: hsl(32, 18%, 88%) !important;
        border-color: hsl(30, 15%, 78%) !important;
        border-radius: 0.6rem !important;
        height: 38px !important;
        width: 100% !important;
        font-size: 0.85rem !important;
        font-family: 'Inter', sans-serif !important;
        color: hsl(25, 30%, 10%) !important;
    }

    .k-dropdownlist:focus,
    .k-dropdownlist.k-focus {
        border-color: hsl(28, 60%, 45%) !important;
        box-shadow: 0 0 0 3px hsl(28 60% 45% / 0.15) !important;
    }

    .k-list-item.k-selected,
    .k-list-item:hover {
        background-color: hsl(28, 60%, 45%) !important;
        color: hsl(35, 30%, 97%) !important;
    }

    /* Password wrapper */
    .pass-wrapper {
        position: relative;
    }

    .pass-wrapper .k-textbox,
    .pass-wrapper .k-input {
        padding-right: 2.4rem !important;
    }

    .pass-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: hsl(25, 15%, 45%);
        display: flex;
        align-items: center;
        z-index: 5;
        padding: 0;
        line-height: 1;
    }

    .pass-toggle:hover {
        color: hsl(25, 30%, 10%);
    }

    /* Kendo Validator error tooltip override */
    .k-tooltip-validation {
        background: hsl(0, 65%, 48%) !important;
        border-color: hsl(0, 65%, 40%) !important;
        border-radius: 0.4rem !important;
        font-size: 0.72rem !important;
        font-family: 'Inter', sans-serif !important;
        margin-top: 3px !important;
        padding: 3px 8px !important;
    }

    .k-tooltip-validation .k-callout {
        color: hsl(0, 65%, 48%) !important;
    }

    /* ── Profile image upload ── */
    .upload-zone {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 84px;
        height: 84px;
        border-radius: 50%;
        border: 2px dashed hsl(30, 15%, 70%);
        background: hsl(32, 18%, 88%);
        cursor: pointer;
        margin: 0.8rem auto 0;
        transition: border-color 0.25s, background 0.25s;
    }

    .upload-zone:hover {
        border-color: hsl(28, 60%, 45%);
        background: hsl(32, 22%, 85%);
    }

    .upload-zone span {
        font-size: 0.62rem;
        color: hsl(25, 15%, 40%);
        margin-top: 3px;
        font-family: 'Inter', sans-serif;
    }

    .profile-preview-wrap {
        position: relative;
        width: 84px;
        margin: 0.8rem auto 0;
    }

    .profile-preview-wrap img {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        object-fit: cover;
        border: 2.5px solid hsl(28 60% 45% / 0.40);
        display: block;
    }

    .remove-img-btn {
        position: absolute;
        top: -3px;
        right: -3px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: hsl(0, 65%, 48%);
        border: none;
        cursor: pointer;
        color: white;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        transition: background 0.2s;
    }

    .remove-img-btn:hover {
        background: hsl(0, 65%, 40%);
    }

    /* ── Gold submit button ── */
    .btn-gold {
        display: block;
        width: 100%;
        height: 42px;
        background: linear-gradient(135deg, hsl(28,60%,45%), hsl(18,70%,38%));
        color: hsl(35, 30%, 97%);
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;   
        border-radius: 0.65rem;
        cursor: pointer;
        margin-top: 1.2rem;
        transition: filter 0.25s, box-shadow 0.25s, transform 0.1s;
        box-shadow: 0 4px 14px hsl(28 60% 45% / 0.32);
        letter-spacing: 0.01em;
    }

    .btn-gold:hover:not(:disabled) {
        filter: brightness(1.08);
        box-shadow: 0 6px 20px hsl(28 60% 45% / 0.42);
    }

    .btn-gold:active:not(:disabled) {
        transform: scale(0.985);
    }

    .btn-gold:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    /* ── Bottom footer link ── */
    .auth-footer {
        text-align: center;
        font-size: 0.82rem;
        color: hsl(25 30% 10% / 0.60);
        font-weight: 500;
        margin-top: 1.1rem;
    }

    .auth-footer a {
        color: hsl(22, 50%, 38%);
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.2s;
    }

    .auth-footer a:hover {
        color: hsl(28, 60%, 45%);
    }

    /* Password hint text */
    .pass-hint {
        font-size: 0.67rem;
        color: hsl(25, 15%, 40%);
        margin-top: 0.35rem;
    }

    /* ── Kendo Notification custom style ── */
    .k-notification-wrap {
        font-family: 'Inter', sans-serif !important;
        font-size: 0.82rem !important;
        border-radius: 0.6rem !important;
    }

    /* ── Animations ── */
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-6px); }
    }

    @@keyframes bgPan {
        0%   { transform: scale(1.15) translate(0%, 0%); }
        25%  { transform: scale(1.20) translate(-2%, -1%); }
        50%  { transform: scale(1.15) translate(-1%, 1%); }
        75%  { transform: scale(1.20) translate(1%, -1%); }
        100% { transform: scale(1.15) translate(0%, 0%); }
    }

    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 1; transform: scale(1); }
    }
</style>

<div class="auth-page">
    <img class="auth-bg-img"
         src="https://images.unsplash.com/photo-1578926375605-eaf7559b1458?w=1920&q=80"
         alt="Art gallery background" />
    <div class="auth-bg-overlay"></div>

    <div class="auth-wrapper">
        <div class="glass-card">

            @* <img class="logo-float"
                 src="~MVC/wwwroot/images/artify-logo.png"
                 onerror="this.style.display='none'"
                 alt="Artify" /> *@
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join the Artify community</p>

            <!-- Kendo Notification container -->
            <span id="kNotification"></span>

            <!-- FORM — no asp-action, AJAX submit karega -->
            <form id="registerForm" novalidate="novalidate">

                <!-- Profile Image -->
                <div style="text-align:center">
                    <input type="file"
                           id="profileImageFile"
                           name="profileImageFile"
                           accept="image/*"
                           style="display:none"
                           onchange="onImageSelected(this)" />

                    <div id="preview-wrap" class="profile-preview-wrap" style="display:none">
                        <img id="preview-img" src="" alt="Profile preview" />
                        <button type="button" class="remove-img-btn"
                                onclick="removeImage()" title="Remove image">
                            &#x2715;
                        </button>
                    </div>

                    <div id="upload-zone" class="upload-zone"
                         onclick="document.getElementById('profileImageFile').click()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                             fill="none" viewBox="0 0 24 24"
                             stroke="hsl(25,15%,40%)" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1
                                     m-4-8l-4-4m0 0L8 8m4-4v12"/>
                        </svg>
                        <span>Upload Photo</span>
                    </div>
                </div>

                <!-- Full Name + Username -->
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label" for="c_FullName">Full Name</label>
                        <input id="c_FullName" name="c_FullName"
                               type="text" placeholder="John Doe"
                               data-required-msg="Full Name is required"
                               data-pattern="^[a-zA-Z\s]+$"
                               data-pattern-msg="Only letters and spaces allowed"
                               class="k-textbox" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="c_UserName">Username</label>
                        <input id="c_UserName" name="c_UserName"
                               type="text" placeholder="johndoe99"
                               data-required-msg="Username is required"
                               data-minlength="3"
                               data-minlength-msg="Min 3 characters"
                               class="k-textbox" />
                    </div>
                </div>

                <!-- Email -->
                <div class="form-group">
                    <label class="form-label" for="c_Email">Email</label>
                    <input id="c_Email" name="c_Email"
                           type="email" placeholder="your@email.com"
                           data-required-msg="Email is required"
                           data-email-msg="Invalid email format"
                           class="k-textbox" />
                </div>

                <!-- Gender + Mobile -->
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label" for="c_Gender">Gender</label>
                        <!--
                            Kendo DropDownList — select element
                            kendoDropDownList() JS mein call hoga
                        -->
                        <select id="c_Gender" name="c_Gender"
                                data-required-msg="Gender is required">
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="c_Mobile">Mobile</label>
                        <!--
                            Kendo MaskedTextBox — sirf digits, exactly 10
                            mask: "0000000000" = 10 digits
                        -->
                        <input id="c_Mobile" name="c_Mobile"
                               placeholder="1234567890" />
                    </div>
                </div>

                <!-- Password + Confirm Password -->
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label" for="c_Password">Password</label>
                        <div class="pass-wrapper">
                            <input id="c_Password" name="c_Password"
                                   type="password" placeholder="••••••••"
                                   data-required-msg="Password is required"
                                   class="k-textbox" />
                            <button type="button" class="pass-toggle"
                                    onclick="togglePass('c_Password','eye-pass')">
                                <svg id="eye-pass" xmlns="http://www.w3.org/2000/svg"
                                     width="15" height="15" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="c_ConfirmPassword">Confirm Password</label>
                        <div class="pass-wrapper">
                            <input id="c_ConfirmPassword" name="c_ConfirmPassword"
                                   type="password" placeholder="••••••••"
                                   data-required-msg="Please confirm password"
                                   class="k-textbox" />
                            <button type="button" class="pass-toggle"
                                    onclick="togglePass('c_ConfirmPassword','eye-conf')">
                                <svg id="eye-conf" xmlns="http://www.w3.org/2000/svg"
                                     width="15" height="15" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <p class="pass-hint">
                    Min 6 chars &middot; uppercase &middot; lowercase
                    &middot; number &middot; special char (@@$!%*?&amp;)
                </p>

                <button type="submit" class="btn-gold" id="registerBtn">
                    Create Account
                </button>
            </form>

            <p class="auth-footer">
                Already have an account?
                <a asp-action="UserLogin" asp-controller="Auth">Sign In</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {

    // ════════════════════════════════════════════════
    // 1. KENDO NOTIFICATION
    //    Top-center mein dikhega — success green, error red
    // ════════════════════════════════════════════════
    var notification = $("#kNotification").kendoNotification({
        position: { pinned: true, top: 20, right: 20 },
        autoHideAfter: 4000,      // 4 sec baad hide
        stacking: "down",
        templates: [
            {
                type: "success",
                template: "<div style='padding:6px 4px;font-family:Inter,sans-serif'>" +
                        "<strong>✔ Success</strong> &nbsp; #: message #</div>"
            },
            {
                type: "error",
                template: "<div style='padding:6px 4px;font-family:Inter,sans-serif'>" +
                        "<strong>✖ Error</strong> &nbsp; #: message #</div>"
            },
            {
                type: "warning",
                template: "<div style='padding:6px 4px;font-family:Inter,sans-serif'>" +
                        "<strong>⚠ Warning</strong> &nbsp; #: message #</div>"
            }
        ]
    }).data("kendoNotification");

    // Helper functions — show karna easy
    function showSuccess(msg) { notification.show({ message: msg }, "success"); }
    function showError(msg)   { notification.show({ message: msg }, "error");   }
    function showWarning(msg) { notification.show({ message: msg }, "warning"); }


    // ════════════════════════════════════════════════
    // 2. KENDO TEXTBOX — sab inputs init
    // ════════════════════════════════════════════════
    $("#c_FullName").kendoTextBox();
    $("#c_UserName").kendoTextBox();
    $("#c_Email").kendoTextBox();
    $("#c_Password").kendoTextBox();
    $("#c_ConfirmPassword").kendoTextBox();


    // ════════════════════════════════════════════════
    // 3. KENDO DROPDOWNLIST — Gender
    // ════════════════════════════════════════════════
    $("#c_Gender").kendoDropDownList({
        optionLabel: "Select Gender"
    });


    // ════════════════════════════════════════════════
    // 4. KENDO MASKEDTEXTBOX — Mobile (sirf 10 digits)
    //    mask "0000000000" = exactly 10 numeric digits
    // ════════════════════════════════════════════════
    $("#c_Mobile").kendoMaskedTextBox({
        mask: "0000000000",
        promptChar: "_"
    });


    // ════════════════════════════════════════════════
    // 5. KENDO VALIDATOR
    //    Custom rules — password strength + confirm match
    // ════════════════════════════════════════════════
    var validator = $("#registerForm").kendoValidator({ 
        rules: {
            // Custom rule: password strong hona chahiye
            passwordStrength: function (input) {
                if (input.is("[name='c_Password']")) {
                    var val = input.val().trim();

                    if (val.length === 0) return true; // required rule handle karega
                    return /^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[@@$!%*?&]).{6,}$/.test(val);
            }
                return true;
            },
            // Custom rule: confirm password match karna chahiye
            passwordMatch: function (input) {
                if (input.is("[name='c_ConfirmPassword']")) {
                    return input.val() === $("#c_Password").val();
                }
                return true;
            },
            // Custom rule: gender select hona chahiye
            genderRequired: function (input) {
                if (input.is("[name='c_Gender']")) {
                    return $("#c_Gender").data("kendoDropDownList").value() !== "";
                }
                return true;
            }
        },
        messages: {
            passwordStrength: "Min 6 chars, uppercase, lowercase, number and special char",
            passwordMatch:    "Passwords do not match",
            genderRequired:   "Please select a gender",
            required:         "#= message #",   // data-required-msg use karega
            email:            "#= message #",
            pattern:          "#= message #",
            minlength:        "#= message #"
        }
    }).data("kendoValidator");


    // ════════════════════════════════════════════════
    // 6. PROFILE IMAGE — preview + remove
    // ════════════════════════════════════════════════
    window.onImageSelected = function (input) {
        var file = input.files[0];
        if (!file) return;

        if (file.size > 5 * 1024 * 1024) {
            showWarning("Image must be under 5MB");
            input.value = "";
            return;
        }

        var reader = new FileReader();
        reader.onload = function (e) {
            $("#preview-img").attr("src", e.target.result);
            $("#preview-wrap").show();
            $("#upload-zone").hide();
        };
        reader.readAsDataURL(file);
    };

    window.removeImage = function () {
        $("#profileImageFile").val("");
        $("#preview-img").attr("src", "");
        $("#preview-wrap").hide();
        $("#upload-zone").show();
    };


    // ════════════════════════════════════════════════
    // 7. TOGGLE PASSWORD VISIBILITY
    // ════════════════════════════════════════════════
    window.togglePass = function (inputId, iconId) {
        var inp = document.getElementById(inputId);
        var isText = inp.type === "text";
        inp.type = isText ? "password" : "text";
        document.getElementById(iconId).innerHTML = isText
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>' +
              '<circle cx="12" cy="12" r="3"/>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8' +
              'a18.45 18.45 0 015.06-5.94"/>' +
              '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8' +
              'a18.5 18.5 0 01-2.16 3.19"/>' +
              '<line x1="1" y1="1" x2="23" y2="23"/>';
    };


    // ════════════════════════════════════════════════
    // 8. AJAX SUBMIT
    //    Kendo Validator → pass hone ke baad FormData build → API call
    // ════════════════════════════════════════════════
    $("#registerForm").on("submit", function (e) {
        e.preventDefault();

        // Profile image check — Kendo Validator se bahar hai
        var fileInput = document.getElementById("profileImageFile");
        if (!fileInput.files || fileInput.files.length === 0) {
            showWarning("Please upload a profile image");
            return;
        }

        // Kendo Validator run karo
        if (!validator.validate()) {
            showError("Please fix the errors before submitting");
            return;
        }

        // Mobile value — Kendo MaskedTextBox se lena
        // .unmaskedValue() = sirf digits, underscores nahi
        var mobileVal = $("#c_Mobile").data("kendoMaskedTextBox").value();
        // underscores hata do (incomplete input case)
        mobileVal = mobileVal.replace(/_/g, "");
        if (mobileVal.length !== 10) {
            showWarning("Enter valid 10 digit mobile number");
            return;
        }

        // FormData build karo
        var formData = new FormData();
        formData.append("c_FullName",        $("#c_FullName").val().trim());
        formData.append("c_UserName",        $("#c_UserName").val().trim());
        formData.append("c_Email",           $("#c_Email").val().trim());
        formData.append("c_Password",       $("#c_Password").data("kendoTextBox").value());
        formData.append("c_ConfirmPassword", $("#c_ConfirmPassword").data("kendoTextBox").value());
        formData.append("c_Gender",          $("#c_Gender").data("kendoDropDownList").value());
        formData.append("c_Mobile",          mobileVal);
        formData.append("profileImageFile",  fileInput.files[0]);

        // Button loading state
        var btn = $("#registerBtn");
        btn.prop("disabled", true).text("Creating Account...");

        $.ajax({
            url: "http://localhost:5183/api/AuthApi/UserRegister/",
            type: "POST",
            data: formData,
            processData: false,   // FormData ko jQuery process mat kare
            contentType: false,   // boundary browser set kare
            success: function (res) {
                btn.prop("disabled", false).text("Create Account");

                // Kendo Notification — success
                showSuccess(res.message || "Registration successful!");

                // Form reset
                $("#registerForm")[0].reset();
                removeImage();
                $("#c_Gender").data("kendoDropDownList").value("");
                $("#c_Mobile").data("kendoMaskedTextBox").value("");

                // 2 sec baad login page pe redirect
                setTimeout(function () {
                    window.location.href = "/Auth/UserLogin";
                }, 2000);
            },
            error: function (err) {
                console.log(err);                 // FULL object
                console.log(err.responseText);    // raw response
                console.log(err.responseJSON);    // parsed JSON

                var msg = "Something went wrong";

                if (err.responseJSON && err.responseJSON.message) {
                    msg = err.responseJSON.message;
                }

                showError(msg);
            }
        });
    });

}); // end document.ready
</script>
}
